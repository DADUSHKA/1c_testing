			Если ПодсказкаРеквизита = СинонимРеквизита Тогда
				УдалитьПодсказкуЭлементаEDT(ДокументDOM, ЭлементDOMРеквизита);
				РеквизитИзменен = Истина;
			КонецЕсли;
			
		КонецЦикла;
		
