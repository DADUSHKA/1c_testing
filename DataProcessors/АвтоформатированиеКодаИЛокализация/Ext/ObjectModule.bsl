Функция ПолучитьТаблицуПустыхТегов()
	
	ТаблицаПустыхТегов = Новый ТаблицаЗначений;
	ТаблицаПустыхТегов.Колонки.Добавить("СокращенныйТег");
	ТаблицаПустыхТегов.Колонки.Добавить("ПолныйТег");
	
	НоваяСтрока = ТаблицаПустыхТегов.Добавить();
	НоваяСтрока.СокращенныйТег = "<value/>";
	НоваяСтрока.ПолныйТег = "<value></value>";
	
	Возврат ТаблицаПустыхТегов;
	
КонецФункции

// Возвращает "Истина", если ПредыдущийРелиз меньше СледующийРелиз.
//
Функция апк_РелизыПоПорядку(ПредыдущийРелиз, СледующийРелиз)
	
	Если ПустаяСтрока(ПредыдущийРелиз) Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если ПредыдущийРелиз = СледующийРелиз Тогда
		Возврат Ложь;
	КонецЕсли;
	
	МассивЧиселПредыдущегоРелиза = СтрРазделить(ПредыдущийРелиз, ".", Ложь);
	МассивЧиселСледующегоРелиза = СтрРазделить(СледующийРелиз, ".", Ложь);
	
	КоличествоЧиселПредыдущегоРелиза = МассивЧиселПредыдущегоРелиза.Количество();
	Если КоличествоЧиселПредыдущегоРелиза <> МассивЧиселСледующегоРелиза.Количество() Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Для НомерЭлемента = 0 По КоличествоЧиселПредыдущегоРелиза - 1 Цикл
		ЧислоПредыдущего = Число(МассивЧиселПредыдущегоРелиза[НомерЭлемента]);
		ЧислоСледующего = Число(МассивЧиселСледующегоРелиза[НомерЭлемента]);
		Если ЧислоПредыдущего <> ЧислоСледующего Тогда
			Возврат (ЧислоСледующего > ЧислоПредыдущего);
		КонецЕсли;
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

Функция ПроверитьПлатформу836() Экспорт
	
	СистемнаяИнформация = Новый СистемнаяИнформация;
	ВерсияПриложения = СистемнаяИнформация.ВерсияПриложения;
	
	Если апк_РелизыПоПорядку("8.3.6.0", ВерсияПриложения) Тогда
		Возврат "";
	КонецЕсли;
	
	Синоним = Метаданные().Синоним;
	
	Статус = НСтр("ru='Для запуска внешней обработки ""%1"" необходима версия платформы не меньше, чем 8.3.6.
		|Текущая версия %2';
		|en='Для запуска внешней обработки ""%1"" необходима версия платформы не меньше, чем 8.3.6.
		|Текущая версия %2'", КодОсновногоЯзыка);
	Статус = СтрШаблон(Статус, Синоним, ВерсияПриложения);
	
	Возврат Статус;
	
КонецФункции

Функция ЗаполнитьТаблицуЗахваченныхОбъектов(ФайлЗахваченныхОбъектов, УдалитьФайл = Истина)
	
	ЗахваченныеОбъекты.Очистить();
	
	Если НЕ апк_ФайлСуществует(ФайлЗахваченныхОбъектов) Тогда
		ТекстОшибки = НСтр("ru='Не найден файл захваченных объектов, указанный по пути:';
			|en='Не найден файл захваченных объектов, указанный по пути:'", КодОсновногоЯзыка)
			+ Символы.ПС + ФайлЗахваченныхОбъектов;
		Возврат ТекстОшибки;
	КонецЕсли;
	
	// Получаем лог захваченных объектов.
	ТекстФайлаЗахваченныхОбъектов = ПолучитьТекстФайла(ФайлЗахваченныхОбъектов,, УдалитьФайл);
	
	// Анализируем лог захвата объектов.
	ТекстНачалоОперации = НСтр("ru='---- Начало операции с хранилищем конфигурации ----';
		|en='---- Начало операции с хранилищем конфигурации ----'", КодОсновногоЯзыка);
	Если СтрНайти(ТекстФайлаЗахваченныхОбъектов, ТекстНачалоОперации) = 0 Тогда
		// Если такой фразы в логе нет, значит, произошла ошибка, возвращаем текст ошибки.
		Возврат ТекстФайлаЗахваченныхОбъектов;
	КонецЕсли;
	
	ТекстОбъектЗахваченУспешно = НСтр("ru='Объект захвачен для редактирования:';
		|en='Объект захвачен для редактирования:'", КодОсновногоЯзыка);
	
	ДокументТекст = Новый ТекстовыйДокумент;
	ДокументТекст.УстановитьТекст(ТекстФайлаЗахваченныхОбъектов);
	
	КоличествоСтрок = ДокументТекст.КоличествоСтрок();
	
	Для НомерСтроки = 1 По КоличествоСтрок Цикл
		
		СтрокаТекста = ДокументТекст.ПолучитьСтроку(НомерСтроки);
		
		// Пытаемся получить объект из строки лога.
		ПозицияПоиска = СтрНайти(СтрокаТекста, ":");
		Если ПозицияПоиска = 0 Тогда
			// Если в строке нет двоеточия, это не строка с объектом, пропускаем.
			Продолжить;
		КонецЕсли;
		
		ПутьОбъекта = Сред(СтрокаТекста, ПозицияПоиска + 1);
		
		// Если объект захвачен другим пользователем, то в конце строки будет имя пользователя в скобках, удаляем.
		ПозицияПоиска = СтрНайти(ПутьОбъекта, "(");
		Если ПозицияПоиска > 0 Тогда
			ПутьОбъекта = Лев(ПутьОбъекта, ПозицияПоиска - 1);
		КонецЕсли;
		
		ПутьОбъекта = СокрЛП(ПутьОбъекта);
		// Если в пути к объекту остались пробелы, значит, это не объект, пропускаем.
		Если СтрНайти(ПутьОбъекта, " ") > 0 Тогда
			Продолжить;
		КонецЕсли;
		
		ОбъектЗахваченУспешно = СтрНачинаетсяС(СтрокаТекста, ТекстОбъектЗахваченУспешно);
		
		// Если в пути к объекту нет точек, тогда это корень конфигурации, переименуем его.
		Если СтрНайти(ПутьОбъекта, ".") = 0 Тогда
			ПутьОбъекта = "Конфигурация";
		КонецЕсли;
		
		НовыйОбъект = ЗахваченныеОбъекты.Добавить();
		НовыйОбъект.Объект = ПутьОбъекта;
		НовыйОбъект.ЗахваченДляРедактирования = ОбъектЗахваченУспешно;
		
	КонецЦикла;
	
	Возврат "";
	
КонецФункции

Функция ПолучитьСтатусЗахватаОбъектаВХранилище(ПутьОбъекта)
	
	// Если не указана ни одна настройка, связанная с хранилищем, то предполагаем, что объект по умолчанию захвачен.
	Если ПустаяСтрока(КаталогХранилища)
	   И (НЕ апк_ФайлСуществует(СписокИзмененныхОбъектов))
	   И (НЕ ПомещатьИзмененныеОбъектыВХранилище) Тогда
		Возврат Истина;
	КонецЕсли;
	
	ЗахваченВХранилище = Ложь;
	
	// Иначе определяем статус захвата объекта в таблице захваченных объектов.
	СтрокаЗахваченногоОбъекта = ЗахваченныеОбъекты.Найти(ПутьОбъекта, "Объект");
	Если (СтрокаЗахваченногоОбъекта = Неопределено) Тогда
		ЗахваченВХранилище = ПолучитьСтатусЗахватаРодителяОбъектаВХранилище(ПутьОбъекта);
	Иначе
		ЗахваченВХранилище = СтрокаЗахваченногоОбъекта.ЗахваченДляРедактирования;
	КонецЕсли;
	
	Возврат ЗахваченВХранилище;
	
КонецФункции

Функция ПолучитьСтатусЗахватаРодителяОбъектаВХранилище(ПутьОбъекта)
	
	// Некоторые объекты, например, команды, нельзя захватить в хранилище.
	// Для них получим состояние родительского объекта.
	МассивЭлементовПути = СтрРазделить(ПутьОбъекта, ".", Ложь);
	Если МассивЭлементовПути.Количество() < 2 Тогда
		// У объекта нет родительского объекта, выходим.
		Возврат Ложь;
	КонецЕсли;
	
	НомерПоследнегоЭлемента = МассивЭлементовПути.ВГраница();
	НомерПредпоследнегоЭлемента = НомерПоследнегоЭлемента - 1;
	
	// Получаем наименование предпоследнего элемента.
	ПредпоследнийЭлемент = МассивЭлементовПути[НомерПредпоследнегоЭлемента];
	Если (СтрСравнить(ПредпоследнийЭлемент, "Команда") <> 0)
	 ИЛИ (СтрСравнить(ПредпоследнийЭлемент, "Command") <> 0) Тогда
		// Если не команда, то выходим.
		Возврат Ложь;
	КонецЕсли;
	
	// Удаляем последний и предпоследний элемент пути.
	МассивЭлементовПути.Удалить(НомерПоследнегоЭлемента);
	МассивЭлементовПути.Удалить(НомерПредпоследнегоЭлемента);
	
	ОбъектРодителяПуть = СтрСоединить(МассивЭлементовПути, ".");
	
	СтрокаЗахваченногоОбъекта = ЗахваченныеОбъекты.Найти(ОбъектРодителяПуть, "Объект");
	Возврат ?(СтрокаЗахваченногоОбъекта = Неопределено, Ложь, СтрокаЗахваченногоОбъекта.ЗахваченДляРедактирования);
	
КонецФункции

Функция ПрочитатьПравилаПоддержки(ФайлПравилПоддержки)
	
	ТекстовыйДокумент = ПолучитьТекстовыйДокументИзФайла(ФайлПравилПоддержки);
	
	ПараметрыПоддержки = ?(ТекстовыйДокумент = Неопределено, "", ТекстовыйДокумент.ПолучитьТекст());
	ТекстовыйДокумент  = Неопределено;
	ПараметрыПоддержки = СтрРазделить(ПараметрыПоддержки, ",", Ложь);
	
	КоличествоКонфигураций = 0;
	СчетчикКонфигураций    = 0;
	КоличествоОбъектов     = 0;
	СчетчикОбъектов        = 0;
	
	МассивПараметров = Новый Массив;
	
	Если ПараметрыПоддержки.ВГраница() > 2 Тогда
		Попытка
			КоличествоКонфигураций = Число(ПараметрыПоддержки[2]);
		Исключение
			Возврат Неопределено;
		КонецПопытки;
	КонецЕсли;
	
	Если КоличествоКонфигураций = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ПравилаПоддержки = Новый Соответствие;
	ПравилаПоддержки.Вставить(0, НСтр("ru='Не редактируется'; en='Не редактируется'", КодОсновногоЯзыка));
	ПравилаПоддержки.Вставить(1, НСтр("ru='Редактируется с сохранением поддержки';
		|en='Редактируется с сохранением поддержки'", КодОсновногоЯзыка));
	ПравилаПоддержки.Вставить(2, НСтр("ru='Снят с поддержки'; en='Снят с поддержки'", КодОсновногоЯзыка));
	
	ПравилаПоставки = Новый Соответствие;
	ПравилаПоставки.Вставить(0, НСтр("ru='Изменения разрешены'; en='Изменения разрешены'", КодОсновногоЯзыка));
	ПравилаПоставки.Вставить(1, НСтр("ru='Изменения не рекомендуются'; en='Изменения не рекомендуются'",
		КодОсновногоЯзыка));
	ПравилаПоставки.Вставить(2, НСтр("ru='Изменения запрещены'; en='Изменения запрещены'", КодОсновногоЯзыка));
	ПравилаПоставки.Вставить(-1, НСтр("ru='Включение в конфигурацию не рекомендуется';
		|en='Включение в конфигурацию не рекомендуется'", КодОсновногоЯзыка));
	
	Индекс = 3;
	Для СчетчикКонфигураций = 1 По КоличествоКонфигураций Цикл
		
		Поставка = Новый Структура;
		// Начало конфигурации
		Поставка.Вставить("УИД1",ПараметрыПоддержки[Индекс]);
		Индекс = Индекс + 1;
		Поставка.Вставить("Параметр", ПараметрыПоддержки[Индекс]);
		Индекс = Индекс + 1;
		Поставка.Вставить("УИД2", ПараметрыПоддержки[Индекс]);
		Индекс = Индекс + 1;
		Поставка.Вставить("Версия", СтрЗаменить(ПараметрыПоддержки[Индекс], """", ""));
		Индекс = Индекс + 1;
		Поставка.Вставить("Поставщик", ПараметрыПоддержки[Индекс]);
		Индекс = Индекс + 1;
		Поставка.Вставить("КонфигурацияПоставщика", СтрЗаменить(ПараметрыПоддержки[Индекс], """", ""));
		Индекс = Индекс + 1;
		Попытка
			КоличествоОбъектов = Число(ПараметрыПоддержки[Индекс]);
			Индекс = Индекс + 1;
		Исключение
			Возврат Неопределено;
		КонецПопытки;
		
		МассивОбъектов = Новый Массив;
		Для СчетчикОбъектов = 1 По КоличествоОбъектов Цикл
			Если Индекс + 4 > ПараметрыПоддержки.ВГраница() Тогда
				СчетчикОбъектов = СчетчикОбъектов + 1;
				Прервать;
			КонецЕсли;
			
			НастройкиОбъекта = Новый Структура;
			НастройкиОбъекта.Вставить("ПравилоПоддержки", ПравилаПоддержки.Получить(Число(ПараметрыПоддержки[Индекс])));
			Индекс = Индекс + 1;
			НастройкиОбъекта.Вставить("ПравилоПоставки", ПравилаПоставки.Получить(Число(ПараметрыПоддержки[Индекс])));
			Индекс = Индекс + 1;
			НастройкиОбъекта.Вставить("ОбъектМетаданных", ПараметрыПоддержки[Индекс]);
			Индекс = Индекс + 1;
			НастройкиОбъекта.Вставить("ОбъектПоставщика", ПараметрыПоддержки[Индекс]);
			Индекс = Индекс + 1;
			
			МассивОбъектов.Добавить(НастройкиОбъекта);
		КонецЦикла;
		
		Поставка.Вставить("Объекты", МассивОбъектов);
		
		Индекс = Индекс + 2; // пустые параметры в конце
		
		МассивПараметров.Добавить(Поставка);
	КонецЦикла;
	
	Возврат МассивПараметров;
	
КонецФункции

Процедура ЗаполнитьПравилаПоддержки() Экспорт
	
	ПравилаПоддержкиОбъектов.Очистить();
	
	Если ЭтоВыгрузкаXMLФайлов() Тогда
		ФайлПравилПоддержки = КаталогВыгрузкиРезультат + СтрШаблон("Ext%1ParentConfigurations.bin", РазделительПути);
	Иначе
		ФайлПравилПоддержки = КаталогВыгрузкиРезультат + СтрШаблон("src%1Configuration%1ParentConfigurations.bin", РазделительПути);
	КонецЕсли;
	
	Если НЕ апк_ФайлСуществует(ФайлПравилПоддержки) Тогда
		Возврат;
	КонецЕсли;
	
	МассивПравилПоддержки = ПрочитатьПравилаПоддержки(ФайлПравилПоддержки);
	Если МассивПравилПоддержки = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекстНеРедактируется = НСтр("ru='Не редактируется'; en='Не редактируется'", КодОсновногоЯзыка);
	
	Для Каждого Элемент Из МассивПравилПоддержки Цикл
		
		// Проверяем свойство "Параметр", если он равен 1, то изменения запрещены.
		ИзмененияЗапрещены = (Элемент.Параметр = "1");
		
		Объекты = Элемент.Объекты;
		Для Каждого Объект Из Объекты Цикл
			
			uuidОбъекта = Объект.ОбъектМетаданных;
			
			// Если объекта еще нет в таблице, то добавим его.
			СтрокаТаблицы = ПравилаПоддержкиОбъектов.Найти(uuidОбъекта, "Объект");
			Если СтрокаТаблицы = Неопределено Тогда
				СтрокаТаблицы = ПравилаПоддержкиОбъектов.Добавить();
				СтрокаТаблицы.Объект = uuidОбъекта;
				СтрокаТаблицы.ПравилоПоддержки = ?(ИзмененияЗапрещены, ТекстНеРедактируется, Объект.ПравилоПоддержки);
				
				Продолжить;
			КонецЕсли;
			
			// Если объект уже есть, проверим его правило поддержки.
			Если СтрСравнить(СтрокаТаблицы.ПравилоПоддержки, ТекстНеРедактируется) <> 0 Тогда
				// Если изменения для объекта возможны, то заменяем текущее правило поддержки.
				СтрокаТаблицы.ПравилоПоддержки = Объект.ПравилоПоддержки;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

Функция ПолучитьДанныеXDTO(ФайлВыгрузкиXML)
	
	ЧтениеXML = Новый ЧтениеXML;
	ЧтениеXML.ОткрытьФайл(ФайлВыгрузкиXML);
	
	Данные = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML);
	ЧтениеXML.Закрыть();
	
	Возврат Данные;
	
КонецФункции

Функция ПолучитьИмяПодчиненногоОбъектаXDTO(ДанныеПодчиненногоОбъекта)
	
	СвойстваПодчиненногоОбъекта = ДанныеПодчиненногоОбъекта.Свойства();
	Если СвойстваПодчиненногоОбъекта.Получить("Properties") = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	
	ДанныеСвойствПодчиненногоОбъекта = ДанныеПодчиненногоОбъекта.Properties;
	
	СвойстваПодчиненногоОбъекта = ДанныеСвойствПодчиненногоОбъекта.Свойства();
	Если СвойстваПодчиненногоОбъекта.Получить("Name") = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	
	Возврат ДанныеСвойствПодчиненногоОбъекта.Name;
	
КонецФункции

Функция ПолучитьUuidПодчиненногоОбъекта(ПутьОбъектаАнгл, КлассОбъекта)
	
	МассивПутиАнгл = СтрРазделить(ПутьОбъектаАнгл, ".", Ложь);
	КоличествоЭлементовПутиАнгл = МассивПутиАнгл.Количество();
	
	// Если путь объекта короче 4-х элементов, то это не подчиненный объект.
	Если КоличествоЭлементовПутиАнгл < 4 Тогда
		Возврат "";
	КонецЕсли;
	
	КлассРодителяОбъектаМнЧ = МассивПутиАнгл[0];
	ПутьРодителяОбъекта = КлассРодителяОбъектаМнЧ + РазделительПути + МассивПутиАнгл[1];
	
	ФайлВыгрузкиXML = КаталогВыгрузкиРезультат + ПутьРодителяОбъекта + ".xml";
	Если НЕ апк_ФайлСуществует(ФайлВыгрузкиXML) Тогда
		Возврат "";
	КонецЕсли;
	
	ИмяОбъекта = МассивПутиАнгл[МассивПутиАнгл.ВГраница()];
	КлассРодителяОбъектаЕдЧ = ПолучитьТипОбъектаПоТаблицеТипов(КлассРодителяОбъектаМнЧ, "ИмяАнглМнФормы", "ИмяАнгл");
	
	Данные = ПолучитьДанныеXDTO(ФайлВыгрузкиXML);
	ДанныеОбъектаРодителя = Данные[КлассРодителяОбъектаЕдЧ];
	
	// Проверяем, что у объекта-родителя указаны подчиненные объекты.
	СвойстваОбъектаРодителя = ДанныеОбъектаРодителя.Свойства();
	Если СвойстваОбъектаРодителя.Получить("ChildObjects") = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	
	ДанныеПодчиненныхОбъектов = ДанныеОбъектаРодителя["ChildObjects"];
	
	// Проверяем, что среди подчиненных объектов есть нужный класс объекта.
	СвойстваПодчиненныхОбъектов = ДанныеПодчиненныхОбъектов.Свойства();
	Если СвойстваПодчиненныхОбъектов.Получить(КлассОбъекта) = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	
	ПодчиненныеОбъектыПоКлассу = ДанныеПодчиненныхОбъектов[КлассОбъекта];
	
	ПодчиненныйОбъект = Неопределено;
	Если ТипЗнч(ПодчиненныеОбъектыПоКлассу) = Тип("ОбъектXDTO") Тогда
		Если СтрСравнить(ПолучитьИмяПодчиненногоОбъектаXDTO(ПодчиненныеОбъектыПоКлассу), ИмяОбъекта) = 0 Тогда
			ПодчиненныйОбъект = ПодчиненныеОбъектыПоКлассу;
		КонецЕсли;
	ИначеЕсли ТипЗнч(ПодчиненныеОбъектыПоКлассу) = Тип("СписокXDTO") Тогда
		Для Каждого ПодчиненныйОбъектПоКлассу Из ПодчиненныеОбъектыПоКлассу Цикл
			Если СтрСравнить(ПолучитьИмяПодчиненногоОбъектаXDTO(ПодчиненныйОбъектПоКлассу), ИмяОбъекта) = 0 Тогда
				ПодчиненныйОбъект = ПодчиненныйОбъектПоКлассу;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Если ПодчиненныйОбъект = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	
	СвойстваПодчиненногоОбъекта = ПодчиненныйОбъект.Свойства();
	Если СвойстваПодчиненногоОбъекта.Получить("uuid") = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	
	Возврат ПодчиненныйОбъект.uuid;
	
КонецФункции

Функция ПолучитьUuidОбъекта(ПутьОбъектаАнгл, КлассОбъекта)
	
	// XML файла для команды не существует, описание команды содержится в XML файле его родителя.
	Если КлассОбъекта = "Command" Тогда
		Возврат ПолучитьUuidПодчиненногоОбъекта(ПутьОбъектаАнгл, КлассОбъекта);
	КонецЕсли;
	
	ИмяФайла = СтрЗаменить(ПутьОбъектаАнгл, ".", РазделительПути);
	ФайлВыгрузкиXML = КаталогВыгрузкиРезультат + ИмяФайла + ".xml";
	
	Если НЕ апк_ФайлСуществует(ФайлВыгрузкиXML) Тогда
		Возврат "";
	КонецЕсли;
	
	Данные = ПолучитьДанныеXDTO(ФайлВыгрузкиXML);
	
	Возврат Данные[КлассОбъекта].uuid;
	
КонецФункции

Процедура ЗаполнитьПравилаПоддержкиДляИзмененныхОбъектов() Экспорт
	
	Если ПравилаПоддержкиОбъектов.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ТекстНеРедактируется = НСтр("ru='Не редактируется'; en='Не редактируется'", КодОсновногоЯзыка);
	
	Для Каждого СтрокаРезультата Из Результат Цикл
		
		Если НЕ СтрокаРезультата.Изменен Тогда
			Продолжить;
		КонецЕсли;
		
		Если НЕ СтрокаРезультата.ЗахваченВХранилище Тогда
			Продолжить;
		КонецЕсли;
		
		ПутьОбъектаАнглМнЧ = ПолучитьПутьОбъектаИзФайлаВыгрузки(СтрокаРезультата.ПолноеИмяФайла,, "ИмяАнглМнФормы");
		КлассОбъектаМнЧ = ПолучитьКлассОбъекта(ПутьОбъектаАнглМнЧ);
		КлассОбъектаЕдЧ = ПолучитьТипОбъектаПоТаблицеТипов(КлассОбъектаМнЧ, "ИмяАнглМнФормы", "ИмяАнгл");
		
		uuidОбъекта = ПолучитьUuidОбъекта(ПутьОбъектаАнглМнЧ, КлассОбъектаЕдЧ);
		
		СтрокаПравилПоддержки = ПравилаПоддержкиОбъектов.Найти(uuidОбъекта, "Объект");
		Если СтрокаПравилПоддержки <> Неопределено Тогда
			СтрокаРезультата.РедактированиеРазрешено = (СтрокаПравилПоддержки.ПравилоПоддержки <> ТекстНеРедактируется);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Функция ПолучитьТаблицуИнструкцийПрепроцессора(Знач ТекстМодуля, ТолькоВерхнегоУровня = Ложь)
	
	ТаблицаИнструкций = Новый ТаблицаЗначений();
	ТаблицаИнструкций.Колонки.Добавить("ТекстИнструкции");
	ТаблицаИнструкций.Колонки.Добавить("ТекстИнструкцииВРег");
	ТаблицаИнструкций.Колонки.Добавить("ПозицияЕсли");
	ТаблицаИнструкций.Колонки.Добавить("ПозицияИначе");
	ТаблицаИнструкций.Колонки.Добавить("ПозицияКонецЕсли");
	ТаблицаИнструкций.Колонки.Добавить("ТекстКонецЕсли");
	ТаблицаИнструкций.Колонки.Добавить("ТекстИначе");
	
	ДеревоИнструкций = Новый ДеревоЗначений;
	Для Каждого Колонка Из ТаблицаИнструкций.Колонки Цикл
		ДеревоИнструкций.Колонки.Добавить(Колонка.Имя);
	КонецЦикла;
	ДеревоИнструкций.Колонки.Добавить("ЭтоИнструкция");
	ДеревоИнструкций.Колонки.Добавить("ЭтоИнструкцияВерхнегоУровня");
	
	ТекущаяИнструкция = ДеревоИнструкций.Строки.Добавить();
	ТекущаяИнструкция.ЭтоИнструкция = Ложь;
	
	ДокументТекст = Новый ТекстовыйДокумент;
	ДокументТекст.УстановитьТекст(ТекстМодуля);
	
	ТекстМодуля = ВРег(ТекстМодуля);
	
	МассивТекстЕсли      = Контекст["МассивТекстЕсли"];
	МассивТекстКонецЕсли = Контекст["МассивТекстКонецЕсли"];
	МассивТекстИначе     = Контекст["МассивТекстИначе"];
	
	МассивПоиска = Новый Массив;
	ДополнитьМассив(МассивПоиска, МассивТекстЕсли);
	ДополнитьМассив(МассивПоиска, МассивТекстКонецЕсли);
	ДополнитьМассив(МассивПоиска, МассивТекстИначе);
	
	ТекущаяИнструкция = ДеревоИнструкций.Строки.Добавить();
	ТекущаяИнструкция.ЭтоИнструкция = Ложь;
	
	ПозицияПоиска = 0;
	Пока Истина Цикл
		
		СтруктураПоиска = СтрНайтиПоМассиву(ТекстМодуля, МассивПоиска,, ПозицияПоиска + 1);
		Если НЕ СтруктураПоиска.Успешно Тогда
			Прервать;
		КонецЕсли;
		
		ПозицияПоиска = СтруктураПоиска.Позиция;
		НомерСтроки = ПолучитьНомерСтрокиМодуля(ТекстМодуля, ПозицияПоиска);
		
		ТекстИнструкции = ДокументТекст.ПолучитьСтроку(НомерСтроки);
		ТекстИнструкции = СокрЛП(ТекстИнструкции);
		
		Если НЕ СтрНачинаетсяС(ТекстИнструкции, "#") Тогда
			Продолжить;
		КонецЕсли;
		
		ТекстИнструкцииВРег = ВРег(ТекстИнструкции);
		ТекстИнструкцииВРег = СтрЗаменить(ТекстИнструкцииВРег, " ", "");
		ТекстИнструкцииВРег = СтрЗаменить(ТекстИнструкцииВРег, Символы.Таб, "");
		
		НайденныйЭлемент = СтруктураПоиска.НайденныйЭлемент;
		Если МассивТекстЕсли.Найти(НайденныйЭлемент) <> Неопределено Тогда
			
			НоваяИнструкция = ТекущаяИнструкция.Строки.Добавить();
			НоваяИнструкция.ТекстИнструкции = ТекстИнструкции;
			НоваяИнструкция.ТекстИнструкцииВРег = ТекстИнструкцииВРег;
			НоваяИнструкция.ПозицияЕсли = ПозицияПоиска;
			НоваяИнструкция.ЭтоИнструкция = Истина;
			НоваяИнструкция.ЭтоИнструкцияВерхнегоУровня = (ТекущаяИнструкция.Родитель = Неопределено);
			
			ТекущаяИнструкция = НоваяИнструкция;
		
		ИначеЕсли МассивТекстИначе.Найти(НайденныйЭлемент) <> Неопределено Тогда
			
			ТекущаяИнструкция.ПозицияИначе = ПозицияПоиска;
			ТекущаяИнструкция.ТекстИначе = НайденныйЭлемент;
			
		ИначеЕсли МассивТекстКонецЕсли.Найти(НайденныйЭлемент) <> Неопределено Тогда
			
			ТекущаяИнструкция.ПозицияКонецЕсли = ПозицияПоиска;
			ТекущаяИнструкция.ТекстКонецЕсли = НайденныйЭлемент;
			
			ТекущаяИнструкция = ТекущаяИнструкция.Родитель;
			Если ТекущаяИнструкция = Неопределено Тогда
				Прервать;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	ПараметрыОтбора = Новый Структура("ЭтоИнструкция", Истина);
	МассивСтрокИнструкций = ДеревоИнструкций.Строки.НайтиСтроки(ПараметрыОтбора, Истина);
	
	Для Каждого СтрокаИнструкции Из МассивСтрокИнструкций Цикл
		
		НоваяИнструкция = ТаблицаИнструкций.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяИнструкция, СтрокаИнструкции);
		
	КонецЦикла;
	
	Возврат ТаблицаИнструкций;
	
КонецФункции

Функция ПолучитьТаблицуДирективКомпиляции(Знач ТекстМодуля)
	
	ТаблицаДиректив = Новый ТаблицаЗначений;
	ТаблицаДиректив.Колонки.Добавить("ТекстДирективы");
	ТаблицаДиректив.Колонки.Добавить("ПозицияНачала");
	ТаблицаДиректив.Колонки.Добавить("ПозицияКонца");
	
	ТекстМодуляВРег = ВРег(ТекстМодуля);
	
	ДокументТекст = Новый ТекстовыйДокумент;
	ДокументТекст.УстановитьТекст(ТекстМодуля);
	
	МассивТекстНачалоДирективы = Новый Массив;
	МассивТекстНачалоДирективы.Добавить(ВРег("&На"));
	МассивТекстНачалоДирективы.Добавить(ВРег("&At"));
	
	Позиция = 0;
	Пока Истина Цикл
		
		Позиция = СтрНайтиПоМассиву(ТекстМодуляВРег, МассивТекстНачалоДирективы,, Позиция + 1).Позиция;
		Если Позиция = 0 Тогда
			Прервать;
		КонецЕсли;
		
		НомерСтроки = ПолучитьНомерСтрокиМодуля(ТекстМодуля, Позиция);
		ТекстСтроки = ДокументТекст.ПолучитьСтроку(НомерСтроки);
		
		Если НЕ СтрНачинаетсяС(СокрЛ(ТекстСтроки), "&") Тогда
			Продолжить;
		КонецЕсли;
		
		ПозицияКонца = Позиция + СтрДлина(ТекстСтроки);
		
		СтрокаТаблицыДиректив = ТаблицаДиректив.Добавить();
		СтрокаТаблицыДиректив.ТекстДирективы = ТекстСтроки;
		СтрокаТаблицыДиректив.ПозицияНачала = Позиция;
		СтрокаТаблицыДиректив.ПозицияКонца = ПозицияКонца;
		
	КонецЦикла;
	
	Возврат ТаблицаДиректив;
	
КонецФункции

Функция ПолучитьТаблицуОбластейМодуля83(Знач ТекстМодуля)
	
	ТаблицаОбластей = Новый ТаблицаЗначений();
	ТаблицаОбластей.Колонки.Добавить("Наименование");
	ТаблицаОбластей.Колонки.Добавить("НаименованиеВРег");
	ТаблицаОбластей.Колонки.Добавить("ТекстОпределения");
	ТаблицаОбластей.Колонки.Добавить("НомерСтрокиНачало");
	ТаблицаОбластей.Колонки.Добавить("НомерСтрокиКонец");
	ТаблицаОбластей.Колонки.Добавить("ВерхнегоУровня");
	
	ДеревоОбластей = Новый ДеревоЗначений;
	Для Каждого Колонка Из ТаблицаОбластей.Колонки Цикл
		ДеревоОбластей.Колонки.Добавить(Колонка.Имя);
	КонецЦикла;
	ДеревоОбластей.Колонки.Добавить("ЭтоОбласть");
	ТаблицаОбластей.Колонки.Добавить("Родитель");
	
	КореньДереваОбластей = ДеревоОбластей.Строки.Добавить();
	КореньДереваОбластей.Наименование = "Области";
	КореньДереваОбластей.ЭтоОбласть = Ложь;
	
	ТекущаяОбласть = КореньДереваОбластей;
	
	ДокументТекст = Новый ТекстовыйДокумент;
	ДокументТекст.УстановитьТекст(ТекстМодуля);
	
	ТекстМодуля = СтрЗаменить(ТекстМодуля, Символы.Таб, "");
	ТекстМодуля = СтрЗаменить(ТекстМодуля, " ", "");
	ТекстМодуля = ВРег(ТекстМодуля);
	
	МассивТекстОбласть      = Контекст["МассивТекстОбласть"];
	МассивТекстКонецОбласти = Контекст["МассивТекстКонецОбласти"];
	
	МассивПоиска = Новый Массив;
	ДополнитьМассив(МассивПоиска, МассивТекстОбласть);
	ДополнитьМассив(МассивПоиска, МассивТекстКонецОбласти);
	
	ПозицияПоиска = 0;
	Пока Истина Цикл
		
		СтруктураПоиска = СтрНайтиПоМассиву(ТекстМодуля, МассивПоиска,, ПозицияПоиска + 1);
		Если НЕ СтруктураПоиска.Успешно Тогда
			Прервать;
		КонецЕсли;
		
		ПозицияПоиска = СтруктураПоиска.Позиция;
		НомерСтроки = ПолучитьНомерСтрокиМодуля(ТекстМодуля, ПозицияПоиска);
		
		ТекстОбласти = ДокументТекст.ПолучитьСтроку(НомерСтроки);
		ТекстОбласти = СокрЛП(ТекстОбласти);
		
		Если НЕ СтрНачинаетсяС(ТекстОбласти, "#") Тогда
			Продолжить;
		КонецЕсли;
		
		ТекстОбластиБезПробелов = ТекстОбласти;
		ТекстОбластиБезПробелов = СтрЗаменить(ТекстОбластиБезПробелов, " ", "");
		ТекстОбластиБезПробелов = СтрЗаменить(ТекстОбластиБезПробелов, Символы.Таб, "");
		
		НайденныйЭлемент = СтруктураПоиска.НайденныйЭлемент;
		
		Если МассивТекстОбласть.Найти(НайденныйЭлемент) <> Неопределено Тогда
			
			НаименованиеОбласти = ПолучитьНаименованиеОбласти(ТекстОбластиБезПробелов);
			
			НоваяОбласть = ТекущаяОбласть.Строки.Добавить();
			НоваяОбласть.Наименование = НаименованиеОбласти;
			НоваяОбласть.НаименованиеВРег = ВРег(НаименованиеОбласти);
			НоваяОбласть.ТекстОпределения = ТекстОбласти;
			НоваяОбласть.НомерСтрокиНачало = НомерСтроки;
			НоваяОбласть.ЭтоОбласть = Истина;
			
			ТекущаяОбласть = НоваяОбласть;
			
		ИначеЕсли МассивТекстКонецОбласти.Найти(НайденныйЭлемент) <> Неопределено Тогда
			
			ТекущаяОбласть.НомерСтрокиКонец = НомерСтроки;
			
			ТекущаяОбласть = ТекущаяОбласть.Родитель;
			Если ТекущаяОбласть = Неопределено Тогда
				Прервать;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	ПараметрыОтбора = Новый Структура("ЭтоОбласть", Истина);
	МассивСтрокОбластей = ДеревоОбластей.Строки.НайтиСтроки(ПараметрыОтбора, Истина);
	Для Каждого СтрокаОбласти Из МассивСтрокОбластей Цикл
		НоваяОбласть = ТаблицаОбластей.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяОбласть, СтрокаОбласти);
		// Заполним флаг "ВерхнегоУровня" для областей.
		НоваяОбласть.ВерхнегоУровня = (СтрокаОбласти.Родитель = КореньДереваОбластей);
	КонецЦикла;
	
	Возврат ТаблицаОбластей.Скопировать();
	
КонецФункции

Функция ПолучитьНаименованиеОбласти(СтрокаМодуля)
	
	НаименованиеОбласти = СокрЛ(СтрокаМодуля);
	
	МассивТекстОбласть = Контекст["МассивТекстОбласть"];
	
	РезультатПоиска = СтрНайтиПоМассиву(ВРег(НаименованиеОбласти), МассивТекстОбласть);
	Если РезультатПоиска.Успешно Тогда
		НаименованиеОбласти = Сред(НаименованиеОбласти, СтрДлина(РезультатПоиска.НайденныйЭлемент) + 1);
	КонецЕсли;
	
	ПозицияКомментария = СтрНайти(НаименованиеОбласти, "//");
	Если ПозицияКомментария > 0 Тогда
		НаименованиеОбласти = Лев(НаименованиеОбласти, ПозицияКомментария - 1);
	КонецЕсли;
	
	Возврат СокрЛП(НаименованиеОбласти);
	
КонецФункции

Функция ПолучитьТаблицуПроцедурИФункций(Знач ТекстМодуля)
	
	СоответствиеПолучитьТаблицуПроцедурИФункций = Контекст["ПолучитьТаблицуПроцедурИФункций"];
	
	КлючСоответствия = ПолучитьХешСуммуИзСтроки(ТекстМодуля, ХешФункция.MD5);
	ЗначениеСоответствия = СоответствиеПолучитьТаблицуПроцедурИФункций[КлючСоответствия];
	Если ЗначениеСоответствия <> Неопределено Тогда
		Возврат ЗначениеСоответствия;
	КонецЕсли;
	
	ТаблицаМетодов = Новый ТаблицаЗначений;
	ТаблицаМетодов.Колонки.Добавить("ТипМетода");
	ТаблицаМетодов.Колонки.Добавить("ИмяМетода");
	ТаблицаМетодов.Колонки.Добавить("ИмяМетодаВРег");
	ТаблицаМетодов.Колонки.Добавить("ОписаниеМетода");
	ТаблицаМетодов.Колонки.Добавить("ТекстМетода");
	ТаблицаМетодов.Колонки.Добавить("ТелоМетода");
	ТаблицаМетодов.Колонки.Добавить("ПозицияНачалаМетода");
	ТаблицаМетодов.Колонки.Добавить("ПозицияКонцаОписания");
	ТаблицаМетодов.Колонки.Добавить("ПозицияКонцаМетода");
	ТаблицаМетодов.Колонки.Добавить("НомерСтрокиНачалаМетода");
	ТаблицаМетодов.Колонки.Добавить("НомерСтрокиКонцаМетода");
	ТаблицаМетодов.Колонки.Добавить("ЕстьЭкспорт");
	ТаблицаМетодов.Колонки.Добавить("МассивПараметров");
	ТаблицаМетодов.Колонки.Добавить("ПозицияНачалаДирективы");
	ТаблицаМетодов.Колонки.Добавить("ТекстДирективы");
	ТаблицаМетодов.Колонки.Добавить("ТекстКомментарияМетода");
	ТаблицаМетодов.Колонки.Добавить("НомерСтрокиНачалаКомментарияМетода");
	ТаблицаМетодов.Колонки.Добавить("НомерСтрокиКонцаКомментарияМетода");
	
	ДокументТекст = Новый ТекстовыйДокумент;
	ДокументТекст.УстановитьТекст(ТекстМодуля);
	
	ВРегТекстМодуля = ВРег(ТекстМодуля);
	
	МассивТекстПроцедураФункция      = Контекст["МассивТекстПроцедураФункция"];
	МассивТекстКонецПроцедурыФункции = Контекст["МассивТекстКонецПроцедурыФункции"];
	МассивТекстЭкспорт               = Контекст["МассивТекстЭкспорт"];
	
	МассивТекстПроцедура = Новый Массив;
	МассивТекстПроцедура.Добавить(ВРег("Процедура"));
	МассивТекстПроцедура.Добавить(ВРег("Procedure"));
	
	МассивПоиска = Новый Массив;
	ДополнитьМассив(МассивПоиска, МассивТекстПроцедураФункция);
	ДополнитьМассив(МассивПоиска, МассивТекстКонецПроцедурыФункции);
	
	ТаблицаДиректив = ПолучитьТаблицуДирективКомпиляции(ТекстМодуля);
	ТаблицаДиректив.Колонки.Добавить("Проверена");
	ТаблицаДиректив.ЗаполнитьЗначения(Ложь, "Проверена");
	
	// Составим массив допустимых символов, которые можно писать после "КонецПроцедуры".
	МассивДопустимыхСимволовПослеКонцаМетода = Новый Массив;
	МассивДопустимыхСимволовПослеКонцаМетода.Добавить("/");
	МассивДопустимыхСимволовПослеКонцаМетода.Добавить(";");
	
	ДлинаТекста = СтрДлина(ВРегТекстМодуля);
	СтрокаТаблицыМетодов = Неопределено;
	ПозицияНачалаМетода = 0;
	Пока Истина Цикл
		
		СтруктураПоиска = СтрНайтиПоМассиву(ВРегТекстМодуля, МассивПоиска,, ПозицияНачалаМетода + 1);
		Если НЕ СтруктураПоиска.Успешно Тогда
			Прервать;
		КонецЕсли;
		
		ТипМетодаВРег = СтруктураПоиска.НайденныйЭлемент;
		ПозицияНачалаМетода = СтруктураПоиска.Позиция;
		
		НомерСтрокиНачалаМетода = ПолучитьНомерСтрокиМодуля(ТекстМодуля, ПозицияНачалаМетода);
		ТекстСтроки = ДокументТекст.ПолучитьСтроку(НомерСтрокиНачалаМетода);
		ТекстСтроки = СокрЛ(ТекстСтроки);
		Если НЕ СтрНачинаетсяС(ВРег(ТекстСтроки), ТипМетодаВРег) Тогда
			Продолжить;
		КонецЕсли;
		
		// Проверяем следующий символ.
		СледующийСимвол = Сред(ТекстСтроки, СтрДлина(ТипМетодаВРег) + 1, 1);
		Если НЕ ПустаяСтрока(СледующийСимвол) Тогда
			// Если не нашли допустимый символ, то пропускаем.
			Если МассивДопустимыхСимволовПослеКонцаМетода.Найти(СледующийСимвол) = Неопределено Тогда
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		
		ПозицияСледующегоСимвола = ПозицияНачалаМетода + СтрДлина(ТипМетодаВРег);
		
		// Если это конец метода, то записываем строку в таблицу методов.
		Если СтрНачинаетсяСПоМассиву(ТипМетодаВРег, МассивТекстКонецПроцедурыФункции).Успешно Тогда
			
			// Если строка в таблице не открыта, то продолжаем.
			Если СтрокаТаблицыМетодов = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			ПозицияКонцаОписания = СтрокаТаблицыМетодов.ПозицияКонцаОписания;
			ТелоМетода = Сред(ТекстМодуля, ПозицияКонцаОписания + 1, ПозицияНачалаМетода - ПозицияКонцаОписания - 1);
			
			ПозицияНачалаМетода = СтрокаТаблицыМетодов.ПозицияНачалаМетода;
			ТекстМетода = Сред(ТекстМодуля, ПозицияНачалаМетода, ПозицияСледующегоСимвола - ПозицияНачалаМетода);
			
			СтрокаТаблицыМетодов.ТелоМетода = ТелоМетода;
			СтрокаТаблицыМетодов.ТекстМетода = ТекстМетода;
			СтрокаТаблицыМетодов.ПозицияКонцаМетода = ПозицияСледующегоСимвола;
			СтрокаТаблицыМетодов.НомерСтрокиКонцаМетода = ПолучитьНомерСтрокиМодуля(ТекстМодуля, ПозицияСледующегоСимвола);
			
			// Обнуляем строку таблицы методов.
			СтрокаТаблицыМетодов = Неопределено;
			ПозицияНачалаМетода = ПозицияСледующегоСимвола;
			Если ДлинаТекста < ПозицияНачалаМетода + 1 Тогда
				Прервать;
			КонецЕсли;
			
			Продолжить;
			
		КонецЕсли;
		
		// Если строка таблицы методов открыта, то это ошибка, продолжаем.
		Если СтрокаТаблицыМетодов <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		// Ищем открывающую скобку.
		ПозицияОткрывающейСкобки = СтрНайти(ТекстМодуля, "(",, ПозицияСледующегоСимвола);
		Если ПозицияОткрывающейСкобки = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		// Ищем закрывающую скобку.
		ПозицияЗакрывающейСкобки = СтрНайти(ТекстМодуля, ")",, ПозицияОткрывающейСкобки);
		Если ПозицияЗакрывающейСкобки = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		ИмяМетода = Сред(ТекстМодуля, ПозицияСледующегоСимвола, ПозицияОткрывающейСкобки - ПозицияСледующегоСимвола);
		ИмяМетода = СокрЛП(ИмяМетода);
		
		// Определяем массив параметров метода.
		ТекстПараметровМетода = Сред(ТекстМодуля, ПозицияОткрывающейСкобки + 1, ПозицияЗакрывающейСкобки - ПозицияОткрывающейСкобки - 1);
		ТекстПараметровМетода = СокрЛП(ТекстПараметровМетода);
		МассивПараметровМетода = СтрРазделить(ТекстПараметровМетода, ",", Ложь);
		
		ПозицияКонцаОписания = ПозицияЗакрывающейСкобки;
		ЕстьЭкспорт = Ложь;
		
		// Определяем, есть ли "Экспорт" после метода.
		ТекстМодуляПослеСкобки = Сред(ТекстМодуля, ПозицияЗакрывающейСкобки + 1);
		СтрДлинаТекстМодуляПослеСкобки = СтрДлина(ТекстМодуляПослеСкобки);
		ТекстМодуляПослеСкобки = СокрЛ(ТекстМодуляПослеСкобки);
		ТекстМодуляПослеСкобки = ВРег(ТекстМодуляПослеСкобки);
		
		РезультатПоискаТекстЭкспорт = СтрНачинаетсяСПоМассиву(ТекстМодуляПослеСкобки, МассивТекстЭкспорт);
		Если РезультатПоискаТекстЭкспорт.Успешно Тогда
			// Если текст после скобки начинается с "Экспорт", то переопределим позицию конца описания метода.
			СдвигНаЭкспорт = СтрДлина(РезультатПоискаТекстЭкспорт.НайденныйЭлемент) + СтрДлинаТекстМодуляПослеСкобки - СтрДлина(ТекстМодуляПослеСкобки);
			ПозицияКонцаОписания = ПозицияКонцаОписания + СдвигНаЭкспорт;
			
			// Проверяем следующий символ после "Экспорт".
			СледующийСимволПослеЭкспорт = Сред(ТекстМодуля, ПозицияКонцаОписания + 1, 1);
			Если ПустаяСтрока(СледующийСимволПослеЭкспорт) Тогда
				ЕстьЭкспорт = Истина;
			Иначе
				ПозицияКонцаОписания = ПозицияЗакрывающейСкобки;
			КонецЕсли;
		КонецЕсли;
		
		ОписаниеМетода = Сред(ТекстМодуля, ПозицияНачалаМетода, ПозицияКонцаОписания - ПозицияНачалаМетода + 1);
		
		ТекстДирективы = "";
		ПозицияНачалаДирективы = 0;
		
		// Определяем директиву компиляции.
		Если ТаблицаДиректив.Количество() > 0 Тогда
			
			Для Каждого СтрокаДирективы Из ТаблицаДиректив Цикл
				
				// Если директива уже проверена, то пропускаем.
				Если СтрокаДирективы.Проверена Тогда
					Продолжить;
				КонецЕсли;
				
				// Если директива находится ниже проверяемого метода, выходим.
				Если СтрокаДирективы.ПозицияНачала > ПозицияНачалаМетода Тогда
					Прервать;
				КонецЕсли;
				
				// Проверяем директиву.
				ПозицияКонцаДирективы = СтрокаДирективы.ПозицияКонца;
				
				// Получаем текст между директивой и началом метода.
				ТекстМеждуДирективойИМетодом = Сред(ТекстМодуля, ПозицияКонцаДирективы, ПозицияНачалаМетода - ПозицияКонцаДирективы);
				
				// Проверяем, есть ли исполняемый код в этом тексте.
				ДокументТекстМеждуДирективойИМетодом = Новый ТекстовыйДокумент;
				ДокументТекстМеждуДирективойИМетодом.УстановитьТекст(ТекстМеждуДирективойИМетодом);
				
				МеждуДирективойИМетодомЕстьКод = Ложь;
				
				КоличествоСтрок = ДокументТекстМеждуДирективойИМетодом.КоличествоСтрок();
				Для НомерСтроки = 1 По КоличествоСтрок Цикл
					
					СтрокаМодуля = ДокументТекстМеждуДирективойИМетодом.ПолучитьСтроку(НомерСтроки);
					СтрокаМодуля = СокрЛ(СтрокаМодуля);
					
					// Не учитываем строки с "#", т.к. если между директивой и методом есть инструкция препроцессору или объявление области,
					// то это некорректный код. Например, удалять пустые методы с директивой при этом явно нельзя -
					// для этого нужен более глубокий анализ человеком.
					Если ПустаяСтрока(СтрокаМодуля) ИЛИ СтрНачинаетсяС(СтрокаМодуля, "//") Тогда
						Продолжить;
					КонецЕсли;
					
					// Нашли код, прерываем.
					МеждуДирективойИМетодомЕстьКод = Истина;
					Прервать;
					
				КонецЦикла;
				
				// Устанавливаем флаг, что директива проверена.
				СтрокаДирективы.Проверена = Истина;
				
				// Нашли код, проверяем следующую директиву.
				Если МеждуДирективойИМетодомЕстьКод Тогда
					Продолжить;
				КонецЕсли;
				
				// Записываем найденную директиву.
				ПозицияНачалаДирективы = СтрокаДирективы.ПозицияНачала;
				ТекстДирективы = СтрокаДирективы.ТекстДирективы;
				
				Прервать;
				
			КонецЦикла;
			
		КонецЕсли;
		
		// Получаем комментарий перед методом.
		ТекстКомментарияМетода = "";
		НомерСтрокиНачалаКомментарияМетода = 0;
		НомерСтрокиКонцаКомментарияМетода = 0;
		
		Для НомерСтроки = 1 По НомерСтрокиНачалаМетода Цикл
			
			НомерСтрокиКомментария = НомерСтрокиНачалаМетода - НомерСтроки;
			СтрокаМодуляИсходная = ДокументТекст.ПолучитьСтроку(НомерСтрокиКомментария);
			
			СтрокаМодуля = СокрЛП(СтрокаМодуляИсходная);
			
			// Если перед методом директива компиляции, то проверяем дальше.
			Если СтрНачинаетсяС(СтрокаМодуля, "&") Тогда
				// Если комментария еще не было, то ищем дальше.
				Если НомерСтрокиКонцаКомментарияМетода = 0 Тогда
					Продолжить;
				Иначе
					// Если комментарий уже был, то запоминаем номер строки начала комментария и прерываем.
					НомерСтрокиНачалаКомментарияМетода = НомерСтрокиКомментария + 1;
					Прервать;
				КонецЕсли;
			КонецЕсли;
			
			// Если перед методом встретилась строка без комментария, то прерываем.
			// Если в строке больше двух слешей, то это не комментарий.
			Если (НЕ СтрНачинаетсяС(СтрокаМодуля, "//"))
				ИЛИ (СтрЧислоВхождений(СтрокаМодуля, "/") > 2) Тогда
				// Запоминаем номер строки начала комментария, если он был.
				Если НомерСтрокиКонцаКомментарияМетода > 0 Тогда
					НомерСтрокиНачалаКомментарияМетода = НомерСтрокиКомментария + 1;
				КонецЕсли;
				// В любом случае, прерываем.
				Прервать;
			КонецЕсли;
			
			// Иначе нашли комментарий.
			Если НомерСтрокиКонцаКомментарияМетода = 0 Тогда
				// Запоминаем номер строки окончания комментария.
				НомерСтрокиКонцаКомментарияМетода = НомерСтрокиКомментария;
			КонецЕсли;
			
			// Запоминаем текст комментария.
			ТекстКомментарияМетода = СтрокаМодуляИсходная + Символы.ПС + ТекстКомментарияМетода;
			
		КонецЦикла;
		
		ЭтоПроцедура = (МассивТекстПроцедура.Найти(ТипМетодаВРег) <> Неопределено);
		
		СтрокаТаблицыМетодов = ТаблицаМетодов.Добавить();
		СтрокаТаблицыМетодов.ТипМетода = ?(ЭтоПроцедура, "Процедура", "Функция");
		СтрокаТаблицыМетодов.ИмяМетода = ИмяМетода;
		СтрокаТаблицыМетодов.ИмяМетодаВРег = ВРег(ИмяМетода);
		СтрокаТаблицыМетодов.ОписаниеМетода = ОписаниеМетода;
		СтрокаТаблицыМетодов.ПозицияНачалаМетода = ПозицияНачалаМетода;
		СтрокаТаблицыМетодов.ПозицияКонцаОписания = ПозицияКонцаОписания;
		СтрокаТаблицыМетодов.НомерСтрокиНачалаМетода = НомерСтрокиНачалаМетода;
		СтрокаТаблицыМетодов.ЕстьЭкспорт = ЕстьЭкспорт;
		СтрокаТаблицыМетодов.МассивПараметров = МассивПараметровМетода;
		СтрокаТаблицыМетодов.ПозицияНачалаДирективы = ПозицияНачалаДирективы;
		СтрокаТаблицыМетодов.ТекстДирективы = ТекстДирективы;
		СтрокаТаблицыМетодов.ТекстКомментарияМетода = СокрП(ТекстКомментарияМетода); // удаляем последний перенос строки.
		СтрокаТаблицыМетодов.НомерСтрокиНачалаКомментарияМетода = НомерСтрокиНачалаКомментарияМетода;
		СтрокаТаблицыМетодов.НомерСтрокиКонцаКомментарияМетода = НомерСтрокиКонцаКомментарияМетода;
		
	КонецЦикла;
	
	СоответствиеПолучитьТаблицуПроцедурИФункций.Вставить(КлючСоответствия, ТаблицаМетодов);
	
	Возврат ТаблицаМетодов;
	
КонецФункции

Функция ПолучитьУровеньВложенностиПараметра(Знач ИмяПараметра)
	
	УровеньВложенностиПараметра = 0;
	Если ПустаяСтрока(ИмяПараметра) Тогда
		Возврат УровеньВложенностиПараметра;
	КонецЕсли;
	
	ИмяПараметра = СокрЛ(ИмяПараметра);
	
	СтрДлинаИмяПараметра = СтрДлина(ИмяПараметра);
	Для НомерСимвола = 1 По СтрДлинаИмяПараметра Цикл
		СимволИмениПараметра = Сред(ИмяПараметра, НомерСимвола, 1);
		Если СимволИмениПараметра <> "*" Тогда
			Прервать;
		КонецЕсли;
		УровеньВложенностиПараметра = УровеньВложенностиПараметра + 1;
	КонецЦикла;
	
	Возврат УровеньВложенностиПараметра;
	
КонецФункции

Функция ПолучитьСтруктуруОписанияПараметра(Знач СтрокаКомментария, ПолучатьИмяПараметра, УровеньВложенностиПредыдущегоПараметра)
	
	ИмяПараметра = Неопределено;
	УровеньВложенностиПараметра = 0;
	ПозицияИмениПараметра = 0;
	ТипПараметра = Неопределено;
	ТипПараметраМножественный = Ложь;
	ПозицияТипаПараметра = 0;
	ТекстовоеОписаниеПараметра = "";
	ПозицияТекстовогоОписанияПараметра = 0;
	
	РазделительЭлементовОписанияПараметра = "-";
	ДлинаРазделителяЭлементовОписанияПараметра = СтрДлина(РазделительЭлементовОписанияПараметра);
	
	// Если в комментарии есть двоеточие, то проверим определенные типы параметров.
	Если СтрНайти(СтрокаКомментария, ":") > 0 Тогда
		МассивТиповПараметровДляКоторыхДопустимРазделительДвоеточие = Контекст["МассивТиповПараметровДляКоторыхДопустимРазделительДвоеточие"];
		Если СтрНайтиПоМассиву(ВРег(СтрокаКомментария), МассивТиповПараметровДляКоторыхДопустимРазделительДвоеточие).Успешно Тогда
			// Если в комментарии есть типы параметров, для которых допустимо двоеточие в качестве разделителя,
			// то переопределим разделитель элементов описания параметра.
			// При этом длину разделителя переопределять не нужно.
			РазделительЭлементовОписанияПараметра = "-:";
		КонецЕсли;
	КонецЕсли;
	
	ДлинаЭлементовОписанияПараметра = 0;
	ПозицияЭлементаОписанияПараметра = 0;
	ПозицияРазделителяПередТипомПараметра = 0;
	ПозицияРазделителяПередТекстовымОписаниемПараметра = 0;
	
	ПервыйЭлементПустой = Ложь;
	
	// Делим всю строку по разделителю и обрабатываем каждый элемент отдельно.
	МассивЭлементовОписанияПараметра = СтрРазделить(СтрокаКомментария, РазделительЭлементовОписанияПараметра);
	Для Каждого ЭлементОписанияПараметра Из МассивЭлементовОписанияПараметра Цикл
		
		ЭлементОписанияПараметраБуфер = ЭлементОписанияПараметра;
		ЭлементОписанияПараметраБуфер = СтрЗаменить(ЭлементОписанияПараметраБуфер, "/", " ");
		ЭлементОписанияПараметраБуфер = СокрЛ(ЭлементОписанияПараметраБуфер);
		
		ПозицияРазделителя = ДлинаЭлементовОписанияПараметра;
		ДлинаЭлементовОписанияПараметра = ДлинаЭлементовОписанияПараметра + СтрДлина(ЭлементОписанияПараметра) + ДлинаРазделителяЭлементовОписанияПараметра;
		ПозицияЭлементаОписанияПараметра = ДлинаЭлементовОписанияПараметра - СтрДлина(ЭлементОписанияПараметраБуфер);
		
		ЭлементОписанияПараметраБуфер = СокрП(ЭлементОписанияПараметраБуфер);
		
		Если ИмяПараметра = Неопределено Тогда
			
			Если ПустаяСтрока(ЭлементОписанияПараметраБуфер) Тогда
				
				// Запоминаем, что описание параметра начинается с тире.
				ПервыйЭлементПустой = Истина;
				
				// Описание параметра начинается с тире, рассмотрим 2 ситуации.
				Если НЕ ПолучатьИмяПараметра Тогда
					// 1. Это описание следующего типа параметра, объявленного на предыдущих строках.
					// Устанавливаем имя элемента пустой строкой, в следующем элементе должен быть описан тип параметра.
					ИмяПараметра = "";
					// Уровень вложенности берем из предыдущего параметра.
					УровеньВложенностиПараметра = УровеньВложенностиПредыдущегоПараметра;
				Иначе
					// 2. Описание каждого параметра начинается с тире.
					// Отступы проверяемого параметра и самого первого параметра в секции равны, ничего не делаем.
				КонецЕсли;
				
				// В любом случае переходим к следующему элементу.
				Продолжить;
				
			КонецЕсли;
			
			ЭтоОписаниеСвойства = СтрНачинаетсяС(ЭлементОписанияПараметраБуфер, "*");
			
			// Если необходимо получать имя параметра или это описание свойства, то запоминаем как имя параметра и его позицию.
			Если ПолучатьИмяПараметра ИЛИ ЭтоОписаниеСвойства Тогда
				ИмяПараметра = ЭлементОписанияПараметраБуфер;
				// Если строка начинается с тире, то наследуем уровень вложенности от предыдущего параметра,
				// иначе определяем по имени параметра.
				УровеньВложенностиПараметра = ?(ПервыйЭлементПустой, УровеньВложенностиПредыдущегоПараметра, ПолучитьУровеньВложенностиПараметра(ИмяПараметра));
				ПозицияИмениПараметра = ПозицияЭлементаОписанияПараметра;
				Продолжить;
			Иначе
				// Это описание возвращаемого значения, тогда имя параметра устанавливаем пустым.
				ИмяПараметра = "";
			КонецЕсли;
			
		КонецЕсли;
		
		Если ТипПараметра = Неопределено Тогда
			
			// Пропускаем пустой элемент.
			Если ПустаяСтрока(ЭлементОписанияПараметраБуфер) Тогда
				Продолжить;
			КонецЕсли;
			
			ЭтоОписаниеТипаПараметра = Истина;
			
			ЭлементОписанияПараметраБуферВРег = ВРег(ЭлементОписанияПараметраБуфер);
			
			// Иногда описание может быть записано в тип параметра. Например:
			//  ... - см.ВариантыОтчетов.СвойстваВариантовОтчетовИзФайлов
			//  ... - См.ВариантыОтчетов.СвойстваВариантовОтчетовИзФайлов
			
			// Проверим, если элемент содержит литерал "см." / "see", это не тип параметра.
			МассивТекстСм = Контекст["МассивТекстСм"];
			Если СтрНачинаетсяСПоМассиву(ЭлементОписанияПараметраБуферВРег, МассивТекстСм).Успешно Тогда
				ЭтоОписаниеТипаПараметра = Ложь;
			КонецЕсли;
			
			Если ЭтоОписаниеТипаПараметра Тогда
				
				ЭлементОписанияПараметраБуферВРег = СтрЗаменить(ЭлементОписанияПараметраБуферВРег, Символы.Таб, " ");
				ЭлементОписанияПараметраБуферВРег = СтрСоединить(СтрРазделить(ЭлементОписанияПараметраБуферВРег, " ", Ложь), " ");
				
				// Заменим некоторые типы с пробелом.
				ТаблицаТиповПараметровДляПолученияОписания = Контекст["ТаблицаТиповПараметровДляПолученияОписания"];
				Для Каждого СтрокаТипаПараметра Из ТаблицаТиповПараметровДляПолученияОписания Цикл
					ЭлементОписанияПараметраБуферВРег = СтрЗаменить(ЭлементОписанияПараметраБуферВРег,
						СтрокаТипаПараметра.ТипПараметраДляПоиска, СтрокаТипаПараметра.ТипПараметраДляЗаменыВРег);
				КонецЦикла;
				
				МассивИсключенийТиповПараметров = Контекст["МассивИсключенийТиповПараметров"];
				
				// Тип параметра может быть множественным (перечислен через запятую), тогда проверяем каждый тип отдельно.
				МассивЭлементовТипаПараметра = СтрРазделить(ЭлементОписанияПараметраБуферВРег, ",;");
				Для Каждого ЭлементТипа Из МассивЭлементовТипаПараметра Цикл
					
					ЭлементТипа = СокрЛП(ЭлементТипа);
					
					// Если нашли исключение из типов параметров, то это не описание типа, прерываем.
					Если МассивИсключенийТиповПараметров.Найти(ЭлементТипа) <> Неопределено Тогда
						ЭтоОписаниеТипаПараметра = Ложь;
						Прервать;
					КонецЕсли;
					
					// Проверяем пробел в элементе описания параметра.
					Если СтрНайти(ЭлементТипа, " ") > 0 Тогда
						// Если нашли, то это не описание типа, прерываем.
						ЭтоОписаниеТипаПараметра = Ложь;
						Прервать;
					КонецЕсли;
					
					// Если элемент заканчивается на скобки, то это не тип параметра.
					Если СтрЗаканчиваетсяНа(ЭлементТипа, "()") ИЛИ СтрЗаканчиваетсяНа(ЭлементТипа, "().") Тогда
						ЭтоОписаниеТипаПараметра = Ложь;
						Прервать;
					КонецЕсли;
					
				КонецЦикла;
				
			КонецЕсли;
			
			Если ЭтоОписаниеТипаПараметра Тогда
				// Если это описание типа параметра, то запоминаем и переходим к следующему элементу описания.
				ТипПараметра = ЭлементОписанияПараметраБуфер;
				ТипПараметраМножественный = (МассивЭлементовТипаПараметра.Количество() > 1);
				ПозицияРазделителяПередТипомПараметра = ПозицияРазделителя;
				ПозицияТипаПараметра = ПозицияЭлементаОписанияПараметра;
				Продолжить;
			Иначе
				// Иначе это описание параметра или возвращаемого значения, тип параметра устанавливаем пустым.
				ТипПараметра = "";
			КонецЕсли;
			
		КонецЕсли;
		
		// Прошли элементы с именем и типом параметра, запоминаем позицию начала текстового описания и выходим.
		ПозицияРазделителяПередТекстовымОписаниемПараметра = ПозицияРазделителя;
		ПозицияТекстовогоОписанияПараметра = ПозицияЭлементаОписанияПараметра;
		Прервать;
		
	КонецЦикла;
	
	// Если удалось определить позицию текстового описания параметра, то получаем текстовое описание.
	Если ПозицияТекстовогоОписанияПараметра > 0 Тогда
		ТекстовоеОписаниеПараметра = Сред(СтрокаКомментария, ПозицияТекстовогоОписанияПараметра);
		
		// Возможно, текстовое описание будет начинаться со следующей строки, тогда очистим его позицию.
		Если ПустаяСтрока(ТекстовоеОписаниеПараметра) Тогда
			ПозицияТекстовогоОписанияПараметра = 0;
		КонецЕсли;
	КонецЕсли;
	
	СтрокаКомментарияБуфер = СтрЗаменить(СтрокаКомментария, "/", "");
	СтрокаКомментарияБуфер = СокрЛ(СтрокаКомментарияБуфер);
	
	СтруктураОписанияПараметра = Новый Структура;
	СтруктураОписанияПараметра.Вставить("ИмяПараметра", Строка(ИмяПараметра));
	СтруктураОписанияПараметра.Вставить("УровеньВложенностиПараметра", УровеньВложенностиПараметра);
	СтруктураОписанияПараметра.Вставить("ПозицияИмениПараметра", ПозицияИмениПараметра);
	СтруктураОписанияПараметра.Вставить("ТипПараметра", Строка(ТипПараметра));
	СтруктураОписанияПараметра.Вставить("ТипПараметраМножественный", ТипПараметраМножественный);
	СтруктураОписанияПараметра.Вставить("ПозицияРазделителяПередТипомПараметра", ПозицияРазделителяПередТипомПараметра);
	СтруктураОписанияПараметра.Вставить("ПозицияТипаПараметра", ПозицияТипаПараметра);
	СтруктураОписанияПараметра.Вставить("ТекстовоеОписаниеПараметра", ТекстовоеОписаниеПараметра);
	СтруктураОписанияПараметра.Вставить("ПозицияРазделителяПередТекстовымОписаниемПараметра", ПозицияРазделителяПередТекстовымОписаниемПараметра);
	СтруктураОписанияПараметра.Вставить("ПозицияТекстовогоОписанияПараметра", ПозицияТекстовогоОписанияПараметра);
	СтруктураОписанияПараметра.Вставить("ОписаниеПараметраНачинаетсяСТире", ПервыйЭлементПустой);
	СтруктураОписанияПараметра.Вставить("ОписаниеПараметраНачинаетсяСоЗвездочки", СтрНачинаетсяС(СтрокаКомментарияБуфер, "*"));
	
	Возврат СтруктураОписанияПараметра;
	
КонецФункции

Функция ПолучитьТекстОписанияПараметраДоПервойПустойСтроки(Знач ОписаниеПараметра)
	
	Если ПустаяСтрока(ОписаниеПараметра) Тогда
		Возврат ОписаниеПараметра;
	КонецЕсли;
	
	МассивСтрокОписанияПараметраИсходный = СтрРазделить(ОписаниеПараметра, Символы.ПС, Истина);
	МассивСтрокОписанияПараметраРезультат = Новый Массив;
	
	Для Каждого СтрокаОписанияПараметра Из МассивСтрокОписанияПараметраИсходный Цикл
		
		// Если строка комментария пустая, то прерываем.
		СтрокаОписанияПараметраБуфер = СтрЗаменить(СтрокаОписанияПараметра, "/", "");
		Если ПустаяСтрока(СтрокаОписанияПараметраБуфер) Тогда
			Прервать;
		КонецЕсли;
		
		// Непустые строки добавляем в результат.
		МассивСтрокОписанияПараметраРезультат.Добавить(СтрокаОписанияПараметра);
		
	КонецЦикла;
	
	Возврат СтрСоединить(МассивСтрокОписанияПараметраРезультат, Символы.ПС);
	
КонецФункции

Функция ПолучитьДлинуОтступаПервогоПараметра(ДокументТекст, НомерСтрокиНачалаСекции, КоличествоСтрокКомментария)
	
	ДлинаОтступаПервогоПараметра = 0;
	Для НомерСтрокиСекции = НомерСтрокиНачалаСекции + 1 По КоличествоСтрокКомментария Цикл
		
		// Ищем первую заполненную строку после открытия секции.
		СтрокаСекции = ДокументТекст.ПолучитьСтроку(НомерСтрокиСекции);
		ОтступПервогоПараметра = ПолучитьОтступПослеЗнакаКомментария(СтрокаСекции, Ложь);
		
		// Нельзя проверять методом "ПустаяСтрока()", т.к. в переменной будут только пробелы.
		Если ОтступПервогоПараметра <> "" Тогда
			// Для сравнения отступов заменим таб на 2 пробела, т.к. отступ часто делают визуально.
			ОтступПервогоПараметра = СтрЗаменить(ОтступПервогоПараметра, Символы.Таб, "  ");
			ДлинаОтступаПервогоПараметра = СтрДлина(ОтступПервогоПараметра);
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ДлинаОтступаПервогоПараметра;
	
КонецФункции

Функция СтрокаСодержитОписаниеПараметра(Знач СтрокаКомментария, СтруктураДанныхОписанияПараметра)
	
	// Если в строке количество знаков комментария больше 2-х, то это может быть шаблон для описания другой процедуры, например:
	//       * ОпределитьНастройкиФормы - Булево - отчет имеет программный интерфейс для тесной интеграции с формой отчета,
	//           в том числе может переопределять некоторые настройки формы и подписываться на ее события.
	//           Если Истина и отчет подключен к общей форме ФормаОтчета,
	//           тогда в модуле объекта отчета следует определить процедуру по шаблону:
	//               
	//               // Задать настройки формы отчета.
	//               //
	//               // Параметры:
	//               //   Форма - ФормаКлиентскогоПриложения, Неопределено -
	//               //   КлючВарианта - Строка, Неопределено -
	//               //   Настройки - см. ОтчетыКлиентСервер.НастройкиОтчетаПоУмолчанию
	//               //
	//               Процедура ОпределитьНастройкиФормы(Форма, КлючВарианта, Настройки) Экспорт
	//               	// Код процедуры.
	//               КонецПроцедуры
	Если СтрЧислоВхождений(СтрокаКомментария, "// ") > 1 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	СтрокаКомментарияБуфер = СтрокаКомментария;
	СтрокаКомментарияБуфер = СтрЗаменить(СтрокаКомментарияБуфер, "/", "");
	СтрокаКомментарияБуфер = СокрЛ(СтрокаКомментарияБуфер);
	
	// Если строка начинается со "*", то это описание свойства составного параметра для Структура, ТаблицаЗначений и т.п.
	Если СтрНачинаетсяС(СтрокаКомментарияБуфер, "*") Тогда
		Возврат Истина;
	КонецЕсли;
	
	// Если строка начинается с "-", то нужен дополнительный анализ.
	Если СтрНачинаетсяС(СтрокаКомментарияБуфер, "-") Тогда
		
		// Если в первом слове есть заглавные буквы, то это описание параметра или его типа.
		ПервоеСлово = ПолучитьПервоеСловоИзСтроки(СтрокаКомментарияБуфер, Истина);
		Если НРег(ПервоеСлово) <> ПервоеСлово Тогда
			Возврат Истина;
		КонецЕсли;
		
		// Если строка начинается со ссылки "- см. ", то считаем, что это описание следующего типа параметра.
		МассивТекстСм = Контекст["МассивТекстСм"];
		Если СтрНачинаетсяСПоМассиву(ВРег(ПервоеСлово) + " ", МассивТекстСм).Успешно Тогда
			Возврат Истина;
		КонецЕсли;
		
		// Если строка комментария начинается с типа параметра, то считаем, что строка содержит описание параметра.
		Если СтрокаНачинаетсяСТипаПараметра(СтрокаКомментарияБуфер).Успешно Тогда
			Возврат Истина;
		КонецЕсли;
		
		// Иначе это продолжение описания предыдущего параметра.
		Возврат Ложь;
		
	КонецЕсли;
	
	СтрокаОписанияПредыдущегоПараметра = СтруктураДанныхОписанияПараметра.СтрокаОписанияПредыдущегоПараметра;
	
	// Получаем уровень вложенности предыдущего параметра.
	УровеньВложенностиПредыдущегоПараметра = 0;
	Если СтрокаОписанияПредыдущегоПараметра <> Неопределено Тогда
		УровеньВложенностиПредыдущегоПараметра = СтрокаОписанияПредыдущегоПараметра.УровеньВложенностиПараметра;
	КонецЕсли;
	
	ДлинаОтступаТекущегоПараметра = СтруктураДанныхОписанияПараметра.ДлинаОтступаТекущегоПараметра;
	ДлинаОтступаПредыдущегоПараметра = СтруктураДанныхОписанияПараметра.ДлинаОтступаПредыдущегоПараметра;
	РазницаОтступовТекущегоИПредыдущегоПараметров = ДлинаОтступаТекущегоПараметра - ДлинаОтступаПредыдущегоПараметра;
	
	// Если уровень вложенности предыдущего параметра больше 0 (перед ним стояла "*"),
	// а уровень вложенности текущего параметра = 0 (проверено выше - не начинается со "*"),
	// но при этом она сдвинута вправо, то это точно не описание нового параметра.
	Если (УровеньВложенностиПредыдущегоПараметра > 0) И (РазницаОтступовТекущегоИПредыдущегоПараметров > 0) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	// Если в строке нет тире, то это не описание параметра.
	ПозицияТире = СтрНайти(СтрокаКомментарияБуфер, " - ");
	Если ПозицияТире = 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	// Выделяем текст до тире.
	ПервыйЭлементОписания = Лев(СтрокаКомментарияБуфер, ПозицияТире);
	ПервыйЭлементОписания = СокрП(ПервыйЭлементОписания);
	
	// Если в строке до тире есть пробелы, то это не описание параметра.
	СтрокаНезначимыхСимволов = " ,.," + Символы.Таб;
	МассивНезначимыхСимволов = СтрРазделить(СтрокаНезначимыхСимволов, ",");
	Если СтрНайтиПоМассиву(ПервыйЭлементОписания, МассивНезначимыхСимволов).Успешно Тогда
		Возврат Ложь;
	КонецЕсли;
	
	// Если в первом элементе описания нет заглавных букв, то это не описание параметра.
	Если НРег(ПервыйЭлементОписания) = ПервыйЭлементОписания Тогда
		Возврат Ложь;
	КонецЕсли;
	
	// Если строка начинается с булевого значения, то это продолжение описания предыдущего параметра.
	МассивТекстИстинаЛожь = Контекст["МассивТекстИстинаЛожь"];
	Если МассивТекстИстинаЛожь.Найти(ВРег(ПервыйЭлементОписания)) <> Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	// Если строка начинается с ссылки "см. ", то считаем, что это продолжение описания предыдущего параметра.
	МассивТекстСм = Контекст["МассивТекстСм"];
	Если СтрНачинаетсяСПоМассиву(ВРег(СтрокаКомментарияБуфер), МассивТекстСм).Успешно Тогда
		Возврат Ложь;
	КонецЕсли;
	
	// Проверяем отдельно секцию "Параметры".
	СекцияОписания = СтруктураДанныхОписанияПараметра.СекцияОписания;
	Если СекцияОписания = "Параметры" Тогда
		
		МассивПараметров = Новый Массив;
		ТекущийОбрабатываемыйМетод = Контекст["ТекущийОбрабатываемыйМетод"];
		Если ТекущийОбрабатываемыйМетод <> Неопределено Тогда
			МассивПараметров = ТекущийОбрабатываемыйМетод.МассивПараметров;
		КонецЕсли;
		
		// Ищем первое слово среди параметров метода.
		Для Каждого Параметр Из МассивПараметров Цикл
			ИмяПараметра = ПолучитьИмяПараметра(Параметр);
			Если СтрСравнить(ИмяПараметра, ПервыйЭлементОписания) = 0 Тогда
				Возврат Истина;
			КонецЕсли;
		КонецЦикла;
		
	КонецЕсли;
	
	// Предполагаем, что если вторым элементом (после тире) написан тип параметра, то это строка с описанием параметра.
	МассивЭлементовОписания = СтрРазделить(СтрокаКомментарияБуфер, "-", Ложь);
	Если МассивЭлементовОписания.Количество() > 1 Тогда
		
		// Определяем второй параметр.
		ВторойЭлементОписания = МассивЭлементовОписания[1];
		ВторойЭлементОписания = СокрЛ(ВторойЭлементОписания);
		ВторойЭлементОписания = ВРег(ВторойЭлементОписания);
		Если СтрНачинаетсяСПоМассиву(ВторойЭлементОписания, МассивТекстСм).Успешно Тогда
			// Если второй элемент описания содержит гиперссылку, то это описание параметра.
			Возврат Истина;
		КонецЕсли;
		
		// Проверим второй параметр в исключениях для типа параметра.
		МассивИсключенийТиповПараметров = Контекст["МассивИсключенийТиповПараметров"];
		Если СтрНачинаетсяСПоМассиву(ВторойЭлементОписания, МассивИсключенийТиповПараметров).Успешно Тогда
			Возврат Ложь;
		КонецЕсли;
		
		// Если второй элемент начинается с типа параметра, то это строка с описанием параметра.
		Если СтрокаНачинаетсяСТипаПараметра(ВторойЭлементОписания).Успешно Тогда
			Возврат Истина;
		КонецЕсли;
		
	КонецЕсли;
	
	Если СтрокаОписанияПредыдущегоПараметра = Неопределено Тогда
		Возврат Истина;
	КонецЕсли;
	
	// Если отступ текущего параметра равен предыдущему, то переопределяем предыдущий параметр.
	Если РазницаОтступовТекущегоИПредыдущегоПараметров = 0 Тогда
		
		// Получаем таблицу параметров.
		ТаблицаОписанияПараметров = СтрокаОписанияПредыдущегоПараметра.Владелец();
		ИндексСтрокиПредыдущегоПараметра = ТаблицаОписанияПараметров.Индекс(СтрокаОписанияПредыдущегоПараметра) - 1;
		
		// Ищем вверх по таблице параметр, у которого отступ меньше, чем у текущего.
		Для ИндексСтроки = 0 По ИндексСтрокиПредыдущегоПараметра Цикл
			
			ИндексСтрокиВверх = ИндексСтрокиПредыдущегоПараметра - ИндексСтроки;
			
			// Если секции не равны, то прерываем.
			СтрокаОписанияПараметраВверх = ТаблицаОписанияПараметров[ИндексСтрокиВверх];
			Если СтрокаОписанияПараметраВверх.СекцияОписания <> СекцияОписания Тогда
				Прервать;
			КонецЕсли;
			
			// Получаем полное описание предыдущего параметра и вычисляем отступ с учетом замены таба на 2 пробела.
			ПолноеОписаниеПараметраВверх = СтрокаОписанияПараметраВверх.ПолноеОписаниеПараметра;
			ОтступПредыдущегоПараметраВверх = ПолучитьОтступПослеЗнакаКомментария(ПолноеОписаниеПараметраВверх, Ложь);
			ОтступПредыдущегоПараметраВверх = СтрЗаменить(ОтступПредыдущегоПараметраВверх, Символы.Таб, "  ");
			ДлинаОтступаПараметраВверх = СтрДлина(ОтступПредыдущегоПараметраВверх);
			
			// Если нашли параметр с отступом меньше, чем у текущего, то запоминаем его как предыдущий параметр.
			Если ДлинаОтступаПараметраВверх < ДлинаОтступаТекущегоПараметра Тогда
				СтрокаОписанияПредыдущегоПараметра = СтрокаОписанияПараметраВверх;
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	// Получаем тип предыдущего параметра.
	ТипПредыдущегоПараметра = СтрокаОписанияПредыдущегоПараметра.ТипПараметра;
	Если СтрокаОписанияПредыдущегоПараметра.ТипПараметраМножественный Тогда
		// Если тип множественный, то берем первый тип из описания.
		МассивТиповПараметра = СтрРазделить(ТипПредыдущегоПараметра, ",", Ложь);
		ТипПредыдущегоПараметра = МассивТиповПараметра[0];
	КонецЕсли;
	
	// Подготовим тип предыдущего параметра для поиска в массиве составных типов параметров.
	ТипПредыдущегоПараметра = ПреобразоватьТекстДляСравнения(ТипПредыдущегоПараметра);
	
	// Если предыдущий параметр составного типа, то проверим другие показатели.
	МассивСоставныхТиповПараметров = Контекст["МассивСоставныхТиповПараметров"];
	Если МассивСоставныхТиповПараметров.Найти(ТипПредыдущегоПараметра) <> Неопределено Тогда
		
		// Нашли тип параметра среди составных типов, проверяем двоеточие в конце описания параметра.
		ПолноеОписаниеПредыдущегоПараметра = СокрП(СтрокаОписанияПредыдущегоПараметра.ПолноеОписаниеПараметра);
		Если СтрЗаканчиваетсяНа(ПолноеОписаниеПредыдущегоПараметра, ":") Тогда
			Возврат Истина;
		КонецЕсли;
		
		// Если текст до тире равен "Ключ" или "Значение", то это описание параметра.
		МассивТекстКлючЗначение = Контекст["МассивТекстКлючЗначение"];
		Если МассивТекстКлючЗначение.Найти(ВРег(ПервыйЭлементОписания)) <> Неопределено Тогда
			Возврат Истина;
		КонецЕсли;
		
	КонецЕсли;
	
	// Иначе это продолжение текстового описания текущего параметра.
	Возврат Ложь;
	
КонецФункции

Функция СтрокаСодержитИмяПараметра(Знач СтрокаКомментария, ЭтоОписаниеВозвращаемогоЗначения = Ложь)
	
	СтрокаКомментария = СтрЗаменить(СтрокаКомментария, "/", "");
	Если ПустаяСтрока(СтрокаКомментария) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	СтрокаКомментария = СтрЗаменить(СтрокаКомментария, Символы.Таб, " ");
	СтрокаКомментария = СокрЛП(СтрокаКомментария);
	СтрокаКомментария = ВРег(СтрокаКомментария);
	
	// Если строка комментария начинается со "*", то имя параметра точно указано.
	Если СтрНачинаетсяС(СтрокаКомментария, "*") Тогда
		// Описание возвращаемого значения не может начинаться со "*", перебиваем флаг "ЭтоОписаниеВозвращаемогоЗначения".
		ЭтоОписаниеВозвращаемогоЗначения = Ложь;
		Возврат Истина;
	КонецЕсли;
	
	// Запомним флаг, что строка начинается с тире.
	СтрокаКомментарияНачинаетсяСТире = СтрНачинаетсяС(СтрокаКомментария, "-");
	Если СтрокаКомментарияНачинаетсяСТире Тогда
		// Удалим все символы "-" в начале комментария.
		Пока СтрНачинаетсяС(СтрокаКомментария, "-") Цикл
			СтрокаКомментария = Сред(СтрокаКомментария, 2);
			СтрокаКомментария = СокрЛ(СтрокаКомментария);
		КонецЦикла;
	КонецЕсли;
	
	// Рассмотрим общий случай - это комментарий любой строки секции "Параметры" или
	// описание любого свойства секции "Возвращаемое значение",
	// кроме самого описания возвращаемого значения (как правило, первой строки секции "Возвращаемое значение").
	Если НЕ ЭтоОписаниеВозвращаемогоЗначения Тогда
		
		// В общем случае всегда необходимо получать имя параметра.
		// Кроме случая, когда строка начинается с "-", возможно, это описание следующего типа предыдущего параметра.
		Если НЕ СтрокаКомментарияНачинаетсяСТире Тогда
			Возврат Истина;
		КонецЕсли;
		
		// Если строка комментария начинается с типа параметра, то имя параметра не указано.
		СтруктураПоискаТипаПараметра = СтрокаНачинаетсяСТипаПараметра(СтрокаКомментария);
		Если СтруктураПоискаТипаПараметра.Успешно Тогда
			
			// Если не нашли тип параметра в массиве типов для проверки, то имя параметра не указано.
			МассивТиповПараметровДляПроверки = Контекст["МассивТиповПараметровДляПроверки"];
			Если МассивТиповПараметровДляПроверки.Найти(СтруктураПоискаТипаПараметра.НайденныйЭлемент) = Неопределено Тогда
				Возврат Ложь;
			КонецЕсли;
			
			// Разделим строку по элементам.
			МассивЭлементовОписания = СтрРазделить(СтрокаКомментария, "-", Ложь);
			Если МассивЭлементовОписания.Количество() < 2 Тогда
				// Если в строке только 1 элемент, то выходим.
				Возврат Ложь;
			КонецЕсли;
			
			// Если второй элемент описания является типом, то первым элементом указано имя параметра.
			Возврат СтрокаНачинаетсяСТипаПараметра(МассивЭлементовОписания[1]).Успешно;
			
		КонецЕсли;
		
		// Если строка комментария начинается со ссылки "см.", то имя параметра не указано.
		МассивТекстСм = Контекст["МассивТекстСм"];
		Если СтрНачинаетсяСПоМассиву(СтрокаКомментария, МассивТекстСм).Успешно Тогда
			Возврат Ложь;
		КонецЕсли;
		
		// Получаем массив параметров текущего метода.
		МассивПараметров = Новый Массив;
		ТекущийОбрабатываемыйМетод = Контекст["ТекущийОбрабатываемыйМетод"];
		Если ТекущийОбрабатываемыйМетод <> Неопределено Тогда
			МассивПараметров = ТекущийОбрабатываемыйМетод.МассивПараметров;
		КонецЕсли;
		
		// Ищем первое слово среди параметров метода.
		ПервоеСловоСтрокиКомментария = ПолучитьПервоеСловоИзСтроки(СтрокаКомментария);
		Для Каждого Параметр Из МассивПараметров Цикл
			ИмяПараметра = ПолучитьИмяПараметра(Параметр);
			Если СтрСравнить(ИмяПараметра, ПервоеСловоСтрокиКомментария) = 0 Тогда
				Возврат Истина;
			КонецЕсли;
		КонецЦикла;
		
		// Иногда тип параметра ошибочно указывается в скобках после имени параметра.
		Если СтрокаСодержитТипПараметраВСкобках(СтрокаКомментария).Успешно Тогда
			// Если текст в скобках является типом параметра, то имя параметра указано.
			Возврат Истина;
		КонецЕсли;
		
	Иначе
		
		// Рассмотрим случай, когда передана строка комментария описания возвращаемого значения.
		// Если строка комментария начинается со ссылки "см.", то имя параметра не указано.
		МассивТекстСм = Контекст["МассивТекстСм"];
		Если СтрНачинаетсяСПоМассиву(СтрокаКомментария, МассивТекстСм).Успешно Тогда
			Возврат Ложь;
		КонецЕсли;
		
		// Если строка начинается с типа параметра, то имя параметра не указано.
		СтруктураПоискаТипаПараметра = СтрокаНачинаетсяСТипаПараметра(СтрокаКомментария);
		Если СтруктураПоискаТипаПараметра.Успешно Тогда
			Возврат Ложь;
		КонецЕсли;
		
	КонецЕсли;
	
	// Проверяем исключения для первого элемента описания параметра.
	МассивИсключенийИменПараметров = Контекст["МассивИсключенийИменПараметров"];
	Если СтрНачинаетсяСПоМассиву(СтрокаКомментария, МассивИсключенийИменПараметров).Успешно Тогда
		Возврат Ложь;
	КонецЕсли;
	
	// Если внутри строки есть тире, то имя параметра указано.
	Если СтрНайти(СтрокаКомментария, " - ") > 0 Тогда
		Возврат Истина;
	КонецЕсли;
	
	// В остальных случаях имя параметра не указано.
	Возврат Ложь;
	
КонецФункции

Функция СтрокаНачинаетсяСТипаПараметра(Знач СтрокаКомментария)
	
	СтруктураВозврата = Новый Структура;
	СтруктураВозврата.Вставить("НайденныйЭлемент", "");
	СтруктураВозврата.Вставить("Успешно", Ложь);
	
	СтрокаКомментария = СтрЗаменить(СтрокаКомментария, "/", "");
	СтрокаКомментария = СтрЗаменить(СтрокаКомментария, Символы.Таб, " ");
	СтрокаКомментария = СокрЛП(СтрокаКомментария);
	СтрокаКомментария = ВРег(СтрокаКомментария);
	
	// Делим строку комментария на элементы описания параметра.
	МассивЭлементовОписания = СтрРазделить(СтрокаКомментария, "-", Ложь);
	Если МассивЭлементовОписания.Количество() = 0 Тогда
		// Если в строке нет элементов, то выходим.
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	ТаблицаТиповПараметров = Контекст["ТаблицаТиповПараметров"];
	
	// Сначала ищем первый элемент описания в массиве всех типов.
	ПервыйЭлементОписания = СокрЛП(МассивЭлементовОписания[0]);
	Если ТаблицаТиповПараметров.Найти(ПервыйЭлементОписания, "ТипПараметраДляПоиска") <> Неопределено Тогда
		// Если нашли, то выходим.
		СтруктураВозврата.Успешно = Истина;
		СтруктураВозврата.НайденныйЭлемент = ПервыйЭлементОписания;
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	// Если не нашли, то получаем первое слово первого элемента описания.
	ПервоеСловоПервогоЭлементаОписания = ПолучитьПервоеСловоИзСтроки(ПервыйЭлементОписания);
	
	// Если первое слово равно первому элементу описания, то искать повторно не имеет смысла, выходим.
	Если ПервоеСловоПервогоЭлементаОписания = ПервыйЭлементОписания Тогда
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	// Затем ищем первое слово первого элемента описания в массиве типов.
	Если ТаблицаТиповПараметров.Найти(ПервоеСловоПервогоЭлементаОписания, "ТипПараметраДляПоиска") <> Неопределено Тогда
		// Если нашли, то выходим.
		СтруктураВозврата.Успешно = Истина;
		СтруктураВозврата.НайденныйЭлемент = ПервоеСловоПервогоЭлементаОписания;
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	// Иначе строка комментария не начинается с типа параметра.
	Возврат СтруктураВозврата;
	
КонецФункции

Функция СтрокаСодержитТипПараметраВСкобках(Знач СтрокаКомментария)
	
	СтруктураВозврата = Новый Структура;
	СтруктураВозврата.Вставить("ПозицияОткрытойСкобки", 0);
	СтруктураВозврата.Вставить("ПозицияЗакрытойСкобки", 0);
	СтруктураВозврата.Вставить("ТекстВСкобках", "");
	СтруктураВозврата.Вставить("Успешно", Ложь);
	
	ПозицияОткрытойСкобки = СтрНайти(СтрокаКомментария, "(");
	Если ПозицияОткрытойСкобки = 0 Тогда
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	СтруктураВозврата.ПозицияОткрытойСкобки = ПозицияОткрытойСкобки;
	
	ПозицияЗакрытойСкобки = СтрНайти(СтрокаКомментария, ")");
	Если ПозицияЗакрытойСкобки = 0 Тогда
		ПозицияЗакрытойСкобки = СтрДлина(СтрокаКомментария);
	КонецЕсли;
	
	СтруктураВозврата.ПозицияЗакрытойСкобки = ПозицияЗакрытойСкобки;
	
	ТекстВСкобках = Сред(СтрокаКомментария, ПозицияОткрытойСкобки + 1, ПозицияЗакрытойСкобки - ПозицияОткрытойСкобки - 1);
	СтруктураВозврата.ТекстВСкобках = ТекстВСкобках;
	
	Если СтрокаНачинаетсяСТипаПараметра(ТекстВСкобках).Успешно Тогда
		СтруктураВозврата.Успешно = Истина;
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции

Функция СтрокаСодержитОписаниеСвойства(Знач СтрокаКомментария, ИмяСвойства)
	
	СтруктураВозврата = Новый Структура;
	СтруктураВозврата.Вставить("Позиция", 0);
	СтруктураВозврата.Вставить("НайденныйЭлемент", "");
	СтруктураВозврата.Вставить("Успешно", Ложь);
	
	МассивПоиска = Новый Массив;
	Если ТипЗнч(ИмяСвойства) = Тип("Строка") Тогда
		МассивПоиска.Добавить(ВРег(ИмяСвойства));
	ИначеЕсли ТипЗнч(ИмяСвойства) = Тип("Массив") Тогда
		МассивПоиска = ИмяСвойства;
	Иначе
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	СтрокаКомментария = ВРег(СтрокаКомментария);
	
	ПозицияСвойства = 0;
	Пока Истина Цикл
		
		РезультатПоиска = СтрНайтиПоМассиву(СтрокаКомментария, МассивПоиска,, ПозицияСвойства + 1);
		Если НЕ РезультатПоиска.Успешно Тогда
			Возврат СтруктураВозврата;
		КонецЕсли;
		
		ПозицияСвойства = РезультатПоиска.Позиция;
		
		// Проверяем предыдущий и следующий символы.
		Если ПозицияСвойства > 1 Тогда
			ПредыдущийСимвол = Сред(СтрокаКомментария, ПозицияСвойства - 1, 1);
			Если апк_СловоСодержитЗначимыеСимволы(ПредыдущийСимвол) Тогда
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		
		НайденныйЭлемент = РезультатПоиска.НайденныйЭлемент;
		СледующийСимвол = Сред(СтрокаКомментария, ПозицияСвойства + СтрДлина(НайденныйЭлемент), 1);
		Если апк_СловоСодержитЗначимыеСимволы(СледующийСимвол) Тогда
			Продолжить;
		КонецЕсли;
		
		СтруктураВозврата.Позиция = ПозицияСвойства;
		СтруктураВозврата.НайденныйЭлемент = НайденныйЭлемент;
		СтруктураВозврата.Успешно = Истина;
		
		Прервать;
		
	КонецЦикла;
	
	Возврат СтруктураВозврата;
	
КонецФункции

Функция СтрокаСодержитОписаниеСвойствКлючИЗначение(Знач СтрокаКомментария)
	
	СтруктураВозврата = Новый Структура;
	СтруктураВозврата.Вставить("ПозицияТекстаКлюч", 0);
	СтруктураВозврата.Вставить("ПозицияТекстаЗначение", 0);
	СтруктураВозврата.Вставить("НайденныйТекстКлюч", "");
	СтруктураВозврата.Вставить("НайденныйТекстЗначение", "");
	СтруктураВозврата.Вставить("Успешно", Ложь);
	
	// Проверяем текст "Ключ" со всеми вариантами склонения в текстовом описании параметра.
	СтруктураПоиска = СтрокаСодержитОписаниеСвойства(СтрокаКомментария, Контекст["МассивТекстКлюч"]);
	Если НЕ СтруктураПоиска.Успешно Тогда
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	СтруктураВозврата.ПозицияТекстаКлюч  = СтруктураПоиска.Позиция;
	СтруктураВозврата.НайденныйТекстКлюч = Контекст["ТекстКлюч"];
	
	// Проверяем текст "Значение" со всеми вариантами склонения в текстовом описании параметра.
	СтруктураПоиска = СтрокаСодержитОписаниеСвойства(СтрокаКомментария, Контекст["МассивТекстЗначение"]);
	Если НЕ СтруктураПоиска.Успешно Тогда
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	СтруктураВозврата.ПозицияТекстаЗначение  = СтруктураПоиска.Позиция;
	СтруктураВозврата.НайденныйТекстЗначение = Контекст["ТекстЗначение"];;
	СтруктураВозврата.Успешно = Истина;
	
	Возврат СтруктураВозврата;
	
КонецФункции

Функция СтрокаСодержитНачалоСекции(Знач СтрокаКомментария, МассивТекстНаименованийСекции)
	
	СтрокаКомментарияБуфер = ВРег(СтрокаКомментария);
	СтрокаКомментарияБуфер = СтрЗаменить(СтрокаКомментарияБуфер, " ", "");
	СтрокаКомментарияБуфер = СтрЗаменить(СтрокаКомментарияБуфер, Символы.Таб, "");
	
	// Проверяем текст строки целиком в массиве возможных вариантов наименований секции.
	Если МассивТекстНаименованийСекции.Найти(СтрокаКомментарияБуфер) <> Неопределено Тогда
		Возврат Истина;
	КонецЕсли;
	
	Для Каждого НаименованиеСекции Из МассивТекстНаименованийСекции Цикл
		
		// Проверяем текст строки среди возможных вариантов наименований секции с двоеточием.
		Если СтрокаКомментарияБуфер = НаименованиеСекции + ":" Тогда
			Возврат Истина;
		КонецЕсли;
		
		// Если строка начинается с возможного варианта наименования секции с тире, то это начало секции.
		Если СтрНачинаетсяС(СтрокаКомментарияБуфер, НаименованиеСекции + "-") Тогда
			Возврат Истина;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

Функция УдалитьПервыйНезначимыйСимволИзСтроки(Знач Строка)
	
	Если ПустаяСтрока(Строка) Тогда
		Возврат Строка;
	КонецЕсли;
	
	Строка = СокрЛ(Строка);
	
	МассивЗначимыхСимволовНачалаСтроки = Контекст["МассивЗначимыхСимволовНачалаСтроки"];
	Если СтрНачинаетсяСПоМассиву(Строка, МассивЗначимыхСимволовНачалаСтроки).Успешно Тогда
		Возврат Строка;
	КонецЕсли;
	
	ПервыйСимвол = Лев(Строка, 1);
	Если НЕ апк_СловоСодержитЗначимыеСимволы(ПервыйСимвол) Тогда
		Строка = Сред(Строка, 2);
		Строка = СокрЛ(Строка);
	КонецЕсли;
	
	Возврат Строка;
	
КонецФункции

Функция УдалитьПоследнийНезначимыйСимволИзСтроки(Знач Строка)
	
	Если ПустаяСтрока(Строка) Тогда
		Возврат Строка;
	КонецЕсли;
	
	Строка = СокрП(Строка);
	
	МассивЗначимыхСимволовОкончанияСтроки = Контекст["МассивЗначимыхСимволовОкончанияСтроки"];
	Если СтрЗаканчиваетсяНаПоМассиву(Строка, МассивЗначимыхСимволовОкончанияСтроки).Успешно Тогда
		Возврат Строка;
	КонецЕсли;
	
	ПоследнийСимвол = Прав(Строка, 1);
	Если НЕ апк_СловоСодержитЗначимыеСимволы(ПоследнийСимвол) Тогда
		Строка = Лев(Строка, СтрДлина(Строка) - 1);
		Строка = СокрП(Строка);
	КонецЕсли;
	
	Возврат Строка;
	
КонецФункции

Функция ИнициализироватьТаблицуОписанияПараметровМетода()
	
	ТаблицаОписанияПараметров = Новый ТаблицаЗначений;
	ТаблицаОписанияПараметров.Колонки.Добавить("ПолноеОписаниеПараметра");
	ТаблицаОписанияПараметров.Колонки.Добавить("ИмяПараметра");
	ТаблицаОписанияПараметров.Колонки.Добавить("УровеньВложенностиПараметра");
	ТаблицаОписанияПараметров.Колонки.Добавить("ПозицияИмениПараметра");
	ТаблицаОписанияПараметров.Колонки.Добавить("ТипПараметра");
	ТаблицаОписанияПараметров.Колонки.Добавить("ТипПараметраМножественный");
	ТаблицаОписанияПараметров.Колонки.Добавить("ПозицияРазделителяПередТипомПараметра");
	ТаблицаОписанияПараметров.Колонки.Добавить("ПозицияТипаПараметра");
	ТаблицаОписанияПараметров.Колонки.Добавить("ТекстовоеОписаниеПараметра");
	ТаблицаОписанияПараметров.Колонки.Добавить("ТекстовоеОписаниеПараметраСодержитГиперссылку");
	ТаблицаОписанияПараметров.Колонки.Добавить("ТекстовоеОписаниеПараметраЯвляетсяГиперссылкой");
	ТаблицаОписанияПараметров.Колонки.Добавить("ПозицияРазделителяПередТекстовымОписаниемПараметра");
	ТаблицаОписанияПараметров.Колонки.Добавить("ПозицияТекстовогоОписанияПараметра");
	ТаблицаОписанияПараметров.Колонки.Добавить("СекцияОписания");
	ТаблицаОписанияПараметров.Колонки.Добавить("ЭтоОписаниеВозвращаемогоЗначения");
	ТаблицаОписанияПараметров.Колонки.Добавить("ЭтоПараметрВерхнегоУровня");
	ТаблицаОписанияПараметров.Колонки.Добавить("ОписаниеПараметраНачинаетсяСТире");
	ТаблицаОписанияПараметров.Колонки.Добавить("ОписаниеПараметраНачинаетсяСоЗвездочки");
	ТаблицаОписанияПараметров.Колонки.Добавить("НомерСтрокиНачалаОписанияПараметра");
	ТаблицаОписанияПараметров.Колонки.Добавить("НомерСтрокиКонцаОписанияПараметра");
	ТаблицаОписанияПараметров.Колонки.Добавить("СостояниеПараметра");
	ТаблицаОписанияПараметров.Колонки.Добавить("ТекстОшибки");
	ТаблицаОписанияПараметров.Колонки.Добавить("НеобходимоПовторноеФорматирование");
	
	Возврат ТаблицаОписанияПараметров;
	
КонецФункции

Функция ПолучитьТаблицуОписанияПараметровМетода(Знач ТекстКомментарияМетода)
	
	ТаблицаОписанияПараметров = ИнициализироватьТаблицуОписанияПараметровМетода();
	
	Если ПустаяСтрока(ТекстКомментарияМетода) Тогда
		Возврат ТаблицаОписанияПараметров;
	КонецЕсли;
	
	МассивТекстПараметры = Контекст["МассивТекстПараметры"];
	МассивТекстВозвращаемоеЗначение = Контекст["МассивТекстВозвращаемоеЗначение"];
	МассивТекстПараметрыВозвращаемоеЗначение = Контекст["МассивТекстПараметрыВозвращаемоеЗначение"];
	МассивТекстОкончанияСекцииОписанияПараметров = Контекст["МассивТекстОкончанияСекцииОписанияПараметров"];
	
	ДокументТекст = Новый ТекстовыйДокумент;
	ДокументТекст.УстановитьТекст(ТекстКомментарияМетода);
	
	КоличествоСтрокКомментария = ДокументТекст.КоличествоСтрок();
	
	ТекстКомментарияМетодаВРег = ТекстКомментарияМетода;
	ТекстКомментарияМетодаВРег = ВРег(ТекстКомментарияМетодаВРег);
	ТекстКомментарияМетодаВРег = СтрЗаменить(ТекстКомментарияМетодаВРег, Символы.Таб, "");
	ТекстКомментарияМетодаВРег = СтрЗаменить(ТекстКомментарияМетодаВРег, " ", "");
	
	ПозицияПоискаСекции = 0;
	ЭтоОписаниеВозвращаемогоЗначения = Ложь;
	Для Каждого НаименованиеСекции Из МассивТекстПараметрыВозвращаемоеЗначение Цикл
		
		ПозицияПоискаСекции = СтрНайти(ТекстКомментарияМетодаВРег, НаименованиеСекции,, ПозицияПоискаСекции + 1);
		Если ПозицияПоискаСекции = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		НомерСтрокиНачалаСекции = ПолучитьНомерСтрокиМодуля(ТекстКомментарияМетодаВРег, ПозицияПоискаСекции);
		СтрокаСекции = ДокументТекст.ПолучитьСтроку(НомерСтрокиНачалаСекции);
		
		// Если в строке начала секции количество знаков комментария больше 2-х,
		// то это может быть шаблон для описания другой процедуры, пример ниже.
		Если СтрЧислоВхождений(СтрокаСекции, "// ") > 1 Тогда
			Продолжить;
		КонецЕсли;
		
		Если МассивТекстПараметры.Найти(НаименованиеСекции) <> Неопределено Тогда
			СекцияОписания = "Параметры";
			ЭтоОписаниеВозвращаемогоЗначения = Ложь;
		ИначеЕсли МассивТекстВозвращаемоеЗначение.Найти(НаименованиеСекции) <> Неопределено Тогда
			СекцияОписания = "ВозвращаемоеЗначение";
			ЭтоОписаниеВозвращаемогоЗначения = Истина;
			// Проверяем, что строка действительно является началом секции, т.к. секция "Возвращаемое значение" часто бывает описана неверно.
			Если НЕ СтрокаСодержитНачалоСекции(СтрокаСекции, МассивТекстВозвращаемоеЗначение) Тогда
				Продолжить;
			КонецЕсли;
		Иначе
			Продолжить;
		КонецЕсли;
		
		// Иногда секция "Возвращаемое значение" описана неверно, например:
		// Возвращаемое значение - Строка - шаблон имя профиля безопасности.
		// Тогда переопределяем номер строки начала секции.
		Если СтрНайти(СтрокаСекции, "-") > 0 Тогда
			НомерСтрокиНачалаСекции = НомерСтрокиНачалаСекции - 1;
		КонецЕсли;
		
		// Получаем длину отступа первого параметра.
		ДлинаОтступаПервогоПараметра = ПолучитьДлинуОтступаПервогоПараметра(ДокументТекст, НомерСтрокиНачалаСекции, КоличествоСтрокКомментария);
		
		// Если не удалось получить отступ первого параметра, то пропускаем секцию.
		Если ДлинаОтступаПервогоПараметра = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаТаблицыОписанияПараметров = Неопределено;
		МассивСтрокПолногоОписанияПараметра = Новый Массив;
		МассивСтрокТекстовогоОписанияПараметра = Новый Массив;
		ТекущийУровеньВложенности = 0;
		ДлинаОтступаТекущегоПараметра = ДлинаОтступаПервогоПараметра;
		ДлинаОтступаПредыдущегоПараметра = ДлинаОтступаТекущегоПараметра;
		
		Для НомерСтроки = НомерСтрокиНачалаСекции + 1 По КоличествоСтрокКомментария Цикл
			
			СтрокаСекцииИсходная = ДокументТекст.ПолучитьСтроку(НомерСтроки);
			СтрокаСекции = СокрЛ(СтрокаСекцииИсходная);
			СтрокаСекции = СтрЗаменить(СтрокаСекции, Символы.Таб, "  "); // Для сравнения отступа также заменяем таб на 2 пробела.
			
			// Если комментарий закончился, то прерываем.
			Если НЕ СтрНачинаетсяС(СтрокаСекции, "//") Тогда
				Прервать;
			КонецЕсли;
			
			// Если обрабатывается секция "Параметры", и встретилась секция "Возвращаемое значение", то прерываем.
			Если СекцияОписания = "Параметры" Тогда
				Если СтрокаСодержитНачалоСекции(СтрокаСекции, МассивТекстВозвращаемоеЗначение) Тогда
					Прервать;
				КонецЕсли;
			КонецЕсли;
			
			СтрокаСекцииБуфер = ВРег(СтрокаСекции);
			СтрокаСекцииБуфер = СтрЗаменить(СтрокаСекцииБуфер, " ", "");
			
			// Если встретились указатели окончания секции описания параметров, например, секция "Пример", то прерываем.
			Если СтрНачинаетсяСПоМассиву(СтрокаСекцииБуфер, МассивТекстОкончанияСекцииОписанияПараметров).Успешно Тогда
				Прервать;
			КонецЕсли;
			
			// Проверяем отступ каждого параметра.
			ОтступТекущегоПараметра = ПолучитьОтступПослеЗнакаКомментария(СтрокаСекции, Ложь);
			ДлинаОтступаТекущегоПараметра = СтрДлина(ОтступТекущегоПараметра);
			
			// Если отступа параметра нет, то параметры могут быть разделены пустой строкой, необходима дополнительная проверка.
			Если ДлинаОтступаТекущегоПараметра = 0 Тогда
				// Добавляем текстовое описание и переходим к следующей строке.
				МассивСтрокПолногоОписанияПараметра.Добавить(СтрокаСекцииИсходная);
				МассивСтрокТекстовогоОписанияПараметра.Добавить(СтрокаСекцииИсходная);
				Продолжить;
			КонецЕсли;
			
			// Если отступ в следующей строке меньше, чем отступ первого параметра, то описание секции закончилось.
			// С учетом замены символа табуляции на 2 пробела делаем допустимой разницу в 1 пробел.
			Если (ДлинаОтступаТекущегоПараметра + 1) < ДлинаОтступаПервогоПараметра Тогда
				Прервать;
			КонецЕсли;
			
			// Если отступ в следующей строке больше, чем отступ первого параметра,
			// то проверяем, содержит ли строка описание параметра.
			Если (ДлинаОтступаТекущегоПараметра > ДлинаОтступаПервогоПараметра) Тогда
				
				// Подготовим структуру параметров описания текущей строки.
				СтруктураДанныхОписанияПараметра = Новый Структура;
				СтруктураДанныхОписанияПараметра.Вставить("СекцияОписания", СекцияОписания);
				СтруктураДанныхОписанияПараметра.Вставить("ДлинаОтступаТекущегоПараметра", ДлинаОтступаТекущегоПараметра);
				СтруктураДанныхОписанияПараметра.Вставить("ДлинаОтступаПредыдущегоПараметра", ДлинаОтступаПредыдущегоПараметра);
				СтруктураДанныхОписанияПараметра.Вставить("СтрокаОписанияПредыдущегоПараметра", СтрокаТаблицыОписанияПараметров);
				
				// Если строка не содержит описание параметра, то добавляем текстовое описание и переходим к следующей строке.
				Если НЕ СтрокаСодержитОписаниеПараметра(СтрокаСекции, СтруктураДанныхОписанияПараметра) Тогда
					МассивСтрокПолногоОписанияПараметра.Добавить(СтрокаСекцииИсходная);
					МассивСтрокТекстовогоОписанияПараметра.Добавить(СтрокаСекцииИсходная);
					Продолжить;
				КонецЕсли;
				
			КонецЕсли;
			
			// Закрываем предыдущий параметр.
			Если СтрокаТаблицыОписанияПараметров <> Неопределено Тогда
				СтрокаТаблицыОписанияПараметров.ПолноеОписаниеПараметра = СтрСоединить(МассивСтрокПолногоОписанияПараметра, Символы.ПС);
				СтрокаТаблицыОписанияПараметров.ТекстовоеОписаниеПараметра = СокрЛ(СтрСоединить(МассивСтрокТекстовогоОписанияПараметра, Символы.ПС));
			КонецЕсли;
			
			МассивСтрокПолногоОписанияПараметра.Очистить();
			МассивСтрокПолногоОписанияПараметра.Добавить(СтрокаСекцииИсходная);
			
			Если СекцияОписания = "ВозвращаемоеЗначение" Тогда
				ЭтоОписаниеВозвращаемогоЗначения = (ДлинаОтступаТекущегоПараметра = ДлинаОтступаПервогоПараметра);
			КонецЕсли;
			
			ПолучатьИмяПараметра = СтрокаСодержитИмяПараметра(СтрокаСекции, ЭтоОписаниеВозвращаемогоЗначения);
			
			// Получаем имя, тип и текстовое описание параметра, а также их позиции в строке секции.
			СтруктураОписанияПараметра = ПолучитьСтруктуруОписанияПараметра(СтрокаСекцииИсходная, ПолучатьИмяПараметра, ТекущийУровеньВложенности);
			
			МассивСтрокТекстовогоОписанияПараметра.Очистить();
			МассивСтрокТекстовогоОписанияПараметра.Добавить(СтруктураОписанияПараметра.ТекстовоеОписаниеПараметра);
			ТекущийУровеньВложенности = СтруктураОписанияПараметра.УровеньВложенностиПараметра;
			
			// Записываем новый параметр.
			СтрокаТаблицыОписанияПараметров = ТаблицаОписанияПараметров.Добавить();
			
			// Заполняем колонки строки таблицы описания параметров.
			ЗаполнитьЗначенияСвойств(СтрокаТаблицыОписанияПараметров, СтруктураОписанияПараметра,, "ТекстовоеОписаниеПараметра");
			СтрокаТаблицыОписанияПараметров.ПолноеОписаниеПараметра = СтрСоединить(МассивСтрокПолногоОписанияПараметра, Символы.ПС);
			СтрокаТаблицыОписанияПараметров.ТекстовоеОписаниеПараметра = СокрЛ(СтрСоединить(МассивСтрокТекстовогоОписанияПараметра, Символы.ПС));
			
			СтрокаТаблицыОписанияПараметров.СекцияОписания = СекцияОписания;
			СтрокаТаблицыОписанияПараметров.ЭтоОписаниеВозвращаемогоЗначения = ЭтоОписаниеВозвращаемогоЗначения;
			СтрокаТаблицыОписанияПараметров.ЭтоПараметрВерхнегоУровня = (ДлинаОтступаТекущегоПараметра <= ДлинаОтступаПервогоПараметра);
			СтрокаТаблицыОписанияПараметров.НомерСтрокиНачалаОписанияПараметра = НомерСтроки;
			
			// Запоминаем длину отступа предыдущего параметра.
			ДлинаОтступаПредыдущегоПараметра = ДлинаОтступаТекущегоПараметра;
			
		КонецЦикла;
		
		// Закрываем последний параметр.
		Если СтрокаТаблицыОписанияПараметров <> Неопределено Тогда
			СтрокаТаблицыОписанияПараметров.ПолноеОписаниеПараметра = СтрСоединить(МассивСтрокПолногоОписанияПараметра, Символы.ПС);
			СтрокаТаблицыОписанияПараметров.ТекстовоеОписаниеПараметра = СокрЛ(СтрСоединить(МассивСтрокТекстовогоОписанияПараметра, Символы.ПС));
		КонецЕсли;
		
		// Определим номера строк конца описания параметра для каждого параметра в таблице.
		Для Каждого СтрокаТаблицыОписанияПараметров Из ТаблицаОписанияПараметров Цикл
			
			// Удалим лишние пустые строки в конце текстового описания параметра.
			ТекстовоеОписаниеПараметра = СтрокаТаблицыОписанияПараметров.ТекстовоеОписаниеПараметра;
			ТекстовоеОписаниеПараметра = ПолучитьТекстОписанияПараметраДоПервойПустойСтроки(ТекстовоеОписаниеПараметра);
			СтрокаТаблицыОписанияПараметров.ТекстовоеОписаниеПараметра = ТекстовоеОписаниеПараметра;
			
			ПолноеОписаниеПараметра = СтрокаТаблицыОписанияПараметров.ПолноеОписаниеПараметра;
			ПолноеОписаниеПараметра = ПолучитьТекстОписанияПараметраДоПервойПустойСтроки(ПолноеОписаниеПараметра);
			СтрокаТаблицыОписанияПараметров.ПолноеОписаниеПараметра = ПолноеОписаниеПараметра;
			
			НомерСтрокиНачалаОписанияПараметра = СтрокаТаблицыОписанияПараметров.НомерСтрокиНачалаОписанияПараметра;
			НомерСтрокиКонцаОписанияПараметра = НомерСтрокиНачалаОписанияПараметра + СтрЧислоСтрок(ПолноеОписаниеПараметра) - 1;
			СтрокаТаблицыОписанияПараметров.НомерСтрокиКонцаОписанияПараметра = НомерСтрокиКонцаОписанияПараметра;
			
		КонецЦикла;
		
	КонецЦикла;
	
	ТаблицаОписанияПараметров.ЗаполнитьЗначения(Ложь, "ТекстовоеОписаниеПараметраСодержитГиперссылку");
	ТаблицаОписанияПараметров.ЗаполнитьЗначения(Ложь, "ТекстовоеОписаниеПараметраЯвляетсяГиперссылкой");
	ТаблицаОписанияПараметров.ЗаполнитьЗначения("Исходный", "СостояниеПараметра");
	ТаблицаОписанияПараметров.ЗаполнитьЗначения("", "ТекстОшибки");
	ТаблицаОписанияПараметров.ЗаполнитьЗначения(Ложь, "НеобходимоПовторноеФорматирование");
	
	Возврат ТаблицаОписанияПараметров;
	
КонецФункции

Функция ПолучитьТаблицуПолныхИменФайловОбъектов()
	
	ТаблицаРезультат = Контекст["ТаблицаРезультат"];
	Если ТаблицаРезультат <> Неопределено Тогда
		Возврат ТаблицаРезультат;
	КонецЕсли;
	
	ТаблицаРезультат = Результат.Выгрузить(, "Объект, ПолноеИмяФайла");
	ТаблицаРезультат.Индексы.Добавить("Объект");
	
	Контекст.Вставить("ТаблицаРезультат", ТаблицаРезультат);
	
	Возврат ТаблицаРезультат;
	
КонецФункции

Функция УдалитьТекстОбщийМодульИзПутиОбъекта(Знач ПутьОбъекта)
	
	Если ПустаяСтрока(ПутьОбъекта) Тогда
		Возврат "";
	КонецЕсли;
	
	ТекстОбщийМодуль = Контекст["ТекстОбщийМодуль"];
	
	Если СтрНачинаетсяС(ВРег(ПутьОбъекта), ВРег(ТекстОбщийМодуль) + ".") Тогда
		ПутьОбъекта = Сред(ПутьОбъекта, СтрДлина(ТекстОбщийМодуль + ".") + 1);
	КонецЕсли;
	
	Возврат ПутьОбъекта;
	
КонецФункции

Функция ПолучитьОбъектПереадресацииИзГиперссылки(Знач ТекстГиперссылки, ТаблицаОписанияПараметров)
	
	ТекстОбъектаГиперссылки = СокрЛП(ТекстГиперссылки);
	
	// Уберем точку в конце текста гиперссылки.
	МассивЭлементовПереадресации = СтрРазделить(ТекстОбъектаГиперссылки, ".", Ложь);
	ТекстОбъектаГиперссылки = СтрСоединить(МассивЭлементовПереадресации, ".");
	
	// Ищем текст гиперссылки в накопленной таблице объектов переадресации.
	ТаблицаОбъектовПереадресации = Контекст["ТаблицаОбъектовПереадресации"];
	СтрокаОбъектаПереадресации = ТаблицаОбъектовПереадресации.Найти(ВРег(ТекстОбъектаГиперссылки), "ОбъектПереадресацииВРег");
	Если СтрокаОбъектаПереадресации <> Неопределено Тогда
		// Если нашли, выходим.
		Возврат СтрокаОбъектаПереадресации;
	КонецЕсли;
	
	ТекстОбщийМодуль = Контекст["ТекстОбщийМодуль"];
	
	ТаблицаРезультат = ПолучитьТаблицуПолныхИменФайловОбъектов();
	
	ГиперссылкаУказанаНаМетодТекущегоМодуля = Ложь;
	
	ТипОбъектаКонфигурации = Неопределено;
	ОбъектКонфигурации = Неопределено;
	МетодОбъектаКонфигурации = Неопределено;
	ПараметрМетодаОбъектаКонфигурации = Неопределено;
	
	МассивЭлементовПутиОбъектаПереадресации = Новый Массив;
	МассивФайловОбъектаКонфигурации = Новый Массив;
	
	Для Каждого ЭлементПереадресации Из МассивЭлементовПереадресации Цикл
		
		// Определяем тип объекта конфигурации.
		Если ТипОбъектаКонфигурации = Неопределено Тогда
			
			ТипОбъектаКонфигурации = ПолучитьТипОбъектаПоТаблицеТипов(ЭлементПереадресации, "", "Имя", "");
			// Если тип объекта не определен, то это либо общий модуль, либо текущий объект.
			Если ПустаяСтрока(ТипОбъектаКонфигурации) Тогда
				ТипОбъектаКонфигурации = ТекстОбщийМодуль;
			Иначе
				// Если определили тип объекта, то проверяем следующий элемент переадресации.
				МассивЭлементовПутиОбъектаПереадресации.Добавить(ЭлементПереадресации);
				Продолжить;
			КонецЕсли;
			
		КонецЕсли;
		
		// Определяем объект конфигурации.
		Если ОбъектКонфигурации = Неопределено Тогда
			
			ОбъектКонфигурации = ТипОбъектаКонфигурации + "." + ЭлементПереадресации;
			СтрокаТаблицыРезультат = ТаблицаРезультат.Найти(ОбъектКонфигурации, "Объект");
			Если СтрокаТаблицыРезультат = Неопределено Тогда
				// Если не нашли объект конфигурации, то считаем, что переадресация ведет к методу в текущем обрабатываемом модуле.
				ГиперссылкаУказанаНаМетодТекущегоМодуля = Истина;
				
				ТекущийОбрабатываемыйФайл = Контекст["ТекущийОбрабатываемыйФайл"];
				СтрокаТаблицыРезультат = ТаблицаРезультат.Найти(ТекущийОбрабатываемыйФайл, "ПолноеИмяФайла");
				ОбъектКонфигурации = ?(СтрокаТаблицыРезультат = Неопределено, "", СтрокаТаблицыРезультат.Объект);
				МассивЭлементовПутиОбъектаПереадресации.Добавить(ОбъектКонфигурации);
				
				// В массив файлов объекта добавляем только текущий обрабатываемый файл.
				МассивФайловОбъектаКонфигурации.Добавить(ТекущийОбрабатываемыйФайл);
			Иначе
				// Если нашли объект конфигурации, то запоминаем и переходим к следующему элементу.
				МассивЭлементовПутиОбъектаПереадресации.Добавить(ЭлементПереадресации);
				Продолжить;
			КонецЕсли;
			
		КонецЕсли;
		
		// Определяем метод объекта конфигурации.
		Если МетодОбъектаКонфигурации = Неопределено Тогда
			МетодОбъектаКонфигурации = ЭлементПереадресации;
			МассивЭлементовПутиОбъектаПереадресации.Добавить(ЭлементПереадресации);
			Продолжить;
		КонецЕсли;
		
		// Определяем параметр метода объекта конфигурации.
		Если ПараметрМетодаОбъектаКонфигурации = Неопределено Тогда
			ПараметрМетодаОбъектаКонфигурации = ЭлементПереадресации;
			МассивЭлементовПутиОбъектаПереадресации.Добавить(ЭлементПереадресации);
		КонецЕсли;
		
		// Определять больше нечего, прерываем.
		Прервать;
		
	КонецЦикла;
	
	// Определяем объект переадресации по тексту гиперссылки.
	ОбъектПереадресации = ТекстОбъектаГиперссылки;
	Если ГиперссылкаУказанаНаМетодТекущегоМодуля Тогда
		
		// Если в гиперссылке содержится только метод, то переопределяем полный путь к объекту переадресации.
		ОбъектПереадресации = СтрСоединить(МассивЭлементовПутиОбъектаПереадресации, ".");
		// Удаляем из наименования объекта конфигурации текст "ОбщийМодуль.".
		ОбъектПереадресации = УдалитьТекстОбщийМодульИзПутиОбъекта(ОбъектПереадресации);
		
		// Т.к. текст объекта гиперссылки изменился, перепроверим еще раз в накопленной таблице объектов переадресации.
		СтрокаОбъектаПереадресации = ТаблицаОбъектовПереадресации.Найти(ВРег(ОбъектПереадресации), "ОбъектПереадресацииВРег");
		Если СтрокаОбъектаПереадресации <> Неопределено Тогда
			// Если нашли, выходим.
			Возврат СтрокаОбъектаПереадресации;
		КонецЕсли;
		
	КонецЕсли;
	
	// Еще возможна ситуация, когда гиперссылка указывает на другой параметр этого же метода, проверяем.
	ТекущийОбрабатываемыйМетод = Контекст["ТекущийОбрабатываемыйМетод"];
	ИмяМетода = ?(ТекущийОбрабатываемыйМетод = Неопределено, "", ТекущийОбрабатываемыйМетод.ИмяМетода);
	
	ОбъектПереадресацииПараметр = УдалитьТекстОбщийМодульИзПутиОбъекта(ОбъектКонфигурации);
	ОбъектПереадресацииПараметр = ОбъектПереадресацииПараметр + "." + ИмяМетода + "." + ТекстОбъектаГиперссылки;
	
	// Перепроверим в накопленной таблице объектов переадресации.
	СтрокаОбъектаПереадресации = ТаблицаОбъектовПереадресации.Найти(ВРег(ОбъектПереадресацииПараметр), "ОбъектПереадресацииВРег");
	Если СтрокаОбъектаПереадресации <> Неопределено Тогда
		// Если нашли, выходим.
		Возврат СтрокаОбъектаПереадресации;
	КонецЕсли;
	
	СтрокаОбъектаПереадресации = ТаблицаОбъектовПереадресации.Добавить();
	СтрокаОбъектаПереадресации.ТипОбъектаПереадресации = "";
	СтрокаОбъектаПереадресации.ОбъектПереадресации = ОбъектПереадресации;
	СтрокаОбъектаПереадресации.ОбъектПереадресацииВРег = ВРег(ОбъектПереадресации);
	СтрокаОбъектаПереадресации.МетодПереадресации = Неопределено;
	СтрокаОбъектаПереадресации.Существует = Ложь;
	СтрокаОбъектаПереадресации.ЗарегистрироватьОшибку = Истина;
	
	// В тексте гиперссылки может быть указан не метод, а другой объект: см. ОпределяемыйТип.УчетныеСистемыИнтеграцииОбластейДанных.
	// Или реквизит: см. Справочники.ВариантыОтчетов.Реквизиты.Отчет
	// Проверяем тип объекта среди типов без модулей (для случая с определяемым типом).
	МассивТиповОбъектовБезМодулей = Контекст["МассивТиповОбъектовБезМодулей"];
	Если МассивТиповОбъектовБезМодулей.Найти(ТипОбъектаКонфигурации) <> Неопределено Тогда
		// Если тип объекта найден, то проверяем наличие объекта.
		Если ТаблицаРезультат.Найти(ТекстОбъектаГиперссылки, "Объект") <> Неопределено Тогда
			СтрокаОбъектаПереадресации.ТипОбъектаПереадресации = ТипОбъектаКонфигурации;
			СтрокаОбъектаПереадресации.ЗарегистрироватьОшибку = Ложь;
			Возврат СтрокаОбъектаПереадресации;
		КонецЕсли;
	КонецЕсли;
	
	// Если количество элементов объекта переадресации больше 2-х, то проверим 3-й элемент (для случая с реквизитом).
	Если МассивЭлементовПереадресации.Количество() > 2 Тогда
		ТретийЭлементПереадресации = МассивЭлементовПереадресации[2];
		ТретийЭлементПереадресации = ПолучитьТипОбъектаПоТаблицеТипов(ТретийЭлементПереадресации, "", "Имя");
		Если МассивТиповОбъектовБезМодулей.Найти(ТретийЭлементПереадресации) <> Неопределено Тогда
			СтрокаОбъектаПереадресации.ТипОбъектаПереадресации = ТретийЭлементПереадресации;
			СтрокаОбъектаПереадресации.ЗарегистрироватьОшибку = Ложь;
			Возврат СтрокаОбъектаПереадресации;
		КонецЕсли;
	КонецЕсли;
	
	// Проверяем, ссылается ли объект переадресации на другой параметр текущего метода.
	ОбъектПереадресацииЯвляетсяДругимПараметромМетода = Истина;
	Для Каждого ЭлементПереадресации Из МассивЭлементовПереадресации Цикл
		
		ЭлементПереадресацииНайденСредиПараметров = Ложь;
		
		ЭлементПереадресации = ПреобразоватьТекстДляСравнения(ЭлементПереадресации);
		Для Каждого СтрокаОписанияПараметра Из ТаблицаОписанияПараметров Цикл
			ИмяПараметра = ПреобразоватьТекстДляСравнения(СтрокаОписанияПараметра.ИмяПараметра);
			Если ЭлементПереадресации = ИмяПараметра Тогда
				ЭлементПереадресацииНайденСредиПараметров = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		Если НЕ ЭлементПереадресацииНайденСредиПараметров Тогда
			ОбъектПереадресацииЯвляетсяДругимПараметромМетода = Ложь;
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	// Если нашли, заполняем значения в таблицу и выходим.
	Если ОбъектПереадресацииЯвляетсяДругимПараметромМетода Тогда
		СтрокаОбъектаПереадресации.ТипОбъектаПереадресации = "Параметр";
		СтрокаОбъектаПереадресации.ОбъектПереадресации = ОбъектПереадресацииПараметр;
		СтрокаОбъектаПереадресации.ОбъектПереадресацииВРег = ВРег(ОбъектПереадресацииПараметр);
		СтрокаОбъектаПереадресации.Существует = Истина;
		СтрокаОбъектаПереадресации.ЗарегистрироватьОшибку = Ложь;
		Возврат СтрокаОбъектаПереадресации;
	КонецЕсли;
	
	// Если объект или метод определить не удалось, выходим.
	Если (ОбъектКонфигурации = Неопределено) ИЛИ (МетодОбъектаКонфигурации = Неопределено) Тогда
		Возврат СтрокаОбъектаПереадресации;
	КонецЕсли;
	
	// Если массив файлов объекта конфигурации для проверки переадресации пустой, то получим набор модулей объекта.
	Если МассивФайловОбъектаКонфигурации.Количество() = 0 Тогда
		СтруктураОтбораОбъект = Новый Структура("Объект", ОбъектКонфигурации);
		МассивСтрокТаблицыРезультат = ТаблицаРезультат.НайтиСтроки(СтруктураОтбораОбъект);
		Для Каждого СтрокаТаблицыРезультат Из МассивСтрокТаблицыРезультат Цикл
			// Добавляем только модули - определяем по расширению ".bsl".
			ПолноеИмяФайла = СтрокаТаблицыРезультат.ПолноеИмяФайла;
			Если СтрЗаканчиваетсяНа(ПолноеИмяФайла, ".bsl") Тогда
				МассивФайловОбъектаКонфигурации.Добавить(ПолноеИмяФайла);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	// Файлов объекта конфигурации не найдено, то выходим.
	Если МассивФайловОбъектаКонфигурации.Количество() = 0 Тогда
		Возврат СтрокаОбъектаПереадресации;
	КонецЕсли;
	
	// Ищем метод в модулях объекта.
	Для Каждого ФайлОбъектаКонфигурации Из МассивФайловОбъектаКонфигурации Цикл
		
		Если НЕ апк_ФайлСуществует(ФайлОбъектаКонфигурации) Тогда
			Продолжить;
		КонецЕсли;
		
		ДокументТекст = ПолучитьТекстовыйДокументИзФайла(ПолноеИмяФайла, КодировкаТекста.UTF8);
		Если ДокументТекст = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ТекстМодуля = ДокументТекст.ПолучитьТекст();
		Если ПустаяСтрока(ТекстМодуля) Тогда
			Продолжить;
		КонецЕсли;
		
		ТаблицаМетодовМодуля = ПолучитьТаблицуПроцедурИФункций(ТекстМодуля);
		Если ТаблицаМетодовМодуля.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		// Ищем метод объекта конфигурации в таблице методов модуля.
		СтрокаТаблицыМетодовМодуля = ТаблицаМетодовМодуля.Найти(ВРег(МетодОбъектаКонфигурации), "ИмяМетодаВРег");
		Если СтрокаТаблицыМетодовМодуля = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		// Если нашли метод, то запоминаем его.
		СтрокаОбъектаПереадресации.МетодПереадресации = СтрокаТаблицыМетодовМодуля;
		
		// И проверяем, указан ли параметр.
		Если ПараметрМетодаОбъектаКонфигурации = Неопределено Тогда
			// Если параметр не указан, то записываем в таблицу, что нашли объект из гиперссылки.
			СтрокаОбъектаПереадресации.ТипОбъектаПереадресации = СтрокаТаблицыМетодовМодуля.ТипМетода;
			СтрокаОбъектаПереадресации.Существует = Истина;
			СтрокаОбъектаПереадресации.ЗарегистрироватьОшибку = Ложь;
			Продолжить;
		КонецЕсли;
		
		// Если параметр указан, то проверяем его существование.
		ПараметрыМетода = СтрокаТаблицыМетодовМодуля.МассивПараметров;
		Для Каждого ПараметрМетода Из ПараметрыМетода Цикл
			ПараметрМетода = ПолучитьИмяПараметра(ПараметрМетода);
			Если СтрСравнить(ПараметрМетода, ПараметрМетодаОбъектаКонфигурации) = 0 Тогда
				// Если нашли параметр, то записываем в таблицу.
				СтрокаОбъектаПереадресации.ТипОбъектаПереадресации = "Параметр";
				СтрокаОбъектаПереадресации.Существует = Истина;
				СтрокаОбъектаПереадресации.ЗарегистрироватьОшибку = Ложь;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат СтрокаОбъектаПереадресации;
	
КонецФункции

// Возвращает "Ложь", если в КаталогВыгрузкиРезультат найден файл "Configuration.mdo"
// Возвращает "Истина", если в КаталогВыгрузкиРезультат найден файл "Configuration.xml"
// По умолчанию возвращает "Истина".
//
Функция ЭтоВыгрузкаXMLФайлов()
	
	Если ЭтоВыгрузкаXMLФайлов <> Неопределено Тогда
		Возврат ЭтоВыгрузкаXMLФайлов;
	КонецЕсли;
	
	КаталогВыгрузкиРезультат = ОтредактироватьПутьККаталогу(КаталогВыгрузкиРезультат);
	
	ИмяФайлаКонфигурацииДляВыгрузкиXML = КаталогВыгрузкиРезультат + "Configuration.xml";
	ИмяФайлаКонфигурацииДляПроектаEDT = КаталогВыгрузкиРезультат + "src" + РазделительПути + "Configuration" + РазделительПути + "Configuration.mdo";
	ИмяФайлаКонфигурацииДляПроектаEDT_SRC = КаталогВыгрузкиРезультат + "Configuration" + РазделительПути + "Configuration.mdo";
	
	Если апк_ФайлСуществует(ИмяФайлаКонфигурацииДляВыгрузкиXML) Тогда
		// Возвращаем "Истину", если КаталогВыгрузкиРезультат содержит файл "Configuration.xml".
		ЭтоВыгрузкаXMLФайлов = Истина;
	ИначеЕсли апк_ФайлСуществует(ИмяФайлаКонфигурацииДляПроектаEDT) Тогда
		// Возвращаем "Ложь" в случае наличия файла "Configuration.mdo" в каталоге проекта.
		ЭтоВыгрузкаXMLФайлов = Ложь;
	ИначеЕсли апк_ФайлСуществует(ИмяФайлаКонфигурацииДляПроектаEDT_SRC) Тогда
		// Возвращаем "Ложь" в случае наличия файла "Configuration.mdo" в каталоге "src" в каталоге проекта.
		ЭтоВыгрузкаXMLФайлов = Ложь;
	Иначе
		
		// Ищем в КаталогВыгрузкиРезультат файл "Configuration.*".
		МассивФайлов = НайтиФайлы(КаталогВыгрузкиРезультат, "Configuration.*", Истина);
		Если МассивФайлов.Количество() = 0 Тогда
			// По умолчанию возвращаем "Истина".
			ЭтоВыгрузкаXMLФайлов = Истина;
		Иначе
			// Проверяем первый найденный файл "Configuration.*".
			РасширениеФайлаКонфигурации = МассивФайлов[0].Расширение;
			Если СтрСравнить(РасширениеФайлаКонфигурации, ".mdo") = 0 Тогда
				ЭтоВыгрузкаXMLФайлов = Ложь;
			ИначеЕсли СтрСравнить(РасширениеФайлаКонфигурации, ".xml") = 0 Тогда
				ЭтоВыгрузкаXMLФайлов = Истина;
			Иначе
				// По умолчанию возвращаем "Истина".
				ЭтоВыгрузкаXMLФайлов = Истина;
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
	// По умолчанию возвращаем "Истина".
	Если ЭтоВыгрузкаXMLФайлов = Неопределено Тогда
		ЭтоВыгрузкаXMLФайлов = Истина;
	КонецЕсли;
	
	Возврат ЭтоВыгрузкаXMLФайлов;
	
КонецФункции

// Возвращает путь к файлу конфигурации в зависимости от значения флага "ЭтоВыгрузкаXMLФайлов".
//
Функция ПолучитьФайлКонфигурации()
	
	Если ЭтоВыгрузкаXMLФайлов = Неопределено Тогда
		ЭтоВыгрузкаXMLФайлов = ЭтоВыгрузкаXMLФайлов();
	КонецЕсли;
	
	Если ЭтоВыгрузкаXMLФайлов Тогда
		ФайлКонфигурации = КаталогВыгрузкиРезультат + "Configuration.xml";
	Иначе
		ФайлКонфигурации = КаталогВыгрузкиРезультат + СтрШаблон("src%1Configuration%1Configuration.mdo", РазделительПути);
	КонецЕсли;
	
	Возврат ФайлКонфигурации;
	
КонецФункции

Процедура ДобавитьСтрокуВТаблицуИзмененныхОбъектов(ПолноеИмяФайла, КлючПунктаСтандарта)
	
	СтрокаФайлаРезультата = Результат.Найти(ПолноеИмяФайла, "ПолноеИмяФайла");
	Если СтрокаФайлаРезультата = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТаблицаСтандартов = Контекст["ТаблицаСтандартов"];
	
	СтрокаМакета = ТаблицаСтандартов.Найти(КлючПунктаСтандарта, "Ключ");
	Если СтрокаМакета = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	НаименованиеСтандарта = "";
	СтрокаРодителя = ТаблицаСтандартов.Найти(СтрокаМакета.КлючРодителя, "Ключ");
	Если СтрокаРодителя <> Неопределено Тогда
		НаименованиеСтандарта = СтрокаРодителя.Наименование;
	КонецЕсли;
	
	НоваяСтрока = ТаблицаИзмененныхОбъектовИСтандартов.Добавить();
	НоваяСтрока.КлючПунктаСтандарта         = КлючПунктаСтандарта;
	НоваяСтрока.КлючСтандарта               = СтрокаМакета.КлючРодителя;
	НоваяСтрока.НаименованиеПунктаСтандарта = СтрокаМакета.Наименование;
	НоваяСтрока.НаименованиеСтандарта       = НаименованиеСтандарта;
	НоваяСтрока.СсылкаСтандарта             = СтрокаМакета.Гиперссылка;
	НоваяСтрока.ПолноеИмяФайла              = ПолноеИмяФайла;
	НоваяСтрока.ПутьОбъекта                 = СтрокаФайлаРезультата.Объект;
	
КонецПроцедуры

// Возвращает структуру, содержащую информацию о результатах поиска.
//
// Параметры:
//   Строка                 - Строка            - строка, в которой будет осуществляться поиск.
//   МассивПоиска           - Массив            - массив подстрок, по которым осуществляется поиск.
//   НаправлениеДляПоиска   - НаправлениеПоиска - указывает направление поиска аналогично параметру метода СтрНайти().
//   НачальнаяПозицияПоиска - Число             - указывает позицию в строке, с которой начинается поиск.
//
// Возвращаемое значение:
//   Структура - структура с ключами:
//     НайденныйЭлемент - Элемент массива, который удалось найти.
//     Позиция - Число, позиция найденного элемента.
//     Успешно - Булево, Истина если, удалось найти хоть один элемент.
//
Функция СтрНайтиПоМассиву(Строка, МассивПоиска, НаправлениеДляПоиска = Неопределено,
	НачальнаяПозицияПоиска = Неопределено, ВернутьПервыйНайденныйЭлемент = Ложь)
	
	СтруктураВозврата = Новый Структура;
	СтруктураВозврата.Вставить("НайденныйЭлемент", "");
	СтруктураВозврата.Вставить("Позиция", 0);
	СтруктураВозврата.Вставить("Успешно", Ложь);
	
	Если НаправлениеДляПоиска = Неопределено Тогда
		НаправлениеДляПоиска = НаправлениеПоиска.СНачала;
	КонецЕсли;
	
	ПоискСНачала = (НаправлениеДляПоиска = НаправлениеПоиска.СНачала);
	
	Если НачальнаяПозицияПоиска = Неопределено Тогда
		НачальнаяПозицияПоиска = ?(ПоискСНачала, 1, СтрДлина(Строка));
	КонецЕсли;
	
	ВременнаяПозицияПоиска = 0;
	Для Каждого ТекстПоиска Из МассивПоиска Цикл
		
		ТекущаяПозицияПоиска = СтрНайти(Строка, ТекстПоиска, НаправлениеДляПоиска, НачальнаяПозицияПоиска);
		Если ТекущаяПозицияПоиска = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Если (ВременнаяПозицияПоиска = 0)
			ИЛИ ?(ПоискСНачала, ТекущаяПозицияПоиска < ВременнаяПозицияПоиска, ТекущаяПозицияПоиска > ВременнаяПозицияПоиска) Тогда
			
			СтруктураВозврата.НайденныйЭлемент = ТекстПоиска;
			СтруктураВозврата.Позиция = ТекущаяПозицияПоиска;
			СтруктураВозврата.Успешно = Истина;
			
			Если ВернутьПервыйНайденныйЭлемент Тогда
				Прервать;
			КонецЕсли;
			
			ВременнаяПозицияПоиска = ТекущаяПозицияПоиска;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат СтруктураВозврата;
	
КонецФункции

// Возвращает структуру, содержащую информацию о результатах поиска.
//
// Параметры:
//   Строка - Строка, по которой будет осуществляться поиск.
//   МассивПоиска - Массив, по элементам которого осуществляется поиск.
//
// Возвращаемое значение:
//   Структура, состоящая из ключей:
//     НайденныйЭлемент - Элемент массива, который удалось найти.
//     Успешно - Булево, Истина если, удалось найти хоть один элемент.
//
Функция СтрНачинаетсяСПоМассиву(Строка, МассивПоиска)
	
	СтруктураВозврата = Новый Структура;
	СтруктураВозврата.Вставить("НайденныйЭлемент", "");
	СтруктураВозврата.Вставить("Успешно", Ложь);
	
	Для Каждого ТекстПоиска Из МассивПоиска Цикл
		Успешно = СтрНачинаетсяС(Строка, ТекстПоиска);
		Если Успешно Тогда
			СтруктураВозврата.НайденныйЭлемент = ТекстПоиска;
			СтруктураВозврата.Успешно = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат СтруктураВозврата;
	
КонецФункции

// Возвращает структуру, содержащую информацию о результатах поиска.
//
// Параметры:
//   Строка - Строка, по которой будет осуществляться поиск.
//   МассивПоиска - Массив, по элементам которого осуществляется поиск.
//
// Возвращаемое значение:
//   Структура, состоящая из ключей:
//     НайденныйЭлемент - Элемент массива, который удалось найти.
//     Успешно - Булево, Истина если, удалось найти хоть один элемент.
//
Функция СтрЗаканчиваетсяНаПоМассиву(Строка, МассивПоиска)
	
	СтруктураВозврата = Новый Структура;
	СтруктураВозврата.Вставить("НайденныйЭлемент", "");
	СтруктураВозврата.Вставить("Успешно", Ложь);
	
	Для Каждого ТекстПоиска Из МассивПоиска Цикл
		Успешно = СтрЗаканчиваетсяНа(Строка, ТекстПоиска);
		Если Успешно Тогда
			СтруктураВозврата.НайденныйЭлемент = ТекстПоиска;
			СтруктураВозврата.Успешно = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат СтруктураВозврата;
	
КонецФункции

// Вычисляет хеш-сумму для строкового значения по указанному типу хеш-функции.
//
// Параметры:
//   Строка         - Строка     - строка, хеш-сумму которой необходимо рассчитать.
//   ТипХешФункции  - ХешФункция - тип хеш-функции.
//   УдалитьПробелы - Булево     - флаг удаления пробелов из результирующей хеш-суммы.
//
// Возвращаемое значение:
//   Строка - контрольная хеш-сумма.
//
Функция ПолучитьХешСуммуИзСтроки(Строка, ТипХешФункции, УдалитьПробелы = Истина)
	
	ХешированиеДанных = Новый ХешированиеДанных(ТипХешФункции);
	ХешированиеДанных.Добавить(Строка(Строка));
	
	ХешСуммаИзСтроки = Строка(ХешированиеДанных.ХешСумма);
	
	Если УдалитьПробелы Тогда
		ХешСуммаИзСтроки = СтрЗаменить(ХешСуммаИзСтроки, " ", "");
	КонецЕсли;
	
	Возврат ХешСуммаИзСтроки;
	
КонецФункции

// Дополняет массив МассивПриемник значениями из массива МассивИсточник.
//
// Параметры:
//  МассивПриемник - Массив - массив, в который необходимо добавить значения.
//  МассивИсточник - Массив - массив значений для заполнения,
//  ТолькоУникальныеЗначения - Булево - необязательный, если истина,
//    то в массив будут включены только те значения, которых в нем еще нет, причем единожды.
//
Процедура ДополнитьМассив(МассивПриемник, МассивИсточник, ТолькоУникальныеЗначения = Ложь)
	
	Для Каждого Значение Из МассивИсточник Цикл
		Если (НЕ ТолькоУникальныеЗначения) ИЛИ (МассивПриемник.Найти(Значение) = Неопределено) Тогда
			МассивПриемник.Добавить(Значение);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Функция МассивВВерхнемРегистре(МассивИсточник)
	
	МассивИсточникВРег = Новый Массив;
	Для Каждого ЭлементМассива Из МассивИсточник Цикл
		МассивИсточникВРег.Добавить(ВРег(ЭлементМассива));
	КонецЦикла;
	
	Возврат МассивИсточникВРег;
	
КонецФункции

// Возвращает преобразованный текст для сравнения.
// Убирает лишние символы и текст для удаления из переданного текста.
//
// Параметры:
//   Текст            - Строка - исходный текст.
//   ТекстДляУдаления - Строка - текст, который будет удален из исходного текста.
//
// Возвращаемое значение:
//   Строка - преобразованный текст.
//
Функция ПреобразоватьТекстДляСравнения(Знач Текст, ТекстДляУдаления = "")
	
	СоответствиеПреобразоватьТекстДляСравнения = Контекст["ПреобразоватьТекстДляСравнения"];
	
	КлючСоответствия = СтрШаблон("%1_%2", Текст, ТекстДляУдаления);
	ЗначениеСоответствия = СоответствиеПреобразоватьТекстДляСравнения[КлючСоответствия];
	Если ЗначениеСоответствия <> Неопределено Тогда
		Возврат ЗначениеСоответствия;
	КонецЕсли;
	
	СтрокаСимволов = " ,.:;""'!?%$#№@`~|&^\/-_*()<>{}[]" + Символы.Таб + Символы.ПС;
	
	ПреобразованныйТекст = ВРег(Текст);
	
	КоличествоСимволов = СтрДлина(СтрокаСимволов);
	Для НомерСимвола = 1 По КоличествоСимволов Цикл
		Символ = Сред(СтрокаСимволов, НомерСимвола, 1);
		ПреобразованныйТекст = СтрЗаменить(ПреобразованныйТекст, Символ, "");
	КонецЦикла;
	
	Если НЕ ПустаяСтрока(ТекстДляУдаления) Тогда
		ПреобразованныйТекст = СтрЗаменить(ПреобразованныйТекст, ВРег(ТекстДляУдаления), "");
	КонецЕсли;
	
	СоответствиеПреобразоватьТекстДляСравнения.Вставить(КлючСоответствия, ПреобразованныйТекст);
	
	Возврат ПреобразованныйТекст;
	
КонецФункции

Функция ПреобразоватьМассивДляСравнения(Знач МассивТекст, ТекстДляУдаления = "")
	
	НомерЭлемента = -1;
	Для Каждого ЭлементМассива Из МассивТекст Цикл
		НомерЭлемента = НомерЭлемента + 1;
		МассивТекст[НомерЭлемента] = ПреобразоватьТекстДляСравнения(ЭлементМассива, ТекстДляУдаления);
	КонецЦикла;
	
	Возврат МассивТекст;
	
КонецФункции

Функция ПолучитьПервоеСловоИзСтроки(Знач Строка, ВключатьТочку = Ложь)
	
	СоответствиеПолучитьПервоеСловоИзСтроки = Контекст["ПолучитьПервоеСловоИзСтроки"];
	
	КлючСоответствия = СтрШаблон("%1_%2", Строка, ВключатьТочку);
	ЗначениеСоответствия = СоответствиеПолучитьПервоеСловоИзСтроки[КлючСоответствия];
	Если ЗначениеСоответствия <> Неопределено Тогда
		Возврат ЗначениеСоответствия;
	КонецЕсли;
	
	Если ПустаяСтрока(Строка) Тогда
		Возврат "";
	КонецЕсли;
	
	Строка = СокрЛП(Строка);
	
	ПервоеСлово = "";
	ДлинаСтроки = СтрДлина(Строка);
	Для НомерСимвола = 1 По ДлинаСтроки Цикл
		
		Символ = Сред(Строка, НомерСимвола, 1);
		ДобавитьТочку = ВключатьТочку И (Символ = ".");
		Если апк_СловоСодержитЗначимыеСимволы(Символ) ИЛИ ДобавитьТочку Тогда
			ПервоеСлово = ПервоеСлово + Символ;
		Иначе
			Если НЕ ПустаяСтрока(ПервоеСлово) Тогда
				Прервать;
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла;
	
	СоответствиеПолучитьПервоеСловоИзСтроки.Вставить(КлючСоответствия, ПервоеСлово);
	
	Возврат ПервоеСлово;
	
КонецФункции

// Получает имя параметра метода.
// Например: для текста "Знач Параметр = Неопределено" будет возвращено значение "Параметр".
//
// Параметры:
//   ПараметрМетода - текст параметра метода.
//
// Возвращаемое значение:
//   Строка.
//
Функция ПолучитьИмяПараметра(Знач ПараметрМетода)
	
	МассивТекстЗнач = Контекст["МассивТекстЗнач"];
	
	ПараметрМетода = СокрЛ(ПараметрМетода);
	ПараметрМетода = СтрЗаменить(ПараметрМетода, Символы.ПС, " ");
	ПараметрМетода = СтрЗаменить(ПараметрМетода, Символы.Таб, " ");
	
	СтруктураРезультата = СтрНачинаетсяСПоМассиву(ВРег(ПараметрМетода), МассивТекстЗнач);
	Если СтруктураРезультата.Успешно Тогда
		ПараметрМетода = Сред(ПараметрМетода, СтрДлина(СтруктураРезультата.НайденныйЭлемент) + 1);
	КонецЕсли;
	
	ПозицияРавно = СтрНайти(ПараметрМетода, "=");
	Если ПозицияРавно > 0 Тогда
		ПараметрМетода = Лев(ПараметрМетода, ПозицияРавно - 1);
	КонецЕсли;
	
	Возврат СокрЛП(ПараметрМетода);
	
КонецФункции

