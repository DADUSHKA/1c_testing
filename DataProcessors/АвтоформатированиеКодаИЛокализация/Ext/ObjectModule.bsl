#Область ОбщиеТребованияККонфигурации

Функция ТаблицыЗначенийРавны(Таблица1, Таблица2)
	
	Если Таблица1.Колонки.Количество() <> Таблица2.Колонки.Количество() Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если Таблица1.Количество() <> Таблица2.Количество() Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ТаблицыРавны = Истина;
	Для Каждого Таблица1Колонка Из Таблица1.Колонки Цикл
		// Проверяем наличие каждой колонки одной таблицы в другой.
		ИмяКолонки = Таблица1Колонка.Имя;
		Если Таблица2.Колонки.Найти(ИмяКолонки) = Неопределено Тогда
			ТаблицыРавны = Ложь;
			Прервать;
		КонецЕсли;
		
		Для НомерСтроки = 0 По Таблица1.Количество() - 1 Цикл
			
			Если Таблица1[НомерСтроки][ИмяКолонки] <> Таблица2[НомерСтроки][ИмяКолонки] Тогда
				ТаблицыРавны = Ложь;
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
		Если НЕ ТаблицыРавны Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ТаблицыРавны;
	
КонецФункции

Функция УдалитьБитыеСсылкиНаОбъектыПодсистемы(ДокументDOM)
	
	ФайлИзменен = Ложь;
	
	Если ЭтоВыгрузкаXMLФайлов Тогда
		ЭлементDOMПодчиненныеОбъекты = ПолучитьЭлементDOMПоВыражениюXPath("//xmlns:Content", ДокументDOM);
	Иначе
		ЭлементDOMПодчиненныеОбъекты = ПолучитьЭлементDOMПоВыражениюXPath("/mdclass:Subsystem", ДокументDOM);
	КонецЕсли;
	
	Если ЭлементDOMПодчиненныеОбъекты = Неопределено Тогда
		// Если подчиненных объектов нет, выходим.
		Возврат ФайлИзменен;
	КонецЕсли;
	
	ДочерниеУзлы = ЭлементDOMПодчиненныеОбъекты.ДочерниеУзлы;
	Если ДочерниеУзлы.Количество() = 0 Тогда
		// Если подчиненных объектов нет, выходим.
		Возврат ФайлИзменен;
	КонецЕсли;
	
	МассивДочернихУзловБитыхСсылок = Новый Массив;
	Для Каждого ДочернийУзел Из ДочерниеУзлы Цикл
		
		// Для выгрузки EDT проверяем имя узла.
		Если (НЕ ЭтоВыгрузкаXMLФайлов) И (ДочернийУзел.ИмяУзла <> "content") Тогда
			Продолжить;
		КонецЕсли;
		
		НаименованиеУдаленногоОбъекта = ДочернийУзел.ТекстовоеСодержимое;
		
		// Если наименование дочернего узла - это уникальный идентификатор, то добавляем дочерний узел в отдельный массив.
		Если ЭтоУникальныйИдентификатор(НаименованиеУдаленногоОбъекта) Тогда
			МассивДочернихУзловБитыхСсылок.Добавить(ДочернийУзел);
		КонецЕсли;
		
	КонецЦикла;
	
	// Если в массиве для удаления нет дочерних узлов, то выходим.
	Если МассивДочернихУзловБитыхСсылок.Количество() = 0 Тогда
		Возврат ФайлИзменен;
	КонецЕсли;
	
	ФайлИзменен = Истина;
	
	Для Каждого ДочернийУзелБитойСсылки Из МассивДочернихУзловБитыхСсылок Цикл
		ЭлементDOMПодчиненныеОбъекты.УдалитьДочерний(ДочернийУзелБитойСсылки);
	КонецЦикла;
	
	Возврат ФайлИзменен;
	
КонецФункции

Функция СортироватьОбъектыМетаданных(ДокументDOM)
	
	ПорядокИзменен = Ложь;
	
	Если ЭтоВыгрузкаXMLФайлов Тогда
		ЭлементDOMПодчиненныеОбъекты = ПолучитьЭлементDOMПоВыражениюXPath("//xmlns:ChildObjects", ДокументDOM);
	Иначе
		ЭлементDOMПодчиненныеОбъекты = ПолучитьЭлементDOMПоВыражениюXPath("/mdclass:Configuration", ДокументDOM);
	КонецЕсли;
	
	Если ЭлементDOMПодчиненныеОбъекты = Неопределено Тогда
		// Если подчиненных объектов нет, выходим.
		Возврат ПорядокИзменен;
	КонецЕсли;
	
	ДочерниеУзлы = ЭлементDOMПодчиненныеОбъекты.ДочерниеУзлы;
	Если ДочерниеУзлы.Количество() = 0 Тогда
		// Если подчиненных объектов нет, выходим.
		Возврат ПорядокИзменен;
	КонецЕсли;
	
	ТаблицаТиповОбъектовИнициализировать();
	
	// Заполним подчиненные объекты в таблицу значений для сортировки.
	ТаблицаОбъектов = Новый ТаблицаЗначений;
	ТаблицаОбъектов.Колонки.Добавить("ДочернийУзел");
	ТаблицаОбъектов.Колонки.Добавить("ИмяОбъекта");
	ТаблицаОбъектов.Колонки.Добавить("ТипОбъекта");
	ТаблицаОбъектов.Колонки.Добавить("НомерТипаОбъекта");       // Поле для сортировки.
	ТаблицаОбъектов.Колонки.Добавить("НомерОбъектаИсключения"); // Поле для сортировки.
	ТаблицаОбъектов.Колонки.Добавить("ПрефиксУдалить");         // Поле для сортировки.
	
	// Типы объектов, которые могут располагаться в любом порядке.
	МассивИсключенийТиповОбъектов = Новый Массив;
	МассивИсключенийТиповОбъектов.Добавить(ВРег("CommonAttribute"));
	МассивИсключенийТиповОбъектов.Добавить(ВРег("CommandGroup"));
	
	// Типы объектов, которые содержат данные.
	МассивТиповОбъектовСодержащихДанные = Контекст["МассивТиповОбъектовСодержащихДанные"];
	
	МассивТекстУдалить = Контекст["МассивТекстУдалить"];
	
	НомерТипаОбъекта = -1;
	НомерОбъектаИсключения = -1;
	
	Для Каждого ДочернийУзел Из ДочерниеУзлы Цикл
		
		ТипОбъекта = ДочернийУзел.ИмяЭлемента;
		ИмяОбъекта = ДочернийУзел.ТекстовоеСодержимое;
		
		// Файл конфигурации со списком объектов в проекте EDT отличается от стандартной выгрузки XML.
		// Обработаем этот файл в отдельном условии.
		Если НЕ ЭтоВыгрузкаXMLФайлов Тогда
			
			// В выгрузке EDT в имени элемента дочернего узла хранится тип объекта с маленькой буквы.
			// Заменим первую букву на верхний регистр.
			ТипОбъекта = ВРег(Лев(ТипОбъекта, 1)) + Сред(ТипОбъекта, 2);
			
			// В выгрузке EDT по заданному "/mdclass:Configuration" содержится большое количество лишней информации,
			// например, свойства конфигурации,
			// поэтому проверяем имя узла (тип объекта) в таблице всех типов.
			Если ТаблицаТиповОбъектов.Найти(ТипОбъекта, "ИмяАнглМнФормы") = Неопределено Тогда
				// Если не нашли, то пропускаем, т.к. это скорее всего не объект.
				Продолжить;
			КонецЕсли;
			
			// В выгрузке EDT языки выгружаются в структуре, отличной от других объектов.
			ЭтоЯзык = (СтрСравнить(ТипОбъекта, "Languages") = 0);
			Если ЭтоЯзык Тогда
				// Наименование самого языка хранится внутри дочернего узла.
				СписокЭлементов = ДочернийУзел.ПолучитьЭлементыПоИмени("name");
				Если СписокЭлементов.Количество() = 0 Тогда
					Продолжить;
				КонецЕсли;
				
				ТипОбъекта = "Language";
				ИмяОбъекта = СписокЭлементов[0].ТекстовоеСодержимое;
			Иначе
				// В выгрузке EDT в текстовом содержимом дочернего узла хранится тип в ед.ч. и имя объекта.
				// Переопределим тип и имя объекта оттуда.
				МассивЭлементовИмени = СтрРазделить(ИмяОбъекта, ".", Ложь);
				Если МассивЭлементовИмени.Количество() < 2 Тогда
					Продолжить;
				КонецЕсли;
				
				ТипОбъекта = МассивЭлементовИмени[0];
				ИмяОбъекта = МассивЭлементовИмени[1];
			КонецЕсли;
			
		КонецЕсли;
		
		// Устанавливаем номер типа объекта в таблице объектов.
		СтрокаОбъекта = ТаблицаОбъектов.Найти(ТипОбъекта, "ТипОбъекта");
		НомерТипаОбъекта = ?(СтрокаОбъекта = Неопределено, НомерТипаОбъекта + 1, СтрокаОбъекта.НомерТипаОбъекта);
		
		ТипОбъектаВРег = ВРег(ТипОбъекта);
		
		// Устанавливаем номера для объектов из типов-исключений, которые не надо сортировать.
		НомерОбъектаИсключения = ?(МассивИсключенийТиповОбъектов.Найти(ТипОбъектаВРег) = Неопределено, - 1, НомерОбъектаИсключения + 1);
		
		// Устанавливаем флаг "ПрефиксУдалить" для объектов, которые содержат данные.
		ПрефиксУдалить = Ложь;
		Если МассивТиповОбъектовСодержащихДанные.Найти(ТипОбъектаВРег) <> Неопределено Тогда
			ПрефиксУдалить = СтрНачинаетсяСПоМассиву(ВРег(ИмяОбъекта), МассивТекстУдалить).Успешно;
		КонецЕсли;
		
		СтрокаОбъекта = ТаблицаОбъектов.Добавить();
		СтрокаОбъекта.ДочернийУзел = ДочернийУзел;
		СтрокаОбъекта.ИмяОбъекта = ИмяОбъекта;
		СтрокаОбъекта.ТипОбъекта = ТипОбъекта;
		СтрокаОбъекта.НомерТипаОбъекта = НомерТипаОбъекта;
		СтрокаОбъекта.НомерОбъектаИсключения = НомерОбъектаИсключения;
		СтрокаОбъекта.ПрефиксУдалить = ПрефиксУдалить;
		
	КонецЦикла;
	
	ТаблицаОбъектовИсходная = ТаблицаОбъектов.Скопировать();
	
	ТаблицаОбъектов.Сортировать("НомерТипаОбъекта, НомерОбъектаИсключения, ПрефиксУдалить, ИмяОбъекта");
	
	Если ТаблицыЗначенийРавны(ТаблицаОбъектов, ТаблицаОбъектовИсходная) Тогда
		Возврат ПорядокИзменен;
	КонецЕсли;
	
	ПорядокИзменен = Истина;
	
	// Если объекты одного или нескольких типов были отсортированы не по порядку, то заполняем дочерние узлы заново.
	Для Каждого СтрокаОбъекта Из ТаблицаОбъектов Цикл
		ЭлементDOMПодчиненныеОбъекты.ДобавитьДочерний(СтрокаОбъекта.ДочернийУзел);
	КонецЦикла;
	
	Возврат ПорядокИзменен;
	
КонецФункции

Функция УдалитьИзбыточноеОбращениеКОбъектуВКодеМодуля(Знач ПолноеИмяФайла, ДокументТекст)
	
	ФайлИзменен = Ложь;
	
	ТипМодуля = ПолучитьТипМодуляПоИмениФайла(ПолноеИмяФайла);
	
	// Пропускаем модули менеджеров, т.к. в них невозможно обращение по "ЭтотОбъект.".
	Если ТипМодуля = "МодульМенеджера" Тогда
		Возврат ФайлИзменен;
	КонецЕсли;
	
	ПолноеИмяФайла = ВРег(ПолноеИмяФайла);
	
	// Пропускаем следующие типы объектов с модулями, т.к. не имеют свойства ЭтотОбъект или ЭтаФорма.
	МассивИсключенийТипов = Новый Массив;
	МассивИсключенийТипов.Добавить("WebServices");      // - WebСервисы
	МассивИсключенийТипов.Добавить("HTTPServices");     // - HTTPСервисы
	МассивИсключенийТипов.Добавить("DocumentJournals"); // - ЖурналыДокументов
	МассивИсключенийТипов.Добавить("Enums");            // - Перечисления
	МассивИсключенийТипов.Добавить("SettingsStorages"); // - ХранилищаНастроек
	МассивИсключенийТипов.Добавить("Ext");              // - Конфигурация
	
	КаталогВыгрузкиКопия = ОтредактироватьПутьККаталогу(КаталогВыгрузкиРезультат);
	
	ОбъектЯвляетсяИсключением = Ложь;
	Для Каждого ИсключениеТипа Из МассивИсключенийТипов Цикл
		
		Если ЭтоВыгрузкаXMLФайлов Тогда
			КаталогТиповОбъектов = КаталогВыгрузкиКопия + ИсключениеТипа + РазделительПути;
		Иначе
			КаталогТиповОбъектов = СтрШаблон("%1src%2%3%2", КаталогВыгрузкиКопия, РазделительПути, ИсключениеТипа);
		КонецЕсли;
		
		Если СтрНачинаетсяС(ПолноеИмяФайла, ВРег(КаталогТиповОбъектов)) Тогда
			ОбъектЯвляетсяИсключением = Истина;
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Если ОбъектЯвляетсяИсключением Тогда
		Возврат ФайлИзменен;
	КонецЕсли;
	
	// Заполняем массив обращений для поиска в зависимости от типа объекта.
	МассивОбращений = Новый Массив;
	
	Если ТипМодуля = "ОбщийМодуль" Тогда
		
		// Если это общий модуль, то учитываем обращение по имени, кроме модулей с повторным использованием.
		Если ЭтоВыгрузкаXMLФайлов Тогда
			КаталогОбщихМодулей = КаталогВыгрузкиКопия + "CommonModules" + РазделительПути;
		Иначе
			КаталогОбщихМодулей = КаталогВыгрузкиКопия + "src" + РазделительПути + "CommonModules" + РазделительПути;
		КонецЕсли;
		
		ИмяМодуля = СтрЗаменить(ПолноеИмяФайла, ВРег(КаталогОбщихМодулей), "");
		МассивКаталогов = СтрРазделить(ИмяМодуля, РазделительПути, Ложь);
		Если МассивКаталогов.Количество() = 0 Тогда
			Возврат ФайлИзменен;
		КонецЕсли;
		
		ИмяМодуля = МассивКаталогов[0];
		
		// Пропускаем общие модули с постфиксом "ПовтИсп".
		Если СтрНайти(ИмяМодуля, ВРег(НСтр("ru='ПовтИсп'; en='Cached'", КодОсновногоЯзыка))) > 0 Тогда
			Возврат ФайлИзменен;
		КонецЕсли;
		
		МассивОбращений.Добавить(ИмяМодуля + ".");
		
	ИначеЕсли ТипМодуля = "МодульФормы" Тогда
		// Если это форма, то пропускаем ее, т.к. удалять для нее нечего:
		// Обращение "ЭтаФорма" удалять нельзя, т.к. очень часто реквизиты на форму добавляются программно,
		// и обращение к ним возможно только через "ЭтаФорма", например, "ЭтаФорма.Объект".
		// Обращение "ЭтотОбъект" удалять нельзя, т.к. в большинстве случаев это обращение к родительскому объекту формы, и без него будет синтаксическая ошибка.
		Возврат ФайлИзменен;
	Иначе
		// Для любого другого объекта учитываем только обращение "ЭтотОбъект".
		МассивОбращений.Добавить(ВРег("ЭтотОбъект") + ".");
		МассивОбращений.Добавить(ВРег("ThisObject") + ".");
	КонецЕсли;
	
	СтрокаДоступныхСимволов = " (,;+-*/=<>" + Символы.Таб + Символы.ПС;
	
	ТекстМодуляИсходный = ДокументТекст.ПолучитьТекст();
	ТекстМодуля = ВРег(ТекстМодуляИсходный);
	
	ТаблицаМетодов = ПолучитьТаблицуПроцедурИФункций(ТекстМодуляИсходный);
	
	Для Каждого Обращение Из МассивОбращений Цикл
		
		ОбращениеБезТочки = СтрЗаменить(Обращение, ".", "");
		ОбращениеБезТочки = СокрЛП(ОбращениеБезТочки);
		
		ПозицияПоиска = 0;
		Пока Истина Цикл
			
			ПозицияПоиска = СтрНайти(ТекстМодуля, Обращение,, ПозицияПоиска + 1);
			Если ПозицияПоиска = 0 Тогда
				Прервать;
			КонецЕсли;
			
			// Проверяем символ перед обращением.
			// Если его нет среди разрешенных, то ищем дальше.
			ПредыдущийСимвол = Сред(ТекстМодуля, ПозицияПоиска - 1, 1);
			Если СтрНайти(СтрокаДоступныхСимволов, ПредыдущийСимвол) = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			// Ищем процедуру или функцию, в которой найдено обращение.
			МассивПараметров = Новый Массив;
			Для Каждого СтрокаМетода Из ТаблицаМетодов Цикл
				Если (ПозицияПоиска > СтрокаМетода.ПозицияКонцаОписания)
				   И (ПозицияПоиска < СтрокаМетода.ПозицияКонцаМетода) Тогда
					МассивПараметров = СтрокаМетода.МассивПараметров;
					Прервать;
				КонецЕсли;
			КонецЦикла;
			
			// Проверяем параметры процедуры или функции, в которой найдено обращение.
			// Если у метода есть параметр, совпадающий с обращением, например, "ЭтотОбъект",
			// то такое обращение удалять нельзя, пропускаем.
			НайденПараметрПоИмениОбращения = Ложь;
			Для Каждого ПараметрМетода Из МассивПараметров Цикл
				ПараметрМетода = ПолучитьИмяПараметра(ПараметрМетода);
				Если ВРег(ПараметрМетода) = ОбращениеБезТочки Тогда
					НайденПараметрПоИмениОбращения = Истина;
					Прервать;
				КонецЕсли;
			КонецЦикла;
			
			Если НайденПараметрПоИмениОбращения Тогда
				Продолжить;
			КонецЕсли;
			
			НомерСтроки = ПолучитьНомерСтрокиМодуля(ТекстМодуля, ПозицияПоиска);
			
			// Получаем строку в исходном виде.
			СтрокаМодуляИсходная = ДокументТекст.ПолучитьСтроку(НомерСтроки);
			СтрокаМодуля = ВРег(СтрокаМодуляИсходная);
			СтрокаМодуля = УдалитьКомментарийИзСтроки(СтрокаМодуля);
			
			Если ПустаяСтрока(СтрокаМодуля) Тогда
				Продолжить;
			КонецЕсли;
			
			ПозицияПоискаВСтроке = СтрНайти(СтрокаМодуля, Обращение);
			Если ПозицияПоискаВСтроке = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			// Проверяем находится ли найденное обращение в кавычках.
			СтрокаДоОбращения = Лев(СтрокаМодуля, ПозицияПоискаВСтроке - 1);
			СтрокаДоОбращения = СокрЛ(СтрокаДоОбращения);
			КоличествоКавычекДоОбращения = СтрЧислоВхождений(СтрокаДоОбращения, """");
			
			КоличествоКавычекЧетное = (КоличествоКавычекДоОбращения % 2 = 0);
			
			// Если обращение в кавычках, то пропускаем.
			Если (КоличествоКавычекЧетное И СтрНачинаетсяС(СтрокаДоОбращения, "|"))
			 ИЛИ (НЕ КоличествоКавычекЧетное) Тогда
				Продолжить;
			КонецЕсли;
			
			// Удаляем обращение к объекту, т.к. оно лишнее.
			СтрокаМодуляДо = Лев(СтрокаМодуляИсходная, ПозицияПоискаВСтроке - 1);
			СтрокаМодуляПосле = Сред(СтрокаМодуляИсходная, ПозицияПоискаВСтроке + СтрДлина(Обращение));
			СтрокаМодуляЗамена = СтрокаМодуляДо + СтрокаМодуляПосле;
			
			ДокументТекст.ЗаменитьСтроку(НомерСтроки, СтрокаМодуляЗамена);
			ФайлИзменен = Истина;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ФайлИзменен;
	
КонецФункции

#КонецОбласти

