Функция ПроверкаКаноническогоНаписанияКлючевыхСловЗапроса(ДокументТекст)
	
	// Получаем массив ключевых слов запроса, по которым определяем, что это текст запроса.
	МассивКлючевыхСловЗапроса = Контекст["МассивКлючевыхСловЗапроса"];
	
	// Получаем таблицу ключевых слов запроса, которые необходимо заменить.
	ТаблицаКлючевыхСловЗапроса = Контекст["ТаблицаКлючевыхСловЗапроса"];
	
	// Получаем массив слов, которые точно не встречаются в запросах.
	МассивИсключенийСловЗапроса = Контекст["МассивИсключенийСловЗапроса"];
	
	ТекстКавычки = """";
	ТекстДвойныеКавычки = ТекстКавычки + ТекстКавычки;
	ТекстДвойныеКавычкиЗамена = "~~"; // берем такие знаки, чтобы сохранить длину замены.
	
	ФайлИзменен = Ложь;
	
	ТекстМодуля = ДокументТекст.ПолучитьТекст();
	
	// Заменяем в тексте модуля двойные кавычки на символы замены.
	ТекстМодуля = СтрЗаменить(ТекстМодуля, ТекстДвойныеКавычки, ТекстДвойныеКавычкиЗамена);
	
	// Формируем регулярное выражение для поиска текстов запросов.
	СловаИсключенияСтрокой = СтрСоединить(МассивИсключенийСловЗапроса, "\b\b");
	КлючевыеСловЗапросаСтрокой = СтрСоединить(МассивКлючевыхСловЗапроса, "\b|\b");
	ВыражениеПоискаТекстаВКавычках = СтрШаблон("""[^"".)\b%1\b]*?(\b%2\b)+[^\b%1\b]*?""", СловаИсключенияСтрокой, КлючевыеСловЗапросаСтрокой);
	РезультатПоискаТекстаВКавычках = СтрНайтиВсеПоРегулярномуВыражению(ТекстМодуля, ВыражениеПоискаТекстаВКавычках, Истина, Истина);
	
	Для Каждого РезультатПоиска Из РезультатПоискаТекстаВКавычках Цикл
		
		СтрокаМеждуКавычками = РезультатПоиска.Значение;
		
		СтрокаМеждуКавычкамиБезПереносовСтрок = СтрЗаменить(СтрокаМеждуКавычками, Символы.ПС, " ");
		СтрокаМеждуКавычкамиБезПереносовСтрок = СокрЛП(СтрокаМеждуКавычкамиБезПереносовСтрок);
		
		// Если в строке нет пробелов, это идентификатор, пропускаем.
		Если СтрНайти(СтрокаМеждуКавычкамиБезПереносовСтрок, " ") = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		ПозицияНачало = РезультатПоиска.НачальнаяПозиция;
		ПозицияКонец  = ПозицияНачало + СтрДлина(СтрокаМеждуКавычками);
		
		// Определяем номера первой и последней строк запроса для построчного обхода.
		НомерСтрокиМодуляНачало = ПолучитьНомерСтрокиМодуля(ТекстМодуля, ПозицияНачало);
		НомерСтрокиМодуляКонец  = ПолучитьНомерСтрокиМодуля(ТекстМодуля, ПозицияКонец);
		
		СтрокаМодуляИзмененная = "";
		
		Для НомерСтрокиМодуля = НомерСтрокиМодуляНачало По НомерСтрокиМодуляКонец Цикл
			
			СтрокаМодуляИсходная = ДокументТекст.ПолучитьСтроку(НомерСтрокиМодуля);
			Если СтрНачинаетсяС(СокрЛ(СтрокаМодуляИсходная), "//") Тогда
				// Пропускаем закомментированные строки.
				Продолжить;
			КонецЕсли;
			
			СтрокаМодуля = СтрокаМодуляИсходная;
			Если НомерСтрокиМодуля = НомерСтрокиМодуляНачало
			 ИЛИ НомерСтрокиМодуля = НомерСтрокиМодуляКонец Тогда
				// Заменяем на пробелы, чтобы не проверять лишнее:
				// в первой строке - все символы до первой кавычки;
				// в последней строке - все символы после последней кавычки.
				ЭтоПерваяСтрока = (НомерСтрокиМодуля = НомерСтрокиМодуляНачало);
				НаправлениеПоискаКавычек = ?(ЭтоПерваяСтрока, НаправлениеПоиска.СНачала, НаправлениеПоиска.СКонца);
				
				ПозицияКавычек = СтрНайти(СтрокаМодуля, ТекстКавычки, НаправлениеПоискаКавычек);
				
				Если ЭтоПерваяСтрока Тогда
					СтрокаМодуля = апк_СтрЗаменить(СтрокаМодуля, " ", 1, ПозицияКавычек - 1);
				Иначе
					СтрокаМодуля = апк_СтрЗаменить(СтрокаМодуля, " ", ПозицияКавычек, СтрДлина(СтрокаМодуля));
				КонецЕсли;
				
			КонецЕсли;
			
			// Очищаем строку для дальнейшего поиска ключевых слов запроса.
			СтрокаМодуля = СтрЗаменить(СтрокаМодуля, Символы.Таб, " ");
			СтрокаМодуля = СтрЗаменить(СтрокаМодуля, ТекстКавычки, " ");
			СтрокаМодуля = СтрЗаменить(СтрокаМодуля, "|", " ");
			СтрокаМодуля = СтрЗаменить(СтрокаМодуля, "(", " ");
			СтрокаМодуля = СтрЗаменить(СтрокаМодуля, ")", " ");
			СтрокаМодуля = СтрЗаменить(СтрокаМодуля, "{", " ");
			СтрокаМодуля = СтрЗаменить(СтрокаМодуля, "}", " ");
			СтрокаМодуля = ВРег(СтрокаМодуля);
			СтрокаМодуля = СтрШаблон(" %1 ", СтрокаМодуля);
			
			СтрокаИзменена = Ложь;
			
			// Проверяем правильное написание каждого ключевого слова запроса.
			Для Каждого СтрокаТаблицы Из ТаблицаКлючевыхСловЗапроса Цикл
				
				Эталон         = СтрокаТаблицы.Эталон;
				ДлинаЭталона   = СтрокаТаблицы.ДлинаЭталона;
				СловоДляПоиска = СтрокаТаблицы.СловоДляПоиска;
				
				// Ищем вхождение ключевого слова запроса в строке модуля.
				ПозицияПоиска = 0;
				Пока Истина Цикл
					
					ПозицияПоиска = СтрНайти(СтрокаМодуля, СловоДляПоиска,, ПозицияПоиска + 1);
					Если ПозицияПоиска = 0 Тогда
						Прервать;
					КонецЕсли;
					
					// Определяем написание из исходной строки.
					КлючевоеСловоИсходное = Сред(СтрокаМодуляИсходная, ПозицияПоиска, ДлинаЭталона);
					
					// Сравниваем исходное ключевое слово запроса с эталоном.
					Если Эталон = СокрЛП(КлючевоеСловоИсходное) Тогда
						Продолжить;
					КонецЕсли;
					
					// Найденное слово отличается от эталона - меняем исходное ключевое слово запроса на эталон.
					СтрокаДо = Лев(СтрокаМодуляИсходная, ПозицияПоиска - 1);
					СтрокаПосле = Сред(СтрокаМодуляИсходная, ПозицияПоиска + ДлинаЭталона);
					
					СтрокаМодуляИзмененная = СтрокаДо + Эталон + СтрокаПосле;
					
					СтрокаИзменена = Истина;
					
				КонецЦикла;
				
			КонецЦикла;
			
			Если СтрокаИзменена Тогда
				// Удаляем пробелы в начале и конце.
				СтрокаМодуляБуфер = Сред(СтрокаМодуляБуфер, 2, СтрДлина(СтрокаМодуляБуфер) - 2);
				ДокументТекст.ЗаменитьСтроку(НомерСтрокиМодуля, СтрокаМодуляИзмененная);
				ФайлИзменен = Истина;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
		
	Возврат ФайлИзменен;
	
КонецФункции

Функция ПроверкаФорматаКомментария(ДокументТекст)
	
	ФайлИзменен = Ложь;
	
	МассивСтрокИсключений = Новый Массив;
	МассивСтрокИсключений.Добавить("_Демо начало примера");
	МассивСтрокИсключений.Добавить("_Demo Example Start");
	МассивСтрокИсключений.Добавить("_Демо конец примера");
	МассивСтрокИсключений.Добавить("_Demo Example End");
	
	// Служебные теги не обрабатываем, только добавляем в начало пробел, если его нет.
	МассивСлужебныхТегов = Контекст["МассивСлужебныхТегов"];
	
	КоличествоСтрок = ДокументТекст.КоличествоСтрок();
	
	МногострочныйКомментарий = "";
	НомерСтрокиНачалаКомментария = 0;
	НадоПроверитьКомментарий = Ложь;
	
	Для НомерСтроки = 1 По КоличествоСтрок Цикл
		
		Если НадоПроверитьКомментарий Тогда
			
			НадоПроверитьКомментарий = Ложь;
			
			// Комментарий кончился, проверяем накопленный многострочный комментарий.
			Если НЕ ПустаяСтрока(МногострочныйКомментарий) Тогда
				
				МногострочныйКомментарий = СокрЛП(МногострочныйКомментарий);
				
				// Определяем, является ли комментарий длинным, по критериям:
				//   однострочный комментарий - длинный, если его длина больше 80 символов;
				//   многострочный комментарий - длинный, если хотя бы 1 его строка длиннее 30-ти символов.
				КоличествоСтрокКомментария = СтрЧислоСтрок(МногострочныйКомментарий);
				Если КоличествоСтрокКомментария = 1 Тогда
					ЭтоДлинныйКомментарий = СтрДлина(МногострочныйКомментарий) > 80;
				Иначе
					ЭтоДлинныйКомментарий = Ложь;
					Для Счетчик = 1 По КоличествоСтрокКомментария Цикл
						СтрокаМногострочногоКомментария = СтрПолучитьСтроку(МногострочныйКомментарий, Счетчик);
						Если СтрДлина(СтрокаМногострочногоКомментария) > 30 Тогда
							ЭтоДлинныйКомментарий = Истина;
							Прервать;
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
				
				Если ЗначениеФлагов.ДлинныеКомментарииСБольшойБуквы И ЭтоДлинныйКомментарий Тогда
					
					// Длинный комментарий должен начинаться с большой буквы.
					ПервыйСимвол = Лев(МногострочныйКомментарий, 1);
					Если ВРег(ПервыйСимвол) <> ПервыйСимвол Тогда
						// Проверим, что комментарий не начался в предыдущей строке.
						ПредыдущаяСтрока = ДокументТекст.ПолучитьСтроку(НомерСтрокиНачалаКомментария - 1);
						ПредыдущаяСтрока = СокрЛ(ПредыдущаяСтрока);
						
						Если СтрНайти(ПредыдущаяСтрока, "//") = 0 Тогда
							
							ИсходнаяСтрока = ДокументТекст.ПолучитьСтроку(НомерСтрокиНачалаКомментария);
							ПозицияКомментария = СтрНайти(ИсходнаяСтрока, "//");
							Если ПозицияКомментария > 0 Тогда
								
								НоваяСтрока = ИсходнаяСтрока;
								
								ДлинаСтроки = СтрДлина(ИсходнаяСтрока);
								Для Счетчик = 1 По ДлинаСтроки Цикл
									Символ = Сред(ИсходнаяСтрока, Счетчик, 1);
									Если Символ <> ВРег(Символ) Тогда
										НоваяСтрока = Лев(ИсходнаяСтрока, Счетчик - 1);
										НоваяСтрока = НоваяСтрока + ВРег(Символ);
										НоваяСтрока = НоваяСтрока + Сред(ИсходнаяСтрока, Счетчик + 1);
										Прервать;
									КонецЕсли;
								КонецЦикла;
								
								ДокументТекст.ЗаменитьСтроку(НомерСтрокиНачалаКомментария, НоваяСтрока);
								
								ФайлИзменен = Истина;
								
							КонецЕсли;
							
						КонецЕсли;
					КонецЕсли;
					
				КонецЕсли;
				
				МногострочныйКомментарий = "";
				
			КонецЕсли;
			
		КонецЕсли;
		
		СтрокаМодуляИсходная = ДокументТекст.ПолучитьСтроку(НомерСтроки);
		Если ПустаяСтрока(СтрокаМодуляИсходная) Тогда
			НадоПроверитьКомментарий = Истина;
			Продолжить;
		КонецЕсли;
		
		СтрокаМодуляИсходная = СокрЛП(СтрокаМодуляИсходная);
		
		// Если это не комментарий, тогда пропускаем.
		Если НЕ СтрНачинаетсяС(СтрокаМодуляИсходная, "//") Тогда
			НадоПроверитьКомментарий = Истина;
			Продолжить;
		КонецЕсли;
		
		// Проверяем наличие комментариев-аннотаций, начинающихся с "//@".
		Если СтрНачинаетсяС(СтрокаМодуляИсходная, "//@") Тогда
			// Для них пробелы не нужны, пропускаем.
			НадоПроверитьКомментарий = Истина;
			Продолжить;
		КонецЕсли;
		
		Строка = СтрокаМодуляИсходная;
		
		// Если после удаления символов "//" строка пустая, то пропускаем.
		Строка = СтрЗаменить(Строка, "/", "");
		Если ПустаяСтрока(Строка) Тогда
			НадоПроверитьКомментарий = Истина;
			Продолжить;
		КонецЕсли;
		
		СтрокаСокрЛ = СокрЛ(Строка);
		
		ЭтоСлужебныйТег = Ложь;
		Для Каждого СлужебныйТег Из МассивСлужебныхТегов Цикл
			Если СтрНачинаетсяС(СтрокаСокрЛ, СлужебныйТег) Тогда
				ЭтоСлужебныйТег = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		Если ЭтоСлужебныйТег Тогда
			// Добавляем пробел, если его нет, и пропускаем.
			Если СтрокаСокрЛ = Строка Тогда
				Если ЗначениеФлагов.ПробелВНачалеКомментариев Тогда
					ДобавитьПробелПослеЗнакаКомментария(ДокументТекст, НомерСтроки);
					ФайлИзменен = Истина;
				КонецЕсли;
			КонецЕсли;
			Продолжить;
		КонецЕсли;
		
		// Если строка состоит только из символов верхнего регистра, то это, например, объявление области, пропускаем.
		Если ВРег(Строка) = Строка Тогда
			// Пропускаем, если до этого комментарий пустой.
			// Возможно, перечисление параметров, тогда пропускать не нужно.
			Если ПустаяСтрока(МногострочныйКомментарий) Тогда
				Продолжить;
			КонецЕсли;
			
			// Проверим следующую строку.
			СледующаяСтрока = ДокументТекст.ПолучитьСтроку(НомерСтроки + 1);
			СледующаяСтрока = СтрЗаменить(СледующаяСтрока, "/", "");
			Если ПустаяСтрока(СледующаяСтрока) Тогда
				МногострочныйКомментарий = "";
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		
		ЭтоИсключение = ЭтоКод(Строка);
		
		// Проверяем пробел (таб) в начале строки.
		Если СтрокаСокрЛ = Строка Тогда
			// Закомментированный код проверять не нужно.
			Если НЕ ЭтоИсключение Тогда
				Если ЗначениеФлагов.ПробелВНачалеКомментариев Тогда
					ДобавитьПробелПослеЗнакаКомментария(ДокументТекст, НомерСтроки);
					ФайлИзменен = Истина;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		НадоПроверитьКомментарий = Ложь;
		
		// Отдельно проверяем описание области.
		Если НЕ ЭтоИсключение Тогда
			ЭтоИсключение = СтрокаСодержитОписаниеОбласти(СокрЛП(Строка));
		КонецЕсли;
		
		// Проверяем исключения из массива.
		Если НЕ ЭтоИсключение Тогда
			Если СтрНайтиПоМассиву(Строка, МассивСтрокИсключений,, Истина).Успешно Тогда
				ЭтоИсключение = Истина;
			КонецЕсли;
		КонецЕсли;
		
		// Для комментариев вида:
		// Обработка входящих сообщений с типом {http://www.1c.ru/1cFresh/ApplicationExtensions/Management/a.b.c.d}InstallExtension
		// Делаем исключение по вхождению в комментарий гиперссылки "http://www.".
		// Если до конца строки пробелов нет, это исключение.
		Если НЕ ЭтоИсключение Тогда
			ПозицияГиперссылки = СтрНайти(СтрокаМодуляИсходная, "http://www.");
			Если ПозицияГиперссылки > 0 Тогда
				СтрокаГиперссылки = Сред(СтрокаМодуляИсходная, ПозицияГиперссылки);
				ЭтоИсключение = (СтрНайти(СтрокаГиперссылки, " ") = 0);
			КонецЕсли;
		КонецЕсли;
		
		// Если это исключение, проверяем следующую строку.
		Если ЭтоИсключение Тогда
			СледующаяСтрока = ДокументТекст.ПолучитьСтроку(НомерСтроки + 1);
			
			// Если следующая строка не содержит комментарий, то пропускаем.
			СледующаяСтрока = СокрЛ(СледующаяСтрока);
			Если НЕ СтрНачинаетсяС(СледующаяСтрока, "//") Тогда
				МногострочныйКомментарий = "";
				Продолжить;
			КонецЕсли;
			
			// Если следующая строка пустая, то пропускаем.
			СледующаяСтрока = СтрЗаменить(СледующаяСтрока, "/", "");
			Если ПустаяСтрока(СледующаяСтрока) Тогда
				МногострочныйКомментарий = "";
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		
		Если ПустаяСтрока(МногострочныйКомментарий) Тогда
			НомерСтрокиНачалаКомментария = НомерСтроки;
		КонецЕсли;
		
		МногострочныйКомментарий = МногострочныйКомментарий + Строка + Символы.ПС;
		
	КонецЦикла;
	
	Возврат ФайлИзменен;
	
КонецФункции

Функция ПолучитьОтступПослеЗнакаКомментария(Знач СтрокаМодуля, УчитыватьНезначимыеСимволы = Истина)
	
	СтрокаМодуля = СокрЛ(СтрокаМодуля);
	
	Если НЕ СтрНачинаетсяС(СтрокаМодуля, "//") Тогда
		Возврат "";
	КонецЕсли;
	
	СтрокаМодуля = СтрЗаменить(СтрокаМодуля, "/", "");
	
	Если ПустаяСтрока(СтрокаМодуля) Тогда
		Возврат "";
	КонецЕсли;
	
	Если НЕ УчитыватьНезначимыеСимволы Тогда
		СтрокаНезначимыхСимволов = "*,-";
		МассивНезначимыхСимволов = СтрРазделить(СтрокаНезначимыхСимволов, ",");
		Для Каждого НезначимыйСимвол Из МассивНезначимыхСимволов Цикл
			СтрокаМодуля = СтрЗаменить(СтрокаМодуля, НезначимыйСимвол, " ");
		КонецЦикла;
	КонецЕсли;
	
	СтрокаМодуляСокрЛ = СокрЛ(СтрокаМодуля);
	ДлинаОтступа = СтрДлина(СтрокаМодуля) - СтрДлина(СтрокаМодуляСокрЛ);
	
	Отступ = Сред(СтрокаМодуля, 1, ДлинаОтступа);
	
	Возврат Отступ;
	
КонецФункции

Функция ПолучитьОтступДоЗнакаКомментария(Знач СтрокаМодуля)
	
	ПозицияКомментария = СтрНайти(СтрокаМодуля, "//");
	ОтступДоЗнакаКомментария = Лев(СтрокаМодуля, ПозицияКомментария - 1);
	
	Возврат ОтступДоЗнакаКомментария;
	
КонецФункции

// Объединяет комментарий текущей строки с комментарием следующей строки.
// Если результирующий комментарий меньше 120 символов,
// то заменяет текущую строку в документе новой получившейся строкой и удаляет следующую строку из документа.
//
Процедура ОбъединитьКомментарииСтрок(ДокументТекст, НомерСтроки)
	
	СледующаяСтрока = ДокументТекст.ПолучитьСтроку(НомерСтроки + 1);
	
	// В следующей строке нет комментария, не объединяем.
	Если СтрНайти(СледующаяСтрока, "//") = 0 Тогда
		
		СледующаяСтрока = СокрЛП(СледующаяСтрока);
		Если ПустаяСтрока(СледующаяСтрока) Тогда
			
			СтрокаПослеСледующейСтроки =  ДокументТекст.ПолучитьСтроку(НомерСтроки + 2);
			МассивТекстПроцедураФункция = Контекст["МассивТекстПроцедураФункция"];
			
			РезультатПроверки = СтрНачинаетсяСПоМассиву(ВРег(СтрокаПослеСледующейСтроки), МассивТекстПроцедураФункция);
			Если РезультатПроверки.Успешно Тогда
				НайденныйЭлемент = РезультатПроверки.НайденныйЭлемент;
				СледующийСимвол = Сред(СтрокаПослеСледующейСтроки, СтрДлина(НайденныйЭлемент) + 1, 1);
				Если апк_СловоСодержитЗначимыеСимволы(СледующийСимвол) Тогда
					Возврат;
				КонецЕсли;
				ДокументТекст.ЗаменитьСтроку(НомерСтроки + 1, "//");
			КонецЕсли;
			
		КонецЕсли;
		
		Возврат;
		
	КонецЕсли;
	
	// Пустые комментарии не переносим.
	Если СокрЛП(СледующаяСтрока) = "//" Тогда
		Возврат;
	КонецЕсли;
	
	// Комментарий в следующей строке расположен после кода, не объединяем.
	СледующаяСтрокаОтступДоКомментария = ПолучитьОтступДоЗнакаКомментария(СледующаяСтрока);
	Если НЕ ПустаяСтрока(СледующаяСтрокаОтступДоКомментария) Тогда
		Возврат;
	КонецЕсли;
	
	СледующаяСтрокаОтступПослеКомментария = ПолучитьОтступПослеЗнакаКомментария(СледующаяСтрока);
	СледующаяСтрокаОтступПослеКомментария = СтрЗаменить(СледующаяСтрокаОтступПослеКомментария, Символы.Таб, "  ");
	
	ТекущаяСтрока = ДокументТекст.ПолучитьСтроку(НомерСтроки);
	ТекущаяСтрокаОтступПослеКомментария = ПолучитьОтступПослеЗнакаКомментария(ТекущаяСтрока);
	
	// Если отступ после знака комментария в следующей строке меньше, чем в текущей, не объединяем.
	Если СтрДлина(СледующаяСтрокаОтступПослеКомментария) < СтрДлина(ТекущаяСтрокаОтступПослеКомментария) Тогда
		Возврат;
	КонецЕсли;
	
	КомментарийСледующейСтроки = ПолучитьКомментарийИзСтроки(СледующаяСтрока, Истина);
	КомментарийСледующейСтроки = СокрЛП(КомментарийСледующейСтроки);
	
	// Если следующая строка содержит описание параметра, не объединяем.
	Если КомментарийСодержитОписаниеПараметра(КомментарийСледующейСтроки) Тогда
		Возврат;
	КонецЕсли;
	
	МассивСлужебныхТегов = Контекст["МассивСлужебныхТегов"];
	
	// Если следующая строка является служебным тегом (// ++ УТКА), то не объединяем.
	Для Каждого СлужебныйТег Из МассивСлужебныхТегов Цикл
		Если СтрНачинаетсяС(КомментарийСледующейСтроки, СлужебныйТег) Тогда
			Возврат;
		КонецЕсли;
	КонецЦикла;
	
	НоваяСтрока = СокрП(ТекущаяСтрока) + " " + КомментарийСледующейСтроки;
	
	ДокументТекст.ЗаменитьСтроку(НомерСтроки, НоваяСтрока);
	ДокументТекст.УдалитьСтроку(НомерСтроки + 1);
	
КонецПроцедуры

Процедура ДобавитьПробелПослеЗнакаКомментария(ДокументТекст, НомерСтроки)
	
	ИсходнаяСтрока = ДокументТекст.ПолучитьСтроку(НомерСтроки);
	ПозицияКомментария = СтрНайти(ИсходнаяСтрока, "//");
	Если ПозицияКомментария = 0 Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаПослеКомментария = Сред(ИсходнаяСтрока, ПозицияКомментария + 2);
	НоваяСтрока = Лев(ИсходнаяСтрока, ПозицияКомментария - 1) + "// " + СтрокаПослеКомментария;
	ДокументТекст.ЗаменитьСтроку(НомерСтроки, НоваяСтрока);
	
КонецПроцедуры

Функция КомментарийСодержитОписаниеПараметра(Знач Комментарий)
	
	Комментарий = ВРег(Комментарий);
	Комментарий = СтрЗаменить(Комментарий, Символы.Таб, " ");
	
	// Иногда в параметре указывают его обязательность, удалим этот текст из комментария.
	Комментарий = СтрЗаменить(Комментарий, ВРег("(обязательный)"), "");
	Комментарий = СтрЗаменить(Комментарий, ВРег("(необязательный)"), "");
	Комментарий = СтрЗаменить(Комментарий, ВРег("(mandatory)"), "");
	Комментарий = СтрЗаменить(Комментарий, ВРег("(optional)"), "");
	
	РазделительЭлементовОписанияПараметра = " - ";
	ДлинаРазделителяЭлементовОписанияПараметра = СтрДлина(РазделительЭлементовОписанияПараметра);
	
	// Иногда параметр начинается с тире, поэтому в цикле.
	Пока Истина Цикл
		
		ПозицияТире = СтрНайти(Комментарий, РазделительЭлементовОписанияПараметра);
		Если ПозицияТире = 0 Тогда
			// Иногда тип параметра указывают в скобках после имени параметра, поэтому дополнительно ищем скобку.
			ПозицияСкобки = СтрНайти(Комментарий, "(");
			Если ПозицияСкобки = 0 Тогда
				Возврат Ложь;
			Иначе
				ПозицияТире = ПозицияСкобки - 1;
			КонецЕсли;
		КонецЕсли;
		
		// Выделяем наименование параметра до тире.
		Параметр = Лев(Комментарий, ПозицияТире);
		Параметр = СтрЗаменить(Параметр, "/", "");
		// Иногда параметр начинается со звездочки, удаляем.
		Параметр = СтрЗаменить(Параметр, "*", "");
		// Иногда параметр начинается с тире, удаляем.
		Параметр = СтрЗаменить(Параметр, "-", "");
		
		// Если до тире пустая строка, ищем следующее тире.
		Если ПустаяСтрока(Параметр) Тогда
			Комментарий = Сред(Комментарий, ПозицияТире + ДлинаРазделителяЭлементовОписанияПараметра);
			Продолжить;
		КонецЕсли;
		
		// В строке может быть описание типов параметра, тогда считаем, что это тоже описание параметра.
		ПараметрСодержитПробел = Ложь;
		
		// Типы разделены через запятую, проверяем каждый элемент отдельно.
		МассивЭлементовПараметра = СтрРазделить(Параметр, ",");
		Для Каждого ЭлементПараметра Из МассивЭлементовПараметра Цикл
			ЭлементПараметра = СокрЛП(ЭлементПараметра);
			Если СтрНайти(ЭлементПараметра, " ") > 0 Тогда
				ПараметрСодержитПробел = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		// Если в параметре есть пробелы, то это не параметр.
		Возврат НЕ ПараметрСодержитПробел;
		
	КонецЦикла;
	
КонецФункции

Функция ПолучитьМассивСлужебныхТегов()
	
	// Примеры служебных тегов:
	// ++ УТКА
	// -- НЕ УТ
	МассивСлужебныхТегов = Новый Массив;
	МассивСлужебныхТегов.Добавить("--");
	МассивСлужебныхТегов.Добавить("++");
	
	Возврат МассивСлужебныхТегов;
	
КонецФункции

Функция ПроверкаКомментариевНаДопустимуюДлину(ДокументТекст)
	
	ФайлИзменен = Ложь;
	НомерСтроки = 0;
	
	КоличествоСимволовДляПереносаКомментария     = Контекст["КоличествоСимволовДляПереносаКомментария"];
	МассивТекстОкончанияСекцииОписанияПараметров = Контекст["МассивТекстОкончанияСекцииОписанияПараметров"];
	МассивТекстПроцедураФункция                  = Контекст["МассивТекстПроцедураФункция"];
	
	ЭтоСекцияПример = Ложь;
	
	Пока НомерСтроки < ДокументТекст.КоличествоСтрок() Цикл
		
		НомерСтроки = НомерСтроки + 1;
		
		СтрокаМодуляИсходная = ДокументТекст.ПолучитьСтроку(НомерСтроки);
		Если ПустаяСтрока(СтрокаМодуляИсходная) Тогда
			ЭтоСекцияПример = Ложь;
			Продолжить;
		КонецЕсли;
		
		СтрокаМодуля = СокрП(СтрокаМодуляИсходная);
		
		СтрокаМодуляБуфер = ВРег(СтрокаМодуля);
		СтрокаМодуляБуфер = СтрЗаменить(СтрокаМодуляБуфер, Символы.Таб, "");
		СтрокаМодуляБуфер = СтрЗаменить(СтрокаМодуляБуфер, " ", "");
		
		// Пропускаем строки, не содержащие комментарий.
		Если НЕ СтрНачинаетсяС(СтрокаМодуляБуфер, "//") Тогда
			ЭтоСекцияПример = Ложь;
			Продолжить;
		КонецЕсли;
		
		РезультатПроверкиСекцииПример = СтрНачинаетсяСПоМассиву(СтрокаМодуляБуфер, МассивТекстОкончанияСекцииОписанияПараметров);
		Если РезультатПроверкиСекцииПример.Успешно Тогда
			// Считаем, что секция пример до конца комментария.
			// Секцией "Пример" считаем любое начало кроме аннотаций-комментариев "@skip-warning".
			ЭтоСекцияПример = (РезультатПроверкиСекцииПример.НайденныйЭлемент <> "//@");
			Продолжить;
		КонецЕсли;
		
		// Секция "Пример" не форматируется.
		Если ЭтоСекцияПример Тогда
			Продолжить;
		КонецЕсли;
		
		// Строки с пустым комментарием не обрабатываем.
		СтрокаМодуляБуфер = СтрЗаменить(СтрокаМодуляБуфер, "/", "");
		Если ПустаяСтрока(СтрокаМодуляБуфер) Тогда
			Продолжить;
		КонецЕсли;
		
		// Пропускаем строки менее 120 символов.
		ДлинаСтроки = СтрДлина(СтрокаМодуля);
		Если ДлинаСтроки <= КоличествоСимволовДляПереносаКомментария Тогда
			Продолжить;
		КонецЕсли;
		
		Комментарий = ПолучитьКомментарийИзСтроки(СтрокаМодуля, Ложь);
		Комментарий = СокрП(Комментарий);
		
		// Пропускаем строки, содержащие таб.
		Если СтрНайти(Комментарий, Символы.Таб) > 0 Тогда
			Продолжить;
		КонецЕсли;
		
		// Пропускаем строки с гиперссылками.
		Если СтрНайти(Комментарий, "{http://") > 0 Тогда
			Продолжить;
		КонецЕсли;
		
		// Пропускаем комментарии, не содержащие ни одного пробела после 120 символов.
		Если СтрНайти(Сред(Комментарий, 121), " ") = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		// Получаем номер первого символа отличного от "/".
		КомментарийСокрЛ = СокрЛ(Комментарий);
		ДлинаКомментарияСокрЛ = СтрДлина(КомментарийСокрЛ);
		Для НомерСимвола = 3 По ДлинаКомментарияСокрЛ + 1 Цикл
			Символ = Сред(КомментарийСокрЛ, НомерСимвола, 1);
			Если Символ <> "/" Тогда
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		// Получаем комментарий без первых знаков комментария.
		КомментарийБезЗнаковКомментария = Сред(КомментарийСокрЛ, НомерСимвола);
		КомментарийБезЗнаковКомментария = СокрЛ(КомментарийБезЗнаковКомментария);
		
		// Если комментарий начинается со слов "процедура" или "функция" и содержит скобку "(",
		// то считаем его кодом, пропускаем.
		Если (СтрНайти(КомментарийБезЗнаковКомментария, "(") > 0) Тогда
			НайденныйЭлемент = СтрНайтиПоМассиву(КомментарийБезЗнаковКомментария, МассивТекстПроцедураФункция).НайденныйЭлемент;
			Если НЕ ПустаяСтрока(НайденныйЭлемент) Тогда
				Если ВРег(Лев(КомментарийБезЗнаковКомментария, СтрДлина(НайденныйЭлемент))) = НайденныйЭлемент Тогда
					Продолжить;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		// Получим отступ до знака комментария.
		ОтступДоЗнакаКомментария = ПолучитьОтступДоЗнакаКомментария(СтрокаМодуля);
		
		// Если отступ до знака комментария не пустой (комментарий написан в строке кода),
		// то такие строки пропускаем, т.к. не понятно, как делать перенос.
		Если НЕ ПустаяСтрока(ОтступДоЗнакаКомментария) Тогда
			Продолжить;
		КонецЕсли;
		
		// Получим отступ после знака комментария.
		ОтступПослеЗнакаКомментария = ПолучитьОтступПослеЗнакаКомментария(Комментарий);
		
		// Если отступ после знака комментария отсутствует, и строка заканчивается на ";", считаем, что это код.
		Если (ОтступПослеЗнакаКомментария = "") И (Прав(СтрокаМодуля, 1) = ";") Тогда
			Продолжить;
		КонецЕсли;
		
		ДлинаОтступаПослеЗнакаКомментария = СтрДлина(ОтступПослеЗнакаКомментария);
		
		// Получим, что необходимо оставить в той же строке, а что перенести.
		НомерСимволаДляПереноса = 0;
		
		// 121-м символом может быть пробел, тогда на нем и надо перенести.
		Для НомерСимволаСКонца = 1 По КоличествоСимволовДляПереносаКомментария + 1 Цикл
			
			НомерСимвола = КоличествоСимволовДляПереносаКомментария + 1 - НомерСимволаСКонца + 1;
			
			Символ = Сред(СтрокаМодуля, НомерСимвола, 1);
			Если Символ <> " " Тогда
				Продолжить;
			КонецЕсли;
			
			// Проверяем следующий символ, если это тире или равно, то ищем дальше.
			СледующийСимвол = Сред(СтрокаМодуля, НомерСимвола + 1, 1);
			Если (СледующийСимвол = "-") ИЛИ (СледующийСимвол = "=") Тогда
				Продолжить;
			КонецЕсли;
			
			НомерСимволаДляПереноса = НомерСимвола;
			Прервать;
			
		КонецЦикла;
		
		ТекущаяСтрока = СокрП(Лев(СтрокаМодуля, НомерСимволаДляПереноса - 1));
		ПереносимаяСтрока = СокрЛ(Сред(СтрокаМодуля, НомерСимволаДляПереноса + 1));
		
		// Если не получается перенести строку по 120 символов,
		// т.е. в оставшейся строке (без переносимой) нет значимых символов, то пропускаем.
		Если ПустаяСтрока(СтрЗаменить(ТекущаяСтрока, "/", "")) Тогда
			Продолжить;
		КонецЕсли;
		
		// Если в текущей строке нет определения параметра, то следующую строку сдвигаем с тем же отступом.
		Если НЕ КомментарийСодержитОписаниеПараметра(КомментарийБезЗнаковКомментария) Тогда
			
			НовыйОтступ = ОтступДоЗнакаКомментария + "//" + ОтступПослеЗнакаКомментария;
			НоваяСтрока = НовыйОтступ + ПереносимаяСтрока;
			
			ДокументТекст.ЗаменитьСтроку(НомерСтроки, ТекущаяСтрока);
			ДокументТекст.ВставитьСтроку(НомерСтроки + 1, НоваяСтрока);
			
			ОбъединитьКомментарииСтрок(ДокументТекст, НомерСтроки + 1);
			
			ФайлИзменен = Истина;
			
			Продолжить;
			
		КонецЕсли;
		
		// Если в текущей строке есть описание параметра, проверим отступ в следующей строке.
		СледующаяСтрока = ДокументТекст.ПолучитьСтроку(НомерСтроки + 1);
		
		// Если в следующей строке нет табов, то проверяем ее отступ.
		Если СтрНайти(СледующаяСтрока, Символы.Таб) = 0 Тогда
			
			ОтступКомментарияСледующейСтроки = ПолучитьОтступПослеЗнакаКомментария(СледующаяСтрока);
			ДлинаОтступаКомментарияСледующейСтроки = СтрДлина(ОтступКомментарияСледующейСтроки);
			
			// Если в следующей строке после определения параметра есть большой отступ,
			Если ДлинаОтступаКомментарияСледующейСтроки > ДлинаОтступаПослеЗнакаКомментария Тогда
				// тогда сдвигаем новую строку на этот отступ.
				НовыйОтступ = ОтступДоЗнакаКомментария + "//" + ОтступКомментарияСледующейСтроки;
				НоваяСтрока = НовыйОтступ + ПереносимаяСтрока;
				
				ДокументТекст.ЗаменитьСтроку(НомерСтроки, ТекущаяСтрока);
				ДокументТекст.ВставитьСтроку(НомерСтроки + 1, НоваяСтрока);
				
				ОбъединитьКомментарииСтрок(ДокументТекст, НомерСтроки + 1);
				
				ФайлИзменен = Истина;
				
				Продолжить;
				
			КонецЕсли;
			
		КонецЕсли;
		
		// Если в следующей строке отступ такой же или меньше, то определяем новый отступ.
		// Для этого определяем, сколько тире в текущей строке, которая уже меньше 120 символов.
		КоличествоТире = СтрЧислоВхождений(ТекущаяСтрока, " - ");
		Если КоличествоТире = 0 Тогда
			// Если тире нет, то переносим с таким отступом + 4 пробела.
			НовыйОтступ = ОтступДоЗнакаКомментария + "//" + ОтступПослеЗнакаКомментария + "    ";
			НоваяСтрока = НовыйОтступ + ПереносимаяСтрока;
			
			ДокументТекст.ЗаменитьСтроку(НомерСтроки, ТекущаяСтрока);
			ДокументТекст.ВставитьСтроку(НомерСтроки + 1, НоваяСтрока);
			
			ОбъединитьКомментарииСтрок(ДокументТекст, НомерСтроки + 1);
			
			ФайлИзменен = Истина;
			
			Продолжить;
			
		КонецЕсли;
		
		// Тире есть, определяем позицию тире:
		// если тире одно, то его позицию; если их больше, то позицию второго тире.
		Если КоличествоТире = 1 Тогда
			ПозицияТире = СтрНайти(ТекущаяСтрока, " - ");
		Иначе
			ПозицияТире = СтрНайти(ТекущаяСтрока, " - ");
			ТекущаяСтрокаВтороеТире = Сред(ТекущаяСтрока, ПозицияТире + 3);
			
			СтрокаДоТире = Лев(ТекущаяСтрока, ПозицияТире);
			СтрокаДоТире = СтрЗаменить(СтрокаДоТире, "/", "");
			
			ПозицияТире = ПозицияТире + СтрНайти(ТекущаяСтрокаВтороеТире, " - ") + 2;
			
			// Иногда описание параметра начинается с тире, тогда надо определять позицию 3-го тире.
			Если (КоличествоТире >= 3) И (ПустаяСтрока(СтрокаДоТире)) Тогда
				ТекущаяСтрокаТретьеТире = Сред(ТекущаяСтрока, ПозицияТире + 3);
				ПозицияТире = ПозицияТире + СтрНайти(ТекущаяСтрокаТретьеТире, " - ") + 2;
			КонецЕсли;
		КонецЕсли;
		
		// Определяем номер значимого символа после тире.
		ДлинаСтроки = СтрДлина(ТекущаяСтрока);
		Для НомерСимвола = ПозицияТире + 3 По ДлинаСтроки Цикл
			Символ = Сред(ТекущаяСтрока, НомерСимвола, 1);
			Если Символ <> " " Тогда
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		// Подготовим новый отступ - заменим все символы, кроме "/" на пробелы.
		НовыйОтступ = "";
		СимволыБезЗамены = " /" + Символы.Таб;
		Для Счетчик = 1 По НомерСимвола - 1 Цикл
			Символ = Сред(ТекущаяСтрока, Счетчик, 1);
			Если СтрНайти(СимволыБезЗамены, Символ) > 0 Тогда
				НовыйОтступ = НовыйОтступ + Символ;
			Иначе
				НовыйОтступ = НовыйОтступ + " ";
			КонецЕсли;
		КонецЦикла;
		
		// Если переносимый текст полностью укладывается в 120 символов (без еще одного переноса), то переносим по тире.
		Если СтрДлина(НовыйОтступ) + СтрДлина(ПереносимаяСтрока) <= КоличествоСимволовДляПереносаКомментария Тогда
			НоваяСтрока = НовыйОтступ + ПереносимаяСтрока;
		Иначе
			// Если не укладывается, то новый отступ = текущему + 4 пробела слева.
			НовыйОтступ = ОтступДоЗнакаКомментария + "//" + ОтступПослеЗнакаКомментария + "    ";
			НоваяСтрока = НовыйОтступ + ПереносимаяСтрока;
		КонецЕсли;
		
		ДокументТекст.ЗаменитьСтроку(НомерСтроки, ТекущаяСтрока);
		ДокументТекст.ВставитьСтроку(НомерСтроки + 1, НоваяСтрока);
		
		ОбъединитьКомментарииСтрок(ДокументТекст, НомерСтроки + 1);
		
		ФайлИзменен = Истина;
		
	КонецЦикла;
	
	Возврат ФайлИзменен;
	
КонецФункции

Процедура ЗаписатьИзмененияВФайл(ДокументТекст, ПолноеИмяФайла)
	
	СтрокаРезультата = Результат.Найти(ПолноеИмяФайла, "ПолноеИмяФайла");
	Если СтрокаРезультата <> Неопределено Тогда
		СтрокаРезультата.Изменен = Истина;
	КонецЕсли;
	
	ТекстДляЗаписи = ДокументТекст.ПолучитьТекст();
	// Пустые файлы не перезаписываем.
	Если ПустаяСтрока(ТекстДляЗаписи) Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыЗаписи = ПараметрыЗаписиДокументаDOM(ПолноеИмяФайла);
	ЗаписатьТекстовыйФайл(ПолноеИмяФайла, ТекстДляЗаписи, ПараметрыЗаписи);
	
КонецПроцедуры

// Процедура вызывается в том случае, когда невозможно исправить ошибку
// Параметры:
//  Объект      - Строка - обрабатываемый модуль
//  Описание    - Строка - описание ошибки
//  НомерСтроки - Число  - номер строки с ошибкой
//
Процедура ОбработатьИсключение(ПолноеИмяФайла, Описание, НомерСтроки)
	
	СтрокаРезультата = Результат.Найти(ПолноеИмяФайла, "ПолноеИмяФайла");
	Если СтрокаРезультата = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаРезультата.ВозниклоИсключение = Истина;
	СтрокаРезультата.СчетчикПропущенных = СтрокаРезультата.СчетчикПропущенных + 1;
	СтрокаРезультата.Пропущено = НСтр("ru='Пропущено мест:'; en='Пропущено мест:'", КодОсновногоЯзыка) + " " + СтрокаРезультата.СчетчикПропущенных;
	
	Если СтрокаРезультата.СчетчикПропущенных > 1 Тогда
		СтрокаРезультата.УточнениеИсключения = СтрокаРезультата.УточнениеИсключения + Символы.ПС;
	КонецЕсли;
	
	СтрокаРезультата.УточнениеИсключения = СтрокаРезультата.УточнениеИсключения
		+ Строка(СтрокаРезультата.СчетчикПропущенных) + ". Строка " + Строка(НомерСтроки) + " - " + Описание;
	
КонецПроцедуры

Функция ПолучитьТипМодуляПоИмениФайла(ПолноеИмяФайла)
	
	ПолноеИмяФайлаВРег = ВРег(ПолноеИмяФайла);
	Если НЕ СтрЗаканчиваетсяНа(ПолноеИмяФайлаВРег, ВРег("Module.bsl")) Тогда
		Возврат "";
	КонецЕсли;
	
	КаталогВыгрузкиИсточник = КаталогВыгрузкиРезультат;
	Если НЕ ЭтоВыгрузкаXMLФайлов Тогда
		// Если это выгрузка EDT, тогда добавим каталог "src" в каталог выгрузки.
		КаталогВыгрузкиИсточник = КаталогВыгрузкиИсточник + "src" + РазделительПути;
	КонецЕсли;
	
	// Получим окончание пути файла.
	ПутьФайла = СтрЗаменить(ПолноеИмяФайлаВРег, ВРег(КаталогВыгрузкиИсточник), "");
	ПутьФайла = СокрЛП(ПутьФайла);
	
	Если СтрНачинаетсяС(ПутьФайла, ВРег("CommonModules") + РазделительПути) Тогда
		ТипМодуля = "ОбщийМодуль";
	ИначеЕсли СтрЗаканчиваетсяНа(ПутьФайла, РазделительПути + ВРег("ObjectModule.bsl")) Тогда
		ТипМодуля = "МодульОбъекта";
	ИначеЕсли СтрЗаканчиваетсяНа(ПутьФайла, РазделительПути + ВРег("RecordSetModule.bsl")) Тогда
		ТипМодуля = "МодульНабораЗаписей";
	ИначеЕсли СтрЗаканчиваетсяНа(ПутьФайла, РазделительПути + ВРег("ManagerModule.bsl")) Тогда
		ТипМодуля = "МодульМенеджера";
	ИначеЕсли СтрНачинаетсяС(ПутьФайла, ВРег("CommonForms") + РазделительПути) Тогда
		// Модуль общей формы.
		ТипМодуля = "МодульФормы";
	ИначеЕсли СтрЗаканчиваетсяНа(ПутьФайла, ВРег(СтрШаблон("%1Ext%1Form%1Module.bsl", РазделительПути))) Тогда
		// Модуль формы для выгрузки XML.
		ТипМодуля = "МодульФормы";
	ИначеЕсли СтрНайти(ПутьФайла, ВРег(СтрШаблон("%1Forms%1", РазделительПути))) > 0 Тогда
		// Модуль формы для проекта EDT.
		ТипМодуля = "МодульФормы";
	Иначе
		ТипМодуля = "";
	КонецЕсли;
	
	Возврат ТипМодуля;
	
КонецФункции

Функция ЗаменитьОбластиВВидеКомментариев(ДокументТекст, ПолноеИмяФайла, ТаблицаСтандартныхОбластей)
	
	МодульИзменен = Ложь;
	
	ШаблонОбластей82 = "////////////////////////////////////////////////////////////////////////////////";
	
	ТекстМодуля = ДокументТекст.ПолучитьТекст();
	Если СтрНайти(ТекстМодуля, ШаблонОбластей82) = 0 Тогда
		Возврат МодульИзменен;
	КонецЕсли;
	
	// Создаем копию текста модуля на случай, если будет необходимо отказаться от изменений в текстовом документе.
	ТекстМодуляИсходный = ТекстМодуля;
	
	// Удаляем пустые строки в конце текстового документа.
	ПоследняяСтрока = "";
	Пока ПустаяСтрока(ПоследняяСтрока) Цикл
		НомерПоследнейСтроки = ДокументТекст.КоличествоСтрок();
		ПоследняяСтрока = ДокументТекст.ПолучитьСтроку(НомерПоследнейСтроки);
		Если НЕ ПустаяСтрока(ПоследняяСтрока) Тогда
			Прервать;
		КонецЕсли;
		ДокументТекст.УдалитьСтроку(НомерПоследнейСтроки);
	КонецЦикла;
	
	ТекстОшибкиЗаменыОбластей = НСтр("ru='Невозможно заменить области формата 8.2 (комментарии) на формат 8.3 (#Область ...)';
		|en='Невозможно заменить области формата 8.2 (комментарии) на формат 8.3 (#Область ...)'", КодОсновногоЯзыка);
	
	ТекстОбласть = НСтр("ru='#Область '; en='#Region '", КодОсновногоЯзыка);
	ТекстОбластьВРег = ВРег(ТекстОбласть);
	
	МассивТекстНачалоМетода = Контекст.Получить("МассивТекстПроцедураФункция");
	МассивТекстКонецМетода  = Контекст.Получить("МассивТекстКонецПроцедурыФункции");
	МассивТекстЕсли         = Контекст.Получить("МассивТекстЕсли");
	МассивТекстКонецЕсли    = Контекст.Получить("МассивТекстКонецЕсли");
	МассивТекстКонецОбласти = Контекст.Получить("МассивТекстКонецОбласти");
	
	// Не обрабатываем строки, содержащие "Copyright (c)", например:
	///////////////////////////////////////////////////////////////////////////////////////////////////////
	// Copyright (c) 2024, ООО 1С-Софт
	МассивИсключенийОбластей = Новый Массив;
	МассивИсключенийОбластей.Добавить(ВРег("Copyright (c)"));
	
	ОткрытаОбластьВерхнегоУровня   = Ложь;
	ОткрытаОбластьВложенногоУровня = Ложь;
	ОткрытаОбласть                 = Ложь;
	ОткрытМетод                    = Ложь;
	ОткрытаИнструкция              = Ложь;
	ОбластьВнутриИнструкции        = Ложь;
	ЭтоОбласть82ВерхнегоУровня     = Ложь;
	
	ИмяОбласти83 = "";
	
	НомерСтрокиОбласти83             = 0;
	КоличествоОткрытыхОбластей       = 0;
	КоличествоЗакрытыхОбластей       = 0;
	НомерСтрокиНеобработаннойОбласти = 0;
	
	// Построчно обходим текстовый документ, начиная с первой строки.
	НомерСтроки = 0;
	Пока НомерСтроки <= ДокументТекст.КоличествоСтрок() Цикл
		
		НомерСтроки = НомерСтроки + 1;
		
		СтрокаМодуля = ДокументТекст.ПолучитьСтроку(НомерСтроки);
		Если ПустаяСтрока(СтрокаМодуля) Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаМодуля = ВРег(СтрокаМодуля);
		
		СтрокаМодуля = СокрЛП(СтрокаМодуля);
		Если СтрНачинаетсяСПоМассиву(СтрокаМодуля, МассивТекстНачалоМетода).Успешно Тогда
			// Начало процедуры(функции).
			ОткрытМетод = Истина;
		КонецЕсли;
		
		Если СтрНачинаетсяСПоМассиву(СтрокаМодуля, МассивТекстКонецМетода).Успешно Тогда
			// Конец процедуры(функции).
			ОткрытМетод = Ложь;
		КонецЕсли;
		
		Если ОткрытМетод Тогда
			// Области внутри процедур(функций) не обрабатываем.
			Продолжить;
		КонецЕсли;
		
		Если СтрНачинаетсяСПоМассиву(СтрокаМодуля, МассивТекстЕсли).Успешно Тогда
			// Начало инструкции препроцессора - оставляем строку в исходном виде.
			ОткрытаИнструкция = Истина;
			Продолжить;
		КонецЕсли;
		
		Если СтрНайтиПоМассиву(СтрокаМодуля, МассивТекстКонецЕсли).Успешно Тогда
			// Конец инструкции препроцессора.
			ОткрытаИнструкция = Ложь;
			
			// Сравниваем количество открытых и закрытых областей.
			Если КоличествоОткрытыхОбластей > КоличествоЗакрытыхОбластей Тогда
				
				// Проверяем наличие области ниже.
				НижеЕстьОбласть = Ложь;
				Для НомерКонтрольнойСтроки = НомерСтроки По ДокументТекст.КоличествоСтрок() Цикл
					ПроверяемаяСтрока = ДокументТекст.ПолучитьСтроку(НомерКонтрольнойСтроки);
					Если СтрНайти(ПроверяемаяСтрока, ШаблонОбластей82) > 0 Тогда
						НижеЕстьОбласть = Истина;
						Прервать;
					КонецЕсли;
				КонецЦикла;
				
				// Ниже есть область, закрываем все незакрытые области, расположенные выше.
				Если НижеЕстьОбласть Тогда
					ЗакрытьОткрытыеОбласти(ДокументТекст, НомерСтроки + 1, КоличествоОткрытыхОбластей, КоличествоЗакрытыхОбластей + 1);
				КонецЕсли;
				
			КонецЕсли;
			
			Продолжить;
			
		КонецЕсли;
		
		// Нашли текст "#Область ".
		Если СтрНачинаетсяС(СтрокаМодуля, ТекстОбластьВРег) Тогда
			// Запоминаем имя области.
			ПозицияТекстОбласть = СтрНайти(СтрокаМодуля, ТекстОбластьВРег);
			ИмяОбласти83 = Сред(СтрокаМодуля, ПозицияТекстОбласть + СтрДлина(ТекстОбластьВРег) );
			НомерСтрокиОбласти83 = НомерСтроки;
			// Закрываем все ранее открытые области.
			Если КоличествоОткрытыхОбластей > КоличествоЗакрытыхОбластей Тогда
				НомерСтрокиЗакрытияОбласти = ?(НомерСтрокиНеобработаннойОбласти > 0, НомерСтрокиНеобработаннойОбласти, НомерСтроки);
				ЗакрытьОткрытыеОбласти(ДокументТекст, НомерСтрокиЗакрытияОбласти, КоличествоОткрытыхОбластей, КоличествоЗакрытыхОбластей);
				ОткрытаОбласть = Ложь;
			КонецЕсли;
			Продолжить;
		КонецЕсли;
		
		// Нашли "#КонецОбласти".
		Если СтрНачинаетсяСПоМассиву(СтрокаМодуля, МассивТекстКонецОбласти).Успешно Тогда
			// Очищаем значение переменной.
			ИмяОбласти83 = "";
			// Закрываем все ранее открытые области
			НомерСтрокиОбласти83 = 0;
			// Закрываем все ранее открытые области.
			Если КоличествоОткрытыхОбластей > КоличествоЗакрытыхОбластей
				И НЕ ЭтоОбласть82ВерхнегоУровня Тогда
				ЗакрытьОткрытыеОбласти(ДокументТекст, НомерСтроки, КоличествоОткрытыхОбластей, КоличествоЗакрытыхОбластей);
				ОткрытаОбласть = Ложь;
			КонецЕсли;
			Продолжить;
		КонецЕсли;
		
		Если НЕ СтрНачинаетсяС(СтрокаМодуля, ШаблонОбластей82) Тогда
			Продолжить;
		КонецЕсли;
		
		СледующаяСтрокаМодуля = ДокументТекст.ПолучитьСтроку(НомерСтроки + 1);
		Если ПустаяСтрока(СледующаяСтрокаМодуля) Тогда
			ОткрытаОбласть = ОткрытаОбластьВерхнегоУровня ИЛИ ОткрытаОбластьВложенногоУровня;
			Продолжить;
		КонецЕсли;
		
		Если СтрНачинаетсяС(СокрЛ(ВРег(СледующаяСтрокаМодуля)), ТекстОбластьВРег) Тогда
			// Ниже открывается область, переходим к следующей строке.
			Продолжить;
		КонецЕсли;
		
		СледующаяСтрокаМодуля = СтрЗаменить(СледующаяСтрокаМодуля, "//", "");
		СледующаяСтрокаМодуля = СокрЛП(СледующаяСтрокаМодуля);
		
		Если СтрНачинаетсяСПоМассиву(ВРег(СледующаяСтрокаМодуля), МассивИсключенийОбластей).Успешно Тогда
			ОткрытаОбласть = ОткрытаОбластьВерхнегоУровня ИЛИ ОткрытаОбластьВложенногоУровня;
			Продолжить;
		КонецЕсли;
		
		// Проверяем третью строку.
		// Считаем, что области, оформленные в несколько строк, - это комментарии.
		// Такие случаи не обрабатываем.
		Если ЭтоМногострочныйКомментарий(ДокументТекст, НомерСтроки, ШаблонОбластей82) Тогда
			Продолжить;
		КонецЕсли;
		
		СтруктураОбласти = ПолучитьСтруктуруОбласти83ИзОбласти82(СледующаяСтрокаМодуля, ТаблицаСтандартныхОбластей);
		
		ИмяОбласти = СтруктураОбласти.Наименование;
		Если ПустаяСтрока(ИмяОбласти) Тогда
			Продолжить;
		КонецЕсли;
		
		Если ВРег(ИмяОбласти) = ИмяОбласти83 Тогда
			// Проверяем, что выше нет открытых областей, оформленных по стандарту 8.3
			// и имеющих такое же имя.
			// Если область с таким именем уже открыта,
			// то удаляем область, оформленную в виде комментария.
			УдалитьОбласть82(ДокументТекст, НомерСтроки, КоличествоОткрытыхОбластей);
			Продолжить;
		КонецЕсли;
		
		ЭтоОбласть82ВерхнегоУровня = СтруктураОбласти.ВерхнегоУровня;
		
		ЭтоПустаяОбласть = ЭтоПустаяОбласть(ДокументТекст, НомерСтроки, ТекстОбласть, ШаблонОбластей82, ЭтоОбласть82ВерхнегоУровня);
		Если ЭтоПустаяОбласть Тогда
			НомерСтрокиНеобработаннойОбласти = НомерСтроки;
			Если КоличествоОткрытыхОбластей > КоличествоЗакрытыхОбластей Тогда
				ЗакрытьОбласть(ДокументТекст, НомерСтроки);
				ОткрытаОбластьВложенногоУровня = Ложь;
				КоличествоЗакрытыхОбластей = КоличествоЗакрытыхОбластей + 1;
			КонецЕсли;
			Продолжить;
		КонецЕсли;
		
		// Проверяем наличие кода перед найденной областью.
		// Если перед областью есть код, то такую область можно преобразовать, независимо от количества вложенных областей.
		ПередОбластью82ЕстьКод = Ложь;
		Если НомерСтрокиОбласти83 > 0 Тогда
			ПередОбластью82ЕстьКод = ПередОбластью82ЕстьКод(ДокументТекст, НомерСтроки,
				НомерСтрокиОбласти83, МассивТекстКонецОбласти, МассивТекстКонецМетода, ТекстОбласть);
		КонецЕсли;
		
		ОбластьМожетБытьПреобразована = ПередОбластью82ЕстьКод;
		Если НЕ ПередОбластью82ЕстьКод Тогда
			// Перед областью нет кода.
			// Для области 8.2 верхнего уровня считаем количество вложенных областей.
			// Если вложенных областей больше одной, то такую область можно преобразовать.
			ОбластьМожетБытьПреобразована = ОбластьМожетБытьПреобразована(ДокументТекст,
				ШаблонОбластей82, НомерСтроки, ТекстОбластьВРег, МассивТекстКонецОбласти, ЭтоОбласть82ВерхнегоУровня, НомерСтрокиОбласти83);
		КонецЕсли;
		
		Если НЕ ОбластьМожетБытьПреобразована Тогда
			НомерСтрокиНеобработаннойОбласти = НомерСтроки;
			Продолжить;
		КонецЕсли;
		
		// Закрываем область, расположенную выше.
		// Можно закрыть область:
		// - после открытия которой не была открыта инструкция препроцессора;
		// - открытую внутри инструкции препроцессора.
		Если ЭтоОбласть82ВерхнегоУровня Тогда
			Если (ОткрытаОбластьВерхнегоУровня И НЕ ОткрытаИнструкция) ИЛИ ОбластьВнутриИнструкции Тогда
				ЗакрытьОбласть(ДокументТекст, НомерСтроки);
				ОткрытаОбластьВерхнегоУровня = Ложь;
				КоличествоЗакрытыхОбластей = КоличествоЗакрытыхОбластей + 1;
			КонецЕсли;
			// Закрываем все ранее открытые области, т.к. область верхнего уровня не может быть вложенной.
			Если КоличествоОткрытыхОбластей > КоличествоЗакрытыхОбластей Тогда
				ЗакрытьОткрытыеОбласти(ДокументТекст, НомерСтроки, КоличествоОткрытыхОбластей, КоличествоЗакрытыхОбластей);
			КонецЕсли;
		ИначеЕсли ((ОткрытаОбластьВложенногоУровня И НЕ ОткрытаИнструкция) И ОткрытаОбласть) ИЛИ ОбластьВнутриИнструкции Тогда
			// Закрываем ранее открытую область.
			// Если выше открыта область по стандарту 8.3, то такую область не закрываем,
			// т.к. по умолчанию считаем, что эта область уже закрыта ниже.
			Если КоличествоОткрытыхОбластей > КоличествоЗакрытыхОбластей Тогда
				ЗакрытьОбласть(ДокументТекст, НомерСтроки);
				ОткрытаОбластьВложенногоУровня = Ложь;
				КоличествоЗакрытыхОбластей = КоличествоЗакрытыхОбластей + 1;
			КонецЕсли;
		КонецЕсли;
		
		// Область открыта.
		КоличествоОткрытыхОбластей = КоличествоОткрытыхОбластей + 1;
		
		ПредыдущаяСтрока = ДокументТекст.ПолучитьСтроку(НомерСтроки - 1);
		Если ПустаяСтрока(ПредыдущаяСтрока) Тогда
			ДокументТекст.УдалитьСтроку(НомерСтроки);
		Иначе
			ДокументТекст.ЗаменитьСтроку(НомерСтроки, "");
			НомерСтроки = НомерСтроки + 1;
		КонецЕсли;
		
		ДокументТекст.ЗаменитьСтроку(НомерСтроки, ТекстОбласть + ИмяОбласти);
		
		// Удаляем лишние пустые строки после объявления области.
		УдалитьНезначащиеСтрокиПослеОпределенияОбласти(ДокументТекст, НомерСтроки);
		
		ОткрытаОбластьВерхнегоУровня     = ОткрытаОбластьВерхнегоУровня ИЛИ СтруктураОбласти.ВерхнегоУровня;
		ОткрытаОбластьВложенногоУровня   = НЕ СтруктураОбласти.ВерхнегоУровня;
		ОткрытаОбласть                   = Истина;
		ОбластьВнутриИнструкции          = ОткрытаОбласть И ОткрытаИнструкция;
		НомерСтрокиНеобработаннойОбласти = 0;
		НомерСтрокиОбласти83             = НомерСтроки;
		
		МодульИзменен = Истина;
		
	КонецЦикла;
	
	Если НЕ МодульИзменен Тогда
		ДокументТекст.УстановитьТекст(ТекстМодуляИсходный);
		Возврат МодульИзменен;
	КонецЕсли;
	
	// Получаем номер строки для вставки "#КонецОбласти" в конце текстового документа.
	НомерСтрокиДляЗакрытияОбласти = НомерСтрокиДляЗакрытияОбласти(ДокументТекст, МассивТекстНачалоМетода,
		МассивТекстКонецМетода, МассивТекстЕсли, МассивТекстКонецЕсли, НомерСтроки, ТекстОбластьВРег);
	
	// Закрываем все незакрытые области, добавляя необходимое количество "#КонецОбласти" в конце текстового документа.
	Если КоличествоОткрытыхОбластей > КоличествоЗакрытыхОбластей Тогда
		ЗакрытьОткрытыеОбласти(ДокументТекст, НомерСтрокиДляЗакрытияОбласти + 1, КоличествоОткрытыхОбластей, КоличествоЗакрытыхОбластей, Ложь);
	КонецЕсли;
	
	Если МодульИзменен Тогда
		// Проверяем наличие ошибок при замене областей.
		СтруктураРезультатаЗаменыОбластей = ПроверитьЗаменуОбластей82На83(ДокументТекст);
		Если НЕ СтруктураРезультатаЗаменыОбластей.ОбластиЗамененыКорректно Тогда
			// Если выявлены ошибки, файл не перезаписываем.
			ТекстОшибки = ТекстОшибкиЗаменыОбластей + СтруктураРезультатаЗаменыОбластей.ТекстОшибки;
			ОбработатьИсключение(ПолноеИмяФайла, ТекстОшибки, СтруктураРезультатаЗаменыОбластей.НомерСтрокиОшибки);
			МодульИзменен = Ложь;
		КонецЕсли;
	КонецЕсли;
	
	Если МодульИзменен Тогда
		СокрТекстДокумента(ДокументТекст, Ложь);
	Иначе
		// Модуль не изменен, возвращаем текстовый документ в исходное состояние.
		ДокументТекст.УстановитьТекст(ТекстМодуляИсходный);
	КонецЕсли;
	
	Возврат МодульИзменен;
	
КонецФункции

Функция ЭтоПустаяОбласть(ДокументТекст, НомерСтроки, ТекстОбласть, ШаблонОбластей82, ЭтоОбласть82ВерхнегоУровня)
	
	ЭтоПустаяОбласть = Истина;
	
	Для НомерСтрокиМодуля = НомерСтроки + 2 По ДокументТекст.КоличествоСтрок() Цикл
		
		СтрокаМодуля = ДокументТекст.ПолучитьСтроку(НомерСтрокиМодуля);
		Если ПустаяСтрока(СтрокаМодуля) Тогда
			Продолжить;
		КонецЕсли;
		
		Если СтрНачинаетсяС(СтрокаМодуля, ТекстОбласть) Тогда
			Прервать;
		КонецЕсли;
		
		Если СтрНачинаетсяС(СтрокаМодуля, ШаблонОбластей82) Тогда
			
			Если ЭтоМногострочныйКомментарий(ДокументТекст, НомерСтрокиМодуля, ШаблонОбластей82) Тогда
				Продолжить;
			КонецЕсли;
			
			Если НЕ ЭтоОбласть82ВерхнегоУровня Тогда
				Прервать;
			КонецЕсли;
			
			СледующаяСтрока = ДокументТекст.ПолучитьСтроку(НомерСтрокиМодуля + 1);
			Если СледующаяСтрока = ВРег(СледующаяСтрока) Тогда
				Прервать;
			КонецЕсли;
			
		КонецЕсли;
		
		Если СтрНачинаетсяС(СтрокаМодуля, "//") Тогда
			Продолжить;
		КонецЕсли;
		
		ЭтоПустаяОбласть = Ложь;
		Прервать;
		
	КонецЦикла;
	
	Возврат ЭтоПустаяОбласть;
	
КонецФункции

Процедура УдалитьНезначащиеСтрокиПослеОпределенияОбласти(ДокументТекст, НомерСтроки)
	
	// После объявления области удаляем лишние пустые строки, а также строки, которые содержат только слеши.
	НомерСледующейСтроки = НомерСтроки;
	Пока Истина Цикл
		
		НомерСледующейСтроки = НомерСледующейСтроки + 1;
		СледующаяСтрокаМодуля = ДокументТекст.ПолучитьСтроку(НомерСледующейСтроки);
		СледующаяСтрокаМодуля = СтрЗаменить(СледующаяСтрокаМодуля, "//", "");
		
		Если НЕ ПустаяСтрока(СледующаяСтрокаМодуля) Тогда
			Прервать;
		КонецЕсли;
		
		НомерСтрокиПослеСледующейСтроки = НомерСледующейСтроки + 1;
		СтрокаМодуляПослеСледующейСтроки = ДокументТекст.ПолучитьСтроку(НомерСтрокиПослеСледующейСтроки);
		
		Если НЕ ПустаяСтрока(СтрокаМодуляПослеСледующейСтроки) Тогда
			ДокументТекст.ЗаменитьСтроку(НомерСледующейСтроки, СледующаяСтрокаМодуля);
			Прервать;
		КонецЕсли;
		
		ДокументТекст.УдалитьСтроку(НомерСледующейСтроки);
		
	КонецЦикла;
	
КонецПроцедуры

Функция ЭтоМногострочныйКомментарий(ДокументТекст, НомерСтроки, ШаблонОбластей82)
	
	НомерСледующейСтроки = НомерСтроки + 1;
	СледующаяСтрока = ДокументТекст.ПолучитьСтроку(НомерСледующейСтроки + 1);
	
	Если СтрНачинаетсяС(СледующаяСтрока, "//") Тогда
		
		Если СтрНачинаетсяС(СледующаяСтрока, ШаблонОбластей82) Тогда
			Возврат Истина;
		КонецЕсли;
		
		СледующаяСтрока = СтрЗаменить(СледующаяСтрока, "//", "");
		
		Если НЕ ПустаяСтрока(СледующаяСтрока) Тогда
			Возврат Истина;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

Процедура УдалитьОбласть82(ДокументТекст, НомерСтроки, КоличествоОткрытыхОбластей)
	
	Если КоличествоОткрытыхОбластей > 0 Тогда
		КоличествоОткрытыхОбластей = КоличествоОткрытыхОбластей - 1;
	КонецЕсли;
	
	ДокументТекст.УдалитьСтроку(НомерСтроки);// Удаляем слеши.
	ДокументТекст.УдалитьСтроку(НомерСтроки);// Удаляем имя области.
	
	// Если в текущей области 8.3 уже была преобразована область, оформленная в виде комментария,
	// то эту область необходимо закрыть, иначе она может поглотить процедуры (функции),
	// не относящиеся к ней.
	Если КоличествоОткрытыхОбластей > 0 Тогда
		ЗакрытьОбласть(ДокументТекст, НомерСтроки);
		КоличествоОткрытыхОбластей = КоличествоОткрытыхОбластей - 1;
	КонецЕсли;
	
	// Определяем номер строки для удаления пустых строк ниже.
	НомерПроверяемойСтроки = НомерСтроки + 1;
	Пока Истина Цикл
		
		ПроверяемаяСтрока = ДокументТекст.ПолучитьСтроку(НомерПроверяемойСтроки);
		Если НЕ ПустаяСтрока(СокрЛП(ПроверяемаяСтрока)) Тогда
			Прервать;
		КонецЕсли;
		
		ДокументТекст.УдалитьСтроку(НомерПроверяемойСтроки);
		НомерПроверяемойСтроки = НомерПроверяемойСтроки + 1;
		
	КонецЦикла;
	
КонецПроцедуры

Функция ПередОбластью82ЕстьКод(ДокументТекст, НомерСтроки, НомерСтрокиОбласти83,
		МассивТекстКонецОбласти, МассивТекстКонецПроцедурыФункции, ТекстОбласть)
	
	ПередОбластьюЕстьКод = Ложь;
	НомерПроверяемойСтроки = НомерСтроки;
	
	Пока НомерПроверяемойСтроки > 0 Цикл
		
		НомерПроверяемойСтроки = НомерПроверяемойСтроки - 1;
		
		// Если выше области 8.2 открыта область 8.3, то проверяем только до начала области 8.3.
		Если НомерПроверяемойСтроки = НомерСтрокиОбласти83 Тогда
			Возврат ПередОбластьюЕстьКод;
		КонецЕсли;
		
		ПроверяемаяСтрока = ДокументТекст.ПолучитьСтроку(НомерПроверяемойСтроки);
		Если ПустаяСтрока(ПроверяемаяСтрока) Тогда
			Продолжить;
		КонецЕсли;
		
		Если СтрНачинаетсяС(ПроверяемаяСтрока, ТекстОбласть) Тогда
			Прервать;
		КонецЕсли;
		
		ПроверяемаяСтрока = ВРег(ПроверяемаяСтрока);
		
		// Нашли закрытие области 8.3, дальше не проверяем.
		Если СтрНачинаетсяСПоМассиву(ПроверяемаяСтрока, МассивТекстКонецОбласти).Успешно Тогда
			Прервать;
		КонецЕсли;
		
		ПередОбластьюЕстьКод = НЕ СтрНачинаетсяС(ПроверяемаяСтрока, "//");
		
		Если ПередОбластьюЕстьКод Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ПередОбластьюЕстьКод;
	
КонецФункции

Функция ОбластьМожетБытьПреобразована(ДокументТекст, ШаблонОбластей82, НомерСтроки,
	ТекстОбластьВРег, МассивТекстКонецОбласти, ЭтоОбласть82ВерхнегоУровня, НомерСтрокиОбласти83)
	
	// Проверяем количество вложенных областей.
	КоличествоВложенныхОбластей = 0;
	ОткрытыхОбластей83          = 0;
	ЗакрытыхОбластей83          = 0;
	Область82СодержитКод        = Ложь;
	ПроверятьНаличиеКода        = Истина;
	
	// Определяем номер строки, начиная с которой будем проверять возможность преобразования проверяемой области.
	// Если выше открыта область 8.3, то проверять будем, начиная с нее.
	НомерПроверяемойСтроки = ?(НомерСтрокиОбласти83 > 0, НомерСтрокиОбласти83, НомерСтроки);
	
	Пока НомерПроверяемойСтроки <= ДокументТекст.КоличествоСтрок() Цикл
		
		НомерПроверяемойСтроки = НомерПроверяемойСтроки + 1;
		
		ПроверяемаяСтрока = ДокументТекст.ПолучитьСтроку(НомерПроверяемойСтроки);
		Если ПустаяСтрока(ПроверяемаяСтрока) Тогда
			Продолжить;
		КонецЕсли;
		
		ПроверяемаяСтрока = ВРег(ПроверяемаяСтрока);
		
		// Для областей 8.2 верхнего уровня или вложенных в область 8.3 проверяем:
		// 1. наличие кода после открытия области - если после открытия области есть код,
		// то проверяемую область можно преобразовать;
		// 2. если кода нет, то считаем количество вложенных областей - проверяемую область можно
		// преобразовать, если найдено больше одной вложенной области.
		Если ЭтоОбласть82ВерхнегоУровня ИЛИ НомерСтрокиОбласти83 > 0 Тогда
			
			// Вложенных областей на данной итерации не найдено, проверяем наличие кода.
			// Кодом считаем любую не пустую строку, которая начинается не с "//".
			// Например, это может быть инициализация переменной "Перем".
			Если КоличествоВложенныхОбластей = 0 И ПроверятьНаличиеКода Тогда
				// Если выше открыта область 8.3, то наличие кода проверяем только до текущей области 8.2.
				Если НомерСтрокиОбласти83 > 0 Тогда
					Если НомерПроверяемойСтроки = (НомерСтроки + 1) Тогда
						ПроверятьНаличиеКода = Ложь;
						Продолжить;
					КонецЕсли;
				КонецЕсли;
				
				// Ищем незакомментированные строки до начала вложенной области.
				Если НЕ СтрНачинаетсяС(СокрЛ(ПроверяемаяСтрока), "//") Тогда
					Если СтрНачинаетсяС(СокрЛ(ПроверяемаяСтрока), ТекстОбластьВРег) Тогда
						Прервать;
					Иначе
						// Нашли код.
						Область82СодержитКод = Истина;
						Прервать;
					КонецЕсли;
				КонецЕсли;
				
			КонецЕсли;
			
			// Нашли область 8.2.
			Если СтрНачинаетсяС(ПроверяемаяСтрока, ШаблонОбластей82) Тогда
				// Проверяем, что найденная область 8.2 не является многострочным комментарием.
				СледующаяПроверяемаяСтрока = ДокументТекст.ПолучитьСтроку(НомерПроверяемойСтроки + 1);
				Если СтрНачинаетсяС(СледующаяПроверяемаяСтрока, "//") Тогда
					//Если СтрНачинаетсяС(СтрокаПослеСледующейСтроки, "//") Тогда
					Если ЭтоМногострочныйКомментарий(ДокументТекст, НомерПроверяемойСтроки, ШаблонОбластей82) Тогда
						// Это многострочный комментарий, пропускаем.
						НомерПроверяемойСтроки = НомерПроверяемойСтроки;
						Продолжить;
					ИначеЕсли СледующаяПроверяемаяСтрока = ВРег(СледующаяПроверяемаяСтрока) Тогда
						//Если НомерСтрокиОбласти83 > 0 И НомерПроверяемойСтроки <= НомерСтроки Тогда
						Если НомерСтрокиОбласти83 > 0 Тогда
							// Поиск осуществляли, начиная с области 8.3, открытой выше, и нашли проверяемую область 8.2.
							КоличествоВложенныхОбластей = КоличествоВложенныхОбластей + 1;
							Продолжить;
						КонецЕсли;
						Если НЕ ЭтоОбласть82ВерхнегоУровня Тогда
							// Нашли область 8.2 верхнего уровня, дальше не проверяем.
							Прервать;
						КонецЕсли;
					Иначе
						// Это вложенная область.
						КоличествоВложенныхОбластей = КоличествоВложенныхОбластей + 1;
						НомерПроверяемойСтроки = НомерПроверяемойСтроки + 1;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			
			Если СтрНачинаетсяС(ПроверяемаяСтрока, ТекстОбластьВРег) Тогда
				// Также могут быть вложенные области 8.3.
				ОткрытыхОбластей83 = ОткрытыхОбластей83 + 1;
			КонецЕсли;
			
			Если СтрНачинаетсяСПоМассиву(ПроверяемаяСтрока, МассивТекстКонецОбласти).Успешно Тогда
				ЗакрытыхОбластей83 = ЗакрытыхОбластей83 + 1;
				Если ОткрытыхОбластей83 > ЗакрытыхОбластей83 Тогда
					// Вложенные области 8.3 не учитываем.
					ОткрытыхОбластей83 = ОткрытыхОбластей83 - 1;
				ИначеЕсли ЗакрытыхОбластей83 > ОткрытыхОбластей83 Тогда
					// Нашли "#КонецОбласти" для области 8.3, открытой до области 8.2.
					Прервать;
				Иначе
					КоличествоВложенныхОбластей = КоличествоВложенныхОбластей + 1;
				КонецЕсли;
			КонецЕсли;
			
		Иначе
			// Для области 8.2, не являющейся областью верхнего уровня и не входящую в состав области 8.3
			// останавливаем поиск, если нашли область 8.2 или область 8.3.
			Если СтрНачинаетсяС(ПроверяемаяСтрока, ТекстОбластьВРег)
			 ИЛИ СтрНачинаетсяС(ПроверяемаяСтрока, ШаблонОбластей82) Тогда
				Если НомерСтрокиОбласти83 > 0 Тогда
					КоличествоВложенныхОбластей = КоличествоВложенныхОбластей + 1;
					Продолжить;
				Иначе
					Прервать;
				КонецЕсли;
				
			КонецЕсли;
			
			Если НЕ СтрНачинаетсяС(СокрЛ(ПроверяемаяСтрока), "//") Тогда
				// Нашли начало процедуры (функции).
				Область82СодержитКод = Истина;
				Прервать;
			КонецЕсли;
			
		КонецЕсли;
		
		// Считаем, что область может быть преобразована, если содержит минимум 2 вложенных области.
		Если КоличествоВложенныхОбластей = 2 Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Если ЭтоОбласть82ВерхнегоУровня ИЛИ НомерСтрокиОбласти83 > 0 Тогда
		ОбластьМожетБытьПреобразована = (Область82СодержитКод ИЛИ (КоличествоВложенныхОбластей > 1));
	Иначе
		ОбластьМожетБытьПреобразована = Область82СодержитКод;
	КонецЕсли;
	
	Возврат ОбластьМожетБытьПреобразована;
	
КонецФункции

Функция НомерСтрокиДляЗакрытияОбласти(ДокументТекст, МассивТекстНачалоМетода, МассивТекстКонецМетода,
		МассивТекстЕсли, МассивТекстКонецЕсли, НомерСтроки, ТекстОбласть)
	
	ТекстДокумента = ДокументТекст.ПолучитьТекст();
	ТекстДокумента = СтрЗаменить(ТекстДокумента, " ", "");
	ТекстДокумента = ВРег(ТекстДокумента);
	
	// Получаем номер строки "КонецПроцедуры" или "КонецФункции" с конца текстового документа.
	ПозицияТекстКонецМетода = СтрНайтиПоМассиву(ТекстДокумента, МассивТекстКонецМетода, НаправлениеПоиска.СКонца).Позиция;
	НомерСтрокиТекстКонецМетода = ПолучитьНомерСтрокиМодуля(ТекстДокумента, ПозицияТекстКонецМетода);
	
	// Определяем позицию "#КонецЕсли" поиском с конца текстового документа.
	РезультатПоиска = СтрНайтиПоМассиву(ТекстДокумента, МассивТекстКонецЕсли, НаправлениеПоиска.СКонца);
	ПозицияТекстКонецЕсли = РезультатПоиска.Позиция;
	НайденныйЭлемент = ?(ПозицияТекстКонецЕсли > 0, РезультатПоиска.НайденныйЭлемент, "");
	
	НомерСтрокиТекстКонецЕсли = 0;
	Если ПозицияТекстКонецЕсли > 0 Тогда
		
		// Получаем текст после "#КонецЕсли".
		ТекстПослеКонецЕсли = Сред(ТекстДокумента, ПозицияТекстКонецЕсли + СтрДлина(НайденныйЭлемент));
		Если НЕ СтрНайтиПоМассиву(ТекстПослеКонецЕсли, МассивТекстНачалоМетода).Успешно Тогда
			// В тексте после "#КонецЕсли" нет процедур(функций), получаем номер строки, содержащей "#КонецЕсли".
			НомерСтрокиТекстКонецЕсли = ПолучитьНомерСтрокиМодуля(ТекстДокумента, ПозицияТекстКонецЕсли);
		КонецЕсли;
		
	КонецЕсли;
	
	МассивТекстКонецОбласти = Контекст["МассивТекстКонецОбласти"];
	
	// Определяем позицию "#КонецОбласти" с конца текстового документа.
	РезультатПоискаТекстКонецОбласти = СтрНайтиПоМассиву(ТекстДокумента, МассивТекстКонецОбласти, НаправлениеПоиска.СКонца,, Истина);
	ПозицияТекстКонецОбласти = РезультатПоискаТекстКонецОбласти.Позиция;
	ТекстКонецОбласти = РезультатПоискаТекстКонецОбласти.НайденныйЭлемент;
	
	// Определяем позицию слова после строк "#КонецОбласти" или "#КонецЕсли".
	ПозицияПослеЗакрывающейКонструкции = ?(ПозицияТекстКонецОбласти > 0, ПозицияТекстКонецОбласти + СтрДлина(ТекстКонецОбласти), ПозицияТекстКонецЕсли + СтрДлина(НайденныйЭлемент));
	
	// Получаем текст после закрывающей конструкции.
	ТекстПослеЗакрывающейКонструкции = Сред(ТекстДокумента, ПозицияПослеЗакрывающейКонструкции);
	ТекстПослеЗакрывающейКонструкции = СокрЛП(ТекстПослеЗакрывающейКонструкции);
	
	Если СтрЗаканчиваетсяНаПоМассиву(СокрП(ТекстДокумента), МассивТекстКонецЕсли).Успешно Тогда
		// В конце текста модуля содержится "#КонецЕсли".
		Если СтрНайтиПоМассиву(ТекстПослеЗакрывающейКонструкции, МассивТекстЕсли).Успешно Тогда
			// Проверяем, что открытие инструкции препроцессора происходит в тексте после закрывающей конструкции.
			// В этом случае необходимо закрыть область после "#КонецЕсли".
			ДокументТекст.ДобавитьСтроку("");
			НомерСтроки = НомерСтрокиТекстКонецЕсли + 1;
		Иначе
			// Ниже нет открытия инструкции препроцессора, значит инструкция препроцессора открыта выше.
			// В этом случае необходимо закрыть область до "#КонецЕсли".
			// Проверяем, что выше "#КонецЕсли" есть "#Иначе" - если есть, то необходимо закрыть область до "#Иначе".
			МассивТекстИначе = Контекст["МассивТекстИначе"];
			ПозицияИначе = СтрНайтиПоМассиву(СокрП(ТекстДокумента), МассивТекстИначе, НаправлениеПоиска.СКонца).Позиция;
			Если ПозицияИначе > 0 Тогда
				НомерСтроки = ПолучитьНомерСтрокиМодуля(ТекстДокумента, ПозицияИначе);
			КонецЕсли;
			
			НомерСтроки = НомерСтроки - 2;
		КонецЕсли;
		
	КонецЕсли;
	
	// Если строка "#КонецЕсли" находится в конце текста модуля, то необходимо закрыть область до нее.
	// Если строки "#КонецЕсли" нет в конце текста модуля, то закрыть область необходимо после окончания процедуры(функции).
	НомерСтрокиДляЗакрытияОбласти = ?(НомерСтрокиТекстКонецЕсли > 0, Мин(НомерСтрокиТекстКонецМетода, НомерСтрокиТекстКонецЕсли), НомерСтрокиТекстКонецМетода);
	// Определяем позицию "#Область " в проверяемом тексте.
	ПозицияТекстОбласть = СтрНайти(ТекстПослеЗакрывающейКонструкции, СокрП(ВРег(ТекстОбласть)));
	// Если в проверяемом тексте есть продолжение текста модуля и при этом нет открытия области, то оставляем номер строки для закрытия области без изменений.
	// Иначе в проверяемом тексте есть открытие области - переопределяем номер строки для закрытия области.
	НомерСтрокиДляЗакрытияОбласти = ?((ПозицияТекстОбласть = 0) И (НЕ ПустаяСтрока(ТекстПослеЗакрывающейКонструкции)), НомерСтрокиДляЗакрытияОбласти, НомерСтроки);
	
	ПредыдущаяСтрока = ДокументТекст.ПолучитьСтроку(НомерСтрокиДляЗакрытияОбласти - 1);
	Если НЕ ПустаяСтрока(ПредыдущаяСтрока) Тогда
		ДокументТекст.ВставитьСтроку(НомерСтрокиДляЗакрытияОбласти, "");
		НомерСтрокиДляЗакрытияОбласти = НомерСтрокиДляЗакрытияОбласти + 1;
	КонецЕсли;
	
	Возврат НомерСтрокиДляЗакрытияОбласти;
	
КонецФункции

Процедура ЗакрытьОткрытыеОбласти(ДокументТекст, НомерСтроки, КоличествоОткрытыхОбластей,
		КоличествоЗакрытыхОбластей, УчитыватьЗакрытиеОбласти = Истина)
	
	Если КоличествоОткрытыхОбластей < КоличествоЗакрытыхОбластей Тогда
		Возврат;
	КонецЕсли;
	
	КоличествоНезакрытыхОбластей = КоличествоОткрытыхОбластей - КоличествоЗакрытыхОбластей;
	Для Счетчик = 1 По КоличествоНезакрытыхОбластей Цикл
		ЗакрытьОбласть(ДокументТекст, НомерСтроки);
		Если УчитыватьЗакрытиеОбласти Тогда
			КоличествоЗакрытыхОбластей = КоличествоЗакрытыхОбластей + 1;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Функция ПолучитьСтруктуруОбласти83ИзОбласти82(Знач СтрокаМодуля, ТаблицаСтандартныхОбластей)
	
	СтруктураОбласти = Новый Структура;
	СтруктураОбласти.Вставить("ВерхнегоУровня", Ложь);
	СтруктураОбласти.Вставить("Наименование", "");
	
	СтрокаМодуляБуфер = СтрокаМодуля;
	СтрокаМодуляБуфер = СтрЗаменить(СтрокаМодуляБуфер, "/", " ");
	СтрокаМодуляБуфер = СтрЗаменить(СтрокаМодуляБуфер, Символы.Таб, " ");
	Если ПустаяСтрока(СтрокаМодуляБуфер) Тогда
		Возврат СтруктураОбласти;
	КонецЕсли;
	
	СтрокаМодуляБуфер = СокрЛП(СтрокаМодуляБуфер);
	
	// Удаляем двойные пробелы для поиска.
	Пока СтрНайти(СтрокаМодуляБуфер, "  ") > 0 Цикл
		СтрокаМодуляБуфер = СтрЗаменить(СтрокаМодуляБуфер, "  ", " ");
	КонецЦикла;
	
	СтрокаСтандартнойОбласти = ТаблицаСтандартныхОбластей.Найти(ВРег(СтрокаМодуляБуфер), "Область82");
	Если СтрокаСтандартнойОбласти <> Неопределено Тогда
		СтруктураОбласти.ВерхнегоУровня = Истина;
		СтруктураОбласти.Наименование = СтрокаСтандартнойОбласти.Область83;
		Возврат СтруктураОбласти;
	КонецЕсли;
	
	СтруктураОтбораПоНеполномуИмени = Новый Структура;
	СтруктураОтбораПоНеполномуИмени.Вставить("ИмяОбластиПолное", Ложь);
	ТаблицаСтандартныхОбластейСНеполнымИменем = ТаблицаСтандартныхОбластей.Скопировать(СтруктураОтбораПоНеполномуИмени);
	Для Каждого СтрокаСтандартнойОбласти Из ТаблицаСтандартныхОбластейСНеполнымИменем Цикл
		
		ИмяОбласти = СтрокаСтандартнойОбласти.Область82;
		Если СтрНачинаетсяС(ВРег(СтрокаМодуляБуфер), ИмяОбласти) Тогда
			
			// Выделяем наименование таблицы формы.
			ИмяТаблицыФормы = Сред(СтрокаМодуляБуфер, СтрДлина(ИмяОбласти) + 1);
			ИмяТаблицыФормы = СтрЗаменить(ИмяТаблицыФормы, " ", "");
			ИмяТаблицыФормы = СтрЗаменить(ИмяТаблицыФормы, """", "");
			ИмяТаблицыФормы = СтрЗаменить(ИмяТаблицыФормы, ".", "");
			
			СтруктураОбласти.ВерхнегоУровня = Истина;
			СтруктураОбласти.Наименование = СтрокаСтандартнойОбласти.Область83 + ИмяТаблицыФормы;
			
			Возврат СтруктураОбласти;
			
		КонецЕсли;
		
	КонецЦикла;
	
	ИмяОбласти = "";
	Для НомерСимвола = 1 По СтрДлина(СтрокаМодуля) Цикл
		Символ = Сред(СтрокаМодуля, НомерСимвола, 1);
		ДобавляемыйСимвол = ?(апк_СловоСодержитЗначимыеСимволы(Символ), Символ, " ");
		ИмяОбласти = ИмяОбласти + ДобавляемыйСимвол;
	КонецЦикла;
	
	МассивИсключенийИменОбласти = Контекст["МассивИсключенийИменОбласти"];
	Если МассивИсключенийИменОбласти.Найти(ВРег(ИмяОбласти)) <> Неопределено Тогда
		// Имя области не может совпадать с ключевыми словами встроенного языка.
		Возврат СтруктураОбласти;
	КонецЕсли;
	
	Если ИмяОбласти = ВРег(ИмяОбласти) Тогда
		// Если имя области полностью написано в верхнем регистре,
		// то переводим все слова в имени области в титульный регистр.
		ИмяОбласти = ТРег(ИмяОбласти);
		ИмяОбласти = СтрЗаменить(ИмяОбласти, " ", "");
		СтруктураОбласти.Наименование = ИмяОбласти;
		СтруктураОбласти.ВерхнегоУровня = Истина;
		Возврат СтруктураОбласти;
	КонецЕсли;
	
	// Обрабатываем каждое слово в имени области отдельно.
	МассивСловОбласти = СтрРазделить(ИмяОбласти, " ", Ложь);
	ИмяОбласти = "";
	Для Каждого СловоОбласти Из МассивСловОбласти Цикл
		// Если отдельное слово в имени области написано в нижнем регистре,
		// то переводим все слова в имени области в титульный регистр.
		// При этом будут сохранены аббревиатуры, написанные в верхнем регистре.
		СловоОбласти = ?((СловоОбласти = НРег(СловоОбласти)) ИЛИ (СловоОбласти = ВРег(СловоОбласти) И СтрДлина(СловоОбласти) > 4), ТРег(СловоОбласти), СловоОбласти);
		ИмяОбласти = ИмяОбласти + СловоОбласти;
	КонецЦикла;
	
	СтруктураОбласти.Наименование = ИмяОбласти;
	
	Возврат СтруктураОбласти;
	
КонецФункции

Процедура ЗакрытьОбласть(ДокументТекст, НомерСтроки)
	
	ТекстКонецОбласти = НСтр("ru='#КонецОбласти'; en='#EndRegion'", КодОсновногоЯзыка);
	
	СтрокаМодуля = ДокументТекст.ПолучитьСтроку(НомерСтроки - 1);
	Если НЕ ПустаяСтрока(СтрокаМодуля) Тогда
		ДокументТекст.ВставитьСтроку(НомерСтроки, "");
		НомерСтроки = НомерСтроки + 1;
	КонецЕсли;
	
	ДокументТекст.ВставитьСтроку(НомерСтроки, ТекстКонецОбласти);
	НомерСтроки = НомерСтроки + 1;
	
	СтрокаМодуля = ДокументТекст.ПолучитьСтроку(НомерСтроки);
	Если НЕ ПустаяСтрока(СтрокаМодуля) Тогда
		ДокументТекст.ВставитьСтроку(НомерСтроки, "");
		НомерСтроки = НомерСтроки + 1;
	КонецЕсли;
	
КонецПроцедуры

Функция ПроверитьЗаменуОбластей82На83(ДокументТекст)
	
	СтруктураРезультатаЗаменыОбластей = Новый Структура;
	СтруктураРезультатаЗаменыОбластей.Вставить("ОбластиЗамененыКорректно", Истина);
	СтруктураРезультатаЗаменыОбластей.Вставить("НомерСтрокиОшибки", 0);
	СтруктураРезультатаЗаменыОбластей.Вставить("ТекстОшибки", "");
	
	ШаблонОшибкиНеСовпадаетКоличествоНачалаИКонцаОбластей = НСтр("ru='
		|Ошибка: Не совпадает количество начала и конца областей после вставки
		|Наименование области: %1
		|Номер строки начала области: %2
		|Номер строки конца области: %3';
		|en='Ошибка: Не совпадает количество начала и конца областей после вставки
		|Наименование области: %1
		|Номер строки начала области: %2
		|Номер строки конца области: %3'", КодОсновногоЯзыка);
	
	ШаблонОшибкиПересечениеОбластейИИнструкций = НСтр("ru='
		|Ошибка: Инструкция препроцессору пересекается со вставкой области
		|Наименование области: %1
		|Номер строки начала области: %2
		|Номер строки конца области: %3
		|Текст инструкции: %4
		|Номер строки начала инструкции: %5
		|Номер строки конца инструкции: %6';
		|en='Ошибка: Инструкция препроцессору пересекается со вставкой области
		|Наименование области: %1
		|Номер строки начала области: %2
		|Номер строки конца области: %3
		|Текст инструкции: %4
		|Номер строки начала инструкции: %5
		|Номер строки конца инструкции: %6'", КодОсновногоЯзыка);
	
	ШаблонОшибкиНеОпределеныГраницыИнструкцийПрепроцессору = НСтр("ru='
		|Ошибка: Не определены границы инструкций препроцессору
		|Текст инструкции: %1
		|Номер строки начала инструкции: %2
		|Номер строки конца инструкции: %3';
		|en='Ошибка: Не определены границы инструкций препроцессору
		|Текст инструкции: %1
		|Номер строки начала инструкции: %2
		|Номер строки конца инструкции: %3'", КодОсновногоЯзыка);
	
	ТекстМодуля = ДокументТекст.ПолучитьТекст();
	ТаблицаИнструкцийПрепроцессора = ПолучитьТаблицуИнструкцийПрепроцессора(ТекстМодуля);
	ТаблицаОбластейМодуля = ПолучитьТаблицуОбластейМодуля83(ТекстМодуля);
	
	ТекстОшибки = "";
	НомерСтрокиОшибки = 0;
	Для Каждого СтрокаТаблицыОбластей Из ТаблицаОбластейМодуля Цикл
		
		НомерСтрокиНачалаОбласти = СтрокаТаблицыОбластей.НомерСтрокиНачало;
		НомерСтрокиКонцаОбласти = СтрокаТаблицыОбластей.НомерСтрокиКонец;
		
		Если (НомерСтрокиНачалаОбласти = Неопределено) ИЛИ (НомерСтрокиКонцаОбласти = Неопределено) Тогда
			НомерСтрокиОшибки = ?(НомерСтрокиНачалаОбласти = Неопределено, НомерСтрокиНачалаОбласти, НомерСтрокиКонцаОбласти);
			ТекстОшибки = СтрШаблон(ШаблонОшибкиНеСовпадаетКоличествоНачалаИКонцаОбластей,
				СтрокаТаблицыОбластей.Наименование,
				НомерСтрокиНачалаОбласти,
				НомерСтрокиКонцаОбласти);
			Прервать;
		КонецЕсли;
		
		Для Каждого СтрокаТаблицыИнструкцийПрепроцессора Из ТаблицаИнструкцийПрепроцессора Цикл
			
			ТекстИнструкции = СтрокаТаблицыИнструкцийПрепроцессора.ТекстИнструкции;
			
			ПозицияНачалаИнструкции = СтрокаТаблицыИнструкцийПрепроцессора.ПозицияЕсли;
			Если ПозицияНачалаИнструкции = Неопределено Тогда
				НомерСтрокиОшибки = НомерСтрокиНачалаОбласти;
				ТекстОшибки = СтрШаблон(ШаблонОшибкиНеОпределеныГраницыИнструкцийПрепроцессору,
					ТекстИнструкции,
					"",
					"");
				Прервать;
			КонецЕсли;
			
			ПозицияКонцаИнструкции = СтрокаТаблицыИнструкцийПрепроцессора.ПозицияКонецЕсли;
			Если ПозицияКонцаИнструкции = Неопределено Тогда
				НомерСтрокиОшибки = НомерСтрокиНачалаОбласти;
				ТекстОшибки = СтрШаблон(ШаблонОшибкиНеОпределеныГраницыИнструкцийПрепроцессору,
					ТекстИнструкции,
					"",
					"");
				Прервать;
			КонецЕсли;
			
			НомерСтрокиНачалаИнструкции = ПолучитьНомерСтрокиМодуля(ТекстМодуля, ПозицияНачалаИнструкции);
			НомерСтрокиКонцаИнструкции = ПолучитьНомерСтрокиМодуля(ТекстМодуля, ПозицияКонцаИнструкции);
			
			// Если вся инструкция лежит до области, то проверяем дальше.
			Если НомерСтрокиКонцаИнструкции < НомерСтрокиНачалаОбласти Тогда
				Продолжить;
			КонецЕсли;
			
			// Если вся инструкция лежит после области, то прерываем и проверяем следующую инструкцию.
			Если НомерСтрокиНачалаИнструкции > НомерСтрокиКонцаОбласти Тогда
				Прервать;
			КонецЕсли;
			
			// Иначе - если пересечение областей и инструкций, то регистрируем ошибку.
			Если ((НомерСтрокиНачалаИнструкции < НомерСтрокиНачалаОбласти) И (НомерСтрокиКонцаИнструкции < НомерСтрокиКонцаОбласти))
			 ИЛИ ((НомерСтрокиНачалаИнструкции > НомерСтрокиНачалаОбласти) И (НомерСтрокиКонцаИнструкции > НомерСтрокиКонцаОбласти)) Тогда
				НомерСтрокиОшибки = НомерСтрокиНачалаИнструкции;
				ТекстОшибки = СтрШаблон(ШаблонОшибкиПересечениеОбластейИИнструкций,
					СтрокаТаблицыОбластей.Наименование,
					НомерСтрокиНачалаОбласти,
					НомерСтрокиКонцаОбласти,
					ТекстИнструкции,
					НомерСтрокиНачалаИнструкции,
					НомерСтрокиКонцаИнструкции);
			КонецЕсли;
			
			Если НЕ ПустаяСтрока(ТекстОшибки) Тогда
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
		Если НЕ ПустаяСтрока(ТекстОшибки) Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Если НЕ ПустаяСтрока(ТекстОшибки) Тогда
		СтруктураРезультатаЗаменыОбластей.Вставить("ОбластиЗамененыКорректно", Ложь);
		СтруктураРезультатаЗаменыОбластей.Вставить("НомерСтрокиОшибки", НомерСтрокиОшибки);
		СтруктураРезультатаЗаменыОбластей.Вставить("ТекстОшибки", ТекстОшибки);
	КонецЕсли;
	
	Возврат СтруктураРезультатаЗаменыОбластей;
	
КонецФункции

// Функция добавляет область "ОписаниеПеременных".
//
Функция ДобавитьОбластьОписаниеПеременных(ПолноеИмяФайла, ДокументТекст)
	
	НаименованиеОбласти     = Контекст["ОбластьОписаниеПеременных"];
	НаименованиеОбластиВРег = ВРег(НаименованиеОбласти);
	НаименованиеОбластиВРег = СтрЗаменить(НаименованиеОбластиВРег, " ", "");
	
	ТекстМодуля = ДокументТекст.ПолучитьТекст();
	ТекстМодуля = ВРег(ТекстМодуля);
	ТекстМодуля = СтрЗаменить(ТекстМодуля, Символы.Таб, "");
	ТекстМодуля = СтрЗаменить(ТекстМодуля, " ", "");
	
	// Проверяем наличие области в модуле, если есть, выходим.
	Если СтрНайти(ТекстМодуля, НаименованиеОбластиВРег + Символы.ПС) > 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	// Проверяем раздел объявления переменных, если нет, то выходим.
	ТекстПерем = Контекст["ТекстПерем"];
	Если СтрНайти(ТекстМодуля, ТекстПерем) = 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	
#Область ПроверкаСуществующейОбластиОписанияПеременных
	
	// Проверим существующие области инициализации.
	ТаблицаОбластей = Новый ТаблицаЗначений;
	ТаблицаОбластей.Колонки.Добавить("Область");
	ТаблицаОбластей.Колонки.Добавить("Найдена");
	ТаблицаОбластей.Колонки.Добавить("НомерСтроки");
	
	ТаблицаОбластей.Добавить().Область = "#Область СостояниеОбъекта";
	ТаблицаОбластей.Добавить().Область = НСтр("ru='#Область ЛокальныеПеременные'; en='#Region LocalVariables'", КодОсновногоЯзыка);
	ТаблицаОбластей.Добавить().Область = "#Область ВнутреннееСостояние";
	ТаблицаОбластей.Добавить().Область = НСтр("ru='#Область ОбъявлениеПеременных'; en='#Region Variables'", КодОсновногоЯзыка);
	
	ТаблицаОбластей.ЗаполнитьЗначения(Ложь, "Найдена");
	ТаблицаОбластей.ЗаполнитьЗначения(0, "НомерСтроки");
	
	Для Каждого СтрокаОбласти Из ТаблицаОбластей Цикл
		
		ОбластьИнициализации = СтрокаОбласти.Область;
		ОбластьИнициализации = СтрЗаменить(ОбластьИнициализации, " ", "");
		ОбластьИнициализации = ВРег(ОбластьИнициализации);
		
		// Если не найдена, продолжаем.
		НомерСимвола = СтрНайти(ТекстМодуля, ОбластьИнициализации + Символы.ПС);
		Если НомерСимвола = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		// Получаем номер строки.
		ТекстДоСимвола = Лев(ТекстМодуля, НомерСимвола);
		НомерСтроки = СтрЧислоСтрок(ТекстДоСимвола);
		
		СтрокаОбласти.Найдена = Истина;
		СтрокаОбласти.НомерСтроки = НомерСтроки;
		
	КонецЦикла;
	
	// Если найдена только 1 область из таблицы, то заменяем ее и выходим.
	СтруктураОтбора = Новый Структура;
	СтруктураОтбора.Вставить("Найдена", Истина);
	
	МассивОбластей = ТаблицаОбластей.НайтиСтроки(СтруктураОтбора);
	Если МассивОбластей.Количество() = 1 Тогда
		НомерСтроки = МассивОбластей[0].НомерСтроки;
		ДокументТекст.ЗаменитьСтроку(НомерСтроки, НаименованиеОбласти);
		
		Возврат Истина;
	КонецЕсли;
	
#КонецОбласти
	
#Область ДобавлениеОбластиОписаниеПеременных
	
	ТекстОбласть      = Контекст["ТекстОбласть"];
	ТекстКонецОбласти = Контекст["ТекстКонецОбласти"];
	
	КоличествоСтрок = ДокументТекст.КоличествоСтрок();
	
	ОбластьОткрыта = Ложь;
	НайденоОписаниеПеременных = Ложь;
	МногострочноеОпределениеПеременных = Ложь;
	
	СтруктураНомераСтрок = Новый Структура;
	СтруктураНомераСтрок.Вставить("НачалоОписания", 0);
	СтруктураНомераСтрок.Вставить("ДирективаПеременной", 0);
	СтруктураНомераСтрок.Вставить("ДирективаМетода", 0);
	СтруктураНомераСтрок.Вставить("ПервыйКомментарий", 0);
	СтруктураНомераСтрок.Вставить("НачалоМетода", 0);
	СтруктураНомераСтрок.Вставить("ПерваяОбласть", 0);
	СтруктураНомераСтрок.Вставить("ПоследняяОбласть", 0);
	
	СтруктураНомераСтрок.Вставить("ПустаяСтрокаПередПеременной", 0);
	СтруктураНомераСтрок.Вставить("ПустаяСтрокаПослеПеременной", 0);
	
	Для НомерСтроки = 1 По КоличествоСтрок Цикл
		
		СтрокаМодуляИсходная = ДокументТекст.ПолучитьСтроку(НомерСтроки);
		
		Если ПустаяСтрока(СтрокаМодуляИсходная) Тогда
			// Описание переменных найдено, запоминаем первую пустую строку.
			Если НайденоОписаниеПеременных Тогда
				Если СтруктураНомераСтрок.ПустаяСтрокаПослеПеременной = 0 Тогда
					// Номер строки увеличен на 1, чтобы вставлять конец область ниже пустой строки.
					СтруктураНомераСтрок.ПустаяСтрокаПослеПеременной = НомерСтроки + 1;
				КонецЕсли;
			Иначе
				// Номер строки увеличен на 1, чтобы вставлять область ниже пустой строки.
				СтруктураНомераСтрок.ПустаяСтрокаПередПеременной = НомерСтроки + 1;
				// Если не было переменных и появилась пустая строка, то сбрасываем номер строки с комментарием.
				СтруктураНомераСтрок.ПервыйКомментарий = 0;
			КонецЕсли;
			
			Продолжить;
		КонецЕсли;
		
		СтрокаМодуля = СокрЛП(СтрокаМодуляИсходная);
		СтрокаМодуля = ВРег(СтрокаМодуля);
		СтрокаМодуля = СтрЗаменить(СтрокаМодуля, Символы.Таб, " ");
		// Добавляем пробел в конец строки, чтобы искать конструкции с пробелом, например, "Перем ".
		// Иначе это может быть, например, наименование переменной "Переменная1" на следующей строке.
		СтрокаМодуля = СтрокаМодуля + " ";
		
		// Над переменной могут быть директивы.
		Если СтрНачинаетсяС(СтрокаМодуля, "&") Тогда
			// Если описание переменных уже было, то вероятнее всего это директива от следующего метода.
			Если НайденоОписаниеПеременных Тогда
				СтруктураНомераСтрок.ДирективаМетода = НомерСтроки;
			КонецЕсли;
			
			// Если директив еще не было, то запоминаем номер строки первой директивы.
			Если СтруктураНомераСтрок.ДирективаПеременной = 0 Тогда
				СтруктураНомераСтрок.ДирективаПеременной = НомерСтроки;
			КонецЕсли;
			
			Продолжить;
		КонецЕсли;
		
		// Если строка начинается с описания переменной, запоминаем.
		Если СтрНачинаетсяС(СтрокаМодуля, ТекстПерем) Тогда
			// Если переменных еще не было, то запоминаем номер строки начала описания.
			Если НЕ НайденоОписаниеПеременных Тогда
				СтруктураНомераСтрок.НачалоОписания = НомерСтроки;
				НайденоОписаниеПеременных = Истина;
			КонецЕсли;
			
			// Если в строке нет ";", то это многострочное описание переменных.
			Если СтрНайти(СтрокаМодуля, ";") = 0 Тогда
				МногострочноеОпределениеПеременных = Истина;
			КонецЕсли;
			
			// Если найдена очередная переменная, сбрасываем пустую строку после предыдущей переменной.
			СтруктураНомераСтрок.ПустаяСтрокаПослеПеременной = 0;
			
			Продолжить;
		КонецЕсли;
		
		// Запоминаем номера строк комментариев.
		Если СтрНачинаетсяС(СтрокаМодуля, "//") Тогда
			// Запоминаем номер строки комментария, относящегося к самой первой переменной.
			// Если после комментария идет пустая строка, то номер строки первого комментария сбрасывается (в начале цикла).
			Если СтруктураНомераСтрок.ПервыйКомментарий = 0 Тогда
				СтруктураНомераСтрок.ПервыйКомментарий = НомерСтроки;
			КонецЕсли;
			
			Продолжить;
		КонецЕсли;
		
		// Области обрабатываем, инструкции препроцессору пропускаем.
		Если СтрНачинаетсяС(СтрокаМодуля, "#") Тогда
			// Если это область, установим некоторые значения.
			Если СтрНачинаетсяС(СтрокаМодуля, ТекстОбласть) Тогда
				// Запомним, что область открыта.
				Если НЕ НайденоОписаниеПеременных Тогда
					ОбластьОткрыта = Истина;
				КонецЕсли;
				
				// Если переменных не было, и началась область, запомним.
				Если СтруктураНомераСтрок.ПерваяОбласть = 0 Тогда
					СтруктураНомераСтрок.ПерваяОбласть = НомерСтроки;
				КонецЕсли;
				
				// Запоминаем номер строки области.
				СтруктураНомераСтрок.ПоследняяОбласть = НомерСтроки;
			КонецЕсли;
			
			// Если это конец области, закроем область.
			Если СтрНачинаетсяС(СтрокаМодуля, ВРег(ТекстКонецОбласти)) Тогда
				ОбластьОткрыта = Ложь;
			КонецЕсли;
			
			Продолжить;
		КонецЕсли;
		
		// Если это многострочное определение переменных, то проверим, что оно закончилось.
		Если МногострочноеОпределениеПеременных Тогда
			Если СтрНайти(СтрокаМодуля, ";") > 0 Тогда
				МногострочноеОпределениеПеременных = Ложь;
			КонецЕсли;
			Продолжить;
		КонецЕсли;
		
		// Встретили начало метода или код, тогда выходим из цикла.
		СтруктураНомераСтрок.НачалоМетода = НомерСтроки;
		Прервать;
		
	КонецЦикла;
	
	// Не найдено описание переменных в начале модуля, выходим.
	Если НЕ НайденоОписаниеПеременных Тогда
		Возврат Ложь;
	КонецЕсли;
	
	// Если в области есть переменные и методы, то это ошибка, не обрабатываем.
	Если ОбластьОткрыта Тогда
		ТекстИсключения = НСтр("ru='Объявление переменной находится в одной области с процедурой, функцией или кодом: %Строка%';
			|en='Объявление переменной находится в одной области с процедурой, функцией или кодом: %Строка%'", КодОсновногоЯзыка);
		ТекстИсключения = СтрЗаменить(ТекстИсключения, "%Строка%", СтрокаМодуляИсходная);
		ОбработатьИсключение(ПолноеИмяФайла, ТекстИсключения, НомерСтроки);
		Возврат Ложь;
	КонецЕсли;
	
	Для Каждого Элемент Из СтруктураНомераСтрок Цикл
		Если Элемент.Значение = 0 Тогда
			СтруктураНомераСтрок.Вставить(Элемент.Ключ, КоличествоСтрок + 1);
		КонецЕсли;
	КонецЦикла;
	
	// Вычисляем номер строки начала описания.
	// Выбираем между началом области переменных, комментарием и директивой перед первой переменной и первой областью.
	НомерСтрокиНачалаОбласти = Мин(
		СтруктураНомераСтрок.НачалоОписания,
		СтруктураНомераСтрок.ПустаяСтрокаПередПеременной,
		СтруктураНомераСтрок.ПервыйКомментарий,
		СтруктураНомераСтрок.ДирективаПеременной,
		СтруктураНомераСтрок.ПерваяОбласть);
	
	// Вычисляем номер строки конца описания.
	// Выбираем между пустой строкой и областью после последней переменной, директивой и началом метода.
	НомерСтрокиКонцаОбласти = Мин(
		СтруктураНомераСтрок.ПустаяСтрокаПослеПеременной,
		СтруктураНомераСтрок.ПоследняяОбласть,
		СтруктураНомераСтрок.ДирективаМетода,
		СтруктураНомераСтрок.НачалоМетода);
	
	ДокументТекст.ВставитьСтроку(НомерСтрокиКонцаОбласти, ТекстКонецОбласти);
	ДокументТекст.ВставитьСтроку(НомерСтрокиКонцаОбласти + 1, "");
	
	ДокументТекст.ВставитьСтроку(НомерСтрокиНачалаОбласти, НаименованиеОбласти);
	ДокументТекст.ВставитьСтроку(НомерСтрокиНачалаОбласти + 1, "");
	
#КонецОбласти
	
	Возврат Истина;
	
КонецФункции

// Функция добавляет область "Инициализация".
//
Функция ДобавитьОбластьИнициализация(ДокументТекст)
	
	НаименованиеОбласти     = Контекст["ОбластьИнициализация"];
	НаименованиеОбластиВРег = ВРег(НаименованиеОбласти);
	НаименованиеОбластиВРег = СтрЗаменить(НаименованиеОбластиВРег, " ", "");
	
	ТекстМодуля = ДокументТекст.ПолучитьТекст();
	ТекстМодуля = ВРег(ТекстМодуля);
	ТекстМодуля = СтрЗаменить(ТекстМодуля, Символы.Таб, "");
	ТекстМодуля = СтрЗаменить(ТекстМодуля, " ", "");
	
	// Проверяем наличие области в модуле, если есть, выходим.
	Если СтрНайти(ТекстМодуля, НаименованиеОбластиВРег + Символы.ПС) > 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	
#Область ПроверкаСуществующейОбластиИнициализации
	
	// Проверим существующие области инициализации.
	МассивОбластейИнициализации = Новый Массив;
	МассивОбластейИнициализации.Добавить("#Область ОператорыОсновнойПрограммы");
	МассивОбластейИнициализации.Добавить("#Область НачальнаяИнициализация");
	МассивОбластейИнициализации.Добавить("#Область Инициализации");
	МассивОбластейИнициализации.Добавить("#Область ИнициализацияОбъекта");
	
	НайденаСуществующаяОбласть = Ложь;
	
	Для Каждого ЭлементОбласти Из МассивОбластейИнициализации Цикл
		
		ОбластьИнициализации = ЭлементОбласти;
		ОбластьИнициализации = СтрЗаменить(ОбластьИнициализации, " ", "");
		ОбластьИнициализации = ВРег(ОбластьИнициализации);
		
		// Если не найдена, продолжаем.
		НомерСимвола = СтрНайти(ТекстМодуля, ОбластьИнициализации);
		Если НомерСимвола = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		// Если нашли область, проверяем, что это действительно область, т.е. выделена в отдельную строку.
		ТекстДоСимвола = Лев(ТекстМодуля, НомерСимвола);
		НомерСтроки = СтрЧислоСтрок(ТекстДоСимвола);
		
		СтрокаМодуля = ДокументТекст.ПолучитьСтроку(НомерСтроки);
		СтрокаМодуля = ВРег(СтрокаМодуля);
		СтрокаМодуля = СтрЗаменить(СтрокаМодуля, " ", "");
		СтрокаМодуля = СтрЗаменить(СтрокаМодуля, Символы.Таб, "");
		
		Если ОбластьИнициализации = СтрокаМодуля Тогда
			ДокументТекст.ЗаменитьСтроку(НомерСтроки, НаименованиеОбласти);
			НайденаСуществующаяОбласть = Истина;
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Если НайденаСуществующаяОбласть Тогда
		Возврат Истина;
	КонецЕсли;
	
#КонецОбласти
	
#Область ДобавлениеОбластиИнициализация
	
	ТекстПерем                       = Контекст["ТекстПерем"];
	МассивТекстКонецПроцедурыФункции = Контекст["МассивТекстКонецПроцедурыФункции"];
	ТекстОбласть                     = Контекст["ТекстОбласть"];
	ТекстКонецОбласти                = Контекст["ТекстКонецОбласти"];
	
	// Здесь перечисляем операторы по одной строке, которые допустимо писать вне области "#Инициализация".
	МассивИсключенийОператоров = Новый Массив;
	
	// Этот вызов исключения должен быть написан в конце каждого модуля объекта в виде кода с инструкцией препроцессора,
	// область "#Инициализация" при этом добавлять не обязательно.
	//#Иначе
	//ВызватьИсключение НСтр("ru = 'Недопустимый вызов объекта на клиенте.'");
	//#КонецЕсли
	МассивИсключенийОператоров.Добавить("ВызватьИсключение НСтр(""ru = 'Недопустимый вызов объекта на клиенте.'"");");
	МассивИсключенийОператоров.Добавить("Raise NStr(""en = 'Invalid object call on the client.'"");");
	МассивИсключенийОператоров.Добавить("ВызватьИсключение НСтр(""ru = 'Недопустимый вызов объекта на клиенте.';");
	МассивИсключенийОператоров.Добавить("|en = 'Nedopustimiy vizov obyekta na kliente.'"")");
	
	ИндексИсключения = -1;
	Для Каждого ИсключениеОператора Из МассивИсключенийОператоров Цикл
		
		// Уберем лишние символы.
		ИсключениеОператора = ВРег(ИсключениеОператора);
		ИсключениеОператора = СтрЗаменить(ИсключениеОператора, " ", "");
		ИсключениеОператора = СтрЗаменить(ИсключениеОператора, Символы.Таб, "");
		ИсключениеОператора = СтрЗаменить(ИсключениеОператора, ";", "");
		
		ИндексИсключения = ИндексИсключения + 1;
		МассивИсключенийОператоров[ИндексИсключения] = ИсключениеОператора;
		
	КонецЦикла;
	
	КоличествоСтрок = ДокументТекст.КоличествоСтрок();
	
	ОбластьОткрыта = Ложь;
	НайденыОператоры = Ложь;
	СчетчикОбластей = 0;
	
	СтруктураНомераСтрок = Новый Структура;
	СтруктураНомераСтрок.Вставить("НачалоОператоров", 0);
	СтруктураНомераСтрок.Вставить("КонецОператоров", 0);
	СтруктураНомераСтрок.Вставить("ПервыйКомментарий", 0);
	
	СтруктураНомераСтрок.Вставить("НачалоОбласти", 0);
	
	Для НомерСтрокиСНачала = 1 По КоличествоСтрок Цикл
		
		НомерСтроки = КоличествоСтрок - НомерСтрокиСНачала + 1;
		СтрокаМодуляИсходная = ДокументТекст.ПолучитьСтроку(НомерСтроки);
		
		Если ПустаяСтрока(СтрокаМодуляИсходная) Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаМодуля = СокрЛП(СтрокаМодуляИсходная);
		СтрокаМодуля = ВРег(СтрокаМодуля);
		СтрокаМодуля = СтрЗаменить(СтрокаМодуля, Символы.Таб, " ");
		// Добавляем пробел в конец строки, чтобы искать конструкции с пробелом, например, "Перем ".
		// Иначе это может быть, например, наименование переменной "Переменная1" на следующей строке.
		СтрокаМодуля = СтрокаМодуля + " ";
		
		// Если встретилось описание переменной, то прерываем.
		Если СтрНачинаетсяС(СтрокаМодуля, ТекстПерем) Тогда
			Прервать;
		КонецЕсли;
		
		// Обрабатываем комментарий.
		Если СтрНачинаетсяС(СтрокаМодуля, "//") Тогда
			// Если операторы найдены, запоминаем самый первый комментарий.
			Если НайденыОператоры Тогда
				СтруктураНомераСтрок.ПервыйКомментарий = НомерСтроки;
			КонецЕсли;
			
			Продолжить;
		КонецЕсли;
		
		// Области обрабатываем, инструкции препроцессору пропускаем.
		Если СтрНачинаетсяС(СтрокаМодуля, "#") Тогда
			// Т.к. строки обрабатываются с конца, если это начало области, то уменьшим счетчик областей.
			Если СтрНачинаетсяС(СтрокаМодуля, ТекстОбласть) Тогда
				СчетчикОбластей = СчетчикОбластей - 1;
				СтруктураНомераСтрок.НачалоОбласти = НомерСтроки;
				
				Если СчетчикОбластей = 0 Тогда
					ОбластьОткрыта = Ложь;
				КонецЕсли;
			КонецЕсли;
			
			// Если это конец области, то увеличим счетчик областей.
			Если СтрНачинаетсяС(СтрокаМодуля, ВРег(ТекстКонецОбласти)) Тогда
				СчетчикОбластей = СчетчикОбластей + 1;
			КонецЕсли;
			
			Продолжить;
		КонецЕсли;
		
		Если СтрНачинаетсяСПоМассиву(СтрокаМодуля, МассивТекстКонецПроцедурыФункции).Успешно Тогда
			Прервать;
		КонецЕсли;
		
		// Проверяем среди исключений операторов.
		ЭтоИсключениеОператора = Ложь;
		СтрокаМодуляДляПроверкиИсключения = СтрокаМодуля;
		СтрокаМодуляДляПроверкиИсключения = СтрЗаменить(СтрокаМодуляДляПроверкиИсключения, " ", "");
		СтрокаМодуляДляПроверкиИсключения = СтрЗаменить(СтрокаМодуляДляПроверкиИсключения, ";", "");
		
		Для Каждого ИсключениеОператора Из МассивИсключенийОператоров Цикл
			Если ИсключениеОператора = СтрокаМодуляДляПроверкиИсключения Тогда
				ЭтоИсключениеОператора = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		Если ЭтоИсключениеОператора Тогда
			Продолжить;
		КонецЕсли;
		
		// Встретили код, тогда запоминаем номер строки.
		Если НЕ НайденыОператоры Тогда
			НайденыОператоры = Истина;
			СтруктураНомераСтрок.КонецОператоров = НомерСтроки;
		КонецЕсли;
		
		СтруктураНомераСтрок.НачалоОператоров = НомерСтроки;
		ОбластьОткрыта = (СчетчикОбластей <> 0);
		
	КонецЦикла;
	
	// Не найдены операторы в конце модуля, выходим.
	Если НЕ НайденыОператоры Тогда
		Возврат Ложь;
	КонецЕсли;
	
	// Если в области есть операторы и методы, то это ошибка, не обрабатываем.
	Если ОбластьОткрыта Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Для Каждого Элемент Из СтруктураНомераСтрок Цикл
		Если Элемент.Значение = 0 Тогда
			СтруктураНомераСтрок.Вставить(Элемент.Ключ, КоличествоСтрок + 1);
		КонецЕсли;
	КонецЦикла;
	
	// Вычисляем номер строки начала операторов.
	НомерСтрокиНачалаОбласти = Мин(
		СтруктураНомераСтрок.НачалоОператоров,
		СтруктураНомераСтрок.НачалоОбласти,
		СтруктураНомераСтрок.ПервыйКомментарий);
	
	// Вычисляем номер строки конца операторов.
	НомерСтрокиКонцаОбласти = СтруктураНомераСтрок.КонецОператоров;
	
	ДокументТекст.ВставитьСтроку(НомерСтрокиКонцаОбласти + 1, "");
	ДокументТекст.ВставитьСтроку(НомерСтрокиКонцаОбласти + 2, ТекстКонецОбласти);
	
	ДокументТекст.ВставитьСтроку(НомерСтрокиНачалаОбласти, НаименованиеОбласти);
	ДокументТекст.ВставитьСтроку(НомерСтрокиНачалаОбласти + 1, "");
	
#КонецОбласти
	
#Область УдалениеОбластиИнициализацияВВидеКомментария
	
	ТекстМодуля = ДокументТекст.ПолучитьТекст();
	ТекстМодуля = ВРег(ТекстМодуля);
	ТекстМодуля = СтрЗаменить(ТекстМодуля, Символы.Таб, "");
	ТекстМодуля = СтрЗаменить(ТекстМодуля, " ", "");
	
	МассивКомментариев = Новый Массив;
	МассивКомментариев.Добавить("// Операторы основной программы");
	МассивКомментариев.Добавить("// Раздел инициализации");
	
	Для Каждого ЭлементМассива Из МассивКомментариев Цикл
		
		СтрокаКомментария = ВРег(ЭлементМассива);
		СтрокаКомментария = СтрЗаменить(СтрокаКомментария, " ", "");
		
		НомерСимвола = СтрНайти(ТекстМодуля, СтрокаКомментария);
		Если НомерСимвола = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		// Если нашли комментарий, проверяем его.
		ТекстДоСимвола = Лев(ТекстМодуля, НомерСимвола);
		НомерСтроки = СтрЧислоСтрок(ТекстДоСимвола);
		
		СтрокаМодуля = ДокументТекст.ПолучитьСтроку(НомерСтроки);
		СтрокаМодуля = ВРег(СтрокаМодуля);
		СтрокаМодуля = СтрЗаменить(СтрокаМодуля, " ", "");
		СтрокаМодуля = СтрЗаменить(СтрокаМодуля, Символы.Таб, "");
		СтрокаМодуля = СтрЗаменить(СтрокаМодуля, ".", "");
		
		Если СтрокаКомментария <> СтрокаМодуля Тогда
			Продолжить;
		КонецЕсли;
		
		ДокументТекст.УдалитьСтроку(НомерСтроки);
		НомерСтроки = НомерСтроки - 1;
		
		// Проверим предыдущую строку, если она состоит только их символов "/", тогда удалим ее.
		СтрокаМодуля = ДокументТекст.ПолучитьСтроку(НомерСтроки);
		СтрокаМодуля = СтрЗаменить(СтрокаМодуля, "/", "");
		Если НЕ ПустаяСтрока(СтрокаМодуля) Тогда
			Продолжить;
		КонецЕсли;
		
		ДокументТекст.УдалитьСтроку(НомерСтроки);
		
		// Как правило остается несколько пустых строк подряд, оставим только одну пустую строку.
		СтрокаМодуля = ДокументТекст.ПолучитьСтроку(НомерСтроки);
		Если НЕ ПустаяСтрока(СтрокаМодуля) Тогда
			Продолжить;
		КонецЕсли;
		
		Пока Истина Цикл
			
			НомерСтроки = НомерСтроки - 1;
			СтрокаМодуля = ДокументТекст.ПолучитьСтроку(НомерСтроки);
			
			Если НЕ ПустаяСтрока(СтрокаМодуля) Тогда
				Прервать;
			КонецЕсли;
			
			ДокументТекст.УдалитьСтроку(НомерСтроки);
			
		КонецЦикла;
		
	КонецЦикла;
	
#КонецОбласти
	
	Возврат Истина;
	
КонецФункции

Функция ПроверкаОператоровСКрайнейЛевойПозиции(ДокументТекст)
	
	ФайлИзменен = Ложь;
	
	МассивОператоров = Новый Массив;
	МассивОператоров.Добавить("КонецПроцедуры");
	МассивОператоров.Добавить("КонецФункции");
	МассивОператоров.Добавить("Процедура");
	МассивОператоров.Добавить("Функция");
	МассивОператоров.Добавить("EndProcedure");
	МассивОператоров.Добавить("EndFunction");
	МассивОператоров.Добавить("Procedure");
	МассивОператоров.Добавить("Function");
	
	МассивДирективИнструкций = Новый Массив;
	МассивДирективИнструкций.Добавить("#");
	МассивДирективИнструкций.Добавить("&");
	
	МассивТекстПерем = Новый Массив;
	МассивТекстПерем.Добавить("Перем");
	МассивТекстПерем.Добавить("Var");
	
	ДлинаСловаКонец = ?(КодОсновногоЯзыка = "ru", 5, 3);
	
	ЗакончилсяБлокПеременных = Ложь;
	КоличествоСтрок = ДокументТекст.КоличествоСтрок();
	ПозицияНеВнутриМетода = Истина;
	Для НомерСтроки = 1 По КоличествоСтрок Цикл
		
		СтрокаМодуляИсходная = ДокументТекст.ПолучитьСтроку(НомерСтроки);
		
		// Пропускаем пустые строки.
		Если ПустаяСтрока(СтрокаМодуляИсходная) Тогда
			Продолжить;
		КонецЕсли;
		
		// Пропускаем комментарии.
		СтрокаМодуля = СокрЛП(СтрокаМодуляИсходная);
		Если СтрНачинаетсяС(СтрокаМодуля, "//") Тогда
			Продолжить;
		КонецЕсли;
		
		// Проверяем операторы "Процедура", "КонецПроцедуры", "Функция", "КонецФункции".
		СтрокаМодуля = ВРег(СтрокаМодуляИсходная);
		УбратьСимволыВНачалеСтроки = Ложь;
		ВхождениеНайдено = Ложь;
		
		Для Каждого ТекущийОператор Из МассивОператоров Цикл
			
			ПозицияОператора = СтрНайти(СтрокаМодуля, ТекущийОператор);
			
			// Если текста оператора нет в строке, пропускаем.
			Если ПозицияОператора = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			СловоКонец = Лев(ТекущийОператор, ДлинаСловаКонец);
			ФлагКонецМетода = (СловоКонец = "КОНЕЦ") ИЛИ (СловоКонец = "END");
			
			// Проверяем первый символ после текста оператора.
			СимволПослеОператора = Сред(СтрокаМодуля, ПозицияОператора + СтрДлина(ТекущийОператор), 1);
			
			// Если строка не пустая, то это вхождение текста не является оператором.
			// Для операторов "КонецФункции" и "КонецПроцедуры" следующим символом может быть ";".
			Если ФлагКонецМетода Тогда
				Если НЕ ПустаяСтрока(СимволПослеОператора) И СимволПослеОператора <> ";" Тогда
					Продолжить;
				КонецЕсли;
			Иначе
				Если НЕ ПустаяСтрока(СимволПослеОператора) Тогда
					Продолжить;
				КонецЕсли;
			КонецЕсли;
			
			// Проверяем строку перед текстом оператора.
			СтрокаДо = Лев(СтрокаМодуля, ПозицияОператора - 1);
			
			// Если строка не пустая, то это вхождение текста не является оператором.
			Если НЕ ПустаяСтрока(СтрокаДо) Тогда
				Продолжить;
			КонецЕсли;
			
			
			// Если строка начинается с оператора, сдвигать влево не нужно.
			Если ПозицияОператора > 1 Тогда
				УбратьСимволыВНачалеСтроки = Истина;
			КонецЕсли;
			
			// Проставляем флаг того, что мы находимся внутри функции для корректного сдвига областей.
			Если ФлагКонецМетода Тогда
				ПозицияНеВнутриМетода = Истина;
			Иначе
				ПозицияНеВнутриМетода = Ложь;
			КонецЕсли;
			
			ЗакончилсяБлокПеременных = Истина;
			ВхождениеНайдено = Истина;
			Прервать;
			
		КонецЦикла;
		
		Если УбратьСимволыВНачалеСтроки Тогда
			НоваяСтрока = СокрЛ(СтрокаМодуляИсходная);
			ДокументТекст.ЗаменитьСтроку(НомерСтроки, НоваяСтрока);
			ФайлИзменен = Истина;
			Продолжить;
		КонецЕсли;
		
		Если ВхождениеНайдено Тогда
			Продолжить;
		КонецЕсли;
		
		
		// Проверяем объявление переменных модуля Перем.
		Если НЕ ЗакончилсяБлокПеременных Тогда
			
			УбратьСимволыВНачалеСтроки = Ложь;
			ВхождениеНайдено = Ложь;
			
			РезультатПоиска = СтрНайтиПоМассиву(СтрокаМодуля, МассивТекстПерем,,,Истина);
			ПозицияОператора = РезультатПоиска.Позиция;
			ТекстПерем = РезультатПоиска.НайденныйЭлемент;
			
			Если ПозицияОператора = 1 Тогда
				
				// Если строка начинается с оператора Перем, ничего менять не нужно.
				ВхождениеНайдено = Истина;
				
			ИначеЕсли ПозицияОператора > 1 Тогда
				
				// Проверяем строку перед текстом оператора и символ после.
				СтрокаДо = Лев(СтрокаМодуля, ПозицияОператора - 1);
				СимволПослеОператора = Сред(СтрокаМодуля, ПозицияОператора + СтрДлина(ТекстПерем), 1);
				
				// Если строка до текста оператора пустая и первый символ после него незначащий, то это вхождение оператора.
				Если ПустаяСтрока(СтрокаДо) Тогда
					ВхождениеНайдено = Истина;
					Если ПустаяСтрока(СимволПослеОператора) Тогда
						УбратьСимволыВНачалеСтроки = Истина;
					КонецЕсли;
				КонецЕсли;
				
			КонецЕсли;
			
			Если УбратьСимволыВНачалеСтроки Тогда
				НоваяСтрока = СокрЛ(СтрокаМодуляИсходная);
				ДокументТекст.ЗаменитьСтроку(НомерСтроки, НоваяСтрока);
				ФайлИзменен = Истина;
				Продолжить;
			КонецЕсли;
			
			Если ВхождениеНайдено Тогда
				Продолжить;
			КонецЕсли;
			
		КонецЕсли;
		
		
		// Проверяем директивы компилятора (&НаКлиенте, &НаСервере и т.д.)
		// и инструкции препроцессора (#Область, #КонецОбласти).
		ИзмененнаяСтрока = СтрокаМодуляИсходная;
		СтрокаИзменена = Ложь;
		
		Для Каждого ТекущийСимвол Из МассивДирективИнструкций Цикл
			
			ПозицияСимвола = СтрНайти(СтрокаМодуля, ТекущийСимвол);
			
			// Если символа нет в строке, пропускаем.
			Если ПозицияСимвола = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			// Проверяем строку перед текстом оператора.
			СтрокаДо = Лев(СтрокаМодуля, ПозицияСимвола - 1);
			// Если строка не пустая, то это вхождение текста не является директивой или инструкцией.
			Если НЕ ПустаяСтрока(СтрокаДо) Тогда
				Продолжить;
			КонецЕсли;
			
			// Проверяем незначащие символы после искомого текста.
			ПозицияТекущегоСимвола = ПозицияСимвола + 1;
			НуженСдвигВлево = Ложь;
			
			Пока Истина Цикл
				
				// Если дошли до конца строки, выходим из цикла.
				Если ПозицияТекущегоСимвола > СтрДлина(СтрокаМодуля) Тогда
					Прервать;
				КонецЕсли;
				
				СимволВСтроке = Сред(СтрокаМодуля, ПозицияТекущегоСимвола, 1);
				ПозицияТекущегоСимвола = ПозицияТекущегоСимвола + 1;
				
				// Если встретили значащий символ или дошли до конца строки, прерываем цикл.
				Если НЕ ПустаяСтрока(СимволВСтроке) Тогда
					Прервать;
				КонецЕсли;
				
				ИзмененнаяСтрока = СтрокаДо + ТекущийСимвол + Прав(ИзмененнаяСтрока, СтрДлина(ИзмененнаяСтрока) - 2 - СтрДлина(СтрокаДо));
				
				СтрокаИзменена = Истина;
				
			КонецЦикла;
			
			// Убираем незначащие символы слева, если это необходимо.
			Если ПозицияСимвола > 1 Тогда
				
				Если ТекущийСимвол = "#" Тогда
					
					НуженСдвигВлево = ПозицияНеВнутриМетода;
					
				ИначеЕсли ТекущийСимвол = "&" Тогда
					
					НуженСдвигВлево = Истина;
					
				КонецЕсли;
				
				Если НуженСдвигВлево Тогда
					ИзмененнаяСтрока = СокрЛ(ИзмененнаяСтрока);
					СтрокаИзменена = Истина;
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
		
		Если СтрокаИзменена Тогда
			ДокументТекст.ЗаменитьСтроку(НомерСтроки, ИзмененнаяСтрока);
			ФайлИзменен = Истина;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ФайлИзменен;
	
КонецФункции

Функция УдалитьПустыеОбластиНижнегоУровня(ДокументТекст)
	
	ФайлИзменен = Ложь;
	
	КоличествоСтрок = ДокументТекст.КоличествоСтрок();
	Если КоличествоСтрок = 0 Тогда
		Возврат ФайлИзменен;
	КонецЕсли;
	
	ДеревоОбластей = Новый ДеревоЗначений;
	ДеревоОбластей.Колонки.Добавить("ЭтоОбласть");
	ДеревоОбластей.Колонки.Добавить("НомерСтрокиНачало");
	ДеревоОбластей.Колонки.Добавить("НомерСтрокиКонец");
	
	МассивТекстОбласть      = Контекст["МассивТекстОбласть"];
	МассивТекстКонецОбласти = Контекст["МассивТекстКонецОбласти"];
	
	ТекущаяОбласть = ДеревоОбластей.Строки.Добавить();
	ТекущаяОбласть.ЭтоОбласть = Ложь;
	ТекущаяОбласть.НомерСтрокиНачало = 0;
	ТекущаяОбласть.НомерСтрокиКонец = 0;
	
	Для НомерСтроки = 1 По КоличествоСтрок Цикл
		
		СтрокаМодуля = ДокументТекст.ПолучитьСтроку(НомерСтроки);
		
		// Пропускаем пустые строки.
		Если ПустаяСтрока(СтрокаМодуля) Тогда
			Продолжить;
		КонецЕсли;
		
		// Пропускаем комментарии.
		СтрокаМодуля = СокрЛ(СтрокаМодуля);
		Если СтрНачинаетсяС(СтрокаМодуля, "//") Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаМодуля = СтрЗаменить(СтрокаМодуля, " ", "");
		СтрокаМодуля = СтрЗаменить(СтрокаМодуля, Символы.Таб, "");
		СтрокаМодуля = ВРег(СтрокаМодуля);
		
		// Проверяем, что находится в начале строки.
		Если СтрНачинаетсяСПоМассиву(СтрокаМодуля, МассивТекстОбласть).Успешно Тогда
			// Если область, то добавляем строку в дерево областей.
			ТекущаяОбласть = ТекущаяОбласть.Строки.Добавить();
			ТекущаяОбласть.ЭтоОбласть = Истина;
			ТекущаяОбласть.НомерСтрокиНачало = НомерСтроки;
		ИначеЕсли СтрНачинаетсяСПоМассиву(СтрокаМодуля, МассивТекстКонецОбласти).Успешно Тогда
			// Если конец области, то закрываем текущую область в дереве областей.
			ТекущаяОбласть.НомерСтрокиКонец = НомерСтроки;
			
			// Переопределяем текущую область как родителя области.
			СтрокаРодителя = ТекущаяОбласть.Родитель;
			Если СтрокаРодителя <> Неопределено Тогда
				// Устанавливаем родителя, если это не корень дерева значений.
				ТекущаяОбласть = СтрокаРодителя;
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла;
	
	Если ДеревоОбластей.Строки.Количество() = 0 Тогда
		Возврат ФайлИзменен;
	КонецЕсли;
	
	// Получим таблицу областей из дерева значений.
	ТаблицаОбластей = Новый ТаблицаЗначений;
	ТаблицаОбластей.Колонки.Добавить("НомерСтрокиНачало");
	ТаблицаОбластей.Колонки.Добавить("НомерСтрокиКонец");
	
	// Заполним массив всеми строками дерева значений.
	ПараметрыОтбора = Новый Структура("ЭтоОбласть", Истина);
	МассивСтрокОбластей = ДеревоОбластей.Строки.НайтиСтроки(ПараметрыОтбора, Истина);
	
	// Заполним таблицу областей по массиву строк дерева значений.
	Для Каждого СтрокаОбласти Из МассивСтрокОбластей Цикл
		НоваяОбласть = ТаблицаОбластей.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяОбласть, СтрокаОбласти);
		
		Если НЕ ЗначениеЗаполнено(НоваяОбласть.НомерСтрокиКонец) Тогда
			НоваяОбласть.НомерСтрокиКонец = КоличествоСтрок;
		КонецЕсли;
	КонецЦикла;
	
	// Добавим колонку - флаг пустоты области.
	ТаблицаОбластей.Колонки.Добавить("ОбластьПустая");
	
	// Заполним колонку "ОбластьПустая" по тексту документа.
	Для Каждого СтрокаОбласти Из ТаблицаОбластей Цикл
		
		НомерСтрокиНачало = СтрокаОбласти.НомерСтрокиНачало;
		НомерСтрокиКонец = СтрокаОбласти.НомерСтрокиКонец;
		
		ОбластьПустая = Истина;
		Для НомерСтроки = НомерСтрокиНачало + 1 По НомерСтрокиКонец - 1 Цикл
			
			СтрокаМодуляИсходная = ДокументТекст.ПолучитьСтроку(НомерСтроки);
			
			// Пропускаем пустые строки.
			Если ПустаяСтрока(СтрокаМодуляИсходная) Тогда
				Продолжить;
			КонецЕсли;
			
			// Пропускаем комментарии.
			СтрокаМодуля = СокрЛ(СтрокаМодуляИсходная);
			Если СтрНачинаетсяС(СтрокаМодуля, "//") Тогда
				Продолжить;
			КонецЕсли;
			
			ОбластьПустая = Ложь;
			Прервать;
			
		КонецЦикла;
		
		СтрокаОбласти.ОбластьПустая = ОбластьПустая;
		
	КонецЦикла;
	
	// Делаем отбор по пустым областям.
	ПараметрыОтбора = Новый Структура("ОбластьПустая", Истина);
	ТаблицаПустыхОбластей = ТаблицаОбластей.Скопировать(ПараметрыОтбора);
	
	Если ТаблицаПустыхОбластей.Количество() = 0 Тогда
		Возврат ФайлИзменен;
	КонецЕсли;
	
	ФайлИзменен = Истина;
	
	ТаблицаПустыхОбластей.Сортировать("НомерСтрокиКонец Убыв, НомерСтрокиНачало Убыв");
	Для Каждого СтрокаОбласти Из ТаблицаПустыхОбластей Цикл
		
		НомерСтрокиНачало = СтрокаОбласти.НомерСтрокиНачало;
		НомерСтрокиКонец = СтрокаОбласти.НомерСтрокиКонец;
		
		Для НомерСтроки = НомерСтрокиНачало По НомерСтрокиКонец Цикл
			// Удаляем одну и ту же строку, т.к. номер строки будет сдвигаться.
			ДокументТекст.УдалитьСтроку(НомерСтрокиНачало);
		КонецЦикла;
		
		// Остается лишняя пустая строка.
		СтрокаМодуля = ДокументТекст.ПолучитьСтроку(НомерСтрокиНачало - 1);
		Если ПустаяСтрока(СтрокаМодуля) И (НомерСтрокиНачало > 1) Тогда
			// Если пустая строка до начала области, то удалим ее.
			ДокументТекст.УдалитьСтроку(НомерСтрокиНачало - 1);
		Иначе
			// Иначе удалим строку после конца области.
			СтрокаМодуля = ДокументТекст.ПолучитьСтроку(НомерСтрокиНачало);
			Если ПустаяСтрока(СтрокаМодуля) Тогда
				ДокументТекст.УдалитьСтроку(НомерСтрокиНачало);
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ФайлИзменен;
	
КонецФункции

Функция УдалитьПустыеОбласти(ДокументТекст)
	
	ФайлИзменен = Ложь;
	
	Пока Истина Цикл
		
		Если УдалитьПустыеОбластиНижнегоУровня(ДокументТекст) Тогда
			ФайлИзменен = Истина;
			Продолжить;
		КонецЕсли;
		
		Прервать;
		
	КонецЦикла;
	
	Возврат ФайлИзменен;
	
КонецФункции

Функция ЗаключитьМодульВИнструкциюПрепроцессора(ДокументТекст, ПолноеИмяФайла)
	
	ФайлИзменен = Ложь;
	
	ТекстМодуля = ДокументТекст.ПолучитьТекст();
	Если ПустаяСтрока(ТекстМодуля) Тогда
		Возврат ФайлИзменен;
	КонецЕсли;
	
	// Если модуль не содержит кода, кроме инструкции и комментариев, то очищаем модуль.
	Если НЕ МодульСодержитКод(ТекстМодуля) Тогда
		ДокументТекст.Очистить();
		ФайлИзменен = Истина;
		Возврат ФайлИзменен;
	КонецЕсли;
	
	МассивОбрабатываемыхМодулей = Новый Массив;
	МассивОбрабатываемыхМодулей.Добавить("ManagerModule");
	МассивОбрабатываемыхМодулей.Добавить("ObjectModule");
	МассивОбрабатываемыхМодулей.Добавить("RecordSetModule");
	МассивОбрабатываемыхМодулей.Добавить("ValueManagerModule");
	МассивОбрабатываемыхМодулей.Добавить("SessionModule");
	
	ИмяФайла = ПолучитьИмяФайлаБезРасширения(ПолноеИмяФайла);
	
	Если МассивОбрабатываемыхМодулей.Найти(ИмяФайла) = Неопределено Тогда
		Возврат ФайлИзменен;
	КонецЕсли;
	
	Если ИмяФайла = "ManagerModule" Тогда
		ФайлИзменен = ЗаключитьМодульМенеджераВИнструкциюПрепроцессора(ДокументТекст);
	ИначеЕсли ИмяФайла = "SessionModule" Тогда
		ФайлИзменен = ЗаключитьМодульСеансаВИнструкциюПрепроцессора(ДокументТекст);
	Иначе
		ФайлИзменен = ЗаключитьМодульОбъектаВИнструкциюПрепроцессора(ДокументТекст);
	КонецЕсли;
	
	Возврат ФайлИзменен;
	
КонецФункции

Функция ДобавитьИнструкциюПрепроцессора(ДокументТекст, ДобавитьИсключение = Ложь)
	
	ФайлИзменен = Ложь;
	
	ТекстМодуля = СокрЛП(ДокументТекст.ПолучитьТекст());
	ДокументТекст.УстановитьТекст(ТекстМодуля);
	
	ИскомаяИнструкция = НСтр("ru='#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда';
		|en='#If Server Or ThickClientOrdinaryApplication Or ExternalConnection Then'", КодОсновногоЯзыка);
	ИскомаяИнструкцияВРег = ВРег(ИскомаяИнструкция);
	ИскомаяИнструкцияВРег = СтрЗаменить(ИскомаяИнструкцияВРег, " ", "");
	
	ТаблицаИнструкций = ПолучитьТаблицуИнструкцийПрепроцессора(ТекстМодуля, Истина);
	
	// Ищем инструкцию в таблице всех инструкций.
	СтрокаИнструкции = ТаблицаИнструкций.Найти(ИскомаяИнструкцияВРег);
	Если СтрокаИнструкции <> Неопределено Тогда
		Возврат ФайлИзменен;
	КонецЕсли;
	
	// Если инструкции нет, то оборачиваем в нее весь модуль. Для этого ищем первую непустую строку, комментарии пропускаем.
	НомерСтроки = 1;
	МодульСодержитКод = Ложь;
	КоличествоСтрок = ДокументТекст.КоличествоСтрок();
	Для Счетчик = 1 По КоличествоСтрок Цикл
		
		СтрокаМодуля = ДокументТекст.ПолучитьСтроку(Счетчик);
		Если ПустаяСтрока(СтрокаМодуля) Тогда
			Продолжить;
		КонецЕсли;
		
		Если СтрНачинаетсяС(СокрЛ(СтрокаМодуля), "//") Тогда
			Продолжить;
		КонецЕсли;
		
		МодульСодержитКод = Истина;
		НомерСтроки = Счетчик;
		Прервать;
		
	КонецЦикла;
	
	Если МодульСодержитКод Тогда
		// Добавляем инструкцию в первую непустую строку.
		ДокументТекст.ВставитьСтроку(НомерСтроки, ИскомаяИнструкция);
		ДокументТекст.ВставитьСтроку(НомерСтроки + 1, "");
	Иначе
		// Если в модуле кода нет, то добавляем в конец модуля.
		ДокументТекст.ДобавитьСтроку("");
		ДокументТекст.ДобавитьСтроку(ИскомаяИнструкция);
	КонецЕсли;
	
	ДокументТекст.ДобавитьСтроку("");
	
	Если ДобавитьИсключение Тогда
		ДокументТекст.ДобавитьСтроку(НСтр("ru='#Иначе'; en='#Else'", КодОсновногоЯзыка));
		ДокументТекст.ДобавитьСтроку(НСтр("ru='ВызватьИсключение НСтр(""ru = 'Недопустимый вызов объекта на клиенте.'"");';
			|en='Raise NStr(""en = 'Invalid object call on the client."");'", КодОсновногоЯзыка));
	КонецЕсли;
	
	ДокументТекст.ДобавитьСтроку(НСтр("ru='#КонецЕсли'; en='#EndIf'", КодОсновногоЯзыка));
	
	ТекстМодуля = СокрЛП(ДокументТекст.ПолучитьТекст());
	ДокументТекст.УстановитьТекст(ТекстМодуля);
	
	ФайлИзменен = Истина;
	
	Возврат ФайлИзменен;
	
КонецФункции

Функция ЗаключитьМодульМенеджераВИнструкциюПрепроцессора(ДокументТекст)
	
	// В модуле менеджера только добавляем инструкцию, если ее не было.
	ФайлИзменен = Ложь;
	
	ТекстМодуля = СокрЛП(ДокументТекст.ПолучитьТекст());
	ДокументТекст.УстановитьТекст(ТекстМодуля);
	
	ИскомаяИнструкция = НСтр("ru='#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда';
		|en='#If Server Or ThickClientOrdinaryApplication Or ExternalConnection Then'", КодОсновногоЯзыка);
	ИскомаяИнструкцияВРег = ВРег(ИскомаяИнструкция);
	ИскомаяИнструкцияВРег = СтрЗаменить(ИскомаяИнструкцияВРег, " ", "");
	
	ТаблицаИнструкций = ПолучитьТаблицуИнструкцийПрепроцессора(ТекстМодуля, Истина);
	
	// Ищем инструкцию в таблице всех инструкций.
	СтрокаИнструкции = ТаблицаИнструкций.Найти(ИскомаяИнструкцияВРег);
	Если СтрокаИнструкции <> Неопределено Тогда
		Возврат ФайлИзменен;
	КонецЕсли;
	
	// Если в модуле нет других процедур, кроме ОбработкаПолученияПредставления и ОбработкаПолученияПолейПредставления,
	// то инструкцию препроцессора не добавляем.
	ТекстОбработкаПолученияПредставления = ВРег(НСтр("ru='ОбработкаПолученияПредставления';
		|en='PresentationGetProcessing'", КодОсновногоЯзыка));
	ТекстОбработкаПолученияПолейПредставления = ВРег(НСтр("ru='ОбработкаПолученияПолейПредставления';
		|en='PresentationFieldsGetProcessing'", КодОсновногоЯзыка));
	
	ТаблицаМетодов = ПолучитьТаблицуПроцедурИФункций(ТекстМодуля);
	СтрокаОбработкиПолученияПредставления = ТаблицаМетодов.Найти(ТекстОбработкаПолученияПредставления, "ИмяМетодаВРег");
	СтрокаОбработкиПолученияПолейПредставления = ТаблицаМетодов.Найти(ТекстОбработкаПолученияПолейПредставления, "ИмяМетодаВРег");
	
	Если (ТаблицаМетодов.Количество() = 1
		И (СтрокаОбработкиПолученияПредставления <> Неопределено ИЛИ СтрокаОбработкиПолученияПолейПредставления <> Неопределено))
		ИЛИ (ТаблицаМетодов.Количество() = 2
		И СтрокаОбработкиПолученияПредставления <> Неопределено И СтрокаОбработкиПолученияПолейПредставления <> Неопределено) Тогда
		Возврат ФайлИзменен;
	КонецЕсли;
	
	ТекстКонецЕсли = НСтр("ru='#КонецЕсли'; en='#EndIf'", КодОсновногоЯзыка);
	
	// Если модуль не содержит кода, то добавляем инструкцию в конец модуля.
	Если ТаблицаМетодов.Количество() = 0 Тогда
		ДокументТекст.ДобавитьСтроку("");
		ДокументТекст.ДобавитьСтроку(ИскомаяИнструкция);
		ДокументТекст.ДобавитьСтроку("");
		ДокументТекст.ДобавитьСтроку(ТекстКонецЕсли);
	КонецЕсли;
	
	МассивМетодовИсключений = Новый Массив;
	Если СтрокаОбработкиПолученияПредставления <> Неопределено Тогда
		МассивМетодовИсключений.Добавить(СтрокаОбработкиПолученияПредставления.ИмяМетодаВРег);
	КонецЕсли;
	
	Если СтрокаОбработкиПолученияПолейПредставления <> Неопределено Тогда
		МассивМетодовИсключений.Добавить(СтрокаОбработкиПолученияПолейПредставления.ИмяМетодаВРег);
	КонецЕсли;
	
	// Строим дерево областей и методов модуля.
	// Данное дерево необходимо для анализа мест, в которые необходимо добавить инструкции,
	// избежав оборачивание в инструкции исключаемых методов.
	ДеревоОбластейИМетодов = Новый ДеревоЗначений;
	ДеревоОбластейИМетодов.Колонки.Добавить("ТипЭлемента");
	ДеревоОбластейИМетодов.Колонки.Добавить("НомерСтрокиНачало");
	ДеревоОбластейИМетодов.Колонки.Добавить("НомерСтрокиКонец");
	ДеревоОбластейИМетодов.Колонки.Добавить("ЭтоМетодИсключение");
	ДеревоОбластейИМетодов.Колонки.Добавить("НачалоИнструкции");
	ДеревоОбластейИМетодов.Колонки.Добавить("КонецИнструкции");
	
	МассивТекстПроцедураФункция      = Контекст["МассивТекстПроцедураФункция"];
	МассивТекстКонецПроцедурыФункции = Контекст["МассивТекстКонецПроцедурыФункции"];
	МассивТекстОбласть               = Контекст["МассивТекстОбласть"];
	МассивТекстКонецОбласти          = Контекст["МассивТекстКонецОбласти"];
	
	ТекущаяСтрокаДерева = ДеревоОбластейИМетодов;
	ТекущаяСтрокаМетода = Неопределено;
	
	КоличествоСтрок = ДокументТекст.КоличествоСтрок();
	Для НомерСтроки = 1 По КоличествоСтрок Цикл
		
		СтрокаМодуля = ДокументТекст.ПолучитьСтроку(НомерСтроки);
		Если ПустаяСтрока(СтрокаМодуля) Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаМодуляВРег = ВРег(СокрЛ(СтрокаМодуля));
		СтрокаМодуляВРег = СтрЗаменить(СтрокаМодуляВРег, "	", " ");
		
		Если СтрНачинаетсяС(СтрокаМодуляВРег, "//") Тогда
			Продолжить;
		КонецЕсли;
		
		Если СтрНачинаетсяСПоМассиву(СтрокаМодуляВРег, МассивТекстОбласть).Успешно Тогда
			ТекущаяСтрокаДерева = ТекущаяСтрокаДерева.Строки.Добавить();
			ТекущаяСтрокаДерева.ТипЭлемента = "Область";
			ТекущаяСтрокаДерева.НомерСтрокиНачало = НомерСтроки;
			ТекущаяСтрокаДерева.ЭтоМетодИсключение = Ложь;
		ИначеЕсли СтрНачинаетсяСПоМассиву(СтрокаМодуляВРег, МассивТекстКонецОбласти).Успешно Тогда
			Если ТекущаяСтрокаДерева = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			ТекущаяСтрокаДерева.НомерСтрокиКонец = НомерСтроки;
			ТекущаяСтрокаДерева = ТекущаяСтрокаДерева.Родитель;
			Если ТекущаяСтрокаДерева = Неопределено Тогда
				ТекущаяСтрокаДерева = ДеревоОбластейИМетодов;
			КонецЕсли;
		ИначеЕсли СтрНачинаетсяСПоМассиву(СтрокаМодуляВРег, МассивТекстПроцедураФункция).Успешно Тогда
			НайденныйЭлемент = СтрНачинаетсяСПоМассиву(СтрокаМодуляВРег, МассивТекстПроцедураФункция).НайденныйЭлемент;
			ИмяМетода = Сред(СтрокаМодуляВРег, СтрДлина(НайденныйЭлемент) + 1);
			ПозицияСкобки = СтрНайти(ИмяМетода, "(");
			Если ПозицияСкобки > 0 Тогда
				ИмяМетода = Лев(ИмяМетода, ПозицияСкобки - 1);
			КонецЕсли;
			
			ТекущаяСтрокаМетода = ТекущаяСтрокаДерева.Строки.Добавить();
			ТекущаяСтрокаМетода.ТипЭлемента = "Метод";
			ТекущаяСтрокаМетода.НомерСтрокиНачало = НомерСтроки;
			ТекущаяСтрокаМетода.ЭтоМетодИсключение = (МассивМетодовИсключений.Найти(ИмяМетода) <> Неопределено);
		ИначеЕсли СтрНачинаетсяСПоМассиву(СтрокаМодуляВРег, МассивТекстКонецПроцедурыФункции).Успешно Тогда
			Если ТекущаяСтрокаМетода = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			ТекущаяСтрокаМетода.НомерСтрокиКонец = НомерСтроки;
		КонецЕсли;
	КонецЦикла;
	
	// Определим области, которые включают в себя исключаемые методы.
	СтруктураОтбора = Новый Структура;
	СтруктураОтбора.Вставить("ЭтоМетодИсключение", Истина);
	
	МассивСтрокИсключений = ДеревоОбластейИМетодов.Строки.НайтиСтроки(СтруктураОтбора, Истина);
	Для Каждого СтрокаИсключения Из МассивСтрокИсключений Цикл
		ТекущаяСтрока = СтрокаИсключения;
		Пока Истина Цикл
			Если ТекущаяСтрока = Неопределено Тогда
				Прервать;
			КонецЕсли;
			ТекущаяСтрока.ЭтоМетодИсключение = Истина;
			ТекущаяСтрока = ТекущаяСтрока.Родитель;
		КонецЦикла;
	КонецЦикла;
	
	// Рекурсивная определение мест, в которые необходимо установить инструкции.
	ЗаполнитьМестаДляИнструкций(ДеревоОбластейИМетодов.Строки);
	
	// Добавление строк инструкций в текст модуля.
	СтруктураОтбора = Новый Структура;
	СтруктураОтбора.Вставить("НачалоИнструкции", Истина);
	МассивСтрокДерева = ДеревоОбластейИМетодов.Строки.НайтиСтроки(СтруктураОтбора, Истина);
	КоличествоДобавленныхИнструкций = 0;
	Для Каждого СтрокаДерева Из МассивСтрокДерева Цикл
		НомерСтроки = СтрокаДерева.НомерСтрокиНачало + КоличествоДобавленныхИнструкций;
		ДокументТекст.ВставитьСтроку(НомерСтроки, ИскомаяИнструкция);
		ДокументТекст.ВставитьСтроку(НомерСтроки + 1, "");
		
		КоличествоДобавленныхИнструкций = КоличествоДобавленныхИнструкций + 2;
		
		СтрокаРодителя = СтрокаДерева.Родитель;
		Если СтрокаРодителя = Неопределено Тогда
			СтрокаРодителя = ДеревоОбластейИМетодов;
		КонецЕсли;
		
		// Ищем ближайшую строку, после которой необходимо закрыть установленную инструкцию.
		НайденаТекущаяСтрока = Ложь;
		Для Каждого Строка Из СтрокаРодителя.Строки Цикл
			Если СтрокаДерева = Строка Тогда
				НайденаТекущаяСтрока = Истина;
			КонецЕсли;
			
			Если НЕ НайденаТекущаяСтрока Тогда
				Продолжить;
			КонецЕсли;
			
			Если Строка.КонецИнструкции = Истина Тогда
				НомерСтроки = Строка.НомерСтрокиКонец + КоличествоДобавленныхИнструкций;
				ДокументТекст.ВставитьСтроку(НомерСтроки + 1, "");
				ДокументТекст.ВставитьСтроку(НомерСтроки + 2, ТекстКонецЕсли);
				КоличествоДобавленныхИнструкций = КоличествоДобавленныхИнструкций + 2;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	Если КоличествоДобавленныхИнструкций > 0 Тогда
		ФайлИзменен = Истина;
	КонецЕсли;
	
	Возврат ФайлИзменен;
	
КонецФункции

// Выполняет рекурсивное заполнение колонок "НачалоИнструкции" и "КонецИнструкции" дерева областей и методов.
//
Процедура ЗаполнитьМестаДляИнструкций(КоллекцияСтрокДерева)
	
	МассивОбластейБезИсключений = Новый Массив;
	Для Каждого СтрокаДерева Из КоллекцияСтрокДерева Цикл
		Если СтрокаДерева.ЭтоМетодИсключение Тогда
			Если МассивОбластейБезИсключений.Количество() > 0 Тогда
				МассивОбластейБезИсключений[0].НачалоИнструкции = Истина;
				МассивОбластейБезИсключений[МассивОбластейБезИсключений.ВГраница()].КонецИнструкции = Истина;
				
				МассивОбластейБезИсключений.Очистить();
			КонецЕсли;
			
			ЗаполнитьМестаДляИнструкций(СтрокаДерева.Строки)
		Иначе
			МассивОбластейБезИсключений.Добавить(СтрокаДерева);
		КонецЕсли;
	КонецЦикла;
	
	Если МассивОбластейБезИсключений.Количество() > 0 Тогда
		МассивОбластейБезИсключений[0].НачалоИнструкции = Истина;
		МассивОбластейБезИсключений[МассивОбластейБезИсключений.ВГраница()].КонецИнструкции = Истина;
		
		МассивОбластейБезИсключений.Очистить();
	КонецЕсли;
	
КонецПроцедуры

Функция ЗаключитьМодульСеансаВИнструкциюПрепроцессора(ДокументТекст)
	
	ФайлИзменен = ДобавитьИнструкциюПрепроцессора(ДокументТекст);
	Если ФайлИзменен Тогда
		Возврат ФайлИзменен;
	КонецЕсли;
	
	ТекстМодуля = СокрП(ДокументТекст.ПолучитьТекст());
	ДокументТекст.УстановитьТекст(ТекстМодуля);
	
	// Удаляем комментарии из модуля.
	ТекстМодуля = ПолучитьТекстМодуляБезКомментариев(ТекстМодуля);
	
	ИскомаяИнструкция = НСтр("ru='#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда';
		|en='#If Server Or ThickClientOrdinaryApplication Or ExternalConnection Then'", КодОсновногоЯзыка);
	ИскомаяИнструкцияВРег = ВРег(ИскомаяИнструкция);
	ИскомаяИнструкцияВРег = СтрЗаменить(ИскомаяИнструкцияВРег, " ", "");
	
	ТаблицаИнструкций = ПолучитьТаблицуИнструкцийПрепроцессора(ТекстМодуля, Истина);
	
	// Ищем инструкцию в таблице всех инструкций.
	// Добавляли раньше, поэтому инструкция должна быть.
	СтрокаИнструкции = ТаблицаИнструкций.Найти(ИскомаяИнструкцияВРег);
	Если СтрокаИнструкции = Неопределено Тогда
		Возврат ФайлИзменен;
	КонецЕсли;
	
	// Если инструкция есть, то проверяем, что она начинается в начале и заканчивается в конце модуля.
	// Сначала проверяем текст после окончания инструкции, чтобы не слетели позиции начала и окончания.
	ПозицияКонецЕсли = СтрокаИнструкции.ПозицияКонецЕсли;
	ТекстКонецЕсли = СтрокаИнструкции.ТекстКонецЕсли;
	ТекстПосле = Сред(ТекстМодуля, ПозицияКонецЕсли + СтрДлина(ТекстКонецЕсли));
	Если НЕ ПустаяСтрока(ТекстПосле) Тогда
		
		// Если после инструкции есть какой-либо текст, то переносим окончание инструкции в конец модуля.
		НомерСтроки = ПолучитьНомерСтрокиМодуля(ТекстМодуля, ПозицияКонецЕсли);
		ДокументТекст.УдалитьСтроку(НомерСтроки);
		
		// Проверяем следующую строку, если пустая, то удаляем.
		Если ПустаяСтрока(ДокументТекст.ПолучитьСтроку(НомерСтроки)) Тогда
			ДокументТекст.УдалитьСтроку(НомерСтроки);
		КонецЕсли;
		
		// Добавляем окончание инструкции в конец модуля.
		СтрокаМодуля = ДокументТекст.ПолучитьСтроку(ДокументТекст.КоличествоСтрок());
		Если НЕ ПустаяСтрока(СтрокаМодуля) Тогда
			ДокументТекст.ДобавитьСтроку("");
		КонецЕсли;
		ДокументТекст.ДобавитьСтроку(НСтр("ru='#КонецЕсли'; en='#EndIf'", КодОсновногоЯзыка));
		
		ФайлИзменен = Истина;
		
	КонецЕсли;
	
	ПозицияЕсли = СтрокаИнструкции.ПозицияЕсли;
	ТекстДо = Лев(ТекстМодуля, ПозицияЕсли - 1);
	Если НЕ ПустаяСтрока(ТекстДо) Тогда
		
		// Если до инструкции есть какой-либо текст, то переносим инструкцию в начало модуля.
		НомерСтроки = ПолучитьНомерСтрокиМодуля(ТекстМодуля, ПозицияЕсли);
		ДокументТекст.УдалитьСтроку(НомерСтроки);
		
		// Проверяем следующую строку, если пустая, то удаляем.
		Если ПустаяСтрока(ДокументТекст.ПолучитьСтроку(НомерСтроки)) Тогда
			ДокументТекст.УдалитьСтроку(НомерСтроки);
		КонецЕсли;
		
		// Ищем первую непустую строку, комментарии пропускаем.
		КоличествоСтрок = ДокументТекст.КоличествоСтрок();
		Для Счетчик = 1 По КоличествоСтрок Цикл
			
			СтрокаМодуля = ДокументТекст.ПолучитьСтроку(Счетчик);
			Если ПустаяСтрока(СтрокаМодуля) Тогда
				Продолжить;
			КонецЕсли;
			
			Если СтрНачинаетсяС(СокрЛ(СтрокаМодуля), "//") Тогда
				Продолжить;
			КонецЕсли;
			
			НомерСтроки = Счетчик;
			Прервать;
			
		КонецЦикла;
		
		ДокументТекст.ВставитьСтроку(НомерСтроки, "");
		ДокументТекст.ВставитьСтроку(НомерСтроки, ИскомаяИнструкция);
		
		ФайлИзменен = Истина;
		
	КонецЕсли;
	
	Возврат ФайлИзменен;
	
КонецФункции

Функция ЗаключитьМодульОбъектаВИнструкциюПрепроцессора(ДокументТекст)
	
	ФайлИзменен = ДобавитьИнструкциюПрепроцессора(ДокументТекст, Истина);
	Если ФайлИзменен Тогда
		Возврат ФайлИзменен;
	КонецЕсли;
	
	ТекстМодуля = СокрП(ДокументТекст.ПолучитьТекст());
	ДокументТекст.УстановитьТекст(ТекстМодуля);
	
	// Удаляем комментарии из модуля.
	ТекстМодуля = ПолучитьТекстМодуляБезКомментариев(ТекстМодуля);
	
	ИскомаяИнструкция = НСтр("ru='#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда';
		|en='#If Server Or ThickClientOrdinaryApplication Or ExternalConnection Then'", КодОсновногоЯзыка);
	ИскомаяИнструкцияВРег = ВРег(ИскомаяИнструкция);
	ИскомаяИнструкцияВРег = СтрЗаменить(ИскомаяИнструкцияВРег, " ", "");
	
	ТекстИсключения = НСтр("ru='ВызватьИсключение НСтр(""ru = 'Недопустимый вызов объекта на клиенте.'"");';
		|en='Raise NStr(""en = 'Invalid object call on the client."");'", КодОсновногоЯзыка);
	ТекстИсключенияВРег = ВРег(ТекстИсключения);
	ТекстИсключенияВРег = СтрЗаменить(ТекстИсключенияВРег, " ", "");
	ТекстИсключенияВРег = СтрЗаменить(ТекстИсключенияВРег, ";", "");
	
	ТаблицаИнструкций = ПолучитьТаблицуИнструкцийПрепроцессора(ТекстМодуля, Истина);
	
	// Ищем инструкцию в таблице всех инструкций.
	// Добавляли раньше, поэтому инструкция должна быть.
	СтрокаИнструкции = ТаблицаИнструкций.Найти(ИскомаяИнструкцияВРег);
	Если СтрокаИнструкции = Неопределено Тогда
		Возврат ФайлИзменен;
	КонецЕсли;
	
	// Если инструкция есть, то проверяем, что она начинается в начале и заканчивается в конце модуля.
	// Сначала проверяем текст после окончания инструкции, чтобы не слетели позиции начала и окончания.
	ПозицияКонецЕсли = СтрокаИнструкции.ПозицияКонецЕсли;
	ТекстКонецЕсли = СтрокаИнструкции.ТекстКонецЕсли;
	ТекстПосле = Сред(ТекстМодуля, ПозицияКонецЕсли + СтрДлина(ТекстКонецЕсли));
	Если НЕ ПустаяСтрока(ТекстПосле) Тогда
		
		// Если после инструкции есть какой-либо текст, то переносим окончание инструкции в конец модуля.
		НомерСтроки = ПолучитьНомерСтрокиМодуля(ТекстМодуля, ПозицияКонецЕсли);
		ДокументТекст.УдалитьСтроку(НомерСтроки);
		
		// Добавляем окончание инструкции в конец модуля.
		СтрокаМодуля = ДокументТекст.ПолучитьСтроку(ДокументТекст.КоличествоСтрок());
		Если НЕ ПустаяСтрока(СтрокаМодуля) Тогда
			ДокументТекст.ДобавитьСтроку("");
		КонецЕсли;
		ДокументТекст.ДобавитьСтроку(ТекстКонецЕсли);
		
		ФайлИзменен = Истина;
		
	КонецЕсли;
	
	// Проверяем, было ли условие "#Иначе" в искомой инструкции.
	ДобавитьИсключение = Истина;
	ПозицияИначе = СтрокаИнструкции.ПозицияИначе;
	Если ПозицияИначе <> Неопределено Тогда
		ТекстПослеИначе = Сред(ТекстМодуля, ПозицияИначе);
		ТекстПослеИначе = ВРег(ТекстПослеИначе);
		ТекстПослеИначе = СтрЗаменить(ТекстПослеИначе, " ", "");
		ТекстПослеИначе = СтрЗаменить(ТекстПослеИначе, Символы.Таб, "");
		
		// Если исключение после "#Иначе" не найдено, то устанавливаем флаг.
		ДобавитьИсключение = (СтрНайти(ТекстПослеИначе, ТекстИсключенияВРег) = 0);
	КонецЕсли;
	
	Если ДобавитьИсключение Тогда
		
		НомерСтрокиКонецЕсли = ПолучитьНомерСтрокиМодуля(ТекстМодуля, ПозицияКонецЕсли);
		
		// Добавляем исключение.
		ДокументТекст.ВставитьСтроку(НомерСтрокиКонецЕсли, ТекстИсключения);
		
		// Если "#Иначе" не было, то добавляем.
		Если ПозицияИначе = Неопределено Тогда
			ДокументТекст.ВставитьСтроку(НомерСтрокиКонецЕсли, СтрокаИнструкции.ТекстИначе);
		КонецЕсли;
		
		ФайлИзменен = Истина;
		
	КонецЕсли;
	
	ПозицияЕсли = СтрокаИнструкции.ПозицияЕсли;
	ТекстДо = Лев(ТекстМодуля, ПозицияЕсли - 1);
	Если НЕ ПустаяСтрока(ТекстДо) Тогда
		
		// Если до инструкции есть какой-либо текст, то переносим инструкцию в начало модуля.
		НомерСтрокиЕсли = ПолучитьНомерСтрокиМодуля(ТекстМодуля, ПозицияЕсли);
		ДокументТекст.УдалитьСтроку(НомерСтрокиЕсли);
		
		// Проверяем следующую строку, если пустая, то удаляем.
		Если ПустаяСтрока(ДокументТекст.ПолучитьСтроку(НомерСтрокиЕсли)) Тогда
			ДокументТекст.УдалитьСтроку(НомерСтрокиЕсли);
		КонецЕсли;
		
		// Ищем первую непустую строку, комментарии пропускаем.
		КоличествоСтрок = ДокументТекст.КоличествоСтрок();
		Для Счетчик = 1 По КоличествоСтрок Цикл
			
			СтрокаМодуля = ДокументТекст.ПолучитьСтроку(Счетчик);
			Если ПустаяСтрока(СтрокаМодуля) Тогда
				Продолжить;
			КонецЕсли;
			
			Если СтрНачинаетсяС(СокрЛ(СтрокаМодуля), "//") Тогда
				Продолжить;
			КонецЕсли;
			
			НомерСтрокиЕсли = Счетчик;
			Прервать;
			
		КонецЦикла;
		
		ДокументТекст.ВставитьСтроку(НомерСтрокиЕсли, "");
		ДокументТекст.ВставитьСтроку(НомерСтрокиЕсли, ИскомаяИнструкция);
		
		ФайлИзменен = Истина;
		
	КонецЕсли;
	
	Возврат ФайлИзменен;
	
КонецФункции

// Удаляет преамбулу и инструкцию препроцессору.
// Возвращает Истину, если модуль содержит еще какой-либо код или другие комментарии.
//
Функция МодульСодержитКод(Знач ТекстМодуля)
	
	Если ПустаяСтрока(ТекстМодуля) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ТекстМодуля = ВРег(ТекстМодуля);
	ТекстМодуля = СтрЗаменить(ТекстМодуля, Символы.Таб, "");
	ТекстМодуля = СтрЗаменить(ТекстМодуля, " ", "");
	
	МассивИнструкций = Новый Массив;
	МассивИнструкций.Добавить("#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда");
	МассивИнструкций.Добавить("#If Server Or ThickClientOrdinaryApplication Or ExternalConnection Then");
	МассивИнструкций.Добавить("#Иначе");
	МассивИнструкций.Добавить("#Else");
	МассивИнструкций.Добавить("ВызватьИсключение НСтр(""ru = 'Недопустимый вызов объекта на клиенте.");
	МассивИнструкций.Добавить("Raise NStr(""en = 'Invalid object call on the client.");
	МассивИнструкций.Добавить("#КонецЕсли");
	МассивИнструкций.Добавить("#EndIf");
	
	Для Каждого ТекстИнструкции Из МассивИнструкций Цикл
		ТекстИнструкции = ВРег(ТекстИнструкции);
		ТекстИнструкции = СтрЗаменить(ТекстИнструкции, Символы.Таб, "");
		ТекстИнструкции = СтрЗаменить(ТекстИнструкции, " ", "");
		
		ТекстМодуля = СтрЗаменить(ТекстМодуля, ТекстИнструкции, "");
	КонецЦикла;
	
	Если ПустаяСтрока(ТекстМодуля) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	// Проверяем преамбулу.
	ТекстМодуля = СокрЛ(ТекстМодуля);
	
	// Если текст модуля не начинается с длинного комментария, тогда он не содержит преамбулу.
	ТекстСимволыНачалаПреамбулы = Контекст["ТекстСимволыНачалаПреамбулы"];
	Если НЕ СтрНачинаетсяС(ТекстМодуля, ТекстСимволыНачалаПреамбулы) Тогда
		Возврат Истина;
	КонецЕсли;
	
	ДокументТекст = Новый ТекстовыйДокумент;
	ДокументТекст.УстановитьТекст(ТекстМодуля);
	
	КоличествоСтрок = ДокументТекст.КоличествоСтрок();
	Для НомерСтроки = 1 По КоличествоСтрок Цикл
		
		СтрокаМодуля = ДокументТекст.ПолучитьСтроку(НомерСтроки);
		Если ПустаяСтрока(СтрокаМодуля) Тогда
			Прервать;
		КонецЕсли;
		
		СтрокаМодуля = СокрЛ(СтрокаМодуля);
		Если НЕ СтрНачинаетсяС(СтрокаМодуля, "//") Тогда
			Прервать;
		КонецЕсли;
		
		ДокументТекст.ЗаменитьСтроку(НомерСтроки, "");
		
	КонецЦикла;
	
	ТекстМодуля = ДокументТекст.ПолучитьТекст();
	
	Возврат НЕ ПустаяСтрока(ТекстМодуля);
	
КонецФункции

Функция УдалитьПроверкуПараметраАвтоТест(ДокументТекстИсходный, ПолноеИмяФайла)
	
	ФайлИзменен = Ложь;
	
	ТипМодуля = ПолучитьТипМодуляПоИмениФайла(ПолноеИмяФайла);
	
	// Проверяем только модули форм, объектов и наборов записей.
	МассивКонструкцийАвтоТест = Новый Массив;
	Если ТипМодуля = "МодульФормы" Тогда
		МассивКонструкцийАвтоТест.Добавить(ВРег("Если Параметры.Свойство(""АвтоТест"") Тогда"));
		МассивКонструкцийАвтоТест.Добавить(ВРег("If Parameters.Property(""AutoTest"") Then"));
		МассивКонструкцийАвтоТест.Добавить(ВРег("If Parameters.Property(""AutoTest_2"") Then"));
	ИначеЕсли (ТипМодуля = "МодульОбъекта")
		  ИЛИ (ТипМодуля = "МодульНабораЗаписей") Тогда
		МассивКонструкцийАвтоТест.Добавить(ВРег("Если ДанныеЗаполнения = ""АвтоТест"" Тогда"));
		МассивКонструкцийАвтоТест.Добавить(ВРег("If FillingData = ""AutoTest"" Then"));
	Иначе
		Возврат ФайлИзменен;
	КонецЕсли;
	
	ТекстВозврат   = Контекст["ТекстВозврат"];
	ТекстКонецЕсли = Контекст["ТекстКонецЕсли"];
	ТекстАвтоТест  = Контекст["ТекстАвтоТест"];
	
	ТекстМодуля = ДокументТекстИсходный.ПолучитьТекст();
	ТекстМодуля = СтрЗаменить(ТекстМодуля, Символы.Таб, "");
	ТекстМодуля = СтрЗаменить(ТекстМодуля, " ", "");
	ТекстМодуля = СтрЗаменить(ТекстМодуля, ";", "");
	ТекстМодуля = ВРег(ТекстМодуля);
	
	ДокументТекст = Новый ТекстовыйДокумент;
	ДокументТекст.УстановитьТекст(ТекстМодуля);
	КоличествоСтрок = ДокументТекст.КоличествоСтрок();
	
	МассивНомеровСтрокКУдалению = Новый Массив;
	
	Для Каждого КонструкцияАвтоТест Из МассивКонструкцийАвтоТест Цикл
		
		КонструкцияАвтоТест = СтрЗаменить(КонструкцияАвтоТест, " ", "");
		
		ПозицияПоиска = 0;
		Пока Истина Цикл
			
			ПозицияПоиска = СтрНайти(ТекстМодуля, КонструкцияАвтоТест,, ПозицияПоиска + 1);
			Если ПозицияПоиска = 0 Тогда
				Прервать;
			КонецЕсли;
			
			НомерСтрокиАвтоТест = ПолучитьНомерСтрокиМодуля(ТекстМодуля, ПозицияПоиска);
			СтрокаМодуляАвтоТест = ДокументТекст.ПолучитьСтроку(НомерСтрокиАвтоТест);
			
			// Если строка не начинается с искомой конструкции, пропускаем.
			Если НЕ СтрНачинаетсяС(СтрокаМодуляАвтоТест, КонструкцияАвтоТест) Тогда
				Продолжить;
			КонецЕсли;
			
			НомерСтрокиНачалоКонструкции = НомерСтрокиАвтоТест;
			
			// После конструкции может быть несколько пустых строк или строк с комментарием, ищем первую непустую.
			СтрокаМодуляВозврат = "";
			НомерСтрокиВозврат = 0;
			Для НомерСтроки = НомерСтрокиНачалоКонструкции + 1 По КоличествоСтрок Цикл
				СтрокаМодуля = ДокументТекст.ПолучитьСтроку(НомерСтроки);
				Если ПустаяСтрока(СтрокаМодуля) ИЛИ СтрНачинаетсяС(СтрокаМодуля, "//") Тогда
					Продолжить;
				КонецЕсли;
				
				НомерСтрокиВозврат = НомерСтроки;
				СтрокаМодуляВозврат = СтрокаМодуля;
				Прервать;
			КонецЦикла;
			
			Если НомерСтрокиВозврат = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			// Если строка не начинается с "Возврат", пропускаем.
			Если НЕ СтрНачинаетсяС(СтрокаМодуляВозврат, ТекстВозврат) Тогда
				Продолжить;
			КонецЕсли;
			
			// После "Возврат" может быть несколько пустых строк или строк с комментарием, ищем первую непустую.
			СтрокаМодуляКонецЕсли = "";
			НомерСтрокиКонецЕсли = 0;
			Для НомерСтроки = НомерСтрокиВозврат + 1 По КоличествоСтрок Цикл
				СтрокаМодуля = ДокументТекст.ПолучитьСтроку(НомерСтроки);
				Если ПустаяСтрока(СтрокаМодуля) ИЛИ СтрНачинаетсяС(СтрокаМодуля, "//") Тогда
					Продолжить;
				КонецЕсли;
				
				НомерСтрокиКонецЕсли = НомерСтроки;
				СтрокаМодуляКонецЕсли = СтрокаМодуля;
				Прервать;
			КонецЦикла;
			
			Если НомерСтрокиКонецЕсли = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			// Если строка не начинается с "КонецЕсли", пропускаем.
			Если НЕ СтрНачинаетсяС(СтрокаМодуляКонецЕсли, ТекстКонецЕсли) Тогда
				Продолжить;
			КонецЕсли;
			
			НомерСтрокиКонецКонструкции = НомерСтрокиКонецЕсли;
			
			// Проверяем предыдущую строку перед искомой конструкцией.
			НомерСтрокиКомментарий = НомерСтрокиАвтоТест - 1;
			СтрокаМодуляКомментарий = ДокументТекст.ПолучитьСтроку(НомерСтрокиКомментарий);
			СтрокаМодуляПередКомментарием = ДокументТекст.ПолучитьСтроку(НомерСтрокиКомментарий - 1);
			
			// Если строка модуля перед конструкцией содержит комментарий про параметр АвтоТест, то записываем строку с комментарием в массив удаляемых.
			ЕстьКомментарийПроАвтоТест = (СтрНачинаетсяС(СтрокаМодуляКомментарий, "//") И (СтрНайти(СтрокаМодуляКомментарий, ТекстАвтоТест) > 0));
			Если ЕстьКомментарийПроАвтоТест Тогда
				НомерСтрокиНачалоКонструкции = НомерСтрокиКомментарий;
			КонецЕсли;
			
			ЕстьКомментарийПроАвтоТестИПредыдущаяСтрокаПустая = (ЕстьКомментарийПроАвтоТест И ПустаяСтрока(СтрокаМодуляПередКомментарием));
			
			НомерСтрокиПослеКонецЕсли = НомерСтрокиКонецЕсли + 1;
			СтрокаМодуляПослеКонецЕсли = ДокументТекст.ПолучитьСтроку(НомерСтрокиПослеКонецЕсли);
			
			// Если до и после конструкции пустые строки, то удалим пустую строку после "КонецЕсли".
			Если ПустаяСтрока(СтрокаМодуляПослеКонецЕсли) Тогда
				Если ЕстьКомментарийПроАвтоТестИПредыдущаяСтрокаПустая ИЛИ ПустаяСтрока(СтрокаМодуляКомментарий) Тогда
					НомерСтрокиКонецКонструкции = НомерСтрокиПослеКонецЕсли;
				КонецЕсли;
			КонецЕсли;
			
			Для НомерСтроки = НомерСтрокиНачалоКонструкции По НомерСтрокиКонецКонструкции Цикл
				МассивНомеровСтрокКУдалению.Добавить(НомерСтроки);
			КонецЦикла;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Если МассивНомеровСтрокКУдалению.Количество() = 0 Тогда
		Возврат ФайлИзменен;
	КонецЕсли;
	
	ФайлИзменен = Истина;
	
	// Загрузим номера строк в таблицу, свернем и упорядочим по убыванию для правильного удаления строк из текстового документа.
	ТаблицаНомеровСтрокКУдалению = Новый ТаблицаЗначений;
	ТаблицаНомеровСтрокКУдалению.Колонки.Добавить("Номер");
	Для Каждого НомерСтроки Из МассивНомеровСтрокКУдалению Цикл
		ТаблицаНомеровСтрокКУдалению.Добавить().Номер = НомерСтроки;
	КонецЦикла;
	
	ТаблицаНомеровСтрокКУдалению.Свернуть("Номер");
	ТаблицаНомеровСтрокКУдалению.Сортировать("Номер Убыв");
	
	Для Каждого СтрокаТаблицы Из ТаблицаНомеровСтрокКУдалению Цикл
		ДокументТекстИсходный.УдалитьСтроку(СтрокаТаблицы.Номер);
	КонецЦикла;
	
	// Если файл был изменен, то проверяем и удаляем пустые процедуры и функции.
	МассивУдаленныхМетодов = УдалитьПустыеПроцедурыИФункции(ДокументТекстИсходный);
	Если МассивУдаленныхМетодов.Количество() > 0 Тогда
		ЗаписатьИзмененияВФайл(ДокументТекстИсходный, ПолноеИмяФайла);
	КонецЕсли;
	
	// Если это форма, то необходимо дополнительно удалить обработчики событий на форме в XML.
	Если ТипМодуля = "МодульФормы" Тогда
		
		// Ищем путь объекта по файлу его модуля.
		ПутьОбъекта = ПолучитьЗначениеОбъекта(ПолноеИмяФайла);
		Если НЕ ПустаяСтрока(ПутьОбъекта) Тогда
			
			ПолноеИмяФайлаОкончание = ?(ЭтоВыгрузкаXMLФайлов, СтрШаблон("%1Ext%1Form.xml", РазделительПути), РазделительПути + "Form.form");
			
			ПараметрыОтбора = Новый Структура;
			ПараметрыОтбора.Вставить("Выбран", Истина);
			ПараметрыОтбора.Вставить("ЗахваченВХранилище", Истина);
			ПараметрыОтбора.Вставить("РедактированиеРазрешено", Истина);
			ПараметрыОтбора.Вставить("ПолноеИмяФайлаОкончание", ПолноеИмяФайлаОкончание);
			
			ПолноеИмяФайлаXML = ПолучитьЗначениеОбъекта(ПутьОбъекта, "Объект", "ПолноеИмяФайла", ПараметрыОтбора);
			Если НЕ ПустаяСтрока(ПолноеИмяФайлаXML) Тогда
				Если ЭтоВыгрузкаXMLФайлов Тогда
					УдалитьОтсутствующиеОбработчикиИзСобытийФормыXML(ПолноеИмяФайлаXML, МассивУдаленныхМетодов);
				Иначе
					УдалитьОтсутствующиеОбработчикиИзСобытийФормыEDT(ПолноеИмяФайлаXML, МассивУдаленныхМетодов);
				КонецЕсли;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	УдалитьПустыеОбласти(ДокументТекстИсходный);
	
	// Если модуль не содержит кода, кроме инструкции и комментариев, то очищаем модуль.
	Если НЕ МодульСодержитКод(ДокументТекстИсходный.ПолучитьТекст()) Тогда
		ДокументТекстИсходный.Очистить();
	КонецЕсли;
	
	Возврат ФайлИзменен;
	
КонецФункции

Функция ДобавитьПустуюСтрокуМеждуОбъявлениемПодсистемыИОписаниемПроцедуры(ДокументТекст)
	
	ФайлИзменен = Ложь;
	
	КоличествоСтрок = ДокументТекст.КоличествоСтрок();
	Если КоличествоСтрок = 0 Тогда
		Возврат ФайлИзменен;
	КонецЕсли;
	
	МассивТекстОбластьДляВызоваИзДругихПодсистем = Новый Массив;
	МассивТекстОбластьДляВызоваИзДругихПодсистем.Добавить("#ОбластьДляВызоваИзДругихПодсистем");
	МассивТекстОбластьДляВызоваИзДругихПодсистем.Добавить("#RegionForCallsFromOtherSubsystems");
	
	МассивТекстОбласть          = Контекст["МассивТекстОбласть"];
	МассивТекстКонецОбласти     = Контекст["МассивТекстКонецОбласти"];
	МассивТекстПроцедураФункция = Контекст["МассивТекстПроцедураФункция"];
	
	ТекстМодуля = ДокументТекст.ПолучитьТекст();
	ТекстМодуля = СтрЗаменить(ТекстМодуля, " ", "");
	ТекстМодуля = СтрЗаменить(ТекстМодуля, Символы.Таб, "");
	ТекстМодуля = ВРег(ТекстМодуля);
	
	ПозицияПоиска = СтрНайтиПоМассиву(ТекстМодуля, МассивТекстОбластьДляВызоваИзДругихПодсистем,,, Истина).Позиция;
	Если ПозицияПоиска = 0 Тогда
		Возврат ФайлИзменен;
	КонецЕсли;
	
	НайденныйНомерСтроки = ПолучитьНомерСтрокиМодуля(ТекстМодуля, ПозицияПоиска);
	
	НайденоНачалоОбласти = Ложь;
	КоличествоВложенныхОбластей = 0;
	
	Для НомерСтроки = НайденныйНомерСтроки По КоличествоСтрок Цикл
		
		СтрокаМодуля = ДокументТекст.ПолучитьСтроку(НомерСтроки);
		
		// Пропускаем пустые строки.
		Если ПустаяСтрока(СтрокаМодуля) Тогда
			Продолжить;
		КонецЕсли;
		
		// Пропускаем комментарии.
		СтрокаМодуля = СокрЛ(СтрокаМодуля);
		Если СтрНачинаетсяС(СтрокаМодуля, "//") Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаМодуля = СтрЗаменить(СтрокаМодуля, " ", "");
		СтрокаМодуля = СтрЗаменить(СтрокаМодуля, Символы.Таб, "");
		СтрокаМодуля = ВРег(СтрокаМодуля);
		
		Если (НЕ НайденоНачалоОбласти) И СтрНачинаетсяСПоМассиву(СтрокаМодуля, МассивТекстОбластьДляВызоваИзДругихПодсистем).Успешно Тогда
			НайденоНачалоОбласти = Истина;
			Продолжить;
		КонецЕсли;
		
		Если НЕ НайденоНачалоОбласти Тогда
			Продолжить;
		КонецЕсли;
		
		Если СтрНачинаетсяСПоМассиву(СтрокаМодуля, МассивТекстКонецОбласти).Успешно Тогда
			
			Если КоличествоВложенныхОбластей = 0 Тогда
				// Конец области ДляВызоваИзДругихПодсистем.
				Прервать;
			Иначе
				// Конец вложенной области.
				КоличествоВложенныхОбластей = КоличествоВложенныхОбластей - 1;
			КонецЕсли;
		
		ИначеЕсли СтрНачинаетсяСПоМассиву(СтрокаМодуля, МассивТекстОбласть).Успешно Тогда
			// Начало вложенной области.
			КоличествоВложенныхОбластей = КоличествоВложенныхОбластей + 1;
			
		ИначеЕсли СтрНачинаетсяСПоМассиву(СтрокаМодуля, МассивТекстПроцедураФункция).Успешно Тогда
			
			НомерСтрокиОписанияПроцедуры = НомерСтроки - 1;
			ПоследняяСтрокаОписания = "";
			
			Пока Истина Цикл
				
				Если НомерСтрокиОписанияПроцедуры = 0 Тогда
					Прервать;
				КонецЕсли;
				
				СтрокаМодуля = ДокументТекст.ПолучитьСтроку(НомерСтрокиОписанияПроцедуры);
				
				Если НЕ СтрНачинаетсяС(СтрокаМодуля, "//") Тогда
					Прервать;
				КонецЕсли;
				
				ПоследняяСтрокаОписания = СтрокаМодуля;
				НомерСтрокиОписанияПроцедуры = НомерСтрокиОписанияПроцедуры - 1;
				
			КонецЦикла;
			
			Если ПустаяСтрока(ПоследняяСтрокаОписания) Тогда
				Продолжить;
			КонецЕсли;
			
			СтрокаОписания = СтрЗаменить(ПоследняяСтрокаОписания, "/", "");
			МассивСлов = СтрРазделить(СтрокаОписания, " ", Ложь);
			Если МассивСлов.Количество() = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			ПервоеСлово = МассивСлов[0];
			
			МассивСлов = СтрРазделить(ПервоеСлово, ".");
			ИмяПодсистемы = МассивСлов[0];
			
			Если ЭтоВыгрузкаXMLФайлов Тогда
				ПутьКФайлуПодсистемы = СтрШаблон("%1Subsystems%2%3.xml", КаталогВыгрузкиРезультат, РазделительПути, ИмяПодсистемы);
			Иначе
				ПутьКФайлуПодсистемы = СтрШаблон("%1src%2Subsystems%2%3", КаталогВыгрузкиРезультат, РазделительПути, ИмяПодсистемы);
			КонецЕсли;
			
			Если апк_ФайлСуществует(ПутьКФайлуПодсистемы) Тогда
				ДокументТекст.ВставитьСтроку(НомерСтрокиОписанияПроцедуры + 2, "");
				КоличествоСтрок = КоличествоСтрок + 1;
				НомерСтроки = НомерСтроки + 1;
				ФайлИзменен = Истина;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ФайлИзменен;
	
КонецФункции

Функция УдалитьПустыеПроцедурыИФункции(ДокументТекст)
	
	МассивУдаленныхМетодов = Новый Массив;
	
	ТекстМодуля = ДокументТекст.ПолучитьТекст();
	ТекстМодуляВРег = ВРег(ТекстМодуля);
	
	ТаблицаМетодов = ПолучитьТаблицуПроцедурИФункций(ТекстМодуля);
	Если ТаблицаМетодов.Количество() = 0 Тогда
		Возврат МассивУдаленныхМетодов;
	КонецЕсли;
	
	МассивТекстПодключаемый = Новый Массив;
	МассивТекстПодключаемый.Добавить(ВРег("Подключаемый_"));
	МассивТекстПодключаемый.Добавить(ВРег("Attachable_"));
	
	ИндексПоследнегоМетода = ТаблицаМетодов.Количество() - 1;
	Для НомерМетода = 0 По ИндексПоследнегоМетода Цикл
		
		СтрокаМетода = ТаблицаМетодов[ИндексПоследнегоМетода - НомерМетода];
		
		// Экспортные методы сразу пропускаем.
		Если СтрокаМетода.ЕстьЭкспорт Тогда
			Продолжить;
		КонецЕсли;
		
		ТелоМетода = СтрокаМетода.ТелоМетода;
		
		// Если тело метода не определено, значит, скорее всего, не нашли конец метода, пропускаем.
		Если ТелоМетода = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		// Если тело метода не пустое, то проверяем, возможно, оно состоит только из комментариев.
		Если НЕ ПустаяСтрока(ТелоМетода) Тогда
			
			ТелоМетодаСодержитКод = Ложь;
			
			// Проверяем, есть ли исполняемый код в этом тексте.
			ДокументТелоМетода = Новый ТекстовыйДокумент;
			ДокументТелоМетода.УстановитьТекст(ТелоМетода);
			
			КоличествоСтрок = ДокументТелоМетода.КоличествоСтрок();
			Для НомерСтроки = 1 По КоличествоСтрок Цикл
				
				СтрокаМодуля = ДокументТелоМетода.ПолучитьСтроку(НомерСтроки);
				СтрокаМодуля = СокрЛ(СтрокаМодуля);
				
				Если ПустаяСтрока(СтрокаМодуля) ИЛИ СтрНачинаетсяС(СтрокаМодуля, "//") Тогда
					Продолжить;
				КонецЕсли;
				
				// Нашли код, прерываем.
				ТелоМетодаСодержитКод = Истина;
				Прервать;
				
			КонецЦикла;
			
			Если ТелоМетодаСодержитКод Тогда
				Продолжить;
			КонецЕсли;
			
		КонецЕсли;
		
		// Пропускаем методы с префиксом "Подключаемый_", т.к. их вызов может быть назначен в другом модуле.
		ИмяМетодаВРег = СтрокаМетода.ИмяМетодаВРег;
		Если СтрНачинаетсяСПоМассиву(ИмяМетодаВРег, МассивТекстПодключаемый).Успешно Тогда
			Продолжить;
		КонецЕсли;
		
		// Ищем вызовы этого метода в коде модуля.
		ПозицияНачалаМетода = СтрокаМетода.ПозицияНачалаМетода;
		ПозицияКонцаОписания = СтрокаМетода.ПозицияКонцаОписания;
		
		ПозицияВызова = 0;
		Пока Истина Цикл
			
			ПозицияВызова = СтрНайти(ТекстМодуляВРег, ИмяМетодаВРег,, ПозицияВызова + 1);
			Если ПозицияВызова = 0 Тогда
				Прервать;
			КонецЕсли;
			
			// Проверяем, не является ли этот вызов описанием метода.
			Если (ПозицияВызова < ПозицияНачалаМетода) ИЛИ (ПозицияВызова > ПозицияКонцаОписания) Тогда
				// Если вызов находится вне описания метода, то выходим.
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
		// Есть вызов метода, пропускаем.
		Если ПозицияВызова > 0 Тогда
			Продолжить;
		КонецЕсли;
		
		ПозицияНачалаУдаленияМетода = СтрокаМетода.ПозицияНачалаДирективы;
		Если ПозицияНачалаУдаленияМетода = 0 Тогда
			ПозицияНачалаУдаленияМетода = СтрокаМетода.ПозицияНачалаМетода;
		КонецЕсли;
		
		ПозицияКонцаУдаленияМетода = СтрокаМетода.ПозицияКонцаМетода;
		Если ПозицияКонцаУдаленияМетода = Неопределено Тогда
			// Не смогли найти позицию окончания метода, пропускаем.
			Продолжить;
		КонецЕсли;
		
		ТекстМодуля = Лев(ТекстМодуля, ПозицияНачалаУдаленияМетода - 1) + Сред(ТекстМодуля, ПозицияКонцаУдаленияМетода + 1);
		
		// Удаляем пустые строки до или после метода.
		СимволыДоИПослеМетода = Сред(ТекстМодуля, ПозицияНачалаУдаленияМетода - 1, 2);
		Если ПустаяСтрока(СимволыДоИПослеМетода) Тогда
			ТекстМодуля = Лев(ТекстМодуля, ПозицияНачалаУдаленияМетода - 1) + Сред(ТекстМодуля, ПозицияНачалаУдаленияМетода + 1);
		КонецЕсли;
		
		МассивУдаленныхМетодов.Вставить(0, СтрокаМетода.ИмяМетода);
		
	КонецЦикла;
	
	ДокументТекст.УстановитьТекст(ТекстМодуля);
	
	Возврат МассивУдаленныхМетодов;
	
КонецФункции

// Удаляет назначенные обработчики в форме, для которых отсутствуют события (процедуры обработчиков).
// Если передан массив, то удаляются только обработчики из массива.
// Если передано Неопределено, то удаляются все отсутствующие обработчики.
//
Функция УдалитьОтсутствующиеОбработчикиИзСобытийФормыXML(ПолноеИмяФайлаXML, МассивОбработчиковДляУдаления = Неопределено)
	
	ФайлИзменен = Ложь;
	
	МассивСуществующихМетодов = Неопределено;
	
	// Если массив обработчиков не определен, то собираем все обработчики из модуля формы.
	Если МассивОбработчиковДляУдаления = Неопределено Тогда
		
		// Ищем путь объекта по файлу XML его формы.
		ПутьОбъекта = ПолучитьЗначениеОбъекта(ПолноеИмяФайлаXML);
		Если НЕ ПустаяСтрока(ПутьОбъекта) Тогда
			
			ПараметрыОтбора = Новый Структура;
			ПараметрыОтбора.Вставить("Выбран", Истина);
			ПараметрыОтбора.Вставить("ЗахваченВХранилище", Истина);
			ПараметрыОтбора.Вставить("РедактированиеРазрешено", Истина);
			ПараметрыОтбора.Вставить("ПолноеИмяФайлаОкончание", СтрШаблон("%1Ext%1Form%1Module.bsl", РазделительПути));
			
			ПолноеИмяФайлаМодуля = ПолучитьЗначениеОбъекта(ПутьОбъекта, "Объект", "ПолноеИмяФайла", ПараметрыОтбора);
			
			ДокументТекст = ПолучитьТекстовыйДокументИзФайла(ПолноеИмяФайлаМодуля, КодировкаТекста.UTF8);
			Если ДокументТекст <> Неопределено Тогда
				ТаблицаМетодовМодуля = ПолучитьТаблицуПроцедурИФункций(ДокументТекст.ПолучитьТекст());
				МассивСуществующихМетодов = ТаблицаМетодовМодуля.ВыгрузитьКолонку("ИмяМетодаВРег");
			КонецЕсли;
			
		КонецЕсли;
		
		// Если не заполнен ни один из массивов, то выходим.
		Если МассивСуществующихМетодов = Неопределено Тогда
			Возврат ФайлИзменен;
		КонецЕсли;
		
	Иначе
		
		// Если не заполнен ни один из массивов, то выходим.
		Если МассивОбработчиковДляУдаления.Количество() = 0 Тогда
			Возврат ФайлИзменен;
		КонецЕсли;
		
		МассивОбработчиковДляУдаленияВРег = Новый Массив;
		
		НомерПоследнегоОбработчика = МассивОбработчиковДляУдаления.ВГраница();
		Для НомерОбработчика = 0 По НомерПоследнегоОбработчика Цикл
			МассивОбработчиковДляУдаленияВРег.Добавить(ВРег(МассивОбработчиковДляУдаления[НомерОбработчика]));
		КонецЦикла;
		
	КонецЕсли;
	
	ДокументDOM = ДокументDOM(ПолноеИмяФайлаXML);
	Если ДокументDOM = Неопределено Тогда
		// Если файл не удалось прочитать, то нет смысла записывать, поэтому возвращаем Ложь.
		Возврат Ложь;
	КонецЕсли;
	
	// Шаблон находит только обработчики формы, для обработчиков элементов необходим другой шаблон, например, "//xmlns:Events".
	ЭлементDOMСобытия = ПолучитьЭлементDOMПоВыражениюXPath("/xmlns:Form/xmlns:Events", ДокументDOM);
	Если ЭлементDOMСобытия = Неопределено Тогда
		// Если назначенных событий нет, выходим.
		Возврат ФайлИзменен;
	КонецЕсли;
	
	ЭлементDOMСобытияДочерниеУзлы = ЭлементDOMСобытия.ДочерниеУзлы;
	Если ЭлементDOMСобытияДочерниеУзлы.Количество() = 0 Тогда
		// Если дочерних узлов нет, выходим.
		Возврат ФайлИзменен;
	КонецЕсли;
	
	МассивЭлементовDOMСобытиеДляУдаления = Новый Массив;
	
	Для Каждого ЭлементDOMСобытие Из ЭлементDOMСобытияДочерниеУзлы Цикл
		
		УдалитьСобытие = Ложь;
		
		ИмяПроцедурыОбработчика = ВРег(ЭлементDOMСобытие.ТекстовоеСодержимое);
		Если ПустаяСтрока(ИмяПроцедурыОбработчика) Тогда
			Продолжить;
		КонецЕсли;
		
		Если МассивОбработчиковДляУдаления <> Неопределено Тогда
			УдалитьСобытие = (МассивОбработчиковДляУдаленияВРег.Найти(ИмяПроцедурыОбработчика) <> Неопределено);
		ИначеЕсли МассивСуществующихМетодов <> Неопределено Тогда
			УдалитьСобытие = (МассивСуществующихМетодов.Найти(ИмяПроцедурыОбработчика) = Неопределено);
		КонецЕсли;
		
		Если НЕ УдалитьСобытие Тогда
			Продолжить;
		КонецЕсли;
		
		МассивЭлементовDOMСобытиеДляУдаления.Добавить(ЭлементDOMСобытие);
		
		ФайлИзменен = Истина;
		
	КонецЦикла;
	
	Если НЕ ФайлИзменен Тогда
		Возврат ФайлИзменен;
	КонецЕсли;
	
	// Удаляем дочерние узлы из узла событий формы.
	Для Каждого ЭлементDOMСобытие Из МассивЭлементовDOMСобытиеДляУдаления Цикл
		ЭлементDOMСобытия.УдалитьДочерний(ЭлементDOMСобытие);
	КонецЦикла;
	
	// Если дочерних узлов нет, удаляем сам узел событий.
	Если ЭлементDOMСобытия.ДочерниеУзлы.Количество() = 0 Тогда
		ЭлементDOMСобытияРодительскийУзел = ЭлементDOMСобытия.РодительскийУзел;
		ЭлементDOMСобытияРодительскийУзел.УдалитьДочерний(ЭлементDOMСобытия);
	КонецЕсли;
	
	ЗаписатьДокументDOMВФайл(ДокументDOM, ПолноеИмяФайлаXML);
	
	Возврат ФайлИзменен;
	
КонецФункции

// Удаляет назначенные обработчики в форме, для которых отсутствуют события (процедуры обработчиков).
// Если передан массив, то удаляются только обработчики из массива.
// Если передано Неопределено, то удаляются все отсутствующие обработчики.
//
Функция УдалитьОтсутствующиеОбработчикиИзСобытийФормыEDT(ПолноеИмяФайлаXML, МассивОбработчиковДляУдаления = Неопределено)
	
	ДокументDOM = ДокументDOM(ПолноеИмяФайлаXML);
	Если ДокументDOM = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ФайлИзменен = Ложь;
	
	МассивСуществующихМетодов = Неопределено;
	
	// Если массив обработчиков не определен, то собираем все обработчики из модуля формы.
	Если МассивОбработчиковДляУдаления = Неопределено Тогда
		
		// Ищем путь объекта по файлу XML его формы.
		ПутьОбъекта = ПолучитьЗначениеОбъекта(ПолноеИмяФайлаXML);
		Если НЕ ПустаяСтрока(ПутьОбъекта) Тогда
			
			ПараметрыОтбора = Новый Структура;
			ПараметрыОтбора.Вставить("Выбран", Истина);
			ПараметрыОтбора.Вставить("ЗахваченВХранилище", Истина);
			ПараметрыОтбора.Вставить("РедактированиеРазрешено", Истина);
			ПараметрыОтбора.Вставить("ПолноеИмяФайлаОкончание", РазделительПути + "Module.bsl");
			
			ПолноеИмяФайлаМодуля = ПолучитьЗначениеОбъекта(ПутьОбъекта, "Объект", "ПолноеИмяФайла", ПараметрыОтбора);
			
			ДокументТекст = ПолучитьТекстовыйДокументИзФайла(ПолноеИмяФайлаМодуля, КодировкаТекста.UTF8);
			Если ДокументТекст <> Неопределено Тогда
				ТаблицаМетодовМодуля = ПолучитьТаблицуПроцедурИФункций(ДокументТекст.ПолучитьТекст());
				МассивСуществующихМетодов = ТаблицаМетодовМодуля.ВыгрузитьКолонку("ИмяМетодаВРег");
			КонецЕсли;
			
		КонецЕсли;
		
		// Если не заполнен ни один из массивов, то выходим.
		Если МассивСуществующихМетодов = Неопределено Тогда
			Возврат ФайлИзменен;
		КонецЕсли;
		
	Иначе
		
		// Если не заполнен ни один из массивов, то выходим.
		Если МассивОбработчиковДляУдаления.Количество() = 0 Тогда
			Возврат ФайлИзменен;
		КонецЕсли;
		
		МассивОбработчиковДляУдаленияВРег = Новый Массив;
		
		НомерПоследнегоОбработчика = МассивОбработчиковДляУдаления.ВГраница();
		Для НомерОбработчика = 0 По НомерПоследнегоОбработчика Цикл
			МассивОбработчиковДляУдаленияВРег.Добавить(ВРег(МассивОбработчиковДляУдаления[НомерОбработчика]));
		КонецЦикла;
		
	КонецЕсли;
	
	ЭлементDOMРодительскийУзел = ПолучитьЭлементDOMПоВыражениюXPath("/form:Form", ДокументDOM);
	Если ЭлементDOMРодительскийУзел = Неопределено Тогда
		Возврат ФайлИзменен;
	КонецЕсли;
	
	МассивЭлементовDOMСобытиеДляУдаления = Новый Массив;
	
	// Шаблон находит только обработчики формы, для обработчиков элементов необходим другой шаблон, например, "//handlers/name".
	РезультатXPath = ВычислитьВыражениеXPath("handlers/name", ДокументDOM, ЭлементDOMРодительскийУзел);
	Пока Истина Цикл
		
		ЭлементDOMv8Type = РезультатXPath.ПолучитьСледующий();
		Если ЭлементDOMv8Type = Неопределено Тогда
			Прервать;
		КонецЕсли;
		
		ИмяПроцедурыОбработчика = ВРег(ЭлементDOMv8Type.ТекстовоеСодержимое);
		Если ПустаяСтрока(ИмяПроцедурыОбработчика) Тогда
			Продолжить;
		КонецЕсли;
		
		Если МассивОбработчиковДляУдаления <> Неопределено Тогда
			УдалитьСобытие = (МассивОбработчиковДляУдаленияВРег.Найти(ИмяПроцедурыОбработчика) <> Неопределено);
		ИначеЕсли МассивСуществующихМетодов <> Неопределено Тогда
			УдалитьСобытие = (МассивСуществующихМетодов.Найти(ИмяПроцедурыОбработчика) = Неопределено);
		КонецЕсли;
		
		Если НЕ УдалитьСобытие Тогда
			Продолжить;
		КонецЕсли;
		
		МассивЭлементовDOMСобытиеДляУдаления.Добавить(ЭлементDOMv8Type.РодительскийУзел);
		ФайлИзменен = Истина;
		
	КонецЦикла;
	
	Если НЕ ФайлИзменен Тогда
		Возврат ФайлИзменен;
	КонецЕсли;
	
	// Удаляем дочерние узлы из узла событий формы.
	Для Каждого ЭлементDOMСобытие Из МассивЭлементовDOMСобытиеДляУдаления Цикл
		ЭлементDOMРодительскийУзел.УдалитьДочерний(ЭлементDOMСобытие);
	КонецЦикла;
	
	ЗаписатьДокументDOMВФайл(ДокументDOM, ПолноеИмяФайлаXML);
	
	Возврат ФайлИзменен;
	
КонецФункции

Функция ДобавитьДополнительныеОтступыВСтрокуСОписаниемПараметраИВозвращаемогоЗначения(ПолноеИмяФайла, ДокументТекст)
	
	ФайлИзменен = Ложь;
	
	КоличествоСтрок = ДокументТекст.КоличествоСтрок();
	Если КоличествоСтрок = 0 Тогда
		Возврат ФайлИзменен;
	КонецЕсли;
	
	ТекстМодуля = ДокументТекст.ПолучитьТекст();
	Если ПустаяСтрока(ТекстМодуля) Тогда
		Возврат ФайлИзменен;
	КонецЕсли;
	
	ТекстМодуля = ВРег(ТекстМодуля);
	
	МассивТекстПараметры = Контекст["МассивТекстПараметры"];
	МассивТекстВозвращаемоеЗначение = Контекст["МассивТекстВозвращаемоеЗначение"];
	
	МассивСекций = Новый Массив;
	ДополнитьМассив(МассивСекций, МассивТекстПараметры);
	ДополнитьМассив(МассивСекций, МассивТекстВозвращаемоеЗначение);
	
	// Если строка начинается с этого текста, то не двигаем ее, но проверяем параметры дальше.
	МассивИсключенийПродолжить = Новый Массив;
	МассивИсключенийПродолжить.Добавить(ВРег("Для внутреннего использования")); // АПК:1297 - не локализуется
	МассивИсключенийПродолжить.Добавить(ВРег("For internal use")); // АПК:1297 - не локализуется
	МассивИсключенийПродолжить.Добавить("-");
	ДополнитьМассив(МассивИсключенийПродолжить, МассивТекстВозвращаемоеЗначение);
	
	МассивИсключенийПрервать = Новый Массив;
	МассивИсключенийПрервать.Добавить(ВРег("Возврат"));
	МассивИсключенийПрервать.Добавить(ВРег("Return"));
	МассивИсключенийПрервать.Добавить(ВРег("Пример"));
	МассивИсключенийПрервать.Добавить(ВРег("Example"));
	ДополнитьМассив(МассивИсключенийПрервать, МассивТекстВозвращаемоеЗначение);
	
	Для Каждого ТекстСекции Из МассивСекций Цикл
		
		ПозицияСекции = 0;
		Пока Истина Цикл
			
			// Определяем описание секции по комментарию, например, "// Параметры:"
			ПозицияСекции = СтрНайти(ТекстМодуля, ТекстСекции,, ПозицияСекции + 1);
			Если ПозицияСекции = 0 Тогда
				Прервать;
			КонецЕсли;
			
			НомерСтрокиСекции = ПолучитьНомерСтрокиМодуля(ТекстМодуля, ПозицияСекции);
			СтрокаСекцииИсходная = ДокументТекст.ПолучитьСтроку(НомерСтрокиСекции);
			
			// Если это не комментарий с начала строки, то пропускаем.
			СтрокаСекции = СокрЛ(СтрокаСекцииИсходная);
			Если НЕ СтрНачинаетсяС(СтрокаСекции, "//") Тогда
				Продолжить;
			КонецЕсли;
			
			СтрокаСекции = СтрЗаменить(СтрокаСекции, "/", "");
			СтрокаСекции = СокрЛП(СтрокаСекции);
			СтрокаСекции = ВРег(СтрокаСекции);
			
			// Если комментарий не начинается с объявления секции "Параметры:" или "Возвращаемое значение", то пропускаем.
			Если НЕ СтрНачинаетсяС(СтрокаСекции, ТекстСекции) Тогда
				Продолжить;
			КонецЕсли;
			
			// Получаем отдельно отступы до и после знака комментария.
			ОтступДоЗнакаКомментарияСтрокаСекции = ПолучитьОтступДоЗнакаКомментария(СтрокаСекцииИсходная);
			ОтступПослеЗнакаКомментарияСтрокаСекции = ПолучитьОтступПослеЗнакаКомментария(СтрокаСекцииИсходная);
			
			// Запоминаем длину отступа после знака комментария.
			ДлинаОтступаПослеЗнакаКомментарияСтрокаСекции = СтрДлина(ОтступПослеЗнакаКомментарияСтрокаСекции);
			
			Для НомерСтроки = НомерСтрокиСекции + 1 По КоличествоСтрок Цикл
				
				// Если пустая строка, то комментарий закончился, прерываем.
				СтрокаМодуляИсходная = ДокументТекст.ПолучитьСтроку(НомерСтроки);
				Если ПустаяСтрока(СтрокаМодуляИсходная) Тогда
					Прервать;
				КонецЕсли;
				
				// Если это не комментарий, прерываем.
				СтрокаМодуля = СокрЛ(СтрокаМодуляИсходная);
				Если НЕ СтрНачинаетсяС(СтрокаМодуля, "//") Тогда
					Прервать;
				КонецЕсли;
				
				// Пустой комментарий в большинстве случаев подразумевает окончание секции, прерываем.
				СтрокаМодуля = СтрЗаменить(СтрокаМодуля, "/", "");
				Если ПустаяСтрока(СтрокаМодуля) Тогда
					Прервать;
				КонецЕсли;
				
				СтрокаМодуля = СокрЛ(СтрокаМодуля);
				СтрокаМодуля = ВРег(СтрокаМодуля);
				
				// Если строка начинается с исключения, например, начало следующей секции, то прерываем.
				ЭтоИсключениеПрервать = Ложь;
				Для Каждого СтрокаИсключения Из МассивИсключенийПрервать Цикл
					Если СтрНачинаетсяС(СтрокаМодуля, СтрокаИсключения) Тогда
						ЭтоИсключениеПрервать = Истина;
						Прервать;
					КонецЕсли;
				КонецЦикла;
				
				Если ЭтоИсключениеПрервать Тогда
					Прервать;
				КонецЕсли;
				
				// Если строка начинается с исключения для дальнейшей проверки, то не двигаем ее, пропускаем.
				ЭтоИсключениеПродолжить = Ложь;
				Для Каждого СтрокаИсключения Из МассивИсключенийПродолжить Цикл
					Если СтрНачинаетсяС(СтрокаМодуля, СтрокаИсключения) Тогда
						ЭтоИсключениеПродолжить = Истина;
						Прервать;
					КонецЕсли;
				КонецЦикла;
				
				Если ЭтоИсключениеПродолжить Тогда
					Продолжить;
				КонецЕсли;
				
				// Если отступ строки до знака комментария не совпадает с отступом строки объявления секции,
				// то непонятно, какие дополнительные отступы добавлять, прерываем.
				ОтступДоЗнакаКомментарияСтрокаМодуля = ПолучитьОтступДоЗнакаКомментария(СтрокаМодуляИсходная);
				Если ОтступДоЗнакаКомментарияСтрокаМодуля <> ОтступДоЗнакаКомментарияСтрокаСекции Тогда
					ТекстИсключения = НСтр("ru='Не совпадают размеры отступов до знака комментария секции ""Параметры"" и строки описания параметра: %Строка%';
						|en='Не совпадают размеры отступов до знака комментария секции ""Параметры"" и строки описания параметра: %Строка%'", КодОсновногоЯзыка);
					ТекстИсключения = СтрЗаменить(ТекстИсключения, "%Строка%", СокрЛП(СтрокаМодуляИсходная));
					ОбработатьИсключение(ПолноеИмяФайла, ТекстИсключения, НомерСтроки);
					Прервать;
				КонецЕсли;
				
				// Получаем длину отступа после знака комментария.
				ОтступПослеЗнакаКомментарияСтрокаМодуля = ПолучитьОтступПослеЗнакаКомментария(СтрокаМодуляИсходная);
				
				// Один таб считаем за 2 пробела.
				ОтступПослеЗнакаКомментарияСтрокаМодуля = СтрЗаменить(ОтступПослеЗнакаКомментарияСтрокаМодуля, Символы.Таб, "  ");
				ДлинаОтступаПослеЗнакаКомментарияСтрокаМодуля = СтрДлина(ОтступПослеЗнакаКомментарияСтрокаМодуля);
				РазницаДлинОтступа = ДлинаОтступаПослеЗнакаКомментарияСтрокаМодуля - ДлинаОтступаПослеЗнакаКомментарияСтрокаСекции;
				
				ДополнительныйОтступ = "";
				Если РазницаДлинОтступа < 0 Тогда
					// Комментарий к параметру располагается левее, чем объявление секции.
					// Возможно, это другая секция, закомментированный код или какой-либо пример, прерываем.
					Прервать;
				ИначеЕсли РазницаДлинОтступа = 0 Тогда
					// Отступы равны, добавляем дополнительный отступ в 2 пробела.
					ДополнительныйОтступ = "  ";
				ИначеЕсли (РазницаДлинОтступа = 1) Тогда
					// Если разница отступов = 1, и это свойство параметра, то добавляем 1 дополнительный пробел.
					Если СтрНачинаетсяС(СтрокаМодуля, "*") Тогда
						ДополнительныйОтступ = " ";
					ИначеЕсли СтрНачинаетсяС(ВРег(СтрокаМодуля), ВРег("см.")) Тогда
						// Если это гиперссылка, то добавляем дополнительные пробелы
						// в зависимости от места положения комментария относительно объявления секции.
						Если (НомерСтрокиСекции + 1 = НомерСтроки) Тогда
							// Если гиперссылка на следующей строке после секции "Возвращаемое значение", то добавляем 1 пробел.
							Если СтрНайтиПоМассиву(ТекстСекции, МассивТекстВозвращаемоеЗначение).Успешно Тогда
								ДополнительныйОтступ = " ";
							Иначе
								// Если гиперссылка находится на следующей строке после секции "Параметры",
								// то это неверное оформление параметров, пропускаем.
								Продолжить;
							КонецЕсли;
						Иначе
							// Если ниже, то сдвигаем на 3 пробела.
							ДополнительныйОтступ = "   ";
						КонецЕсли;
					Иначе
						Продолжить;
					КонецЕсли;
				Иначе
					// Параметр описан с дополнительными отступами правее объявления секции, пропускаем.
					Продолжить;
				КонецЕсли;
				
				ПозицияПервогоСимволаПослеЗнакаКомментария = СтрДлина(ОтступДоЗнакаКомментарияСтрокаМодуля + "//") + 1;
				ДлинаСтроки = СтрДлина(СтрокаМодуляИсходная);
				
				// Ищем первый символ после знака комментария.
				Для ПозицияСимвола = ПозицияПервогоСимволаПослеЗнакаКомментария По ДлинаСтроки Цикл
					Символ = Сред(СтрокаМодуляИсходная, ПозицияСимвола, 1);
					Если Символ <> "/" Тогда
						ПозицияПервогоСимволаПослеЗнакаКомментария = ПозицияСимвола;
						Прервать;
					КонецЕсли;
				КонецЦикла;
				
				// Если после символов комментария нет непустых символов, то добавлять отступ не нужно, пропускаем.
				СтрокаМодуляПослеЗнакаКомментария = Сред(СтрокаМодуляИсходная, ПозицияПервогоСимволаПослеЗнакаКомментария);
				Если ПустаяСтрока(СтрокаМодуляПослеЗнакаКомментария) Тогда
					Продолжить;
				КонецЕсли;
				
				СтрокаМодуляСоЗнакомКомментария = Лев(СтрокаМодуляИсходная, ПозицияПервогоСимволаПослеЗнакаКомментария - 1);
				СтрокаМодуляСДополнительнымОтступом = СтрокаМодуляСоЗнакомКомментария + ДополнительныйОтступ + СтрокаМодуляПослеЗнакаКомментария;
				
				ДокументТекст.ЗаменитьСтроку(НомерСтроки, СтрокаМодуляСДополнительнымОтступом);
				
				ФайлИзменен = Истина;
				
			КонецЦикла;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ФайлИзменен;
	
КонецФункции

Функция ИсправитьЗнакМинусВДругихКодировках(ДокументТекст)
	
	ФайлИзменен = Ложь;
	
	КоличествоСтрок = ДокументТекст.КоличествоСтрок();
	Если КоличествоСтрок = 0 Тогда
		Возврат ФайлИзменен;
	КонецЕсли;
	
	ТекстМодуля = ДокументТекст.ПолучитьТекст();
	Если ПустаяСтрока(ТекстМодуля) Тогда
		Возврат ФайлИзменен;
	КонецЕсли;
	
	МассивЗнаковМинус = Новый Массив;
	МассивЗнаковМинус.Добавить(Символ(173));
	МассивЗнаковМинус.Добавить(Символ(8210));
	МассивЗнаковМинус.Добавить(Символ(8211));
	МассивЗнаковМинус.Добавить(Символ(8212));
	МассивЗнаковМинус.Добавить(Символ(8213));
	МассивЗнаковМинус.Добавить(Символ(8722));
	
	Для Каждого ЗнакМинус Из МассивЗнаковМинус Цикл
		
		ПозицияЗнакаМинус = 0;
		Пока Истина Цикл
			
			ПозицияЗнакаМинус = СтрНайти(ТекстМодуля, ЗнакМинус,, ПозицияЗнакаМинус + 1);
			Если ПозицияЗнакаМинус = 0 Тогда
				Прервать;
			КонецЕсли;
			
			СтрокаИзменена = Ложь;
			
			НомерСтроки = ПолучитьНомерСтрокиМодуля(ТекстМодуля, ПозицияЗнакаМинус);
			СтрокаМодуля = ДокументТекст.ПолучитьСтроку(НомерСтроки);
			
			// Ищем комментарий в строке.
			ПозицияКомментария = СтрНайти(СтрокаМодуля, "//");
			
			// Если строка не содержит комментарий, то пропускаем ее, т.к. минусы в коде заменять не нужно.
			Если ПозицияКомментария = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			// Если строка модуля полностью является комментарием, то заменяем знак минус во всей строке.
			СтрокаМодуляСокрЛ = СокрЛ(СтрокаМодуля);
			Если СтрНачинаетсяС(СтрокаМодуляСокрЛ, "//") Тогда
				
				СтрокаМодуля = СтрЗаменить(СтрокаМодуля, ЗнакМинус, "-");
				СтрокаИзменена = Истина;
				
			Иначе
				
				СтрокаНачинаетсяСоСтроковойКонстанты = СтрНачинаетсяС(СтрокаМодуляСокрЛ, "|");
				
				// Если комментарий внутри строки, то надо заменить минусы только после знака комментария.
				// Получаем комментарий из строки.
				ПозицияКомментария = ПозицияКомментария - 1;
				Пока Истина Цикл
					
					ПозицияКомментария = СтрНайти(СтрокаМодуля, "//",, ПозицияКомментария + 1);
					Если ПозицияКомментария = 0 Тогда
						Прервать;
					КонецЕсли;
					
					// Проверяем, находится ли знак комментария в строковой константе.
					СтрокаДоКомментария = Лев(СтрокаМодуля, ПозицияКомментария - 1);
					КоличествоКавычек = СтрЧислоВхождений(СтрокаДоКомментария, """");
					КоличествоКавычекЧетное = (КоличествоКавычек % 2 = 0);
					
					// Если знак комментария находится за строковой константой, то комментарий найден, прерываем.
					Если (СтрокаНачинаетсяСоСтроковойКонстанты И (НЕ КоличествоКавычекЧетное))
					 ИЛИ ((НЕ СтрокаНачинаетсяСоСтроковойКонстанты) И КоличествоКавычекЧетное) Тогда
						Прервать;
					КонецЕсли;
					
				КонецЦикла;
				
				// Если комментарий не нашли, то пропускаем строку.
				Если ПозицияКомментария = 0 Тогда
					Продолжить;
				КонецЕсли;
				
				// Получаем текст комментария.
				ТекстКомментария = Сред(СтрокаМодуля, ПозицияКомментария);
				// Проверяем, что в нем есть знак минус в другой кодировке.
				Если СтрНайти(ТекстКомментария, ЗнакМинус) > 0 Тогда
					// Тогда заменяем его и склеиваем строку модуля.
					ТекстКомментария = СтрЗаменить(ТекстКомментария, ЗнакМинус, "-");
					СтрокаМодуля = Лев(СтрокаМодуля, ПозицияКомментария - 1) + ТекстКомментария;
					СтрокаИзменена = Истина;
				КонецЕсли;
				
			КонецЕсли;
			
			Если СтрокаИзменена Тогда
				ДокументТекст.ЗаменитьСтроку(НомерСтроки, СтрокаМодуля);
				ТекстМодуля = ДокументТекст.ПолучитьТекст();
				ФайлИзменен = Истина;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ФайлИзменен;
	
КонецФункции

Функция УдалитьКомментарийПослеКонецПроцедурыФункции(Знач СтрокаМодуля)
	
	МассивТекстКонецПроцедурыФункции = Контекст["МассивТекстКонецПроцедурыФункции"];
	
	СтрокаМодуляВРег = ВРег(СтрокаМодуля);
	СтрокаМодуляВРег = СокрЛП(СтрокаМодуляВРег);
	
	// Проверяем, что строка содержит окончание процедуры или функции.
	РезультатПоискаКонецПроцедурыФункции = СтрНачинаетсяСПоМассиву(СтрокаМодуляВРег, МассивТекстКонецПроцедурыФункции);
	Если НЕ РезультатПоискаКонецПроцедурыФункции.Успешно Тогда
		// Если нет, то выходим.
		Возврат СтрокаМодуля;
	КонецЕсли;
	
	// Если в строке только текст окончания процедуры или функции, то выходим.
	НайденныйЭлемент = РезультатПоискаКонецПроцедурыФункции.НайденныйЭлемент;
	Если СтрокаМодуляВРег = НайденныйЭлемент Тогда
		Возврат СтрокаМодуля;
	КонецЕсли;
	
	// Проверяем следующий символ.
	СледующийСимвол = Сред(СтрокаМодуляВРег, СтрДлина(НайденныйЭлемент) + 1, 1);
	Если апк_СловоСодержитЗначимыеСимволы(СледующийСимвол) Тогда
		// Если следующий символ после окончания процедуры или функции - значимый, тогда это не окончание процедуры или функции.
		Возврат СтрокаМодуля;
	КонецЕсли;
	
	// Ищем комментарий в исходной строке.
	ПозицияКомментария = СтрНайти(СтрокаМодуля, "//");
	Если ПозицияКомментария = 0 Тогда
		Возврат СтрокаМодуля;
	КонецЕсли;
	
	// Удаляем комментарий из строки.
	СтрокаМодуля = Лев(СтрокаМодуля, ПозицияКомментария - 1);
	СтрокаМодуля = СокрЛП(СтрокаМодуля);
	
	Возврат СтрокаМодуля;
	
КонецФункции

// Если в первой строке комментария перед методом содержит гиперссылку "см.",
// то функция удаляет весь комментарий, расположенный ниже гиперссылки, оставляя только текст гиперссылки.
// Нюансы и исключения:
// 1. Остаются служебные комментарии, содержащие «//@», «//АПК:» и «//ACC:».
// 2. Текст ниже гиперссылки не удаляется, т.е. комментарий остается в исходном виде, если:
//   2.1. Объект (процедура/функция) гиперссылки не существует.
//   2.2. Состав реальных параметров описываемой процедуры и процедуры из гиперссылки не совпадает.
//
Функция ОчиститьКомментарийПередМетодомСодержащийГиперссылку(СтрокаМетодаМодуля)
	
	ТекстКомментарияМетода = СтрокаМетодаМодуля.ТекстКомментарияМетода;
	Если ПустаяСтрока(ТекстКомментарияМетода) Тогда
		Возврат "";
	КонецЕсли;
	
	// Если комментарий перед процедурой (функцией) содержит только одну строку, то пропускаем.
	КоличествоСтрокКомментария = СтрЧислоСтрок(ТекстКомментарияМетода);
	Если КоличествоСтрокКомментария = 1 Тогда
		Возврат "";
	КонецЕсли;
	
	МассивТекстСм = Контекст["МассивТекстСм"];
	
	ТекстКомментарияМетодаБуфер = СтрЗаменить(ТекстКомментарияМетода, "/", "");
	ТекстКомментарияМетодаБуфер = СокрЛП(ТекстКомментарияМетодаБуфер);
	ТекстКомментарияМетодаБуфер = ВРег(ТекстКомментарияМетодаБуфер);
	
	РезультатПоискаТекстаСм = СтрНачинаетсяСПоМассиву(ТекстКомментарияМетодаБуфер, МассивТекстСм);
	
	// Если текст комментария не начинается с "См.", то это не гиперссылка, выходим.
	Если НЕ РезультатПоискаТекстаСм.Успешно Тогда
		Возврат "";
	КонецЕсли;
	
	ДокументТекстКомментария = Новый ТекстовыйДокумент;
	ДокументТекстКомментария.УстановитьТекст(ТекстКомментарияМетода);
	
	// Получаем исходную строку с гиперссылкой из текста комментария.
	СтрокаГиперссылки = "";
	Для НомерСтрокиКомментария = 1 По КоличествоСтрокКомментария Цикл
		СтрокаКомментария = ДокументТекстКомментария.ПолучитьСтроку(НомерСтрокиКомментария);
		СтрокаКомментарияБуфер = СтрЗаменить(СтрокаКомментария, "/", "");
		Если НЕ ПустаяСтрока(СтрокаКомментарияБуфер) Тогда
			СтрокаГиперссылки = СтрокаКомментария;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	СтрокаГиперссылки = СокрЛП(СтрокаГиперссылки);
	
	// Если после сокращений строк пустых символов осталась только одна строка,
	// то не проверяем гиперссылку и выходим с исходной строкой.
	Если СтрЧислоСтрок(ТекстКомментарияМетодаБуфер) = 1 Тогда
		Возврат СтрокаГиперссылки;
	КонецЕсли;
	
	// Выделяем текст объекта гиперссылки из текста комментария метода.
	МассивТекстГиперссылокСм = Контекст["МассивТекстГиперссылокСм"];
	РезультатПоискаГиперссылки = СтрНайтиПоМассиву(ВРег(СтрокаГиперссылки), МассивТекстГиперссылокСм,,, Истина);
	Если НЕ РезультатПоискаГиперссылки.Успешно Тогда
		// Если не нашли текст с указателем гиперссылки, то выходим.
		Возврат "";
	КонецЕсли;
	
	ПозицияГиперссылки = РезультатПоискаГиперссылки.Позиция;
	НайденныйУказательГиперссылки = РезультатПоискаГиперссылки.НайденныйЭлемент;
	ТекстОбъектаГиперссылки = Сред(СтрокаГиперссылки, ПозицияГиперссылки + СтрДлина(НайденныйУказательГиперссылки));
	Если ПустаяСтрока(ТекстОбъектаГиперссылки) Тогда
		Возврат "";
	КонецЕсли;
	
	ТекстОбъектаГиперссылки = СтрЗаменить(ТекстОбъектаГиперссылки, "()", "");
	ТекстОбъектаГиперссылки = СтрСоединить(СтрРазделить(ТекстОбъектаГиперссылки, ".", Ложь), ".");
	ТекстОбъектаГиперссылки = СокрЛП(ТекстОбъектаГиперссылки);
	
	// Проверяем объект гиперссылки.
	СтрокаОбъектаПереадресации = ПолучитьОбъектПереадресацииИзГиперссылки(ТекстОбъектаГиперссылки, Новый ТаблицаЗначений);
	Если СтрокаОбъектаПереадресации = Неопределено Тогда
		// Если не удалось определить объект из гиперссылки, то выходим.
		Возврат "";
	КонецЕсли;
	
	// Если объект из гиперссылки не существует, то выходим.
	Если НЕ СтрокаОбъектаПереадресации.Существует Тогда
		Возврат "";
	КонецЕсли;
	
	// Проверяем метод из гиперссылки.
	МетодПереадресации = СтрокаОбъектаПереадресации.МетодПереадресации;
	Если МетодПереадресации = Неопределено Тогда
		// Если метод не определен, то выходим.
		Возврат "";
	КонецЕсли;
	
	// Проверяем параметры метода переадресации.
	МассивПараметровМетодаМодуля = СтрокаМетодаМодуля.МассивПараметров;
	МассивПараметровМетодаПереадресации = МетодПереадресации.МассивПараметров;
	Если МассивПараметровМетодаМодуля.Количество() <> МассивПараметровМетодаПереадресации.Количество() Тогда
		// Состав параметров текущего метода не соответствует составу параметров метода переадресации, выходим.
		Возврат "";
	КонецЕсли;
	
	// Сравниваем параметры по элементам.
	ПараметрыМетодовРавны = Истина;
	НомерПараметра = -1;
	Для Каждого ПараметрМетодаМодуля Из МассивПараметровМетодаМодуля Цикл
		НомерПараметра = НомерПараметра + 1;
		ПараметрМетодаПереадресации = МассивПараметровМетодаПереадресации[НомерПараметра];
		Если ПолучитьИмяПараметра(ПараметрМетодаМодуля) <> ПолучитьИмяПараметра(ПараметрМетодаПереадресации) Тогда
			ПараметрыМетодовРавны = Ложь;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если НЕ ПараметрыМетодовРавны Тогда
		// Состав параметров текущего метода не соответствует составу параметров метода переадресации, выходим.
		Возврат "";
	КонецЕсли;
	
	ТекстСм = РезультатПоискаТекстаСм.НайденныйЭлемент;
	
	// Иначе приводим строку комментария с объектом гиперссылки к правильному виду.
	СтрокаГиперссылки = СтрШаблон("// %1 %2", ТРег(ТекстСм), ТекстОбъектаГиперссылки);
	
	// Добавляем в общий комментарий служебные комментарии, если они есть.
	МассивСлужебныхКомментариев = Контекст["МассивСлужебныхКомментариев"];
	НовыйТекстКомментарияМетода = СтрокаГиперссылки;
	Для НомерСтрокиКомментария = 1 По КоличествоСтрокКомментария Цикл
		
		СтрокаКомментария = ДокументТекстКомментария.ПолучитьСтроку(НомерСтрокиКомментария);
		
		СтрокаКомментарияБуфер = СтрокаКомментария;
		СтрокаКомментарияБуфер = СтрЗаменить(СтрокаКомментарияБуфер, Символы.Таб, "");
		СтрокаКомментарияБуфер = СтрЗаменить(СтрокаКомментарияБуфер, " ", "");
		
		Если СтрНачинаетсяСПоМассиву(СтрокаКомментарияБуфер, МассивСлужебныхКомментариев).Успешно Тогда
			НовыйТекстКомментарияМетода = НовыйТекстКомментарияМетода + Символы.ПС + СтрокаКомментария;
		КонецЕсли;
		
	КонецЦикла;
	
	// Если количество строк больше одной, то добавляем строку с пустым комментарием в конец.
	Если СтрЧислоСтрок(НовыйТекстКомментарияМетода) > 1 Тогда
		НовыйТекстКомментарияМетода = НовыйТекстКомментарияМетода + Символы.ПС + "//";
	КонецЕсли;
	
	Возврат НовыйТекстКомментарияМетода;
	
КонецФункции

Функция ВставитьПустойКомментарийПередНачаломПроцедурыФункции(ТекстКомментарияМетода)
	
	Если ПустаяСтрока(ТекстКомментарияМетода) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	// Если комментарий перед процедурой (функцией) содержит только одну строку, то пропускаем.
	// Возможна неоднозначная ситуация, например, когда этот комментарий является служебным:
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	КоличествоСтрокКомментария = СтрЧислоСтрок(ТекстКомментарияМетода);
	Если КоличествоСтрокКомментария = 1 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	// Проверяем последнюю строку комментария.
	ПоследняяСтрокаКомментария = СтрПолучитьСтроку(ТекстКомментарияМетода, КоличествоСтрокКомментария);
	
	// Удаляем символы комментария.
	ПоследняяСтрокаКомментария = СтрЗаменить(ПоследняяСтрокаКомментария, "/", "");
	Если ПустаяСтрока(ПоследняяСтрокаКомментария) Тогда
		// Последняя строка комментария уже содержит пустой комментарий, выходим.
		Возврат Ложь;
	КонецЕсли;
	
	// Вставляем пустой комментарий.
	ТекстКомментарияМетода = ТекстКомментарияМетода + Символы.ПС + "//";
	
	Возврат Истина;
	
КонецФункции

Процедура ПереопределитьОписаниеПараметра(СтрокаОписанияПараметра, ПерваяСтрокаПолногоОписанияПараметра)
	
	// Запоминаем позицию текстового описания параметра до переопределения.
	ПозицияТекстовогоОписанияПараметраДоПереопределения = СтрокаОписанияПараметра.ПозицияТекстовогоОписанияПараметра;
	
	// Флаг "ОписаниеПараметраНачинаетсяСоЗвездочки" оставляем, т.к. он понадобится в нескольких исправлениях.
	ОписаниеПараметраНачинаетсяСоЗвездочки = СтрокаОписанияПараметра.ОписаниеПараметраНачинаетсяСоЗвездочки;
	
	// Получаем структуру описания параметра по новой первой строке полного описания параметра.
	ПолучатьИмяПараметра = НЕ ПустаяСтрока(СтрокаОписанияПараметра.ИмяПараметра);
	СтруктураОписанияПараметра = ПолучитьСтруктуруОписанияПараметра(ПерваяСтрокаПолногоОписанияПараметра, ПолучатьИмяПараметра, 0);
	
	// Переопределяем все свойства, кроме уровня вложенности и текстового описания.
	ЗаполнитьЗначенияСвойств(СтрокаОписанияПараметра, СтруктураОписанияПараметра,, "УровеньВложенностиПараметра, ТекстовоеОписаниеПараметра");
	
	// Переопределяем полное и текстовое описания параметра.
	МассивСтрокОписания = СтрРазделить(СтрокаОписанияПараметра.ПолноеОписаниеПараметра, Символы.ПС, Истина);
	МассивСтрокОписания[0] = ПерваяСтрокаПолногоОписанияПараметра;
	СтрокаОписанияПараметра.ПолноеОписаниеПараметра = СтрСоединить(МассивСтрокОписания, Символы.ПС);
	
	МассивСтрокОписания = СтрРазделить(СтрокаОписанияПараметра.ТекстовоеОписаниеПараметра, Символы.ПС, Истина);
	// Если позиция текстового описания до переопределения была больше 0, то заменяем первую строку.
	Если ПозицияТекстовогоОписанияПараметраДоПереопределения > 0 Тогда
		МассивСтрокОписания[0] = СтруктураОписанияПараметра.ТекстовоеОписаниеПараметра;
	Иначе
		// Иначе добавляем новое текстовое описание в начало старого.
		МассивСтрокОписания.Вставить(0, СтруктураОписанияПараметра.ТекстовоеОписаниеПараметра);
	КонецЕсли;
	СтрокаОписанияПараметра.ТекстовоеОписаниеПараметра = СокрЛ(СтрСоединить(МассивСтрокОписания, Символы.ПС));
	
	СтрокаОписанияПараметра.ОписаниеПараметраНачинаетсяСоЗвездочки = ОписаниеПараметраНачинаетсяСоЗвездочки;
	СтрокаОписанияПараметра.СостояниеПараметра = "Изменен";
	
КонецПроцедуры

Процедура УдалитьЛишниеСимволыИзОписанияПараметра(СтрокаОписанияПараметра)
	
	// Проверяем только первую строку описания параметра.
	ПолноеОписаниеПараметра = СтрокаОписанияПараметра.ПолноеОписаниеПараметра;
	ПерваяСтрокаПолногоОписанияПараметра = СтрПолучитьСтроку(ПолноеОписаниеПараметра, 1);
	
	ПерваяСтрокаПолногоОписанияПараметраБуфер = ПерваяСтрокаПолногоОписанияПараметра;
	ПерваяСтрокаПолногоОписанияПараметраБуфер = СтрЗаменить(ПерваяСтрокаПолногоОписанияПараметраБуфер, " ", "");
	ПерваяСтрокаПолногоОписанияПараметраБуфер = СтрЗаменить(ПерваяСтрокаПолногоОписанияПараметраБуфер, Символы.Таб, "");
	
	МассивЛишнихСимволов = Контекст["МассивЛишнихСимволов"];
	
	РезультатПоискаЛишнихСимволов = СтрНайтиПоМассиву(ПерваяСтрокаПолногоОписанияПараметраБуфер, МассивЛишнихСимволов);
	Если НЕ РезультатПоискаЛишнихСимволов.Успешно Тогда
		Возврат;
	КонецЕсли;
	
	МассивТире = Контекст["МассивТире"];
	
	ОписаниеПараметраИзменено = Ложь;
	
	// Рассмотрим следующие ситуации:
	// 1. Текстовое описание параметра начинается с запятой (случай "-,").
	ТекстовоеОписаниеПараметра = СтрокаОписанияПараметра.ТекстовоеОписаниеПараметра;
	Если СтрНачинаетсяС(ТекстовоеОписаниеПараметра, ",") Тогда
		
		// Возможны 2 случая:
		// 1.1. Тип параметра описан неверно, тогда лишнее тире, например:
		// Структура - , ФиксированнаяСтруктура,
		// 1.2. Тип параметра описан верно, тогда лишняя запятая, например:
		// Массив - , содержащий полные имена объектов метаданных.
		
		// Чтобы понять, какой из случаев обрабатывать, определим, является ли начало текстового описания типом параметра.
		// Для этого удаляем первую запятую из текстового описания.
		ТекстовоеОписаниеПараметра = УдалитьПервыйНезначимыйСимволИзСтроки(ТекстовоеОписаниеПараметра);
		Если СтрокаНачинаетсяСТипаПараметра(ТекстовоеОписаниеПараметра).Успешно Тогда
			
			// Если текстовое описание начинается с типа параметра, то обрабатываем случай 1.1.
			ПозицияРазделителяПередТекстовымОписаниемПараметра = СтрокаОписанияПараметра.ПозицияРазделителяПередТекстовымОписаниемПараметра;
			Если ПозицияРазделителяПередТекстовымОписаниемПараметра > 0 Тогда
				ПерваяСтрокаПолногоОписанияПараметраДоТире = Лев(ПерваяСтрокаПолногоОписанияПараметра, ПозицияРазделителяПередТекстовымОписаниемПараметра - 1);
				ПерваяСтрокаПолногоОписанияПараметраПослеТире = Сред(ПерваяСтрокаПолногоОписанияПараметра, ПозицияРазделителяПередТекстовымОписаниемПараметра + 1);
				ПерваяСтрокаПолногоОписанияПараметра = СокрП(ПерваяСтрокаПолногоОписанияПараметраДоТире) + СокрЛ(ПерваяСтрокаПолногоОписанияПараметраПослеТире);
				
				ОписаниеПараметраИзменено = Истина;
			КонецЕсли;
			
		Иначе
			
			// Если текстовое описание не начинается с типа параметра, то обрабатываем случай 1.2.
			ПерваяСтрокаТекстовогоОписанияПараметра = СтрПолучитьСтроку(ТекстовоеОписаниеПараметра, 1);
			ПозицияТекстовогоОписанияПараметра = СтрокаОписанияПараметра.ПозицияТекстовогоОписанияПараметра;
			Если ПозицияТекстовогоОписанияПараметра > 0 Тогда
				ПерваяСтрокаПолногоОписанияПараметраДоТекстовогоОписания = Лев(ПерваяСтрокаПолногоОписанияПараметра, ПозицияТекстовогоОписанияПараметра - 1);
				ПерваяСтрокаПолногоОписанияПараметра = ПерваяСтрокаПолногоОписанияПараметраДоТекстовогоОписания + ПерваяСтрокаТекстовогоОписанияПараметра;
				
				ОписаниеПараметраИзменено = Истина;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	// Если описание параметра было изменено, то переопределяем все колонки строки описания параметра.
	Если ОписаниеПараметраИзменено Тогда
		ПереопределитьОписаниеПараметра(СтрокаОписанияПараметра, ПерваяСтрокаПолногоОписанияПараметра);
		ОписаниеПараметраИзменено = Ложь;
	КонецЕсли;
	
	// 2. Тип параметра заканчивается на запятую (случай ",-").
	ТипПараметра = СтрокаОписанияПараметра.ТипПараметра;
	ПозицияРазделителяПередТекстовымОписаниемПараметра = СтрокаОписанияПараметра.ПозицияРазделителяПередТекстовымОписаниемПараметра;
	Если СтрЗаканчиваетсяНа(ТипПараметра, ",") И (ПозицияРазделителяПередТекстовымОписаниемПараметра > 0) Тогда
		
		// Возможны 2 случая:
		// 2.1. Тип параметра описан неверно, тогда лишнее тире, например:
		// Объект - КонстантаМенеджерЗначения, - СправочникОбъект, ДокументОбъект,
		// 2.2. Тип параметра описан верно, тогда лишняя запятая, например:
		// Массив, - содержащий полные имена объектов метаданных.
		
		// Чтобы понять, какой из случаев обрабатывать, определим, является ли начало текстового описания типом параметра.
		ТекстовоеОписаниеПараметра = СтрокаОписанияПараметра.ТекстовоеОписаниеПараметра;
		Если СтрокаНачинаетсяСТипаПараметра(ТекстовоеОписаниеПараметра).Успешно Тогда
			
			// Если текстовое описание начинается с типа параметра, то обрабатываем случай 2.1.
			ПерваяСтрокаПолногоОписанияПараметраДоТире = Лев(ПерваяСтрокаПолногоОписанияПараметра, ПозицияРазделителяПередТекстовымОписаниемПараметра - 1);
			ПерваяСтрокаПолногоОписанияПараметраПослеТире = Сред(ПерваяСтрокаПолногоОписанияПараметра, ПозицияРазделителяПередТекстовымОписаниемПараметра + 1);
			ПерваяСтрокаПолногоОписанияПараметра = ПерваяСтрокаПолногоОписанияПараметраДоТире + СокрЛ(ПерваяСтрокаПолногоОписанияПараметраПослеТире);
			
			ОписаниеПараметраИзменено = Истина;
			
		Иначе
			
			// Если текстовое описание не начинается с типа параметра, то обрабатываем случай 2.2.
			ПозицияЗапятой = СтрНайти(ПерваяСтрокаПолногоОписанияПараметра, ",", НаправлениеПоиска.СКонца, ПозицияРазделителяПередТекстовымОписаниемПараметра);
			ПерваяСтрокаПолногоОписанияПараметраДоЗапятой = Лев(ПерваяСтрокаПолногоОписанияПараметра, ПозицияЗапятой - 1);
			ПерваяСтрокаПолногоОписанияПараметраПослеЗапятой = Сред(ПерваяСтрокаПолногоОписанияПараметра, ПозицияЗапятой + 1);
			ПерваяСтрокаПолногоОписанияПараметра = СокрП(ПерваяСтрокаПолногоОписанияПараметраДоЗапятой) + ПерваяСтрокаПолногоОписанияПараметраПослеЗапятой;
			
			ОписаниеПараметраИзменено = Истина;
			
		КонецЕсли;
		
	КонецЕсли;
	
	// Если описание параметра было изменено, то переопределяем все колонки строки описания параметра.
	Если ОписаниеПараметраИзменено Тогда
		ПереопределитьОписаниеПараметра(СтрокаОписанияПараметра, ПерваяСтрокаПолногоОписанияПараметра);
		ОписаниеПараметраИзменено = Ложь;
	КонецЕсли;
	
	// 3. Лишнее тире в полном описании параметра (случай "--").
	ПозицияВторогоТире = 0;
	Пока Истина Цикл
		
		// Ищем первое тире.
		Если ПозицияВторогоТире > 0 Тогда
			// Если второе тире определено, то переопределяем его позицией первое тире.
			ПозицияПервогоТире = ПозицияВторогоТире;
		Иначе
			ПозицияПервогоТире = СтрНайтиПоМассиву(ПерваяСтрокаПолногоОписанияПараметра, МассивТире,, ПозицияВторогоТире + 1).Позиция;
			Если ПозицияПервогоТире = 0 Тогда
				Прервать;
			КонецЕсли;
		КонецЕсли;
		
		// Если строка заканчивается на тире, то прерываем.
		Если ПозицияПервогоТире >= СтрДлина(ПерваяСтрокаПолногоОписанияПараметра) Тогда
			Прервать;
		КонецЕсли;
		
		// Ищем второе тире.
		ПозицияВторогоТире = СтрНайтиПоМассиву(ПерваяСтрокаПолногоОписанияПараметра, МассивТире,, ПозицияПервогоТире + 1, Истина).Позиция;
		Если ПозицияВторогоТире = 0 Тогда
			Прервать;
		КонецЕсли;
		
		// Если текст между тире не пустой, то пропускаем.
		ТекстМеждуТире = Сред(ПерваяСтрокаПолногоОписанияПараметра, ПозицияПервогоТире + 1, ПозицияВторогоТире - ПозицияПервогоТире - 1);
		Если НЕ ПустаяСтрока(ТекстМеждуТире) Тогда
			Продолжить;
		КонецЕсли;
		
		// Получаем текст до первого тире.
		ПерваяСтрокаПолногоОписанияПараметраДоПервогоТире = Лев(ПерваяСтрокаПолногоОписанияПараметра, ПозицияПервогоТире - 1);
		
		// Если строка до первого тире пустая, т.е. полное описание параметра начинается с "--", то пропускаем эту замену.
		ПерваяСтрокаПолногоОписанияПараметраДоПервогоТиреБуфер = СтрЗаменить(ПерваяСтрокаПолногоОписанияПараметраДоПервогоТире, "/", "");
		Если ПустаяСтрока(ПерваяСтрокаПолногоОписанияПараметраДоПервогоТиреБуфер) Тогда
			Продолжить;
		КонецЕсли;
		
		ПоследнийСимволДоПервогоТире = Прав(ПерваяСтрокаПолногоОписанияПараметраДоПервогоТире, 1);
		Если НЕ ПустаяСтрока(ПоследнийСимволДоПервогоТире) Тогда
			// Если до первого тире нет пробелов, то добавляем один пробел.
			ПерваяСтрокаПолногоОписанияПараметраДоПервогоТире = ПерваяСтрокаПолногоОписанияПараметраДоПервогоТире + " ";
		КонецЕсли;
		
		// Получаем текст после второго тире.
		ПерваяСтрокаПолногоОписанияПараметраПослеВторогоТире = Сред(ПерваяСтрокаПолногоОписанияПараметра, ПозицияВторогоТире + 1);
		ПервыйСимволПослеВторогоТире = Лев(ПерваяСтрокаПолногоОписанияПараметраПослеВторогоТире, 1);
		Если НЕ ПустаяСтрока(ПервыйСимволПослеВторогоТире) Тогда
			// Если после второго тире нет пробелов, то добавляем один пробел.
			ПерваяСтрокаПолногоОписанияПараметраПослеВторогоТире = " " + ПерваяСтрокаПолногоОписанияПараметраПослеВторогоТире;
		КонецЕсли;
		
		// Склеиваем результирующую строку описания параметра.
		ПерваяСтрокаПолногоОписанияПараметра = ПерваяСтрокаПолногоОписанияПараметраДоПервогоТире + "-" + ПерваяСтрокаПолногоОписанияПараметраПослеВторогоТире;
		
		// Переопределяем позицию поиска тире.
		ПозицияВторогоТире = СтрДлина(ПерваяСтрокаПолногоОписанияПараметраДоПервогоТире) + 1;
		
		ОписаниеПараметраИзменено = Истина;
		
	КонецЦикла;
	
	// Если описание параметра было изменено, то переопределяем все колонки строки описания параметра.
	Если ОписаниеПараметраИзменено Тогда
		ПереопределитьОписаниеПараметра(СтрокаОписанияПараметра, ПерваяСтрокаПолногоОписанияПараметра);
		ОписаниеПараметраИзменено = Ложь;
	КонецЕсли;
	
КонецПроцедуры

Процедура УдалитьТекстОбязательныйНеобязательныйИзОписанияПараметра(СтрокаОписанияПараметра)
	
	// Обрабатываем только параметры процедур и функций, поэтому секцию "Возвращаемое значение" проверять бесполезно.
	Если СтрокаОписанияПараметра.СекцияОписания = "ВозвращаемоеЗначение" Тогда
		Возврат;
	КонецЕсли;
	
	// Если имя параметра не задано, то пропускаем.
	ИмяПараметра = СтрокаОписанияПараметра.ИмяПараметра;
	Если ПустаяСтрока(ИмяПараметра) Тогда
		Возврат;
	КонецЕсли;
	
	// Если уровень вложенности параметра больше 0 или имя параметра начинается с "*",
	// то это не параметр процедуры или функции, а свойство параметра, например, ключ структуры или колонка таблицы значений.
	Если (СтрокаОписанияПараметра.УровеньВложенностиПараметра > 0) ИЛИ СтрНачинаетсяС(ИмяПараметра, "*") Тогда
		Возврат;
	КонецЕсли;
	
	// Получаем первую строку полного описания параметра для поиска текстов "обязательный" и "необязательный".
	ПолноеОписаниеПараметра = СтрокаОписанияПараметра.ПолноеОписаниеПараметра;
	ПерваяСтрокаПолногоОписанияПараметра = СтрПолучитьСтроку(ПолноеОписаниеПараметра, 1);
	
	// Ищем различные варианты текстов "обязательный" и "необязательный" в первой строке описания параметра.
	МассивТекстОбязательныйНеобязательный = Контекст["МассивТекстОбязательныйНеобязательный"];
	СтруктураПоиска = СтрНайтиПоМассиву(ВРег(ПерваяСтрокаПолногоОписанияПараметра), МассивТекстОбязательныйНеобязательный);
	Если НЕ СтруктураПоиска.Успешно Тогда
		// Если не нашли, то выходим.
		Возврат;
	КонецЕсли;
	
	// Проверяем исключение конструкции текста "обязательный".
	МассивТекстИсключенийОбязательный = Контекст["МассивТекстИсключенийОбязательный"];
	СтруктураПоискаИсключения = СтрНайтиПоМассиву(ВРег(ПерваяСтрокаПолногоОписанияПараметра), МассивТекстИсключенийОбязательный);
	Если СтруктураПоискаИсключения.Успешно Тогда
		// Если нашли, то выходим.
		Возврат;
	КонецЕсли;
	
	// В имени параметра могут быть дополнительные символы или текст "обязательный", поэтому берем первое слово.
	ИмяПараметра = ПолучитьПервоеСловоИзСтроки(ИмяПараметра);
	ИмяПараметра = ВРег(ИмяПараметра);
	
	// Получаем массив параметров текущего метода.
	МассивПараметров = Новый Массив;
	ТекущийОбрабатываемыйМетод = Контекст["ТекущийОбрабатываемыйМетод"];
	Если ТекущийОбрабатываемыйМетод <> Неопределено Тогда
		МассивПараметров = ТекущийОбрабатываемыйМетод.МассивПараметров;
	КонецЕсли;
	
	// Ищем описанный параметр в комментарии среди параметров объявленного метода.
	ПараметрНайден = Ложь;
	Для Каждого Параметр Из МассивПараметров Цикл
		ИмяПараметраИзМетода = ПолучитьИмяПараметра(Параметр);
		Если СтрСравнить(ИмяПараметра, ИмяПараметраИзМетода) = 0 Тогда
			ПараметрНайден = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	// Если параметр не найден, то выходим, т.к. это может быть неверно описанное свойство параметра,
	// тогда удалять текст не надо.
	Если НЕ ПараметрНайден Тогда
		Возврат;
	КонецЕсли;
	
	ПозицияТекстаНеобязательный = СтруктураПоиска.Позиция;
	ДлинаТекстаНеобязательный = СтрДлина(СтруктураПоиска.НайденныйЭлемент);
	
	// Получаем текст первой строки до и после найденной конструкции текста "обязательный".
	ПерваяСтрокаДоТекстаНеобязательный = Лев(ПерваяСтрокаПолногоОписанияПараметра, ПозицияТекстаНеобязательный - 1);
	ПерваяСтрокаПослеТекстаНеобязательный = Сред(ПерваяСтрокаПолногоОписанияПараметра, ПозицияТекстаНеобязательный + ДлинаТекстаНеобязательный);
	ПерваяСтрокаПослеТекстаНеобязательный = СокрЛП(ПерваяСтрокаПослеТекстаНеобязательный);
	
	// Если следующий символ после текста "обязательный" - точка или запятая, то удаляем его.
	ПервыйСимволПослеТекстаНеобязательный = Лев(ПерваяСтрокаПослеТекстаНеобязательный, 1);
	Если СтрНайти(".,", ПервыйСимволПослеТекстаНеобязательный) > 0 Тогда
		ПерваяСтрокаПослеТекстаНеобязательный = УдалитьПервыйНезначимыйСимволИзСтроки(ПерваяСтрокаПослеТекстаНеобязательный);
	КонецЕсли;
	
	// Если строка заканчивается на конструкцию текста "обязательный", то сокращаем последние пробелы перед конструкцией.
	Если ПустаяСтрока(ПерваяСтрокаПослеТекстаНеобязательный) Тогда
		ПерваяСтрокаДоТекстаНеобязательный = СокрП(ПерваяСтрокаДоТекстаНеобязательный);
	КонецЕсли;
	
	// Склеиваем первую строку полного описания параметра.
	ПерваяСтрокаПолногоОписанияПараметра = ПерваяСтрокаДоТекстаНеобязательный + ПерваяСтрокаПослеТекстаНеобязательный;
	
	// Переопределяем все колонки строки описания параметра.
	ПереопределитьОписаниеПараметра(СтрокаОписанияПараметра, ПерваяСтрокаПолногоОписанияПараметра);
	
КонецПроцедуры

Процедура УдалитьДефисВКонцеСтрокиОписанияПараметра(СтрокаОписанияПараметра)
	
	ПолноеОписаниеПараметра = СокрП(СтрокаОписанияПараметра.ПолноеОписаниеПараметра);
	ИсходноеПолноеОписаниеПараметраЗаканчиваетсяНаДвоеточие = Ложь;
	
	// Иногда описание параметра заканчивается на "-." или "-:", тогда удаляем оба знака.
	Если НЕ СтрЗаканчиваетсяНа(ПолноеОписаниеПараметра, "-") Тогда
		ИсходноеПолноеОписаниеПараметраЗаканчиваетсяНаДвоеточие = СтрЗаканчиваетсяНа(ПолноеОписаниеПараметра, ":");
		ПолноеОписаниеПараметра = УдалитьПоследнийНезначимыйСимволИзСтроки(ПолноеОписаниеПараметра);
		// Проверяем "-" в конце описания параметра.
		Если НЕ СтрЗаканчиваетсяНа(ПолноеОписаниеПараметра, "-") Тогда
			// Если текстовое описание параметра не заканчивается на "-", то выходим.
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	// Иначе удаляем "-" в конце описания параметра.
	// Иногда в конце описания параметра встречается 2 тире, поэтому удаляем в цикле.
	Пока СтрЗаканчиваетсяНа(ПолноеОписаниеПараметра, "-") Цикл
		ПолноеОписаниеПараметра = Лев(ПолноеОписаниеПараметра, СтрДлина(ПолноеОписаниеПараметра) - 1);
		ПолноеОписаниеПараметра = СокрП(ПолноеОписаниеПараметра);
	КонецЦикла;
	
	// Если позиция типа параметра заполнена, но тип параметра пустой, то очистим позицию типа параметра.
	Если (СтрокаОписанияПараметра.ПозицияТипаПараметра > 0) И ПустаяСтрока(СтрокаОписанияПараметра.ТипПараметра) Тогда
		СтрокаОписанияПараметра.ПозицияТипаПараметра = 0;
	КонецЕсли;
	
	// Заменяем текстовое описание параметра.
	ТекстовоеОписаниеПараметра = СтрокаОписанияПараметра.ТекстовоеОписаниеПараметра;
	Если НЕ ПустаяСтрока(ТекстовоеОписаниеПараметра) Тогда
		
		// Получаем текстовое описание.
		ПозицияТекстовогоОписанияПараметра = СтрокаОписанияПараметра.ПозицияТекстовогоОписанияПараметра;
		Если ПозицияТекстовогоОписанияПараметра > 0 Тогда
			ТекстовоеОписаниеПараметра = Сред(ПолноеОписаниеПараметра, ПозицияТекстовогоОписанияПараметра);
		Иначе
			// Если позиция текстового описания равна 0, значит, текстовое описание начинается со следующей строки.
			МассивСтрокОписанияПараметра = СтрРазделить(ПолноеОписаниеПараметра, Символы.ПС, Ложь);
			МассивСтрокОписанияПараметра.Удалить(0);
			ТекстовоеОписаниеПараметра = СтрСоединить(МассивСтрокОписанияПараметра, Символы.ПС);
		КонецЕсли;
		
		// Если текстовое описание параметра стало пустым, то очистим его позицию.
		Если ПустаяСтрока(ТекстовоеОписаниеПараметра) Тогда
			СтрокаОписанияПараметра.ПозицияТекстовогоОписанияПараметра = 0;
		КонецЕсли;
		
	КонецЕсли;
	
	// Если исходное полное описание параметра заканчивалось на двоеточие, то добавим его обратно.
	Если ИсходноеПолноеОписаниеПараметраЗаканчиваетсяНаДвоеточие Тогда
		
		ИмяПараметра = СтрокаОписанияПараметра.ИмяПараметра;
		ТипПараметра = СтрокаОписанияПараметра.ТипПараметра;
		
		ПолноеОписаниеПараметра = УдалитьПоследнийНезначимыйСимволИзСтроки(ПолноеОписаниеПараметра) + ":";
		
		Если НЕ ПустаяСтрока(ТекстовоеОписаниеПараметра) Тогда
			ТекстовоеОписаниеПараметра = УдалитьПоследнийНезначимыйСимволИзСтроки(ТекстовоеОписаниеПараметра) + ":";
		ИначеЕсли НЕ ПустаяСтрока(ТипПараметра) Тогда
			ТипПараметра = УдалитьПоследнийНезначимыйСимволИзСтроки(ТипПараметра) + ":";
			СтрокаОписанияПараметра.ТипПараметра = ТипПараметра;
		ИначеЕсли НЕ ПустаяСтрока(ИмяПараметра) Тогда
			ИмяПараметра = УдалитьПоследнийНезначимыйСимволИзСтроки(ИмяПараметра) + ":";
			СтрокаОписанияПараметра.ИмяПараметра = ИмяПараметра;
		КонецЕсли;
		
	КонецЕсли;
	
	// Переопределяем измененные колонки строки описания параметра.
	СтрокаОписанияПараметра.ТекстовоеОписаниеПараметра = ТекстовоеОписаниеПараметра;
	СтрокаОписанияПараметра.ПолноеОписаниеПараметра    = ПолноеОписаниеПараметра;
	СтрокаОписанияПараметра.СостояниеПараметра         = "Изменен";
	
КонецПроцедуры

Процедура УстановитьТипПараметраИзИмениПараметра(СтрокаОписанияПараметра)
	
	ИмяПараметра = СтрокаОписанияПараметра.ИмяПараметра;
	ДлинаИмениПараметра = СтрДлина(ИмяПараметра);
	
	// Получаем полное описание параметра до имени параметра и после него.
	ПолноеОписаниеПараметра = СтрокаОписанияПараметра.ПолноеОписаниеПараметра;
	ПозицияИмениПараметра = СтрокаОписанияПараметра.ПозицияИмениПараметра;
	ПолноеОписаниеПараметраДоИмениПараметра = Лев(ПолноеОписаниеПараметра, ПозицияИмениПараметра - 1);
	ПолноеОписаниеПараметраПослеИмениПараметра = Сред(ПолноеОписаниеПараметра, ПозицияИмениПараметра + ДлинаИмениПараметра);
	
	// Ищем тип параметра в скобках в имени параметра в цикле, т.к. в одной строке может быть описание нескольких параметров.
	ТипПараметраУстановлен = Ложь;
	Пока Истина Цикл
		
		СтруктураРезультата = СтрокаСодержитТипПараметраВСкобках(ИмяПараметра);
		Если НЕ СтруктураРезультата.Успешно Тогда
			Прервать;
		КонецЕсли;
		
		ТипПараметраУстановлен = Истина;
		
		// Выделяем тип параметра.
		ИмяПараметраДоСкобки = Лев(ИмяПараметра, СтруктураРезультата.ПозицияОткрытойСкобки - 1);
		ТипПараметра = Сред(ИмяПараметра, СтруктураРезультата.ПозицияОткрытойСкобки + 1,
			СтруктураРезультата.ПозицияЗакрытойСкобки - СтруктураРезультата.ПозицияОткрытойСкобки - 1);
		ИмяПараметраПослеСкобки = Сред(ИмяПараметра, СтруктураРезультата.ПозицияЗакрытойСкобки + 1);
		
		ИмяПараметраПослеСкобки = СокрЛ(ИмяПараметраПослеСкобки);
		
		// Если после типа параметра в скобках есть еще описание, то добавляем разделитель.
		ДополнительныйРазделитель = "";
		Если апк_СловоСодержитЗначимыеСимволы(ИмяПараметраПослеСкобки) Тогда
			
			ДополнительныйРазделитель = " - ";
			Если СтрНачинаетсяС(ИмяПараметраПослеСкобки, ",") Тогда
				// Если после типа параметра в скобках сразу идет запятая, то скорее всего далее будет описание нового параметра.
				// Переносим его на следующую строку с тем же отступом.
				ИмяПараметраПослеСкобки = Сред(ИмяПараметраПослеСкобки, 2);
				ДополнительныйРазделитель = Символы.ПС + ПолноеОписаниеПараметраДоИмениПараметра;
			ИначеЕсли СтрНачинаетсяС(ИмяПараметраПослеСкобки, ":") Тогда
				// Двоеточие просто удаляем.
				ИмяПараметраПослеСкобки = Сред(ИмяПараметраПослеСкобки, 2);
			КонецЕсли;
			
		КонецЕсли;
		
		// Получаем объединенную строку с правильным описанием имени и типа параметра.
		ИмяПараметра = СокрП(ИмяПараметраДоСкобки) + " - " + ТипПараметра + ДополнительныйРазделитель + СокрЛ(ИмяПараметраПослеСкобки);
		
	КонецЦикла;
	
	// Если тип параметра в скобках не был найден, то выходим.
	Если НЕ ТипПараметраУстановлен Тогда
		Возврат;
	КонецЕсли;
	
	// Переопределяем полное описание параметра.
	ПолноеОписаниеПараметра = ПолноеОписаниеПараметраДоИмениПараметра + ИмяПараметра + ПолноеОписаниеПараметраПослеИмениПараметра;
	
	// Т.к. могло быть описано несколько параметров в одной строке, и мы их в цикле перенесли на следующие строки,
	// необходимо пересчитать номер строки конца описания параметра.
	НомерСтрокиНачалаОписанияПараметра = СтрокаОписанияПараметра.НомерСтрокиНачалаОписанияПараметра;
	НомерСтрокиКонцаОписанияПараметра = НомерСтрокиНачалаОписанияПараметра + СтрЧислоСтрок(ПолноеОписаниеПараметра) - 1;
	
	// Важно переопределить исходное описание параметра, т.к. количество строк полного описания параметра могло измениться.
	СтрокаОписанияПараметра.ПолноеОписаниеПараметра = ПолноеОписаниеПараметра;
	ПерваяСтрокаПолногоОписанияПараметра = СтрПолучитьСтроку(ПолноеОписаниеПараметра, 1);
	
	// Переопределяем остальные колонки строки описания параметра.
	ПереопределитьОписаниеПараметра(СтрокаОписанияПараметра, ПерваяСтрокаПолногоОписанияПараметра);
	СтрокаОписанияПараметра.НомерСтрокиКонцаОписанияПараметра = НомерСтрокиКонцаОписанияПараметра;
	СтрокаОписанияПараметра.НеобходимоПовторноеФорматирование = Истина;
	
КонецПроцедуры

Процедура УстановитьТипПараметраИзТекстовогоОписанияПараметра(СтрокаОписанияПараметра)
	
	// Если тип параметра заполнен, то выходим.
	Если НЕ ПустаяСтрока(СтрокаОписанияПараметра.ТипПараметра) Тогда
		Возврат;
	КонецЕсли;
	
	// Если текстовое описание параметра не заполнено, то выходим.
	ТекстовоеОписаниеПараметра = СтрокаОписанияПараметра.ТекстовоеОписаниеПараметра;
	Если ПустаяСтрока(ТекстовоеОписаниеПараметра) Тогда
		Возврат;
	КонецЕсли;
	
	МассивТиповПараметровДляВыделенияТипа = Контекст["МассивТиповПараметровДляВыделенияТипа"];
	ТаблицаТиповПараметровДляФорматирования = Контекст["ТаблицаТиповПараметровДляФорматирования"];
	ДлинаТиповПараметра = 0;
	
	НайденныйТип = "";
	ТипПараметраМножественный = Ложь;
	МассивТиповИзТекстовогоОписания = СтрРазделить(ТекстовоеОписаниеПараметра, ",;");
	Для Каждого ТипИзТекстовогоОписания Из МассивТиповИзТекстовогоОписания Цикл
		
		ТипИзТекстовогоОписанияБуфер = СокрЛ(ТипИзТекстовогоОписания);
		
		// Если текстовое описание не начинается с типа, то прерываем.
		РезультатПоискаТипаПараметра = СтрНачинаетсяСПоМассиву(ВРег(ТипИзТекстовогоОписанияБуфер), МассивТиповПараметровДляВыделенияТипа);
		Если НЕ РезультатПоискаТипаПараметра.Успешно Тогда
			Прервать;
		КонецЕсли;
		
		НайденныйЭлемент = РезультатПоискаТипаПараметра.НайденныйЭлемент;
		
		Если НЕ ПустаяСтрока(НайденныйТип) Тогда
			
			// Если предыдущий тип равен вновь найденному, то прерываем,
			// т.к. скорее всего, началось текстовое описание параметра с повторением типа, например:
			// ДатаФормированияФайла - Дата, дата и время выполнения замера.
			Если НайденныйТип = НайденныйЭлемент Тогда
				Прервать;
			Иначе
				// Текущее наименование типа может быть написано неверно, и далее будет заменено.
				// Проверим в таблице типов для замены.
				СтрокаТипаПараметра = ТаблицаТиповПараметровДляФорматирования.Найти(НайденныйЭлемент, "ТипПараметраДляПоиска");
				Если СтрокаТипаПараметра <> Неопределено Тогда
					// Найдено повторение типа, прерываем.
					Если НайденныйТип = СтрокаТипаПараметра.ТипПараметраДляЗаменыВРег Тогда
						Прервать;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			
		КонецЕсли;
		
		// Если какой-то тип уже был выделен, то добавляем длину запятой.
		Если ДлинаТиповПараметра > 0 Тогда
			ДлинаТиповПараметра = ДлинаТиповПараметра + 1;
			ТипПараметраМножественный = Истина;
		КонецЕсли;
		
		// Если найденный тип полностью является одним из возможных типов, то добавляем длину исходного элемента.
		НайденныйТип = НайденныйЭлемент;
		Если ВРег(СокрП(ТипИзТекстовогоОписанияБуфер)) = НайденныйТип Тогда
			ДлинаТиповПараметра = ДлинаТиповПараметра + СтрДлина(ТипИзТекстовогоОписания);
		Иначе
			// Если тип начинается с одного из возможных, но не равен ему,
			// то добавляем длину типа и прерываем для дальнейшего анализа следующего текста.
			ДлинаПробеловПередТипом = СтрДлина(ТипИзТекстовогоОписания) - СтрДлина(ТипИзТекстовогоОписанияБуфер);
			ДлинаТиповПараметра = ДлинаТиповПараметра + ДлинаПробеловПередТипом + СтрДлина(НайденныйТип);
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	// Если тип параметра в текстовом описании не обнаружен, то выходим.
	Если ДлинаТиповПараметра = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ТипПараметра = Лев(ТекстовоеОписаниеПараметра, ДлинаТиповПараметра);
	
	// Получаем текстовое описание параметра после типа параметра.
	ТекстовоеОписаниеПараметра = Сред(ТекстовоеОписаниеПараметра, ДлинаТиповПараметра + 1);
	
	// Если текстовое описание пустое, то выходим, т.к. добавлять нечего.
	Если ПустаяСтрока(ТекстовоеОписаниеПараметра) Тогда
		Возврат;
	КонецЕсли;
	
	ТекстовоеОписаниеПараметра = СокрЛ(ТекстовоеОписаниеПараметра);
	
	// Проверяем, с чего начинается текстовое описание параметра после сокращенного выделенного.
	МассивСимволовДляВыделенияТипаПараметра = Контекст["МассивСимволовДляВыделенияТипаПараметра"];
	РезультатПоискаСимволов = СтрНачинаетсяСПоМассиву(ВРег(ТекстовоеОписаниеПараметра), МассивСимволовДляВыделенияТипаПараметра);
	Если НЕ РезультатПоискаСимволов.Успешно Тогда
		// Если не нашли в специальном массиве символов, то выходим.
		Возврат;
	КонецЕсли;
	
	НаборСимволов = РезультатПоискаСимволов.НайденныйЭлемент;
	
	// Если символы незначимые, то обрезаем. Например, точку или запятую.
	Если НЕ апк_СловоСодержитЗначимыеСимволы(НаборСимволов) Тогда
		ТекстовоеОписаниеПараметра = Сред(ТекстовоеОписаниеПараметра, СтрДлина(НаборСимволов) + 1);
		ТекстовоеОписаниеПараметра = СокрЛ(ТекстовоеОписаниеПараметра);
	КонецЕсли;
	
	// Иначе заменяем первый символ на тире и пробелы.
	РазделительЭлементовОписанияПараметра = " - ";
	ДлинаРазделителяЭлементовОписанияПараметра = СтрДлина(РазделительЭлементовОписанияПараметра);
	
	// Переопределяем позицию типа параметра позицией текстового описания параметра.
	ПозицияТипаПараметра = СтрокаОписанияПараметра.ПозицияТекстовогоОписанияПараметра;
	ПозицияТекстовогоОписанияПараметра = ПозицияТипаПараметра + ДлинаТиповПараметра;
	СтрокаОписанияПараметра.ПозицияРазделителяПередТекстовымОписаниемПараметра = ПозицияТекстовогоОписанияПараметра + 1;
	ПозицияТекстовогоОписанияПараметра = ПозицияТекстовогоОписанияПараметра + ДлинаРазделителяЭлементовОписанияПараметра;
	
	ПолноеОписаниеПараметра = СтрокаОписанияПараметра.ПолноеОписаниеПараметра;
	ПолноеОписаниеПараметра = Лев(ПолноеОписаниеПараметра, ПозицияТипаПараметра - 1 + ДлинаТиповПараметра);
	ПолноеОписаниеПараметра = ПолноеОписаниеПараметра + РазделительЭлементовОписанияПараметра + ТекстовоеОписаниеПараметра;
	
	// Переопределяем все измененные колонки строки описания параметра.
	СтрокаОписанияПараметра.ПолноеОписаниеПараметра = ПолноеОписаниеПараметра;
	СтрокаОписанияПараметра.ТипПараметра = ТипПараметра;
	СтрокаОписанияПараметра.ТипПараметраМножественный = ТипПараметраМножественный;
	СтрокаОписанияПараметра.ПозицияТипаПараметра = ПозицияТипаПараметра;
	СтрокаОписанияПараметра.ТекстовоеОписаниеПараметра = ТекстовоеОписаниеПараметра;
	СтрокаОписанияПараметра.ПозицияТекстовогоОписанияПараметра = ПозицияТекстовогоОписанияПараметра;
	СтрокаОписанияПараметра.СостояниеПараметра = "Изменен";
	
КонецПроцедуры

Процедура ЗаменитьНеправильноеОписаниеТипаПараметра(СтрокаОписанияПараметра)
	
	ТипПараметра = СтрокаОписанияПараметра.ТипПараметра;
	Если ПустаяСтрока(ТипПараметра) Тогда
		Возврат;
	КонецЕсли;
	
	ПозицияТипаПараметра = СтрокаОписанияПараметра.ПозицияТипаПараметра;
	Если ПозицияТипаПараметра = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ТаблицаТиповПараметровДляФорматированияПоложениеРавно = Контекст["ТаблицаТиповПараметровДляФорматированияПоложениеРавно"];
	ТаблицаТиповПараметровДляФорматированияПоложениеНачало = Контекст["ТаблицаТиповПараметровДляФорматированияПоложениеНачало"];
	ТаблицаТиповПараметровДляФорматированияПоложениеКонец = Контекст["ТаблицаТиповПараметровДляФорматированияПоложениеКонец"];
	
	НомерЭлемента = -1;
	ТипПараметраЗаменен = Ложь;
	МассивТиповПараметра = СтрРазделить(ТипПараметра, ",;", Ложь);
	Для Каждого ЭлементТипаПараметра Из МассивТиповПараметра Цикл
		
		ЭлементТипаПараметраНайден = Ложь;
		
		НомерЭлемента = НомерЭлемента + 1;
		
		ЭлементТипаПараметра = СтрЗаменить(ЭлементТипаПараметра, "/", "");
		ЭлементТипаПараметра = СокрЛП(ЭлементТипаПараметра);
		
		// Если элемент типа параметра заканчивается на двоеточие, то запомним его.
		ПоследнийСимвол = ?(СтрЗаканчиваетсяНа(ЭлементТипаПараметра, ":"), ":", "");
		
		// И в любом случае удаляем последний незначимый символ (например, точку) для поиска по таблице типов.
		ЭлементТипаПараметра = УдалитьПоследнийНезначимыйСимволИзСтроки(ЭлементТипаПараметра);
		ЭлементТипаПараметраБуфер = ВРег(ЭлементТипаПараметра);
		ЭлементТипаПараметраБуфер = СтрЗаменить(ЭлементТипаПараметраБуфер, Символы.Таб, " ");
		ЭлементТипаПараметраБуфер = СтрСоединить(СтрРазделить(ЭлементТипаПараметраБуфер, " ", Ложь), " ");
		
		// Сначала ищем элемент типа параметра в таблице типов для замены с положением "Равно".
		СтрокаТипаПараметра = ТаблицаТиповПараметровДляФорматированияПоложениеРавно.Найти(ЭлементТипаПараметраБуфер, "ТипПараметраДляПоиска");
		Если СтрокаТипаПараметра <> Неопределено Тогда
			
			ЭлементТипаПараметраНайден = Истина;
			
			// Если текст для замены отличается от исходного типа в модуле, то заменяем.
			ТипПараметраДляЗамены = СтрокаТипаПараметра.ТипПараметраДляЗамены;
			Если ЭлементТипаПараметра <> ТипПараметраДляЗамены Тогда
				МассивТиповПараметра[НомерЭлемента] = " " + ТипПараметраДляЗамены + ПоследнийСимвол;
				ТипПараметраЗаменен = Истина;
			КонецЕсли;
			
		КонецЕсли;
		
		Если ЭлементТипаПараметраНайден Тогда
			Продолжить;
		КонецЕсли;
		
		// Если не нашли, то ищем в таблице типов для замены с положением "Начало".
		Для Каждого СтрокаТипаПараметра Из ТаблицаТиповПараметровДляФорматированияПоложениеНачало Цикл
			
			// Проверяем начало написания типа в верхнем регистре.
			ТипПараметраДляПоиска = СтрокаТипаПараметра.ТипПараметраДляПоиска;
			Если НЕ СтрНачинаетсяС(ЭлементТипаПараметраБуфер, ТипПараметраДляПоиска) Тогда
				// Если не совпадают, то проверяем следующий тип из таблицы.
				Продолжить;
			КонецЕсли;
			
			ЭлементТипаПараметраНайден = Истина;
			
			// Сравниваем начало написания типа с типом для замены.
			ТипПараметраДляЗамены = СтрокаТипаПараметра.ТипПараметраДляЗамены;
			Если (НЕ СтрНачинаетсяС(ЭлементТипаПараметра, ТипПараметраДляЗамены))
			 ИЛИ (СтрСравнить(ТипПараметраДляПоиска, ТипПараметраДляЗамены) <> 0) Тогда
				// Если не совпадают, то надо заменить.
				ТипПараметраТекстЗамены = ТипПараметраДляЗамены + Сред(ЭлементТипаПараметра, СтрДлина(ТипПараметраДляПоиска) + 1);
				МассивТиповПараметра[НомерЭлемента] = " " + ТипПараметраТекстЗамены + ПоследнийСимвол;
				ТипПараметраЗаменен = Истина;
			КонецЕсли;
			
			// Найден подходящий тип, прерываем.
			Прервать;
			
		КонецЦикла;
		
		Если ЭлементТипаПараметраНайден Тогда
			Продолжить;
		КонецЕсли;
		
		// Если не нашли, то ищем в таблице типов для замены с положением "Конец".
		Для Каждого СтрокаТипаПараметра Из ТаблицаТиповПараметровДляФорматированияПоложениеКонец Цикл
			
			// Проверяем конец написания типа в верхнем регистре.
			ТипПараметраДляПоиска = СтрокаТипаПараметра.ТипПараметраДляПоиска;
			Если НЕ СтрЗаканчиваетсяНа(ЭлементТипаПараметраБуфер, ТипПараметраДляПоиска) Тогда
				// Если не совпадают, то проверяем следующий тип из таблицы.
				Продолжить;
			КонецЕсли;
			
			ЭлементТипаПараметраНайден = Истина;
			
			// Сравниваем конец написания типа с типом для замены.
			ТипПараметраДляЗамены = СтрокаТипаПараметра.ТипПараметраДляЗамены;
			Если НЕ СтрЗаканчиваетсяНа(ЭлементТипаПараметра, ТипПараметраДляЗамены) Тогда
				// Если не совпадают, то надо заменить.
				ТипПараметраТекстЗамены = Лев(ЭлементТипаПараметра, СтрДлина(ЭлементТипаПараметра) - СтрДлина(ТипПараметраДляПоиска));
				ТипПараметраТекстЗамены = ТипПараметраТекстЗамены + ТипПараметраДляЗамены;
				МассивТиповПараметра[НомерЭлемента] = " " + ТипПараметраТекстЗамены + ПоследнийСимвол;
				ТипПараметраЗаменен = Истина;
			КонецЕсли;
			
			// Найден подходящий тип, прерываем.
			Прервать;
			
		КонецЦикла;
		
	КонецЦикла;
	
	// Если не было ни одной замены, то выходим.
	Если НЕ ТипПараметраЗаменен Тогда
		Возврат;
	КонецЕсли;
	
	// Соединяем массив типов параметра в строку.
	ТипПараметра = СтрСоединить(МассивТиповПараметра, ",");
	ТипПараметра = СокрЛП(ТипПараметра);
	
	Если НЕ СтрокаОписанияПараметра.ТипПараметраМножественный Тогда
		МассивТиповПараметра = СтрРазделить(ТипПараметра, ",", Ложь);
		Если МассивТиповПараметра.Количество() > 1 Тогда
			СтрокаОписанияПараметра.ТипПараметраМножественный = Истина;
		КонецЕсли;
	КонецЕсли;
	
	// Если тип параметра не изменился, то выходим.
	Если ТипПараметра = СтрокаОписанияПараметра.ТипПараметра Тогда
		Возврат;
	КонецЕсли;
	
	// Переопределяем полное описание типа параметра.
	ПолноеОписаниеПараметраИсходное = СтрокаОписанияПараметра.ПолноеОписаниеПараметра;
	ПолноеОписаниеПараметра = ПолноеОписаниеПараметраИсходное;
	ПолноеОписаниеПараметра = Лев(ПолноеОписаниеПараметра, ПозицияТипаПараметра - 1);
	ПолноеОписаниеПараметра = ПолноеОписаниеПараметра + ТипПараметра;
	
	// Если текстовое описание параметра заполнено, то добавляем его в полное описание.
	ТекстовоеОписаниеПараметра = СтрокаОписанияПараметра.ТекстовоеОписаниеПараметра;
	Если НЕ ПустаяСтрока(ТекстовоеОписаниеПараметра) Тогда
		
		// Если позиция тире перед текстовым описанием больше 0, то переопределим ее.
		ПозицияРазделителяПередТекстовымОписаниемПараметра = СтрокаОписанияПараметра.ПозицияРазделителяПередТекстовымОписаниемПараметра;
		Если ПозицияРазделителяПередТекстовымОписаниемПараметра > 0 Тогда
			РазделительОписанияПараметра = Сред(ПолноеОписаниеПараметраИсходное, ПозицияРазделителяПередТекстовымОписаниемПараметра, 1);
			ПолноеОписаниеПараметра = ПолноеОписаниеПараметра + ?(РазделительОписанияПараметра = ":", "", " ") + РазделительОписанияПараметра;
			СтрокаОписанияПараметра.ПозицияРазделителяПередТекстовымОписаниемПараметра = СтрДлина(ПолноеОписаниеПараметра);
		КонецЕсли;
		
		ПозицияТекстовогоОписанияПараметра = СтрокаОписанияПараметра.ПозицияТекстовогоОписанияПараметра;
		Если ПозицияТекстовогоОписанияПараметра > 0 Тогда
			ПолноеОписаниеПараметра = ПолноеОписаниеПараметра + " ";
			СтрокаОписанияПараметра.ПозицияТекстовогоОписанияПараметра = СтрДлина(ПолноеОписаниеПараметра) + 1;
		КонецЕсли;
		
		Если (ПозицияРазделителяПередТекстовымОписаниемПараметра = 0)
		 ИЛИ (ПозицияТекстовогоОписанияПараметра = 0)
		 ИЛИ СтрНачинаетсяС(ТекстовоеОписаниеПараметра, "//") Тогда
			ПолноеОписаниеПараметра = ПолноеОписаниеПараметра + Символы.ПС;
		КонецЕсли;
		
		ПолноеОписаниеПараметра = ПолноеОписаниеПараметра + ТекстовоеОписаниеПараметра;
		
	КонецЕсли;
	
	// Переопределяем необходимые колонки строки описания параметра.
	СтрокаОписанияПараметра.ТипПараметра = ТипПараметра;
	СтрокаОписанияПараметра.ПолноеОписаниеПараметра = ПолноеОписаниеПараметра;
	СтрокаОписанияПараметра.СостояниеПараметра = "Изменен";
	
КонецПроцедуры

Функция ФорматироватьТекстовоеОписаниеПараметраПослеТекстаКлючИЗначение(Знач ТекстОписанияСвойства)
	
	// Удаляем первый и последний незначимые символы.
	ТекстОписанияСвойства = УдалитьПервыйНезначимыйСимволИзСтроки(ТекстОписанияСвойства);
	ТекстОписанияСвойства = УдалитьПоследнийНезначимыйСимволИзСтроки(ТекстОписанияСвойства);
	
	// Заменяем текст в текстовом описании свойства.
	СписокЗаменПриПереносеСвойствКлючИЗначение = Контекст["СписокЗаменПриПереносеСвойствКлючИЗначение"];
	Для Каждого ЭлементСписка Из СписокЗаменПриПереносеСвойствКлючИЗначение Цикл
		
		ЗначениеПоиска = ЭлементСписка.Значение;
		ПозицияПоиска = СтрНайти(ВРег(ТекстОписанияСвойства), ЗначениеПоиска);
		Если ПозицияПоиска = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		ПозицияПослеЗначенияПоиска = ПозицияПоиска + СтрДлина(ЗначениеПоиска);
		
		ТекстОписанияСвойстваДоПозицииПоиска = Лев(ТекстОписанияСвойства, ПозицияПоиска - 1);
		ТекстОписанияСвойстваПослеЗначенияПоиска = Сред(ТекстОписанияСвойства, ПозицияПослеЗначенияПоиска);
		
		ТекстОписанияСвойства = ТекстОписанияСвойстваДоПозицииПоиска
			+ ЭлементСписка.Представление
			+ ТекстОписанияСвойстваПослеЗначенияПоиска;
		
	КонецЦикла;
	
	// Проверяем окончание части текстового описания после текста "Ключ" до текста "Значение".
	МассивУдаляемогоТекстаОкончанияТекстаКлючИЗначение = Новый Массив;
	МассивУдаляемогоТекстаОкончанияТекстаКлючИЗначение.Добавить(ВРег(" а"));
	МассивУдаляемогоТекстаОкончанияТекстаКлючИЗначение.Добавить(ВРег(" и"));
	МассивУдаляемогоТекстаОкончанияТекстаКлючИЗначение.Добавить(ВРег(" в"));
	
	// Если нашли какой-либо из элементов, то удаляем его.
	СтруктураПроверки = СтрЗаканчиваетсяНаПоМассиву(ВРег(ТекстОписанияСвойства), МассивУдаляемогоТекстаОкончанияТекстаКлючИЗначение);
	Если СтруктураПроверки.Успешно Тогда
		ДлинаУдаляемогоТекста = СтрДлина(СтруктураПроверки.НайденныйЭлемент);
		ДлинаТекстаОписанияСвойства = СтрДлина(ТекстОписанияСвойства);
		ТекстОписанияСвойства = Лев(ТекстОписанияСвойства, ДлинаТекстаОписанияСвойства - ДлинаУдаляемогоТекста);
	КонецЕсли;
	
	// Проверяем наличие скобок в текстовом описании свойства.
	Если СтрНачинаетсяС(ТекстОписанияСвойства, "(") И СтрЗаканчиваетсяНа(ТекстОписанияСвойства, ")") Тогда
		ТекстОписанияСвойства = Сред(ТекстОписанияСвойства, 2, СтрДлина(ТекстОписанияСвойства) - 2);
		ТекстОписанияСвойства = СокрЛП(ТекстОписанияСвойства);
	КонецЕсли;
	
	// Если текстовое описание свойства содержит тип параметра в скобках, то выносим его вперед.
	СтруктураПоискаТекстаВСкобках = СтрокаСодержитТипПараметраВСкобках(ТекстОписанияСвойства);
	Если СтруктураПоискаТекстаВСкобках.Успешно Тогда
		
		ПозицияОткрытойСкобки = СтруктураПоискаТекстаВСкобках.ПозицияОткрытойСкобки;
		ТекстОписанияСвойстваДоОткрытойСкобки = СокрЛП(Лев(ТекстОписанияСвойства, ПозицияОткрытойСкобки - 1));
		Если апк_СловоСодержитЗначимыеСимволы(ТекстОписанияСвойстваДоОткрытойСкобки) Тогда
			ТекстОписанияСвойстваДоОткрытойСкобки = " - " + ТекстОписанияСвойстваДоОткрытойСкобки;
		КонецЕсли;
		
		ПозицияЗакрытойСкобки = СтруктураПоискаТекстаВСкобках.ПозицияЗакрытойСкобки;
		ТекстОписанияСвойстваПослеЗакрытойСкобки = СокрЛП(Сред(ТекстОписанияСвойства, ПозицияЗакрытойСкобки + 1));
		Если апк_СловоСодержитЗначимыеСимволы(ТекстОписанияСвойстваПослеЗакрытойСкобки) Тогда
			ТекстОписанияСвойстваПослеЗакрытойСкобки = ", " + ТекстОписанияСвойстваПослеЗакрытойСкобки;
		КонецЕсли;
		
		ТекстОписанияСвойства = СтруктураПоискаТекстаВСкобках.ТекстВСкобках
			+ ТекстОписанияСвойстваДоОткрытойСкобки
			+ ТекстОписанияСвойстваПослеЗакрытойСкобки;
		
	КонецЕсли;
	
	// Если в текстовом описании свойства остались знаки комментария, значит, есть перенос на следующие строки.
	// Попробуем объединить короткие строки в одну.
	Если СтрНайти(ТекстОписанияСвойства, "//") > 0 Тогда
		ТекстОписанияСвойстваБуфер = СтрЗаменить(ТекстОписанияСвойства, "/", "");
		МассивСтрокОписанияСвойства = СтрРазделить(ТекстОписанияСвойстваБуфер, Символы.ПС + Символы.Таб + " ", Ложь);
		ТекстОписанияСвойстваБуфер = СтрСоединить(МассивСтрокОписанияСвойства, " ");
		// Если длина получившейся объединенной строки меньше 120 символов, то оставляем.
		Если СтрДлина(ТекстОписанияСвойстваБуфер) <= Контекст["КоличествоСимволовДляПереносаКомментария"] Тогда
			ТекстОписанияСвойства = ТекстОписанияСвойстваБуфер;
		КонецЕсли;
	КонецЕсли;
	
	// Еще раз удаляем первый и последний незначимые символы.
	ТекстОписанияСвойства = УдалитьПервыйНезначимыйСимволИзСтроки(ТекстОписанияСвойства);
	ТекстОписанияСвойства = УдалитьПоследнийНезначимыйСимволИзСтроки(ТекстОписанияСвойства);
	
	Возврат ТекстОписанияСвойства;
	
КонецФункции

Процедура ПеренестиКлючИЗначениеНаСледующиеСтрокиОписанияПараметра(СтрокаОписанияПараметра, СтруктураПоиска)
	
	ТекстовоеОписаниеПараметра = СтрокаОписанияПараметра.ТекстовоеОписаниеПараметра;
	
	// Вводим условное ограничение: если количество строк текстового описания параметра больше 3,
	// то ничего не анализируем и не переносим.
	Если СтрЧислоСтрок(ТекстовоеОписаниеПараметра) > 3 Тогда
		Возврат;
	КонецЕсли;
	
	МассивТекстИсключенийДляПереносаСвойствКлючИЗначение = Новый Массив;
	МассивТекстИсключенийДляПереносаСвойствКлючИЗначение.Добавить(ВРег("Ключ и Значение"));
	МассивТекстИсключенийДляПереносаСвойствКлючИЗначение.Добавить(ВРег("может быть"));
	
	Если СтрНайтиПоМассиву(ВРег(ТекстовоеОписаниеПараметра), МассивТекстИсключенийДляПереносаСвойствКлючИЗначение).Успешно Тогда
		Возврат;
	КонецЕсли;
	
	// Получаем отступ для текста "Ключ" и "Значение".
	ПолноеОписаниеПараметра = СтрокаОписанияПараметра.ПолноеОписаниеПараметра;
	ОтступДляТекстаКлючИЗначение = ПолучитьОтступПослеЗнакаКомментария(ПолноеОписаниеПараметра, Ложь);
	ОтступДляТекстаКлючИЗначение = ОтступДляТекстаКлючИЗначение + "  ";
	
	УровеньВложенностиПараметра = СтрокаОписанияПараметра.УровеньВложенностиПараметра;
	Для Счетчик = 0 По УровеньВложенностиПараметра Цикл
		ОтступДляТекстаКлючИЗначение = ОтступДляТекстаКлючИЗначение + "*";
	КонецЦикла;
	
	// Добавляем знаки комментария и пробел в отступ.
	ОтступДляТекстаКлючИЗначение = "//" + ОтступДляТекстаКлючИЗначение + " ";
	
	ПозицияТекстаКлюч = СтруктураПоиска.ПозицияТекстаКлюч;
	ПозицияТекстаЗначение = СтруктураПоиска.ПозицияТекстаЗначение;
	ПозицияПослеТекстаКлюч = ПозицияТекстаКлюч + СтрДлина(СтруктураПоиска.НайденныйТекстКлюч);
	ПозицияПослеТекстаЗначение = ПозицияТекстаЗначение + СтрДлина(СтруктураПоиска.НайденныйТекстЗначение);
	
	// Получаем части текстового описания параметра.
	ТекстовоеОписаниеПараметраДоТекстаКлюч = Лев(ТекстовоеОписаниеПараметра, ПозицияТекстаКлюч - 1);
	ТекстовоеОписаниеПараметраПослеТекстаКлюч = Сред(ТекстовоеОписаниеПараметра, ПозицияПослеТекстаКлюч, ПозицияТекстаЗначение - ПозицияПослеТекстаКлюч);
	ТекстовоеОписаниеПараметраПослеТекстаЗначение = Сред(ТекстовоеОписаниеПараметра, ПозицияПослеТекстаЗначение);
	
	ТекстовоеОписаниеПараметраДоТекстаКлюч = СокрЛП(ТекстовоеОписаниеПараметраДоТекстаКлюч);
	ТекстовоеОписаниеПараметраПослеТекстаКлюч = СокрЛП(ТекстовоеОписаниеПараметраПослеТекстаКлюч);
	ТекстовоеОписаниеПараметраПослеТекстаЗначение = СокрЛП(ТекстовоеОписаниеПараметраПослеТекстаЗначение);
	
	// Проверяем окончание части текстового описания до текста "Ключ".
	// Если последняя строка текстового описания до текста "Ключ" - пустая, то удаляем ее.
	МассивСтрокДоТекстаКлюч = СтрРазделить(ТекстовоеОписаниеПараметраДоТекстаКлюч, Символы.ПС, Истина);
	КоличествоСтрокДоТекстаКлюч = МассивСтрокДоТекстаКлюч.Количество();
	Если КоличествоСтрокДоТекстаКлюч > 1 Тогда
		ПоследняяСтрокаДоТекстаКлюч = МассивСтрокДоТекстаКлюч[КоличествоСтрокДоТекстаКлюч - 1];
		ПоследняяСтрокаДоТекстаКлюч = СтрЗаменить(ПоследняяСтрокаДоТекстаКлюч, "/", "");
		Если ПустаяСтрока(ПоследняяСтрокаДоТекстаКлюч) Тогда
			МассивСтрокДоТекстаКлюч.Удалить(КоличествоСтрокДоТекстаКлюч - 1);
			ТекстовоеОписаниеПараметраДоТекстаКлюч = СтрСоединить(МассивСтрокДоТекстаКлюч, Символы.ПС);
		КонецЕсли;
	КонецЕсли;
	
	// Добавляем двоеточие после текстового описания параметра до текста "Ключ".
	Если НЕ ПустаяСтрока(ТекстовоеОписаниеПараметраДоТекстаКлюч) Тогда
		ТекстовоеОписаниеПараметраДоТекстаКлюч = УдалитьПоследнийНезначимыйСимволИзСтроки(ТекстовоеОписаниеПараметраДоТекстаКлюч);
		ТекстовоеОписаниеПараметраДоТекстаКлюч = ТекстовоеОписаниеПараметраДоТекстаКлюч + ":";
	КонецЕсли;
	
	// Обрабатываем текстовое описание после текста "Ключ" и "Значение".
	ТекстовоеОписаниеПараметраПослеТекстаКлюч =
		ФорматироватьТекстовоеОписаниеПараметраПослеТекстаКлючИЗначение(ТекстовоеОписаниеПараметраПослеТекстаКлюч);
	ТекстовоеОписаниеПараметраПослеТекстаЗначение =
		ФорматироватьТекстовоеОписаниеПараметраПослеТекстаКлючИЗначение(ТекстовоеОписаниеПараметраПослеТекстаЗначение);
	
	// Соединяем части текстового описания.
	ТекстовоеОписаниеПараметра = СокрЛП(ТекстовоеОписаниеПараметраДоТекстаКлюч)
		+ Символы.ПС
		+ ОтступДляТекстаКлючИЗначение + СтруктураПоиска.НайденныйТекстКлюч + " - " + СокрЛП(ТекстовоеОписаниеПараметраПослеТекстаКлюч)
		+ Символы.ПС
		+ ОтступДляТекстаКлючИЗначение + СтруктураПоиска.НайденныйТекстЗначение + " - " + СокрЛП(ТекстовоеОписаниеПараметраПослеТекстаЗначение);
	
	// Получаем новое полное описание параметра.
	ПозицияТекстовогоОписанияПараметра = СтрокаОписанияПараметра.ПозицияТекстовогоОписанияПараметра;
	
	// Если позиция текстового параметра определена, то добавляем текстовое описание в полное с этой позиции.
	// Иначе вставляем текстовое описание со 2-й строки.
	НачалоПолногоОписанияПараметра = ?(ПозицияТекстовогоОписанияПараметра > 0,
		Лев(ПолноеОписаниеПараметра, ПозицияТекстовогоОписанияПараметра - 1),
		СтрПолучитьСтроку(ПолноеОписаниеПараметра, 1) + Символы.ПС);
	ПолноеОписаниеПараметра = НачалоПолногоОписанияПараметра + ТекстовоеОписаниеПараметра;
	
	// Переопределяем остальные колонки строки описания параметра.
	НомерСтрокиНачалаОписанияПараметра = СтрокаОписанияПараметра.НомерСтрокиНачалаОписанияПараметра;
	НомерСтрокиКонцаОписанияПараметра = НомерСтрокиНачалаОписанияПараметра + СтрЧислоСтрок(ПолноеОписаниеПараметра) - 1;
	
	СтрокаОписанияПараметра.ПолноеОписаниеПараметра = ПолноеОписаниеПараметра;
	СтрокаОписанияПараметра.ТекстовоеОписаниеПараметра = ТекстовоеОписаниеПараметра;
	СтрокаОписанияПараметра.НомерСтрокиКонцаОписанияПараметра = НомерСтрокиКонцаОписанияПараметра;
	СтрокаОписанияПараметра.СостояниеПараметра = "Изменен";
	СтрокаОписанияПараметра.НеобходимоПовторноеФорматирование = Истина;
	
КонецПроцедуры

Функция НайтиОписаниеСвойстваПараметра(СтрокаОписанияПараметра, ИмяСвойства, КоличествоСвойствДляПоиска = 0)
	
	СтрокаОписанияСвойства = Неопределено;
	
	// Получаем таблицу описания параметров.
	ТаблицаОписанияПараметров = СтрокаОписанияПараметра.Владелец();
	ИндексСтрокиОписанияПараметра = ТаблицаОписанияПараметров.Индекс(СтрокаОписанияПараметра);
	КоличествоСтрокТаблицыОписанияПараметров = ТаблицаОписанияПараметров.Количество();
	
	Если КоличествоСвойствДляПоиска = 0 Тогда
		КоличествоСвойствДляПоиска = КоличествоСтрокТаблицыОписанияПараметров - ИндексСтрокиОписанияПараметра - 1;
	КонецЕсли;
	
	// Запоминаем текущую секцию описания.
	СекцияОписания = СтрокаОписанияПараметра.СекцияОписания;
	
	КоличествоСвойствПроверено = 0;
	Для ИндексСтроки = ИндексСтрокиОписанияПараметра + 1 По КоличествоСтрокТаблицыОписанияПараметров - 1 Цикл
		
		// Если следующий параметр в другой секции описания, то прерываем.
		СтрокаОписанияСледующегоПараметра = ТаблицаОписанияПараметров[ИндексСтроки];
		Если СтрокаОписанияСледующегоПараметра.СекцияОписания <> СекцияОписания Тогда
			Прервать;
		КонецЕсли;
		
		// Если имя параметра не заполнено, то описан тип параметра, проверяем следующий.
		ИмяСледующегоПараметра = СтрокаОписанияСледующегоПараметра.ИмяПараметра;
		Если ПустаяСтрока(ИмяСледующегоПараметра) Тогда
			Продолжить;
		КонецЕсли;
		
		ИмяСледующегоПараметра = ПреобразоватьТекстДляСравнения(ИмяСледующегоПараметра);
		
		// Проверяем, является ли следующий параметр искомым свойством.
		// Дополнительную проверку на уровень вложенности (количество "*") пока не вводим,
		// т.к. очень часто свойства описывают некорректно.
		Если ИмяСледующегоПараметра = ВРег(ИмяСвойства) Тогда
			СтрокаОписанияСвойства = СтрокаОписанияСледующегоПараметра;
			Прервать;
		КонецЕсли;
		
		// Если количество проверенных свойств больше или равно количеству заявленных свойств для проверки, то прерываем.
		КоличествоСвойствПроверено = КоличествоСвойствПроверено + 1;
		Если КоличествоСвойствПроверено >= КоличествоСвойствДляПоиска Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат СтрокаОписанияСвойства;
	
КонецФункции

Процедура ЗаменитьОписаниеТипаПараметраСоответствие(СтрокаОписанияПараметра)
	
	ТипПараметра = СтрокаОписанияПараметра.ТипПараметра;
	Если ПустаяСтрока(ТипПараметра) Тогда
		Возврат;
	КонецЕсли;
	
	ПозицияТипаПараметра = СтрокаОписанияПараметра.ПозицияТипаПараметра;
	Если ПозицияТипаПараметра = 0 Тогда
		Возврат;
	КонецЕсли;
	
	СписокТекстСоответствие = Контекст["СписокТекстСоответствие"];
	
	// Ищем "Соответствие" в типе параметра.
	НомерЭлемента = -1;
	НомерЭлементаТипаПараметраСоответствие = -1;
	ЭлементСпискаТекстСоответствия = Неопределено;
	МассивТиповПараметра = СтрРазделить(ТипПараметра, ",", Ложь);
	Для Каждого ЭлементТипаПараметра Из МассивТиповПараметра Цикл
		
		НомерЭлемента = НомерЭлемента + 1;
		
		ЭлементТипаПараметра = ПреобразоватьТекстДляСравнения(ЭлементТипаПараметра);
		
		ЭлементСпискаТекстСоответствия = СписокТекстСоответствие.НайтиПоЗначению(ЭлементТипаПараметра);
		Если ЭлементСпискаТекстСоответствия <> Неопределено Тогда
			НомерЭлементаТипаПараметраСоответствие = НомерЭлемента;
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	// Если не нашли "Соответствие" в типе параметра, то выходим.
	Если (НомерЭлементаТипаПараметраСоответствие < 0) ИЛИ (ЭлементСпискаТекстСоответствия = Неопределено) Тогда
		Возврат;
	КонецЕсли;
	
	// Инициализируем флаг наличия ключа и значения.
	НайденоОписаниеКлючИЗначение = Ложь;
	
	// По таблице параметров ищем ниже параметры с наименованием "Ключ" и "Значение".
	Если НЕ НайденоОписаниеКлючИЗначение Тогда
		Если (НайтиОписаниеСвойстваПараметра(СтрокаОписанияПараметра, Контекст["ТекстКлюч"], 1) <> Неопределено)
		   И (НайтиОписаниеСвойстваПараметра(СтрокаОписанияПараметра, Контекст["ТекстЗначение"], 2) <> Неопределено) Тогда
			НайденоОписаниеКлючИЗначение = Истина;
		КонецЕсли;
	КонецЕсли;
	
	// Если не нашли, проверяем текст "Ключ" и "Значение" в текстовом описании.
	Если НЕ НайденоОписаниеКлючИЗначение Тогда
		ТекстовоеОписаниеПараметра = СтрокаОписанияПараметра.ТекстовоеОписаниеПараметра;
		СтруктураПоискаКлючИЗначение = СтрокаСодержитОписаниеСвойствКлючИЗначение(ТекстовоеОписаниеПараметра);
		// Если нашли, то сразу автоматически перенесем их на следующие строки описания параметра.
		Если СтруктураПоискаКлючИЗначение.Успешно Тогда
			НайденоОписаниеКлючИЗначение = Истина;
			ПеренестиКлючИЗначениеНаСледующиеСтрокиОписанияПараметра(СтрокаОписанияПараметра, СтруктураПоискаКлючИЗначение);
		КонецЕсли;
	КонецЕсли;
	
	// Не нашли описание параметров "Ключ" или "Значение", выходим.
	Если НЕ НайденоОписаниеКлючИЗначение Тогда
		Возврат;
	КонецЕсли;
	
	// Нашли описание параметров "Ключ" и "Значение", заменяем "Соответствие" на "Соответствие из КлючИЗначение",
	// при этом оставляем все дополнительные специальные символы.
	ТипПараметраСоответствие = МассивТиповПараметра[НомерЭлементаТипаПараметраСоответствие];
	ТипПараметраСоответствие = ВРег(ТипПараметраСоответствие);
	ТипПараметраСоответствие = СтрЗаменить(ТипПараметраСоответствие, ЭлементСпискаТекстСоответствия.Значение,
		ЭлементСпискаТекстСоответствия.Представление);
	МассивТиповПараметра[НомерЭлементаТипаПараметраСоответствие] = ТипПараметраСоответствие;
	
	// Соединяем массив типов параметра в строку.
	ТипПараметра = СтрСоединить(МассивТиповПараметра, ",");
	ТипПараметра = СокрЛП(ТипПараметра);
	
	// Переопределяем полное описание типа параметра.
	ПолноеОписаниеПараметра = СтрокаОписанияПараметра.ПолноеОписаниеПараметра;
	ПолноеОписаниеПараметра = Лев(ПолноеОписаниеПараметра, ПозицияТипаПараметра - 1);
	ПолноеОписаниеПараметра = ПолноеОписаниеПараметра + ТипПараметра;
	
	// Если текстовое описание параметра заполнено, то добавляем его в полное описание.
	ТекстовоеОписаниеПараметра = СтрокаОписанияПараметра.ТекстовоеОписаниеПараметра;
	Если НЕ ПустаяСтрока(ТекстовоеОписаниеПараметра) Тогда
		
		// Если позиция тире перед текстовым описанием больше 0, то переопределим ее.
		ПозицияРазделителяПередТекстовымОписаниемПараметра = СтрокаОписанияПараметра.ПозицияРазделителяПередТекстовымОписаниемПараметра;
		Если ПозицияРазделителяПередТекстовымОписаниемПараметра > 0 Тогда
			ПолноеОписаниеПараметра = ПолноеОписаниеПараметра + " -";
			СтрокаОписанияПараметра.ПозицияРазделителяПередТекстовымОписаниемПараметра = СтрДлина(ПолноеОписаниеПараметра);
		КонецЕсли;
		
		ПозицияТекстовогоОписанияПараметра = СтрокаОписанияПараметра.ПозицияТекстовогоОписанияПараметра;
		Если ПозицияТекстовогоОписанияПараметра > 0 Тогда
			ПолноеОписаниеПараметра = ПолноеОписаниеПараметра + " ";
			СтрокаОписанияПараметра.ПозицияТекстовогоОписанияПараметра = СтрДлина(ПолноеОписаниеПараметра) + 1;
		Иначе
			ПолноеОписаниеПараметра = ПолноеОписаниеПараметра + Символы.ПС;
		КонецЕсли;
		
		ПолноеОписаниеПараметра = ПолноеОписаниеПараметра + ТекстовоеОписаниеПараметра;
		
	КонецЕсли;
	
	// Переопределяем необходимые колонки строки описания параметра.
	СтрокаОписанияПараметра.ТипПараметра = ТипПараметра;
	СтрокаОписанияПараметра.ПолноеОписаниеПараметра = ПолноеОписаниеПараметра;
	СтрокаОписанияПараметра.СостояниеПараметра = "Изменен";
	
КонецПроцедуры

// Процедура выравнивается описание типа параметра относительно предыдущего,
// если строка описания начинается с тире и типа параметра.
//
// Пример:
//
// Было:
// Параметры:
//   ТекущийОбъект - ДокументОбъект
//                   - СправочникОбъект
//               - ПланОбменаОбъект - объект метаданных.
//
// Станет:
// Параметры:
//   ТекущийОбъект - ДокументОбъект
//                 - СправочникОбъект
//                 - ПланОбменаОбъект - объект метаданных.
// 
Процедура ВыровнятьТипПараметраОтносительноПредыдущего(СтрокаОписанияПараметра)
	
	// Если описание параметра не начинается с тире, то выходим.
	Если НЕ СтрокаОписанияПараметра.ОписаниеПараметраНачинаетсяСТире Тогда
		Возврат;
	КонецЕсли;
	
	// Если уровень вложенности параметра больше 0, т.е. это описание свойства, то выходим.
	УровеньВложенностиПараметра = СтрокаОписанияПараметра.УровеньВложенностиПараметра;
	Если УровеньВложенностиПараметра > 0 Тогда
		Возврат;
	КонецЕсли;
	
	// Если имя параметра указано, то выходим.
	ИмяПараметра = СтрокаОписанияПараметра.ИмяПараметра;
	Если НЕ ПустаяСтрока(ИмяПараметра) Тогда
		Возврат;
	КонецЕсли;
	
	// Если позиция разделителя перед типом параметра не определена, то выходим.
	ПозицияРазделителяПередТипомПараметра = СтрокаОписанияПараметра.ПозицияРазделителяПередТипомПараметра;
	Если ПозицияРазделителяПередТипомПараметра = 0 Тогда
		Возврат;
	КонецЕсли;
	
	// Если тип параметра сложный (через точку), и текстовое описание многострочное, то выходим.
	ПолноеОписаниеПараметра = СтрокаОписанияПараметра.ПолноеОписаниеПараметра;
	ТипПараметра = СтрокаОписанияПараметра.ТипПараметра;
	Если (СтрНайти(ТипПараметра, ".") > 0) И (СтрЧислоСтрок(ПолноеОписаниеПараметра) > 1) Тогда
		Возврат;
	КонецЕсли;
	
	// Проверим описание предыдущего параметра, для это получаем таблицу всех параметров.
	ТаблицаОписанияПараметров = СтрокаОписанияПараметра.Владелец();
	ИндексСтрокиОписанияПараметра = ТаблицаОписанияПараметров.Индекс(СтрокаОписанияПараметра);
	
	// Если текущий параметр - первый, то выравнивать не надо, выходим.
	Если ИндексСтрокиОписанияПараметра = 0 Тогда
		Возврат;
	КонецЕсли;
	
	// Если предыдущий параметр из другой секции описания, то выходим.
	СтрокаОписанияПредыдущегоПараметра = ТаблицаОписанияПараметров[ИндексСтрокиОписанияПараметра - 1];
	Если СтрокаОписанияПараметра.СекцияОписания <> СтрокаОписанияПредыдущегоПараметра.СекцияОписания Тогда
		Возврат;
	КонецЕсли;
	
	// Если уровни вложенности не совпадают, то выходим.
	Если УровеньВложенностиПараметра <> СтрокаОписанияПредыдущегоПараметра.УровеньВложенностиПараметра Тогда
		Возврат;
	КонецЕсли;
	
	// Если позиция тире перед типом предыдущего параметра не определена, то выходим.
	ПозицияТиреПередТипомПредыдущегоПараметра = СтрокаОписанияПредыдущегоПараметра.ПозицияРазделителяПередТипомПараметра;
	Если ПозицияТиреПередТипомПредыдущегоПараметра = 0 Тогда
		Возврат;
	КонецЕсли;
	
	// Проверяем тип предыдущего параметра в массиве исключений типов для выравнивания.
	МассивИсключенийТиповПараметровДляВыравнивания = Контекст["МассивИсключенийТиповПараметровДляВыравнивания"];
	
	ТипПараметраВРег = ВРег(ТипПараметра);
	ТипПараметраВРег = УдалитьПоследнийНезначимыйСимволИзСтроки(ТипПараметраВРег);
	ТипПредыдущегоПараметра = ВРег(СтрокаОписанияПредыдущегоПараметра.ТипПараметра);
	Если СтрНайтиПоМассиву(ТипПредыдущегоПараметра, МассивИсключенийТиповПараметровДляВыравнивания).Успешно Тогда
		// Если один из типов исключений нашли в типе предыдущего параметра, то выходим.
		Возврат;
	КонецЕсли;
	
	// Если тип текущего параметра есть в типах предыдущего параметра, то сдвигать не нужно, выходим.
	МассивТиповПредыдущегоПараметра = СтрРазделить(ТипПредыдущегоПараметра, ",;: " + Символы.Таб, Ложь);
	Если МассивТиповПредыдущегоПараметра.Найти(ТипПараметраВРег) <> Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	// Получаем новый отступ из полного описания предыдущего параметра до тире перед типом параметра.
	ПолноеОписаниеПредыдущегоПараметра = СтрокаОписанияПредыдущегоПараметра.ПолноеОписаниеПараметра;
	ПолноеОписаниеПредыдущегоПараметраДоТире = Лев(ПолноеОписаниеПредыдущегоПараметра, ПозицияТиреПередТипомПредыдущегоПараметра - 1);
	ПолноеОписаниеПредыдущегоПараметраПослеТире = СтрЗаменить(ПолноеОписаниеПредыдущегоПараметра, ПолноеОписаниеПредыдущегоПараметраДоТире, "");
	ОписаниеПредыдущегоПараметраСодержитПробелПослеТире = СтрНачинаетсяС(ПолноеОписаниеПредыдущегоПараметраПослеТире, "- ");
	
	// Заменяем все символы, кроме знаков комментария и табов.
	СтрокаНезаменяемыхСимволов = "/" + Символы.Таб;
	ПолноеОписаниеПараметраДоТире = "";
	ДлинаПолногоОписанияПредыдущегоПараметраДоТире = СтрДлина(ПолноеОписаниеПредыдущегоПараметраДоТире);
	Для НомерСимвола = 1 По ДлинаПолногоОписанияПредыдущегоПараметраДоТире Цикл
		Символ = Сред(ПолноеОписаниеПредыдущегоПараметраДоТире, НомерСимвола, 1);
		// Добавляем в строку либо символ, либо пробел.
		СимволЗамены = ?(СтрНайти(СтрокаНезаменяемыхСимволов, Символ) > 0, Символ, " ");
		ПолноеОписаниеПараметраДоТире = ПолноеОписаниеПараметраДоТире + СимволЗамены;
	КонецЦикла;
	
	ПолноеОписаниеПараметраНачинаяСТире = Сред(ПолноеОписаниеПараметра, ПозицияРазделителяПередТипомПараметра);
	Если ОписаниеПредыдущегоПараметраСодержитПробелПослеТире
		И НЕ СтрНачинаетсяС(ПолноеОписаниеПараметраНачинаяСТире, "- ") Тогда
		ПолноеОписаниеПараметраНачинаяСТире = СтрЗаменить(ПолноеОписаниеПараметраНачинаяСТире, "-", "- ");
	КонецЕсли;
	ПолноеОписаниеПараметра = ПолноеОписаниеПараметраДоТире + ПолноеОписаниеПараметраНачинаяСТире;
	
	// Проверяем случай, когда перед типом параметра есть незначимый символ, Например, ", <ТипПараметра>".
	ТипПараметраБезНезначимыхСимволов = УдалитьПервыйНезначимыйСимволИзСтроки(ТипПараметра);
	Если ТипПараметра <> ТипПараметраБезНезначимыхСимволов Тогда
		ПолноеОписаниеПараметра = СтрЗаменить(ПолноеОписаниеПараметра, ТипПараметра, ТипПараметраБезНезначимыхСимволов);
	КонецЕсли;
	
	// Полное описание не изменилось, то выходим.
	Если СтрокаОписанияПараметра.ПолноеОписаниеПараметра = ПолноеОписаниеПараметра Тогда
		Возврат;
	КонецЕсли;
	
	// Переопределяем позиции элементов полного описания.
	РазницаПозицийТиреПередТипом = ПозицияТиреПередТипомПредыдущегоПараметра - ПозицияРазделителяПередТипомПараметра;
	ТаблицаПозицийОписанияПараметра = Контекст["ТаблицаПозицийОписанияПараметра"].Скопировать();
	Для Каждого СтрокаПозицииОписанияПараметра Из ТаблицаПозицийОписанияПараметра Цикл
		
		НаименованиеПозицииОписанияПараметра = СтрокаПозицииОписанияПараметра.НаименованиеПозиции;
		ПозицияЭлементаОписанияПараметра = СтрокаОписанияПараметра[НаименованиеПозицииОписанияПараметра];
		
		Если ПозицияЭлементаОписанияПараметра = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		ПозицияЭлементаОписанияПараметра = ПозицияЭлементаОписанияПараметра + РазницаПозицийТиреПередТипом;
		СтрокаОписанияПараметра[НаименованиеПозицииОписанияПараметра] = ПозицияЭлементаОписанияПараметра;
		
	КонецЦикла;
	
	СтрокаОписанияПараметра.ПолноеОписаниеПараметра = ПолноеОписаниеПараметра;
	СтрокаОписанияПараметра.СостояниеПараметра = "Изменен";
	
КонецПроцедуры

Процедура ЗаменитьТабыНаПробелыПередОписаниемПараметра(СтрокаОписанияПараметра)
	
	// Если в описании параметра нет табов, то выходим.
	ПолноеОписаниеПараметра = СтрокаОписанияПараметра.ПолноеОписаниеПараметра;
	Если СтрНайти(ПолноеОписаниеПараметра, Символы.Таб) = 0 Тогда
		Возврат;
	КонецЕсли;
	
	// В общем случае пока заменяем табы на пробелы только до имени параметра.
	// Если имя параметра не указано (например, строка описания параметра начинается с тире и типа), то замены не будет.
	ТаблицаПозицийОписанияПараметра = Контекст["ТаблицаПозицийОписанияПараметра"].Скопировать();
	Если СтрокаОписанияПараметра.ЭтоОписаниеВозвращаемогоЗначения Тогда
		// Кроме случая описания возвращаемого значения - в этих строках замена табов происходит до типа параметра.
		СтрокаПозицииОписанияПараметра = ТаблицаПозицийОписанияПараметра.Найти("ПозицияТипаПараметра", "НаименованиеПозиции");
		Если СтрокаПозицииОписанияПараметра <> Неопределено Тогда
			СтрокаПозицииОписанияПараметра.ЗаменятьТабыДоПозиции = Истина;
		КонецЕсли;
	КонецЕсли;
	
	// Получаем позицию для замены табов.
	ПозицияЗаменыТабов = 0;
	Для Каждого СтрокаПозицииОписанияПараметра Из ТаблицаПозицийОписанияПараметра Цикл
		
		// Запоминаем во временную таблицу позиций описания параметров текущие позиции.
		НаименованиеПозицииОписанияПараметра = СтрокаПозицииОписанияПараметра.НаименованиеПозиции;
		ПозицияЭлементаОписанияПараметра = СтрокаОписанияПараметра[НаименованиеПозицииОписанияПараметра];
		СтрокаПозицииОписанияПараметра.Позиция = ПозицияЭлементаОписанияПараметра;
		
		// Если позиция найдена, то пропускаем.
		Если ПозицияЗаменыТабов > 0 Тогда
			Продолжить;
		КонецЕсли;
		
		// Если для этой позиции не надо заменять табы, то пропускаем.
		Если НЕ СтрокаПозицииОписанияПараметра.ЗаменятьТабыДоПозиции Тогда
			Продолжить;
		КонецЕсли;
		
		// Если нашли позицию, то запоминаем ее.
		Если ПозицияЭлементаОписанияПараметра > 0 Тогда
			ПозицияЗаменыТабов = ПозицияЭлементаОписанияПараметра;
		КонецЕсли;
		
	КонецЦикла;
	
	// Если ни одна из позиций не определена, то выходим.
	Если ПозицияЗаменыТабов = 0 Тогда
		Возврат;
	КонецЕсли;
	
	// Определяем текст описания, в котором необходимо заменить табы на пробелы.
	ТекстДоПозицииЗаменыТабов = Лев(ПолноеОписаниеПараметра, ПозицияЗаменыТабов - 1);
	КоличествоТабов = СтрЧислоВхождений(ТекстДоПозицииЗаменыТабов, Символы.Таб);
	Если КоличествоТабов = 0 Тогда
		Возврат;
	КонецЕсли;
	
	// Заменяем таб на 2 пробела.
	ТекстДоПозицииЗаменыТабов = СтрЗаменить(ТекстДоПозицииЗаменыТабов, Символы.Таб, "  ");
	ПолноеОписаниеПараметра = ТекстДоПозицииЗаменыТабов + Сред(ПолноеОписаниеПараметра, ПозицияЗаменыТабов);
	
	// Переопределяем необходимые колонки строки описания параметра.
	Для Каждого СтрокаПозицииОписанияПараметра Из ТаблицаПозицийОписанияПараметра Цикл
		
		ПозицияЭлементаОписанияПараметра = СтрокаПозицииОписанияПараметра.Позиция;
		Если НЕ апк_ЭтоЧисло(ПозицияЭлементаОписанияПараметра) Тогда
			Продолжить;
		КонецЕсли;
		
		ПозицияЭлементаОписанияПараметра = Число(ПозицияЭлементаОписанияПараметра);
		Если ПозицияЭлементаОписанияПараметра = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		// Заменяем значения всех определенных позиций больше 0.
		НаименованиеПозицииОписанияПараметра = СтрокаПозицииОписанияПараметра.НаименованиеПозиции;
		СтрокаОписанияПараметра[НаименованиеПозицииОписанияПараметра] = ПозицияЭлементаОписанияПараметра + КоличествоТабов;
		
	КонецЦикла;
	
	СтрокаОписанияПараметра.ПолноеОписаниеПараметра = ПолноеОписаниеПараметра;
	СтрокаОписанияПараметра.СостояниеПараметра = "Изменен";
	
КонецПроцедуры

Процедура РазделитьТипыПараметраПоСтрокам(СтрокаОписанияПараметра)
	
	// Если тип параметра не указан, то выходим.
	ТипПараметра = СтрокаОписанияПараметра.ТипПараметра;
	Если ПустаяСтрока(ТипПараметра) Тогда
		Возврат;
	КонецЕсли;
	
	// Получаем позицию типа параметра.
	ПозицияТипаПараметра = СтрокаОписанияПараметра.ПозицияТипаПараметра;
	Если ПозицияТипаПараметра = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ДлинаТипаПараметра = СтрДлина(ТипПараметра);
	
	// Если это описание возвращаемого значения, то проверяем длину описания типа параметра.
	Если СтрокаОписанияПараметра.ЭтоОписаниеВозвращаемогоЗначения Тогда
		// Если длина описания типа параметра не более 80-ти символов, то оставляем в исходном виде.
		Если ДлинаТипаПараметра <= 80 Тогда
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	ТекстовоеОписаниеПараметра = СтрокаОписанияПараметра.ТекстовоеОписаниеПараметра;
	
	// Определяем, закончено ли описание типа параметра на первой строке описания параметра.
	ПозицияРазделителяПередТекстовымОписаниемПараметра = СтрокаОписанияПараметра.ПозицияРазделителяПередТекстовымОписаниемПараметра;
	ТипПараметраЗакончен = ПустаяСтрока(ТекстовоеОписаниеПараметра) ИЛИ (ПозицияРазделителяПередТекстовымОписаниемПараметра > 0);
	
	// Если тип параметра единственный, и описание типа параметра закончилось,
	// т.к. есть тире перед текстовым описанием параметра, то выходим.
	Если (НЕ СтрокаОписанияПараметра.ТипПараметраМножественный) И ТипПараметраЗакончен Тогда
		Возврат;
	КонецЕсли;
	
	// Проверим скобки в описании типа.
	ПозицияЗакрывающейсяСкобки = 0;
	Пока Истина Цикл
		
		Если ПозицияЗакрывающейсяСкобки >= ДлинаТипаПараметра Тогда
			Прервать;
		КонецЕсли;
		
		ПозицияОткрывающейсяСкобки = СтрНайти(ТипПараметра, "(",, ПозицияЗакрывающейсяСкобки + 1);
		Если ПозицияОткрывающейсяСкобки = 0 Тогда
			Прервать;
		КонецЕсли;
		
		ПозицияЗакрывающейсяСкобки = СтрНайти(ТипПараметра, ")",, ПозицияОткрывающейсяСкобки + 1);
		Если ПозицияЗакрывающейсяСкобки = 0 Тогда
			ПозицияЗакрывающейсяСкобки = ДлинаТипаПараметра;
		КонецЕсли;
		
		// Если текст в скобках содержит запятую, тогда разделение пройдет неверно, выходим.
		ТекстВСкобках = Сред(ТипПараметра, ПозицияОткрывающейсяСкобки + 1, ПозицияЗакрывающейсяСкобки - ПозицияОткрывающейсяСкобки - 1);
		Если СтрНайти(ТекстВСкобках, ",") > 0 Тогда
			Возврат;
		КонецЕсли;
		
	КонецЦикла;
	
	// Разделяем типы параметра на массив типов.
	МассивТиповПараметра = СтрРазделить(ТипПараметра, ",;", Ложь);
	Если ТипПараметраЗакончен Тогда
		
		КоличествоТиповПараметра = МассивТиповПараметра.Количество();
		
		// Если описание типа закончено и только один тип параметра, то выходим.
		Если КоличествоТиповПараметра < 2 Тогда
			Возврат;
		КонецЕсли;
		
		ПозицияНачалаОписанияТипаПараметра = СтрокаОписанияПараметра.ПозицияРазделителяПередТипомПараметра;
		Если ПозицияНачалаОписанияТипаПараметра = 0 Тогда
			ПозицияНачалаОписанияТипаПараметра = ПозицияТипаПараметра;
		КонецЕсли;
		
		ПозицияКонцаОписанияТипаПараметра = СтрокаОписанияПараметра.ПозицияРазделителяПередТекстовымОписаниемПараметра;
		Если ПозицияКонцаОписанияТипаПараметра = 0 Тогда
			ПозицияКонцаОписанияТипаПараметра = ПозицияТипаПараметра + ДлинаТипаПараметра;
		Иначе
			// Тире после описание типа также учитываем при подсчете длины.
			ПозицияКонцаОписанияТипаПараметра = ПозицияКонцаОписанияТипаПараметра + 1;
		КонецЕсли;
		
		ДлинаТипаПараметра = ПозицияКонцаОписанияТипаПараметра - ПозицияНачалаОписанияТипаПараметра;
		
		// Если количество типов параметра не более 5, и длина описания типов до 50 символов,
		// то оставляем описание типов на одной строке и выходим.
		Если (КоличествоТиповПараметра <= 5) И (ДлинаТипаПараметра <= 50) Тогда
			Возврат;
		КонецЕсли;
		
	КонецЕсли;
	
	ТаблицаТиповПараметра = Новый ТаблицаЗначений;
	ТаблицаТиповПараметра.Колонки.Добавить("ТипПараметра");
	
	Для Каждого ЭлементТипаПараметра Из МассивТиповПараметра Цикл
		
		// Если элемент типа пустой, то пропускаем его.
		Если ПустаяСтрока(ЭлементТипаПараметра) Тогда
			Продолжить;
		КонецЕсли;
		
		// Если один из элементов типа является числом, то выходим.
		ЭлементТипаПараметра = СокрЛП(ЭлементТипаПараметра);
		Если апк_ЭтоЧисло(ЭлементТипаПараметра) Тогда
			Возврат;
		КонецЕсли;
		
		// Добавляем тип в таблицу.
		СтрокаТаблицыТиповПараметра = ТаблицаТиповПараметра.Добавить();
		СтрокаТаблицыТиповПараметра.ТипПараметра = ЭлементТипаПараметра;
		
	КонецЦикла;
	
	// Если описание типа параметра не закончено, то, возможно, в текстовом описании есть еще описание типа параметра,
	// рассмотрим его отдельно.
	Если НЕ ТипПараметраЗакончен Тогда
		
		ТипыПараметраИзТекстовогоОписания = ТекстовоеОписаниеПараметра;
		ПозицияТире = СтрНайти(ТипыПараметраИзТекстовогоОписания, "-");
		Если ПозицияТире > 0 Тогда
			ТипыПараметраИзТекстовогоОписания = Лев(ТекстовоеОписаниеПараметра, ПозицияТире - 1);
		КонецЕсли;
		
		МассивИсключенийТиповПараметров = Контекст["МассивИсключенийТиповПараметров"];
		ДлинаТиповПараметраИзТекстовогоОписания = 0;
		
		// Разделяем типы параметра на массив типов.
		НомерЭлементаТипа = -1;
		МассивТиповПараметра = СтрРазделить(ТипыПараметраИзТекстовогоОписания, ",;", Ложь);
		Для Каждого ЭлементТипаПараметра Из МассивТиповПараметра Цикл
			
			НомерЭлементаТипа = НомерЭлементаТипа + 1;
			
			ЭлементТипаПараметраБуфер = ЭлементТипаПараметра;
			ЭлементТипаПараметраБуфер = СтрЗаменить(ЭлементТипаПараметраБуфер, "/", "");
			ЭлементТипаПараметраБуфер = СокрЛП(ЭлементТипаПараметраБуфер);
			
			// Если элемент описания параметра пустой, то прерываем.
			Если ПустаяСтрока(ЭлементТипаПараметраБуфер) Тогда
				Прервать;
			КонецЕсли;
			
			// Если элемент описания параметра не содержит заглавных букв, то это не тип параметра, прерываем.
			Если НРег(ЭлементТипаПараметраБуфер) = ЭлементТипаПараметраБуфер Тогда
				Прервать;
			КонецЕсли;
			
			// Если в элементе описания параметра есть пробелы, тогда это не тип, прерываем.
			Если СтрНайти(ЭлементТипаПараметраБуфер, " ") > 0 Тогда
				Прервать;
			КонецЕсли;
			
			// Если элемент текстового параметра не содержит буквы, то прерываем.
			Если НЕ апк_СловоСодержитБуквы(ЭлементТипаПараметраБуфер) Тогда
				Прервать;
			КонецЕсли;
			
			// Если элемент текстового параметра есть в массиве исключений типов параметров, то прерываем.
			Если МассивИсключенийТиповПараметров.Найти(ВРег(ЭлементТипаПараметраБуфер)) <> Неопределено Тогда
				Прервать;
			КонецЕсли;
			
			// Если в текстовом описании встретился тип параметра, который уже есть в таблице типов,
			// и он является последним в текстовом описании, то, скорее всего, далее идет описание этого типа параметра, прерываем.
			СтрокаТаблицыТиповПараметра = ТаблицаТиповПараметра.Найти(ЭлементТипаПараметраБуфер, "ТипПараметра");
			Если СтрокаТаблицыТиповПараметра <> Неопределено Тогда
				Если НомерЭлементаТипа = МассивТиповПараметра.ВГраница() Тогда
					Прервать;
				КонецЕсли;
			КонецЕсли;
			
			// Если у текущего параметра не заполнено наименование,
			// то, возможно, перед этим уже есть перечисление этого типа параметра.
			Если ПустаяСтрока(СтрокаОписанияПараметра.ИмяПараметра) Тогда
				
				// Ищем вверх по всей таблице описания параметров первый параметр с заполненным наименованием.
				ТаблицаОписанияПараметров = СтрокаОписанияПараметра.Владелец();
				ИндексСтрокиОписанияПараметра = ТаблицаОписанияПараметров.Индекс(СтрокаОписанияПараметра);
				
				СекцияОписания = СтрокаОписанияПараметра.СекцияОписания;
				
				ТипПараметраНайденВТаблицеОписанияПараметров = Ложь;
				Для ИндексСтроки = 1 По ИндексСтрокиОписанияПараметра Цикл
					
					// Если секция не совпадает, то прерываем.
					ИндексСтрокиВверх = ИндексСтрокиОписанияПараметра - ИндексСтроки;
					СтрокаОписанияПараметраВверх = ТаблицаОписанияПараметров[ИндексСтрокиВверх];
					Если СтрокаОписанияПараметраВверх.СекцияОписания <> СекцияОписания Тогда
						Прервать;
					КонецЕсли;
					
					// Если тип параметра уже был описан ранее, прерываем.
					Если СтрокаОписанияПараметраВверх.ТипПараметра = ЭлементТипаПараметраБуфер Тогда
						ТипПараметраНайденВТаблицеОписанияПараметров = Истина;
						Прервать;
					КонецЕсли;
					
					// Если нашли параметр с заполненным наименованием, то прерываем.
					Если НЕ ПустаяСтрока(СтрокаОписанияПараметраВверх.ИмяПараметра) Тогда
						Прервать;
					КонецЕсли;
					
				КонецЦикла;
				
				// Если нашли тип параметра в таблице описания параметров,
				// то добавлять этот тип в таблицу параметров не нужно, прерываем.
				Если ТипПараметраНайденВТаблицеОписанияПараметров Тогда
					Прервать;
				КонецЕсли;
				
			КонецЕсли;
			
			// Добавляем тип в таблицу.
			СтрокаТаблицыТиповПараметра = ТаблицаТиповПараметра.Добавить();
			СтрокаТаблицыТиповПараметра.ТипПараметра = ЭлементТипаПараметраБуфер;
			
			ДлинаТиповПараметраИзТекстовогоОписания = ДлинаТиповПараметраИзТекстовогоОписания + СтрДлина(ЭлементТипаПараметра) + 1;
			
		КонецЦикла;
		
		Если ПозицияТире = ДлинаТиповПараметраИзТекстовогоОписания Тогда
			ПозицияРазделителяПередТекстовымОписаниемПараметра = ПозицияТире;
		КонецЕсли;
		
		ТекстовоеОписаниеПараметра = Сред(ТекстовоеОписаниеПараметра, ДлинаТиповПараметраИзТекстовогоОписания);
		ТекстовоеОписаниеПараметра = СокрЛ(ТекстовоеОписаниеПараметра);
		Если ПустаяСтрока(ТекстовоеОписаниеПараметра) Тогда
			ТекстовоеОписаниеПараметра = "";
		Иначе
			СтрокаСимволовДляУдаления = "- , .";
			МассивСимволовДляУдаления = СтрРазделить(СтрокаСимволовДляУдаления, " ");
			
			Если СтрНачинаетсяСПоМассиву(ТекстовоеОписаниеПараметра, МассивСимволовДляУдаления).Успешно Тогда
				ТекстовоеОписаниеПараметра = Сред(ТекстовоеОписаниеПараметра, 2);
				ТекстовоеОписаниеПараметра = СокрЛ(ТекстовоеОписаниеПараметра);
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
	МассивТиповПараметра = ТаблицаТиповПараметра.ВыгрузитьКолонку("ТипПараметра");
	Если МассивТиповПараметра.Количество() < 2 Тогда
		Возврат;
	КонецЕсли;
	
	// Рассчитаем разделитель для переноса параметра.
	РазделительТипов = Символы.ПС;
	
	СтрокаНезаменяемыхСимволов = "/-" + Символы.Таб;
	
	ПолноеОписаниеПараметра = СтрокаОписанияПараметра.ПолноеОписаниеПараметра;
	СтрокаДоТипаПараметра = Лев(ПолноеОписаниеПараметра, ПозицияТипаПараметра - 1);
	
	ДлинаСтрокиДоТипаПараметра = СтрДлина(СтрокаДоТипаПараметра);
	Для НомерСимвола = 1 По ДлинаСтрокиДоТипаПараметра Цикл
		Символ = Сред(СтрокаДоТипаПараметра, НомерСимвола, 1);
		// Добавляем в разделитель либо символ, либо пробел.
		РазделительТипов = РазделительТипов + ?(СтрНайти(СтрокаНезаменяемыхСимволов, Символ) > 0, Символ, " ");
	КонецЦикла;
	
	// Проверим количество тире в получившемся разделителе.
	// Если больше 1, то оставим только последний.
	КоличествоТире = СтрЧислоВхождений(РазделительТипов, "-");
	Если КоличествоТире > 1 Тогда
		НомерТире = 0;
		Для НомерСимвола = 1 По ДлинаСтрокиДоТипаПараметра Цикл
			// Проверяем символ.
			Символ = Сред(РазделительТипов, НомерСимвола, 1);
			Если Символ <> "-" Тогда
				Продолжить;
			КонецЕсли;
			// Заменяем тире на пробел.
			РазделительТипов = Лев(РазделительТипов, НомерСимвола - 1) + " " + Сред(РазделительТипов, НомерСимвола + 1);
			// Если это предпоследнее тире, то прерываем.
			НомерТире = НомерТире + 1;
			Если (НомерТире + 1) = КоличествоТире Тогда
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	ТипПараметра = СтрСоединить(МассивТиповПараметра, РазделительТипов);
	
	ПозицияТекстовогоОписанияПараметра = 0;
	
	// Если текстовое описание не пустое, то добавим его к новому полному описанию параметра.
	ПолноеОписаниеПараметра = СтрокаДоТипаПараметра + ТипПараметра;
	Если НЕ ПустаяСтрока(ТекстовоеОписаниеПараметра) Тогда
		
		// Если текстовое описание начинается с новой строки после типа, то разделителем будет являться перенос.
		Если СтрНачинаетсяС(ТекстовоеОписаниеПараметра, "//") Тогда
			
			РазделительМеждуТипомИТекстовымОписанием = Символы.ПС;
			
			// Если в первой строке описания параметра было тире перед текстовым описанием, то оставим его.
			Если ПозицияРазделителяПередТекстовымОписаниемПараметра > 0 Тогда
				РазделительМеждуТипомИТекстовымОписанием = " -" + РазделительМеждуТипомИТекстовымОписанием;
			КонецЕсли;
			
		Иначе
			
			// Если текстовое описание находится на той же строке, что и тип, то разделителем будет являться тире.
			РазделительМеждуТипомИТекстовымОписанием = " - ";
			
			// Если текстовое описание состоит из нескольких строк, то необходимо их сдвинуть на новую позицию.
			МассивСтрокТекстовогоОписания = СтрРазделить(ТекстовоеОписаниеПараметра, Символы.ПС, Ложь);
			Если МассивСтрокТекстовогоОписания.Количество() > 1 Тогда
				
				// Сдвигаем каждую строку текстового описания параметра влево на уровень тире.
				ПоследнийТипПараметра = МассивТиповПараметра[МассивТиповПараметра.ВГраница()];
				ДлинаСтрокиДоТекстовогоОписания = ДлинаСтрокиДоТипаПараметра + СтрДлина(ПоследнийТипПараметра) + СтрДлина(РазделительМеждуТипомИТекстовымОписанием);
				
				// Обрабатываем все строки текстового описания кроме первой, т.к. первая будет в одной строке с типом.
				Для НомерСтроки = 1 По МассивСтрокТекстовогоОписания.ВГраница() Цикл
					
					СтрокаТекстовогоОписания = МассивСтрокТекстовогоОписания[НомерСтроки];
					СтрокаТекстовогоОписанияБуфер = СтрЗаменить(СтрокаТекстовогоОписания, "/", " ");
					
					// Если текущая длина отступа строки текстового описания меньше или равна той, которую собираемся установить, то пропускаем.
					ДлинаТекущегоОтступаСтроки = СтрДлина(СтрокаТекстовогоОписанияБуфер) - СтрДлина(СокрЛ(СтрокаТекстовогоОписанияБуфер));
					Если ДлинаТекущегоОтступаСтроки <= ДлинаСтрокиДоТекстовогоОписания Тогда
						Продолжить;
					КонецЕсли;
					
					СтрокаТекстовогоОписания = Лев(СтрокаТекстовогоОписания, ДлинаСтрокиДоТекстовогоОписания) + СокрЛ(СтрокаТекстовогоОписанияБуфер);
					МассивСтрокТекстовогоОписания[НомерСтроки] = СтрокаТекстовогоОписания;
					
				КонецЦикла;
				
				ТекстовоеОписаниеПараметра = СтрСоединить(МассивСтрокТекстовогоОписания, Символы.ПС);
				
			КонецЕсли;
			
		КонецЕсли;
		
		ПолноеОписаниеПараметра = ПолноеОписаниеПараметра + РазделительМеждуТипомИТекстовымОписанием;
		ПозицияТекстовогоОписанияПараметра = СтрДлина(ПолноеОписаниеПараметра) + 1;
		ПолноеОписаниеПараметра = ПолноеОписаниеПараметра + ТекстовоеОписаниеПараметра;
		
	КонецЕсли;
	
	// Переопределяем остальные колонки строки описания параметра.
	НомерСтрокиНачалаОписанияПараметра = СтрокаОписанияПараметра.НомерСтрокиНачалаОписанияПараметра;
	НомерСтрокиКонцаОписанияПараметра = НомерСтрокиНачалаОписанияПараметра + СтрЧислоСтрок(ПолноеОписаниеПараметра) - 1;
	
	СтрокаОписанияПараметра.ТипПараметра = ТипПараметра;
	СтрокаОписанияПараметра.ПолноеОписаниеПараметра = ПолноеОписаниеПараметра;
	СтрокаОписанияПараметра.ТекстовоеОписаниеПараметра = ТекстовоеОписаниеПараметра;
	СтрокаОписанияПараметра.ПозицияТекстовогоОписанияПараметра = ПозицияТекстовогоОписанияПараметра;
	СтрокаОписанияПараметра.НомерСтрокиКонцаОписанияПараметра = НомерСтрокиКонцаОписанияПараметра;
	СтрокаОписанияПараметра.СостояниеПараметра = "Изменен";
	
КонецПроцедуры

Процедура УстановитьПервыйСимволТекстовогоОписанияПараметраВНижнийРегистр(СтрокаОписанияПараметра)
	
	ТекстовоеОписаниеПараметра = СтрокаОписанияПараметра.ТекстовоеОписаниеПараметра;
	Если ПустаяСтрока(ТекстовоеОписаниеПараметра) Тогда
		Возврат;
	КонецЕсли;
	
	// Если позиция текстового описания не заполнена, значит, текстовое описание находится на следующей строке.
	// В таком случае не меняем регистр первого символа текстового описания и выходим.
	ПозицияТекстовогоОписанияПараметра = СтрокаОписанияПараметра.ПозицияТекстовогоОписанияПараметра;
	Если ПозицияТекстовогоОписанияПараметра = 0 Тогда
		Возврат;
	КонецЕсли;
	
	// Проверяем регистр первого символа текстового описания параметра.
	ПервыйСимволТекстовогоОписанияПараметра = Лев(ТекстовоеОписаниеПараметра, 1);
	Если ПервыйСимволТекстовогоОписанияПараметра = НРег(ПервыйСимволТекстовогоОписанияПараметра) Тогда
		// Если первый символ уже в нижнем регистре, то выходим.
		Возврат;
	КонецЕсли;
	
	// Если первый символ не из кириллического алфавита, то выходим.
	Если НЕ апк_СловоСодержитКириллицу(ПервыйСимволТекстовогоОписанияПараметра) Тогда
		Возврат;
	КонецЕсли;
	
	// Если описание параметра состоит только из текстового описания,
	// то устанавливать первый символ в нижний регистр не нужно, выходим.
	Если ПустаяСтрока(СтрокаОписанияПараметра.ИмяПараметра)
	   И ПустаяСтрока(СтрокаОписанияПараметра.ТипПараметра)
	   И (НЕ СтрокаОписанияПараметра.ОписаниеПараметраНачинаетсяСТире) Тогда
		Возврат;
	КонецЕсли;
	
	ТекстовоеОписаниеПараметраБуфер = СтрЗаменить(ТекстовоеОписаниеПараметра, Символы.Таб, " ");
	
	// Исключаем некоторые конструкции, с которых может начинаться текстовое описание параметра.
	МассивИсключенийСлов = Контекст["МассивИсключенийСловДляУстановкиПервогоСимволаТекстовогоОписанияПараметраВНижнийРегистр"];
	Если СтрНачинаетсяСПоМассиву(ВРег(ТекстовоеОписаниеПараметраБуфер), МассивИсключенийСлов).Успешно Тогда
		Возврат;
	КонецЕсли;
	
	// Иногда в текстовом описании первым словом указан тип параметра, нужна дополнительная проверка.
	МассивСловТекстовогоОписанияПараметра = СтрРазделить(ТекстовоеОписаниеПараметраБуфер, " ", Ложь);
	Если МассивСловТекстовогоОписанияПараметра.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	// Проверяем первое слово текстового описания.
	ПервоеСловоТекстовогоОписанияПараметра = МассивСловТекстовогоОписанияПараметра[0];
	
	// Если оно заканчивается на двоеточие, то выходим.
	Если СтрЗаканчиваетсяНа(ПервоеСловоТекстовогоОписанияПараметра, ":") Тогда
		Возврат;
	КонецЕсли;
	
	// Убираем первый символ первого слова текстового описания.
	ПервоеСловоТекстовогоОписанияПараметра = Сред(ПервоеСловоТекстовогоОписанияПараметра, 2);
	
	// Если в первом слове есть еще заглавные буквы, то это, скорее всего, описание типа параметра.
	Если ПервоеСловоТекстовогоОписанияПараметра <> НРег(ПервоеСловоТекстовогоОписанияПараметра) Тогда
		// Устанавливать первый символ в нижний регистр не нужно, выходим.
		Возврат;
	КонецЕсли;
	
	// Устанавливаем первый символ текстового описания параметра в нижний регистр.
	ТекстовоеОписаниеПараметра = НРег(ПервыйСимволТекстовогоОписанияПараметра) + Сред(ТекстовоеОписаниеПараметра, 2);
	
	// Заменяем полное описание параметра.
	ПолноеОписаниеПараметра = СтрокаОписанияПараметра.ПолноеОписаниеПараметра;
	ПолноеОписаниеПараметра = Лев(ПолноеОписаниеПараметра, ПозицияТекстовогоОписанияПараметра - 1) + ТекстовоеОписаниеПараметра;
	
	// Переопределяем все измененные колонки строки описания параметра.
	СтрокаОписанияПараметра.ПолноеОписаниеПараметра = ПолноеОписаниеПараметра;
	СтрокаОписанияПараметра.ТекстовоеОписаниеПараметра = ТекстовоеОписаниеПараметра;
	СтрокаОписанияПараметра.СостояниеПараметра = "Изменен";
	
КонецПроцедуры

Процедура УдалитьНезначащееТекстовоеОписаниеПараметра(СтрокаОписанияПараметра)
	
	// Если нет текстового описания параметра, то выходим.
	ТекстовоеОписаниеПараметра = СтрокаОписанияПараметра.ТекстовоеОписаниеПараметра;
	Если ПустаяСтрока(ТекстовоеОписаниеПараметра) Тогда
		Возврат;
	КонецЕсли;
	
	// Если в текстовом описании только аббревиатуры, то выходим.
	Если ВРег(ТекстовоеОписаниеПараметра) = ТекстовоеОписаниеПараметра Тогда
		Возврат;
	КонецЕсли;
	
	ТекстовоеОписаниеПараметра = СокрЛП(ТекстовоеОписаниеПараметра);
	
	// Возводим обратный флаг для проверки.
	ТекстовоеОписаниеПараметраЯвляетсяЗначащим = Истина;
	
	Если ТекстовоеОписаниеПараметраЯвляетсяЗначащим Тогда
		// Проверяем текстовое описание параметра среди вариантов незначащих описаний, пока без проверки типа параметра.
		МассивНезначащихОписаний = Контекст["МассивНезначащихОписаний"];
		Если МассивНезначащихОписаний.Найти(ПреобразоватьТекстДляСравнения(ТекстовоеОписаниеПараметра)) <> Неопределено Тогда
			ТекстовоеОписаниеПараметраЯвляетсяЗначащим = Ложь;
		КонецЕсли;
	КонецЕсли;
	
	Если ТекстовоеОписаниеПараметраЯвляетсяЗначащим Тогда
		
		// Проверяем тип параметра, если тип пустой, то выходим.
		ТипПараметра = СтрокаОписанияПараметра.ТипПараметра;
		Если ПустаяСтрока(ТипПараметра) Тогда
			Возврат;
		КонецЕсли;
		
		// Проверяем только последний тип параметра в массиве составных типов,
		// т.к. ранее было разделение типов по строкам (поэтому делим строку типа параметра по запятой и тире),
		// и текстовое описание будет визуально относиться только к последнему типу.
		МассивТиповПараметра = СтрРазделить(ТипПараметра, ",-", Ложь);
		ПоследнийТипПараметра = МассивТиповПараметра[МассивТиповПараметра.ВГраница()];
		ПоследнийТипПараметра = ПреобразоватьТекстДляСравнения(ПоследнийТипПараметра);
		
		// Если последний тип параметра не составной, то выходим.
		МассивСоставныхТиповПараметров = Контекст["МассивСоставныхТиповПараметров"];
		Если МассивСоставныхТиповПараметров.Найти(ПоследнийТипПараметра) = Неопределено Тогда
			Возврат;
		КонецЕсли;
		
	КонецЕсли;
	
	// Проверяем следующие условия незначащего параметра:
	// 1. Текстовое описание закачивается на ":" и содержит менее 25 символов.
	Если ТекстовоеОписаниеПараметраЯвляетсяЗначащим Тогда
		// Если текстовое описание меньше 25-ти символов,
		Если СтрДлина(ТекстовоеОписаниеПараметра) < 25 Тогда
			// То проверяем, надо ли добавить двоеточие в конце.
			// (Двоеточие будет добавлено отдельно в цикле по таблице параметров, сейчас эта процедура вызывается только для проверки).
			ДобавитьДвоеточиеВКонцеСтрокиОписанияПараметра(СтрокаОписанияПараметра);
			ТекстовоеОписаниеПараметра = СокрЛП(СтрокаОписанияПараметра.ТекстовоеОписаниеПараметра);
			// Если двоеточие уже было или добавлено только что, то считаем, что параметр незначащий.
			Если СтрЗаканчиваетсяНа(ТекстовоеОписаниеПараметра, ":") Тогда
				ТекстовоеОписаниеПараметраЯвляетсяЗначащим = Ложь;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	// 2. Написано по шаблону, например:
	//  ... - <структура|таблица|дерево значений|...>, содержащая передаваемые параметры:
	//  ... - таблица значений с колонками:
	Если ТекстовоеОписаниеПараметраЯвляетсяЗначащим Тогда
		
		ТекстовоеОписаниеПараметраБуфер = ВРег(ТекстовоеОписаниеПараметра);
		ТаблицаШаблоновНезначащихОписаний = Контекст["ТаблицаШаблоновНезначащихОписаний"];
		
		ШаблонНайден = Ложь;
		Для Каждого СтрокаШаблонаНезначащегоОписания Из ТаблицаШаблоновНезначащихОписаний Цикл
			
			ПоложениеШаблона = СтрокаШаблонаНезначащегоОписания.Положение;
			ТекстШаблона = СтрокаШаблонаНезначащегоОписания.ТекстШаблона;
			
			Если ПоложениеШаблона = "Равно" Тогда
				ШаблонНайден = (ТекстовоеОписаниеПараметраБуфер = ТекстШаблона);
			ИначеЕсли ПоложениеШаблона = "Конец" Тогда
				ШаблонНайден = СтрЗаканчиваетсяНа(ТекстовоеОписаниеПараметраБуфер, ТекстШаблона);
			ИначеЕсли ПоложениеШаблона = "Начало" Тогда
				ШаблонНайден = СтрНачинаетсяС(ТекстовоеОписаниеПараметраБуфер, ТекстШаблона);
			ИначеЕсли ПоложениеШаблона = "Любое" Тогда
				ШаблонНайден = (СтрНайти(ТекстовоеОписаниеПараметраБуфер, ТекстШаблона) > 0);
			КонецЕсли;
			
			Если ШаблонНайден Тогда
				ТекстовоеОписаниеПараметраЯвляетсяЗначащим = Ложь;
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	// 3. Совпадает с именем по правилам образования имени от синонима, например:
	//  ОтборЖурналаРегистрации - Структура - отбор журнала регистрации.
	Если ТекстовоеОписаниеПараметраЯвляетсяЗначащим Тогда
		ИмяПараметраБуфер = ПреобразоватьТекстДляСравнения(СтрокаОписанияПараметра.ИмяПараметра);
		ТекстовоеОписаниеПараметраБуфер = ПреобразоватьТекстДляСравнения(ТекстовоеОписаниеПараметра);
		Если ИмяПараметраБуфер = ТекстовоеОписаниеПараметраБуфер Тогда
			ТекстовоеОписаниеПараметраЯвляетсяЗначащим = Ложь;
		КонецЕсли;
	КонецЕсли;
	
	// Если ни одно условие не сработало, то удалять текстовое описание параметра не нужно, выходим.
	Если ТекстовоеОписаниеПараметраЯвляетсяЗначащим Тогда
		Возврат;
	КонецЕсли;
	
	// Иначе удаляем текстовое описание параметра.
	ПолноеОписаниеПараметра = СтрокаОписанияПараметра.ПолноеОписаниеПараметра;
	ПозицияТекстовогоОписанияПараметра = СтрокаОписанияПараметра.ПозицияТекстовогоОписанияПараметра;
	
	// Если текстовое описание параметра находится на 2-й строке, то определим его позицию.
	Если ПозицияТекстовогоОписанияПараметра = 0 Тогда
		ПерваяСтрокаПолногоОписанияПараметра = СтрПолучитьСтроку(ПолноеОписаниеПараметра, 1);
		ПозицияТекстовогоОписанияПараметра = СтрДлина(ПерваяСтрокаПолногоОписанияПараметра) + 1;
	КонецЕсли;
	
	// Запоминаем, было ли двоеточие в конце исходного описания параметра.
	ПолноеОписаниеПараметра = СокрП(ПолноеОписаниеПараметра);
	ИсходноеПолноеОписаниеПараметраЗаканчиваетсяНаДвоеточие = СтрЗаканчиваетсяНа(ПолноеОписаниеПараметра, ":");
	
	// Удаляем незначащее текстовое описание.
	ПолноеОписаниеПараметра = Лев(ПолноеОписаниеПараметра, ПозицияТекстовогоОписанияПараметра - 1);
	ПолноеОписаниеПараметра = СокрП(ПолноеОписаниеПараметра);
	
	// Если исходное описание параметра заканчивалось на двоеточие, то добавляем двоеточие в конец нового описания.
	Если ИсходноеПолноеОписаниеПараметраЗаканчиваетсяНаДвоеточие Тогда
		ПолноеОписаниеПараметра = УдалитьПоследнийНезначимыйСимволИзСтроки(ПолноеОписаниеПараметра) + ":";
		// Если тип параметра заполнен, то добавляем двоеточие в него.
		ТипПараметра = СтрокаОписанияПараметра.ТипПараметра;
		Если НЕ ПустаяСтрока(ТипПараметра) Тогда
			СтрокаОписанияПараметра.ТипПараметра = УдалитьПоследнийНезначимыйСимволИзСтроки(ТипПараметра) + ":";
		КонецЕсли;
	КонецЕсли;
	
	// Переопределяем колонки строки описания параметра.
	НомерСтрокиНачалаОписанияПараметра = СтрокаОписанияПараметра.НомерСтрокиНачалаОписанияПараметра;
	НомерСтрокиКонцаОписанияПараметра = НомерСтрокиНачалаОписанияПараметра + СтрЧислоСтрок(ПолноеОписаниеПараметра) - 1;
	
	СтрокаОписанияПараметра.ПолноеОписаниеПараметра = ПолноеОписаниеПараметра;
	СтрокаОписанияПараметра.ТекстовоеОписаниеПараметра = "";
	СтрокаОписанияПараметра.ПозицияТекстовогоОписанияПараметра = 0;
	СтрокаОписанияПараметра.НомерСтрокиКонцаОписанияПараметра = НомерСтрокиКонцаОписанияПараметра;
	СтрокаОписанияПараметра.СостояниеПараметра = "Изменен";
	
КонецПроцедуры

Процедура УстановитьТекстГиперссылкиВОписаниеПараметра(СтрокаОписанияПараметра)
	
	ТекстовоеОписаниеПараметра = СтрокаОписанияПараметра.ТекстовоеОписаниеПараметра;
	
	// Вводим условное ограничение: если количество строк больше 3, то, возможно,
	// текстовое описание содержит пример описания другой процедуры, в котором есть гиперссылка "см.",
	// или описание подробно описывает нюансы параметра.
	// В любом случае, такое текстовое описание не удаляем - оставляем как есть.
	// Искать гиперссылку "см." бессмысленно, сразу выходим.
	Если СтрЧислоСтрок(ТекстовоеОписаниеПараметра) > 3 Тогда
		Возврат;
	КонецЕсли;
	
	ТекстовоеОписаниеПараметраВРег = ВРег(ТекстовоеОписаниеПараметра);
	
	// Проверяем вхождения "см." и "см " в текстовое описание параметра.
	КоличествоВхожденийСм = 0;
	МассивТекстСм = Контекст["МассивТекстСм"];
	Для Каждого ТекстСм Из МассивТекстСм Цикл
		КоличествоВхожденийТекстСм = СтрЧислоВхождений(ТекстовоеОписаниеПараметраВРег, ТекстСм);
		КоличествоВхожденийСм = КоличествоВхожденийСм + КоличествоВхожденийТекстСм;
	КонецЦикла;
	
	Если КоличествоВхожденийСм <> 1 Тогда
		// Если вхождений нет или их больше 1, тогда выходим.
		Возврат;
	КонецЕсли;
	
	РезультатПоискаТекстСм = СтрНайтиПоМассиву(ТекстовоеОписаниеПараметраВРег, МассивТекстСм,,, Истина);
	Если НЕ РезультатПоискаТекстСм.Успешно Тогда
		Возврат;
	КонецЕсли;
	
	ПозицияТекстСм = РезультатПоискаТекстСм.Позиция;
	НайденныйТекстСм = РезультатПоискаТекстСм.НайденныйЭлемент;
	
	ТекстСм = Сред(ТекстовоеОписаниеПараметра, ПозицияТекстСм, СтрДлина(НайденныйТекстСм));
	ТекстСмСокрЛ = СокрЛ(ТекстСм);
	
	Если СтрСравнить(ТекстСмСокрЛ, "См") = 0 Тогда
		ТекстСм = ТекстСмСокрЛ + ".";
	КонецЕсли;
	
	// Заменяем ненужные символы.
	ТекстГиперссылки = ТекстовоеОписаниеПараметра;
	ТекстГиперссылки = СтрЗаменить(ТекстГиперссылки, "/", "");
	ТекстГиперссылки = СтрЗаменить(ТекстГиперссылки, Символы.Таб, " ");
	ТекстГиперссылки = СтрЗаменить(ТекстГиперссылки, Символы.ПС, " ");
	
	// Удаляем двойные пробелы для поиска.
	Пока СтрНайти(ТекстГиперссылки, "  ") > 0 Цикл
		ТекстГиперссылки = СтрЗаменить(ТекстГиперссылки, "  ", " ");
	КонецЦикла;
	
	// Сначала ищем в текстовом описании параметра каждый элемент из массива исключений гиперссылок,
	// из которых не нужно получать объект гиперссылки.
	МассивТекстИсключенийГиперссылокСм = Контекст["МассивТекстИсключенийГиперссылокСм"];
	РезультатПоискаИсключенияГиперссылки = СтрНайтиПоМассиву(ВРег(ТекстГиперссылки), МассивТекстИсключенийГиперссылокСм);
	Если РезультатПоискаИсключенияГиперссылки.Успешно Тогда
		// Если нашли, то выходим.
		Возврат;
	КонецЕсли;
	
	// Затем ищем каждый элемент из массива гиперссылок "см." в текстовом описании параметра.
	МассивТекстГиперссылокСм = Контекст["МассивТекстГиперссылокСм"];
	РезультатПоискаГиперссылки = СтрНайтиПоМассиву(ВРег(ТекстГиперссылки), МассивТекстГиперссылокСм);
	Если НЕ РезультатПоискаГиперссылки.Успешно Тогда
		// Если не нашли, то выходим.
		Возврат;
	КонецЕсли;
	
	НайденныйУказательГиперссылки = РезультатПоискаГиперссылки.НайденныйЭлемент;
	ПозицияГиперссылки = РезультатПоискаГиперссылки.Позиция;
	ТекстГиперссылки = Сред(ТекстГиперссылки, ПозицияГиперссылки + СтрДлина(НайденныйУказательГиперссылки));
	
	Если ПустаяСтрока(ТекстГиперссылки) Тогда
		Возврат;
	КонецЕсли;
	
	ТекстГиперссылки = СокрЛ(ТекстГиперссылки);
	ДлинаТекстаГиперссылки = СтрДлина(ТекстГиперссылки);
	
	// Получаем объект гиперссылки, для этого ищем первый незначимый символ, при этом точка считается значимым символом.
	КоличествоЗначимыхСимволов = ДлинаТекстаГиперссылки;
	Для НомерСимвола = 1 По ДлинаТекстаГиперссылки Цикл
		
		СимволГиперссылки = Сред(ТекстГиперссылки, НомерСимвола, 1);
		
		// Если в тексте гиперссылки встретился знак "\", то это обозначение событий подсистемы, например,
		// См. СтандартныеПодсистемы.БазоваяФункциональность\ПередЗавершениемРаботыСистемы.
		// В этом случае, это не текст гиперссылки, выходим.
		Если СимволГиперссылки = "\" Тогда
			Возврат;
		КонецЕсли;
		
		// Если нашли первый незначимый символ, то прерываем.
		Если НЕ (апк_СловоСодержитЗначимыеСимволы(СимволГиперссылки) ИЛИ (СимволГиперссылки = ".")) Тогда
			КоличествоЗначимыхСимволов = НомерСимвола - 1;
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	// Запоминаем текст гиперссылки в буфер, позже понадобится.
	ТекстГиперссылкиБуфер = ТекстГиперссылки;
	ТекстГиперссылки = Лев(ТекстГиперссылки, КоличествоЗначимыхСимволов);
	
	// Проверяем, является ли полученный текст гиперссылки объектом, процедурой, функцией или параметром.
	// Пока проверяем только по наличию заглавных букв в тексте: если их нет, то это не гиперссылка.
	Если ТекстГиперссылки = НРег(ТекстГиперссылки) Тогда
		Возврат;
	КонецЕсли;
	
	// Устанавливаем флаг, что в текстовом описании параметра содержится гиперссылка.
	СтрокаОписанияПараметра.ТекстовоеОписаниеПараметраСодержитГиперссылку = Истина;
	
	// Если тип параметра множественный, то выходим.
	Если СтрокаОписанияПараметра.ТипПараметраМножественный Тогда
		Возврат;
	КонецЕсли;
	
	// Если описание параметра начинается с тире, то, скорее всего, описан следующий тип предыдущего параметра, проверим его.
	Если СтрокаОписанияПараметра.ОписаниеПараметраНачинаетсяСТире Тогда
		// Получаем полную таблицу с описанием всех параметров.
		ТаблицаОписанияПараметров = СтрокаОписанияПараметра.Владелец();
		ИндексСтрокиОписанияПараметра = ТаблицаОписанияПараметров.Индекс(СтрокаОписанияПараметра);
		Если ИндексСтрокиОписанияПараметра > 0 Тогда
			// Получаем строку описания предыдущего параметра.
			ПредыдущаяСтрокаОписанияПараметра = ТаблицаОписанияПараметров[ИндексСтрокиОписанияПараметра - 1];
			// Если у предыдущего параметра отсутствует описание, то считаем,
			// что описание текущего параметра с гиперссылкой распространяется и на предыдущий,
			// тогда оставляем исходное описание без изменений и выходим.
			Если ПустаяСтрока(ПредыдущаяСтрокаОписанияПараметра.ТекстовоеОписаниеПараметра) Тогда
				Возврат;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	// Проверяем параметр в списке исключений типов и описаний для установки гиперссылки.
	ТипПараметра = ВРег(СтрокаОписанияПараметра.ТипПараметра);
	СписокТекстИсключенийТиповИОписанийПараметровДляУстановкиГиперссылкиСм = Контекст["СписокТекстИсключенийТиповИОписанийПараметровДляУстановкиГиперссылкиСм"];
	ЭлементИсключения = СписокТекстИсключенийТиповИОписанийПараметровДляУстановкиГиперссылкиСм.НайтиПоЗначению(ТипПараметра);
	Если ЭлементИсключения <> Неопределено Тогда
		// Проверяем конструкцию из представления найденного элемента списка значений в текстовом описании параметра.
		Если СтрНайти(ВРег(ТекстовоеОписаниеПараметра), ЭлементИсключения.Представление) > 0 Тогда
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	// Ищем дополнительные конструкции, которые могут быть указаны в текстовом описании после гиперссылки "см.".
	ТаблицаКонструкцийОбъектовПослеГиперссылокСм = Контекст["ТаблицаКонструкцийОбъектовПослеГиперссылокСм"];
	Для Каждого СтрокаКонструкцииОбъектаГиперссылки Из ТаблицаКонструкцийОбъектовПослеГиперссылокСм Цикл
		
		// Ищем текст конструкции после текста гиперссылки "см.".
		ТекстКонструкции = СтрокаКонструкцииОбъектаГиперссылки.ТекстКонструкции;
		ПозицияПоискаКонструкции = СтрНайти(ВРег(ТекстГиперссылкиБуфер), ТекстКонструкции,, КоличествоЗначимыхСимволов);
		Если ПозицияПоискаКонструкции = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		// Получаем имя объекта после искомой конструкции.
		ИмяНайденногоОбъекта = Сред(ТекстГиперссылкиБуфер, ПозицияПоискаКонструкции + СтрДлина(ТекстКонструкции));
		ИмяНайденногоОбъекта = ПолучитьПервоеСловоИзСтроки(ИмяНайденногоОбъекта);
		
		Если ПустаяСтрока(ИмяНайденногоОбъекта) Тогда
			Продолжить;
		КонецЕсли;
		
		// Если удалось получить, то добавляем имя объекта в текст гиперссылки.
		ПоложениеДобавленияОбъекта = СтрокаКонструкцииОбъектаГиперссылки.ПоложениеДобавленияОбъекта;
		Если ПоложениеДобавленияОбъекта = "Начало" Тогда
			ТекстГиперссылки = ИмяНайденногоОбъекта + "." + ТекстГиперссылки;
		ИначеЕсли ПоложениеДобавленияОбъекта = "Конец" Тогда
			ТекстГиперссылки = ТекстГиперссылки + "." + ИмяНайденногоОбъекта;
		КонецЕсли;
		
		// Добавляем тип объекта, если указан.
		ДобавляемыйТипОбъекта = СтрокаКонструкцииОбъектаГиперссылки.ДобавляемыйТипОбъекта;
		Если НЕ ПустаяСтрока(ДобавляемыйТипОбъекта) Тогда
			ТекстГиперссылки = ДобавляемыйТипОбъекта + "." + ТекстГиперссылки;
		КонецЕсли;
		
	КонецЦикла;
	
	// Запоминаем текст объекта гиперссылки.
	ТекстОбъектаГиперссылки = ТекстГиперссылки;
	
	// Добавляем статичный текст "см. ", "Массив из см. " или "ФиксированныйМассив из см. ".
	МассивТекстМассив = Контекст["МассивТекстМассив"];
	МассивТекстМассивИз = Контекст["МассивТекстМассивИз"];
	МассивТекстМассивИзСм = Контекст["МассивТекстМассивИзСм"];
	
	МассивТекстФиксированныйМассив = Контекст["МассивТекстФиксированныйМассив"];
	МассивТекстФиксированныйМассивИз = Контекст["МассивТекстФиксированныйМассивИз"];
	МассивТекстФиксированныйМассивИзСм = Контекст["МассивТекстФиксированныйМассивИзСм"];
	
	МассивТекстМассивИзСтрокаТаблицыЗначений = Контекст["МассивТекстМассивИзСтрокаТаблицыЗначений"];
	МассивТекстМассивИзСтрокаТаблицыЗначенийВРег = Контекст["МассивТекстМассивИзСтрокаТаблицыЗначенийВРег"];
	
	СтруктураПоискаТекстМассивИзСтрокаТаблицыЗначений = СтрНачинаетсяСПоМассиву(ТипПараметра, МассивТекстМассивИзСтрокаТаблицыЗначенийВРег);
	Если СтруктураПоискаТекстМассивИзСтрокаТаблицыЗначений.Успешно Тогда
		// Если был найден один из элементов, например, "Массив из СтрокаТаблицыЗначений", то добавляем этот статичный текст в текст гиперссылки.
		ТекстМассивИзСтрокаТаблицыЗначенийВРег = СтруктураПоискаТекстМассивИзСтрокаТаблицыЗначений.НайденныйЭлемент;
		НомерЭлемента = МассивТекстМассивИзСтрокаТаблицыЗначенийВРег.Найти(ТекстМассивИзСтрокаТаблицыЗначенийВРег);
		Если НомерЭлемента = Неопределено Тогда
			ДобавляемыйТекстГиперссылки = СтрокаОписанияПараметра.ТипПараметра + ": " + ТекстСм + " ";
		Иначе
			ТекстМассивИзСтрокаТаблицыЗначений = МассивТекстМассивИзСтрокаТаблицыЗначений[НомерЭлемента];
			ДобавляемыйТекстГиперссылки = ТекстМассивИзСтрокаТаблицыЗначений + ": " + ТекстСм + " ";
		КонецЕсли;
	ИначеЕсли (МассивТекстМассивИзСм.Найти(НайденныйУказательГиперссылки) <> Неопределено)
	 ИЛИ (МассивТекстМассив.Найти(ПреобразоватьТекстДляСравнения(ТипПараметра)) <> Неопределено)
	 ИЛИ СтрНачинаетсяСПоМассиву(ТипПараметра, МассивТекстМассивИз).Успешно Тогда
		// Если был найден элемент "Массив из см. " или тип параметра - "Массив", то добавляем этот статичный текст в текст гиперссылки.
		ДобавляемыйТекстГиперссылки = Контекст["ТекстМассивИзСм"];
	ИначеЕсли (МассивТекстФиксированныйМассивИзСм.Найти(НайденныйУказательГиперссылки) <> Неопределено)
		  ИЛИ (МассивТекстФиксированныйМассив.Найти(ПреобразоватьТекстДляСравнения(ТипПараметра)) <> Неопределено)
		  ИЛИ СтрНачинаетсяСПоМассиву(ТипПараметра, МассивТекстФиксированныйМассивИз).Успешно Тогда
		// Если был найден элемент "ФиксированныйМассив из см. " или тип параметра - "ФиксированныйМассив", то добавляем этот статичный текст в текст гиперссылки.
		ДобавляемыйТекстГиперссылки = Контекст["ТекстФиксированныйМассивИзСм"];
	Иначе
		// Иначе просто добавляем "см. ".
		ДобавляемыйТекстГиперссылки = ТекстСм + " ";
	КонецЕсли;
	
	ТекстГиперссылки = ДобавляемыйТекстГиперссылки + ТекстГиперссылки;
	
	// Если объект из гиперссылки не найден, то текстовое описание не меняем и выходим.
	СтрокаТаблицыОбъектовПереадресации = ПолучитьОбъектПереадресацииИзГиперссылки(ТекстОбъектаГиперссылки, СтрокаОписанияПараметра.Владелец());
	Если СтрокаТаблицыОбъектовПереадресации = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	// Если объект переадресации не существует, то оставляем текстовое описание в исходном виде.
	Если НЕ СтрокаТаблицыОбъектовПереадресации.Существует Тогда
		// Если необходимо, то регистрируем ошибку.
		Если СтрокаТаблицыОбъектовПереадресации.ЗарегистрироватьОшибку Тогда
			ТекстОшибки = НСтр("ru='Не найден объект переадресации ""%1"" из текста гиперссылки ""см."":%3%2';
				|en='Не найден объект переадресации ""%1"" из текста гиперссылки ""см."":%3%2'", КодОсновногоЯзыка);
			ТекстОшибки = СтрШаблон(ТекстОшибки, ТекстОбъектаГиперссылки, СтрокаОписанияПараметра.ПолноеОписаниеПараметра, Символы.ПС);
			СтрокаОписанияПараметра.ТекстОшибки = ТекстОшибки;
		КонецЕсли;
		Возврат;
	КонецЕсли;
	
	// Текстовое описание с гиперссылкой на процедуру оставляем в исходном виде.
	Если СтрокаТаблицыОбъектовПереадресации.ТипОбъектаПереадресации = "Процедура" Тогда
		Возврат;
	КонецЕсли;
	
	МассивСохраняемыхТиповПараметровПриУстановкеГиперссылкиСм = Контекст["МассивСохраняемыхТиповПараметровПриУстановкеГиперссылкиСм"];
	
	// Определяем номер символа, начиная с которого надо вставить новое текстовое описание параметра с гиперссылкой.
	// Сначала определяем ее как позицию типа параметра.
	ПозицияТекстовогоОписанияПараметра = СтрокаОписанияПараметра.ПозицияТипаПараметра;
	// Тип не указан.
	Если (ПозицияТекстовогоОписанияПараметра = 0)
		// Описание параметра начинается с тире.
		// В таком случае оставляем тип параметра, т.к. есть перечисление нескольких типов одного параметра.
	 ИЛИ (СтрокаОписанияПараметра.ОписаниеПараметраНачинаетсяСТире)
		// Этот тип параметра не надо удалять (нашли в отдельном массиве сохраняемых типов).
	 ИЛИ (МассивСохраняемыхТиповПараметровПриУстановкеГиперссылкиСм.Найти(ТипПараметра) <> Неопределено) Тогда
		// Вставляем начиная с прежнего текстового описания параметра.
		ПозицияТекстовогоОписанияПараметра = СтрокаОписанияПараметра.ПозицияТекстовогоОписанияПараметра;
	КонецЕсли;
	
	// Если позиция не определена, то выходим.
	Если ПозицияТекстовогоОписанияПараметра = 0 Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаОписанияПараметра.ТекстовоеОписаниеПараметраЯвляетсяГиперссылкой = Истина;
	
	ТекстовоеОписаниеПараметра = ТекстГиперссылки;
	
	// Изменяем полное описание параметра.
	ПолноеОписаниеПараметра = СтрокаОписанияПараметра.ПолноеОписаниеПараметра;
	ПолноеОписаниеПараметра = Лев(ПолноеОписаниеПараметра, ПозицияТекстовогоОписанияПараметра - 1);
	
	// Если это первая строка описания возвращаемого значения,
	// и вставка гиперссылки происходит в начало строки комментария, то увеличим отступ до 3-х пробелов.
	Если СтрокаОписанияПараметра.ЭтоОписаниеВозвращаемогоЗначения Тогда
		ПолноеОписаниеПараметраБуфер = СокрП(ПолноеОписаниеПараметра);
		Если СтрЗаканчиваетсяНа(ПолноеОписаниеПараметраБуфер, "//") Тогда
			РазницаОтступов = СтрДлина(ПолноеОписаниеПараметра) - СтрДлина(ПолноеОписаниеПараметраБуфер);
			Если РазницаОтступов < 3 Тогда
				ПолноеОписаниеПараметра = ПолноеОписаниеПараметраБуфер + "   ";
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	ПолноеОписаниеПараметра = ПолноеОписаниеПараметра + ТекстовоеОписаниеПараметра;
	
	// Если полное описание параметра не изменилось, то выходим.
	Если СокрЛП(СтрокаОписанияПараметра.ПолноеОписаниеПараметра) = ПолноеОписаниеПараметра Тогда
		Возврат;
	КонецЕсли;
	
	// Переопределяем остальные колонки строки описания параметра.
	НомерСтрокиНачалаОписанияПараметра = СтрокаОписанияПараметра.НомерСтрокиНачалаОписанияПараметра;
	НомерСтрокиКонцаОписанияПараметра = НомерСтрокиНачалаОписанияПараметра + СтрЧислоСтрок(ПолноеОписаниеПараметра) - 1;
	
	// Тип параметра и его позицию необходимо очистить, только если описание не начинается с тире.
	Если НЕ СтрокаОписанияПараметра.ОписаниеПараметраНачинаетсяСТире Тогда
		СтрокаОписанияПараметра.ТипПараметра = "";
		СтрокаОписанияПараметра.ПозицияТипаПараметра = 0;
	КонецЕсли;
	СтрокаОписанияПараметра.ПолноеОписаниеПараметра = ПолноеОписаниеПараметра;
	СтрокаОписанияПараметра.ТекстовоеОписаниеПараметра = ТекстовоеОписаниеПараметра;
	СтрокаОписанияПараметра.ПозицияТекстовогоОписанияПараметра = ПозицияТекстовогоОписанияПараметра;
	СтрокаОписанияПараметра.НомерСтрокиКонцаОписанияПараметра = НомерСтрокиКонцаОписанияПараметра;
	СтрокаОписанияПараметра.ТекстовоеОписаниеПараметраЯвляетсяГиперссылкой = Истина;
	СтрокаОписанияПараметра.СостояниеПараметра = "Изменен";
	
КонецПроцедуры

Процедура ДобавитьДвоеточиеВКонцеСтрокиОписанияПараметра(СтрокаОписанияПараметра)
	
	// Если описание параметра уже заканчивается на двоеточие, то выходим.
	ПолноеОписаниеПараметра = СтрокаОписанияПараметра.ПолноеОписаниеПараметра;
	ПолноеОписаниеПараметра = СокрП(ПолноеОписаниеПараметра);
	Если СтрЗаканчиваетсяНа(ПолноеОписаниеПараметра, ":") Тогда
		Возврат;
	КонецЕсли;
	
	// Если описание параметра заканчивается на многоточие, то выходим.
	Если СтрЗаканчиваетсяНа(ПолноеОписаниеПараметра, "...") Тогда
		Возврат;
	КонецЕсли;
	
	// Для параметров с гиперссылкой в текстовом описании добавлять двоеточие не требуется, выходим.
	Если СтрокаОписанияПараметра.ТекстовоеОписаниеПараметраСодержитГиперссылку Тогда
		Возврат;
	КонецЕсли;
	
	// Если не заполнены ни тип параметра, ни текстовое описание, то выходим.
	ТипПараметра = СтрокаОписанияПараметра.ТипПараметра;
	ТекстовоеОписаниеПараметра = СтрокаОписанияПараметра.ТекстовоеОписаниеПараметра;
	Если ПустаяСтрока(ТипПараметра) И ПустаяСтрока(ТекстовоеОписаниеПараметра) Тогда
		Возврат;
	КонецЕсли;
	
	// Получаем полную таблицу с описанием всех параметров.
	ТаблицаОписанияПараметров = СтрокаОписанияПараметра.Владелец();
	
	// Если текущий параметр - последний, то выходим.
	ИндексСтрокиОписанияПараметра = ТаблицаОписанияПараметров.Индекс(СтрокаОписанияПараметра);
	Если ИндексСтрокиОписанияПараметра >= ТаблицаОписанияПараметров.Количество() - 1 Тогда
		Возврат;
	КонецЕсли;
	
	// Получаем строку описания следующего параметра.
	СтрокаОписанияСледующегоПараметра = ТаблицаОписанияПараметров[ИндексСтрокиОписанияПараметра + 1];
	
	// Если текущий и следующий параметры находятся в разных секциях описания, то выходим.
	СекцияОписания = СтрокаОписанияПараметра.СекцияОписания;
	Если СекцияОписания <> СтрокаОписанияСледующегоПараметра.СекцияОписания Тогда
		Возврат;
	КонецЕсли;
	
	// Проверим, является ли следующий описанный параметр параметром текущего метода.
	Если СекцияОписания = "Параметры" Тогда
		ИмяСледующегоПараметра = СтрокаОписанияСледующегоПараметра.ИмяПараметра;
		// Если следующий параметр является свойством предыдущего параметра, то проверять бессмысленно.
		Если НЕ СтрНачинаетсяС(ИмяСледующегоПараметра, "*") Тогда
			ТекущийОбрабатываемыйМетод = Контекст["ТекущийОбрабатываемыйМетод"];
			Если ТекущийОбрабатываемыйМетод <> Неопределено Тогда
				// Получаем массив параметров текущего метода.
				МассивПараметровМетода = ТекущийОбрабатываемыйМетод.МассивПараметров;
				Для Каждого ИмяПараметраМетода Из МассивПараметровМетода Цикл
					// Проверяем каждый параметр метода.
					ИмяПараметраМетода = ПолучитьИмяПараметра(ИмяПараметраМетода);
					Если СтрСравнить(ИмяПараметраМетода, ИмяСледующегоПараметра) = 0 Тогда
						// Нашли следующий параметр среди параметров текущего метода.
						// Двоеточие не нужно, выходим.
						Возврат;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	// Проверяем исключения для строк параметров, в которые не нужно добавлять двоеточие.
	МассивОписанийБезДобавленияДвоеточия = Контекст["МассивОписанийБезДобавленияДвоеточия"];
	Если СтрНайтиПоМассиву(ВРег(ПолноеОписаниеПараметра), МассивОписанийБезДобавленияДвоеточия).Успешно Тогда
		Возврат;
	КонецЕсли;
	
	// Инициализируем дополнительный флаг.
	ДобавитьДвоеточие = Ложь;
	
	// Если уровень вложенности следующего параметра больше текущего, то двоеточие нужно.
	Если СтрокаОписанияСледующегоПараметра.УровеньВложенностиПараметра > СтрокаОписанияПараметра.УровеньВложенностиПараметра Тогда
		ДобавитьДвоеточие = Истина;
	КонецЕсли;
	
	// Проверяем следующее условие.
	Если НЕ ДобавитьДвоеточие Тогда
		
		// Иногда уровень вложенности параметра (количество звездочек в имени параметра) установлено неверно.
		// Тогда определяем, является ли тип параметра составным.
		МассивСоставныхТиповПараметров = Контекст["МассивСоставныхТиповПараметров"];
		ЕстьСоставнойТип = Ложь;
		
		// Проверяем все типы параметра в массиве составных типов.
		// Ранее было разделение типов по строкам, поэтому массив типов параметра получаем, разделив строку по запятой и тире.
		МассивТиповПараметра = СтрРазделить(ТипПараметра, ",-", Ложь);
		Для Каждого ЭлементМассиваТиповПараметра Из МассивТиповПараметра Цикл
			ЭлементМассиваТиповПараметра = ПреобразоватьТекстДляСравнения(ЭлементМассиваТиповПараметра);
			// Если какой-то из типов параметра составной, то устанавливаем флаг.
			Если МассивСоставныхТиповПараметров.Найти(ЭлементМассиваТиповПараметра) <> Неопределено Тогда
				ЕстьСоставнойТип = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		// Если у параметра нет составного типа, то выходим.
		Если НЕ ЕстьСоставнойТип Тогда
			Возврат;
		КонецЕсли;
		
		// Если позиция имени параметра равна 0, то берем позицию типа параметра.
		ПозицияНачалаПараметра = СтрокаОписанияПараметра.ПозицияИмениПараметра;
		Если ПозицияНачалаПараметра = 0 Тогда
			ПозицияНачалаПараметра = СтрокаОписанияПараметра.ПозицияТипаПараметра;
		КонецЕсли;
		
		// Если отступ следующего параметра больше, чем у текущего параметра, то нужно добавить двоеточие.
		ПозицияИмениСледующегоПараметра = СтрокаОписанияСледующегоПараметра.ПозицияИмениПараметра;
		Если ПозицияИмениСледующегоПараметра > ПозицияНачалаПараметра Тогда
			ДобавитьДвоеточие = Истина;
		КонецЕсли;
		
		// Ранее в текущей строке описания мы заменили каждый таб на 2 пробела, поэтому отступы могут не совпадать.
		Если НЕ ДобавитьДвоеточие Тогда
			// Заменим табы на пробелы в строке описания следующего параметра.
			ЗаменитьТабыНаПробелыПередОписаниемПараметра(СтрокаОписанияСледующегоПараметра);
			ПозицияИмениСледующегоПараметра = СтрокаОписанияСледующегоПараметра.ПозицияИмениПараметра;
			// И сравним отступы текущего и следующего параметра еще раз.
			Если ПозицияИмениСледующегоПараметра > ПозицияНачалаПараметра Тогда
				ДобавитьДвоеточие = Истина;
			КонецЕсли;
		КонецЕсли;
		
		// Если текущий параметр является первой строкой описания возвращаемого значения,
		// и он составного типа (проверили выше),
		// и у следующего параметра заполнено наименование, то добавим двоеточие.
		Если НЕ ДобавитьДвоеточие Тогда
			Если СтрокаОписанияПараметра.ЭтоОписаниеВозвращаемогоЗначения Тогда
				Если НЕ ПустаяСтрока(СтрокаОписанияСледующегоПараметра.ИмяПараметра) Тогда
					ДобавитьДвоеточие = Истина;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
	// Если ни одно из условий не сработало, то выходим.
	Если НЕ ДобавитьДвоеточие Тогда
		Возврат;
	КонецЕсли;
	
	// В остальных случаях добавляем двоеточие и переопределяем колонки строки описания параметра.
	Если НЕ ПустаяСтрока(ТекстовоеОписаниеПараметра) Тогда
		СтрокаОписанияПараметра.ТекстовоеОписаниеПараметра = УдалитьПоследнийНезначимыйСимволИзСтроки(ТекстовоеОписаниеПараметра) + ":";
	ИначеЕсли НЕ ПустаяСтрока(ТипПараметра) Тогда
		СтрокаОписанияПараметра.ТипПараметра = УдалитьПоследнийНезначимыйСимволИзСтроки(ТипПараметра) + ":";
	Иначе
		Возврат;
	КонецЕсли;
	
	СтрокаОписанияПараметра.ПолноеОписаниеПараметра = УдалитьПоследнийНезначимыйСимволИзСтроки(ПолноеОписаниеПараметра) + ":";
	СтрокаОписанияПараметра.СостояниеПараметра = "Изменен";
	
КонецПроцедуры

Процедура ФорматироватьОписаниеСекцииВозвращаемоеЗначение(СтрокаОписанияПараметра)
	
	// Если это не секция описания возвращаемого значения, то выходим.
	Если НЕ СтрокаОписанияПараметра.ЭтоОписаниеВозвращаемогоЗначения Тогда
		Возврат;
	КонецЕсли;
	
	// Если описание параметра не начинается с "// Возвращаемое значение", то выходим.
	ПолноеОписаниеПараметра = СтрокаОписанияПараметра.ПолноеОписаниеПараметра;
	ПолноеОписаниеПараметраБуфер = ПреобразоватьТекстДляСравнения(ПолноеОписаниеПараметра);
	ПолноеОписаниеПараметраБуфер = "//" + ПолноеОписаниеПараметраБуфер;
	МассивТекстВозвращаемоеЗначение = Контекст["МассивТекстВозвращаемоеЗначение"];
	
	Если НЕ СтрНачинаетсяСПоМассиву(ПолноеОписаниеПараметраБуфер, МассивТекстВозвращаемоеЗначение).Успешно Тогда
		Возврат;
	КонецЕсли;
	
	РезультатПоиска = СтрНайтиПоМассиву(ВРег(ПолноеОписаниеПараметра), МассивТекстВозвращаемоеЗначение,,, Истина);
	Если НЕ РезультатПоиска.Успешно Тогда
		Возврат;
	КонецЕсли;
	
	ТекстВозвращаемоеЗначение = РезультатПоиска.НайденныйЭлемент;
	
	ТекстПослеВозвращаемогоЗначения = Сред(ПолноеОписаниеПараметра, РезультатПоиска.Позиция
		+ СтрДлина(ТекстВозвращаемоеЗначение));
	
	ТекстПослеВозвращаемогоЗначения = УдалитьПервыйНезначимыйСимволИзСтроки(ТекстПослеВозвращаемогоЗначения);
	Если СтрНачинаетсяС(ТекстПослеВозвращаемогоЗначения, "//") Тогда
		ТекстПослеВозвращаемогоЗначения = СтрЗаменить(ТекстПослеВозвращаемогоЗначения, "/", "");
		ТекстПослеВозвращаемогоЗначения = СокрЛ(ТекстПослеВозвращаемогоЗначения);
	КонецЕсли;
	
	ПолноеОписаниеПараметра = "// " + ТекстВозвращаемоеЗначение + ":"
		+ Символы.ПС
		+ "//   " + ТекстПослеВозвращаемогоЗначения;
	
	// Переопределяем остальные колонки строки описания параметра.
	НомерСтрокиНачалаОписанияПараметра = СтрокаОписанияПараметра.НомерСтрокиНачалаОписанияПараметра;
	НомерСтрокиКонцаОписанияПараметра = НомерСтрокиНачалаОписанияПараметра + СтрЧислоСтрок(ПолноеОписаниеПараметра) - 1;
	
	СтрокаОписанияПараметра.ПолноеОписаниеПараметра = ПолноеОписаниеПараметра;
	СтрокаОписанияПараметра.НомерСтрокиКонцаОписанияПараметра = НомерСтрокиКонцаОписанияПараметра;
	СтрокаОписанияПараметра.СостояниеПараметра = "Изменен";
	СтрокаОписанияПараметра.НеобходимоПовторноеФорматирование = Истина;
	
КонецПроцедуры

Процедура ДобавитьДополнительныйОтступДляПараметраОписанияВозвращаемогоЗначения(СтрокаОписанияПараметра)
	
	// Если это не секция описания возвращаемого значения, то выходим.
	Если НЕ СтрокаОписанияПараметра.ЭтоОписаниеВозвращаемогоЗначения Тогда
		Возврат;
	КонецЕсли;
	
	// Если заполнено имя или тип параметра, то выходим.
	Если (НЕ ПустаяСтрока(СтрокаОписанияПараметра.ИмяПараметра))
	 ИЛИ (НЕ ПустаяСтрока(СтрокаОписанияПараметра.ТипПараметра)) Тогда
		Возврат;
	КонецЕсли;
	
	// Получаем позицию текстового описания текущего параметра.
	ПозицияТекстовогоОписанияПараметра = СтрокаОписанияПараметра.ПозицияТекстовогоОписанияПараметра;
	Если ПозицияТекстовогоОписанияПараметра = 0 Тогда
		// Если не заполнено, то выходим.
		Возврат;
	КонецЕсли;
	
	// Ищем предыдущий параметр, получаем таблицу параметров.
	ТаблицаОписанияПараметров = СтрокаОписанияПараметра.Владелец();
	ИндексСтрокиТекущегоПараметра = ТаблицаОписанияПараметров.Индекс(СтрокаОписанияПараметра);
	Если ИндексСтрокиТекущегоПараметра = 0 Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаОписанияПредыдущегоПараметра = ТаблицаОписанияПараметров[ИндексСтрокиТекущегоПараметра - 1];
	
	// Если секции не равны, то выходим.
	Если СтрокаОписанияПредыдущегоПараметра.СекцияОписания <> СтрокаОписанияПараметра.СекцияОписания Тогда
		Возврат;
	КонецЕсли;
	
	ПолноеОписаниеПредыдущегоПараметра = СтрокаОписанияПредыдущегоПараметра.ПолноеОписаниеПараметра;
	
	// Если между описанием предыдущего и текущего параметра есть пустая строка,
	// то, вероятно, отступ сделан специально, пропускаем такие случаи.
	Если (ИндексСтрокиТекущегоПараметра - ТаблицаОписанияПараметров.Индекс(СтрокаОписанияПредыдущегоПараметра)) = 1 Тогда
		
		// Проверяем номера строк текущего и предыдущего параметра.
		НомерСтрокиКонцаОписанияПредыдущегоПараметра = СтрокаОписанияПредыдущегоПараметра.НомерСтрокиКонцаОписанияПараметра;
		НомерСтрокиНачалаОписанияПараметра = СтрокаОписанияПараметра.НомерСтрокиНачалаОписанияПараметра;
		
		// Если номер строки окончания описания предыдущего подряд параметра отличается
		// от номера строки начала описания текущего параметра больше, чем на 1,
		// то считаем, что между параметрами есть пустая строка, тогда пропускаем.
		Если НомерСтрокиНачалаОписанияПараметра - НомерСтрокиКонцаОписанияПредыдущегоПараметра > 1 Тогда
			Возврат;
		КонецЕсли;
		
	КонецЕсли;
	
	СписокТекстСоответствие = Контекст["СписокТекстСоответствие"];
	МассивТекстСоответствиеИзКлючИЗначение = Новый Массив;
	Для Каждого ЭлементСписка Из СписокТекстСоответствие Цикл
		МассивТекстСоответствиеИзКлючИЗначение.Добавить(ЭлементСписка.Представление);
	КонецЦикла;
	МассивТекстСоответствиеИзКлючИЗначение = ПреобразоватьМассивДляСравнения(МассивТекстСоответствиеИзКлючИЗначение);
	
	// Если тип предыдущего параметра называется "Соответствие из КлючИЗначение",
	ТипПредыдущегоПараметра = ПреобразоватьТекстДляСравнения(СтрокаОписанияПредыдущегоПараметра.ТипПараметра);
	Если МассивТекстСоответствиеИзКлючИЗначение.Найти(ТипПредыдущегоПараметра) <> Неопределено Тогда
		// то проверим, нет ли в его описании свойства "* Значение".
		ТекстЗначение = "* " + Контекст["ТекстЗначение"] + " - ";
		ПозицияТекстаЗначение = СтрНайти(ПолноеОписаниеПредыдущегоПараметра, ТекстЗначение);
		Если ПозицияТекстаЗначение > 0 Тогда
			// Если нашли текст "* Значение", то в качестве полного описания предыдущего параметра берем строку со значением.
			НомерСтрокиТекстаЗначение = ПолучитьНомерСтрокиМодуля(ПолноеОписаниеПредыдущегоПараметра, ПозицияТекстаЗначение);
			ПолноеОписаниеПредыдущегоПараметра = СтрПолучитьСтроку(ПолноеОписаниеПредыдущегоПараметра, НомерСтрокиТекстаЗначение);
		КонецЕсли;
	КонецЕсли;
	
	// Если отступ текущего параметра больше предыдущего, то пропускаем.
	ПолноеОписаниеПараметра = СтрокаОписанияПараметра.ПолноеОписаниеПараметра;
	ОтступТекущегоПараметра = ПолучитьОтступПослеЗнакаКомментария(ПолноеОписаниеПараметра);
	ОтступПредыдущегоПараметра = ПолучитьОтступПослеЗнакаКомментария(ПолноеОписаниеПредыдущегоПараметра, Ложь);
	ДлинаОтступаТекущегоПараметра = СтрДлина(ОтступТекущегоПараметра);
	ДлинаОтступаПредыдущегоПараметра = СтрДлина(ОтступПредыдущегоПараметра);
	Если ДлинаОтступаТекущегоПараметра > ДлинаОтступаПредыдущегоПараметра Тогда
		Возврат;
	КонецЕсли;
	
	// Берем отступ предыдущего параметра, заменяем таб на 2 пробела.
	ОтступПредыдущегоПараметра = СтрЗаменить(ОтступПредыдущегоПараметра, Символы.Таб, "  ");
	
	// Если у предыдущего параметра нет имени и типа,
	Если ПустаяСтрока(СтрокаОписанияПредыдущегоПараметра.ИмяПараметра) И ПустаяСтрока(СтрокаОписанияПредыдущегоПараметра.ТипПараметра) Тогда
		
		// и отступы параметров равны, то пропускаем.
		Если (ДлинаОтступаТекущегоПараметра = ДлинаОтступаПредыдущегоПараметра) Тогда
			Возврат;
		КонецЕсли;
		
		// Если отступы не равны, то берем за основу отступ предыдущего параметра, т.к. он уже сдвинут.
		ОтступТекущегоПараметра = ОтступПредыдущегоПараметра;
		
	Иначе
		
		// Иначе добавляем в отступ предыдущего параметра 2 пробела.
		ОтступТекущегоПараметра = ОтступПредыдущегоПараметра + "  ";
		
	КонецЕсли;
	
	// Заменяем отступ в текущем описании параметра.
	ПолноеОписаниеПараметра = "//" + ОтступТекущегоПараметра + Сред(ПолноеОписаниеПараметра, ПозицияТекстовогоОписанияПараметра);
	
	// Переопределяем остальные колонки строки описания параметра.
	ПереопределитьОписаниеПараметра(СтрокаОписанияПараметра, СтрПолучитьСтроку(ПолноеОписаниеПараметра, 1));
	СтрокаОписанияПараметра.НеобходимоПовторноеФорматирование = Истина;
	
КонецПроцедуры

Процедура ДобавитьДополнительныйОтступДляСвойстваПараметраОписанияВозвращаемогоЗначения(СтрокаОписанияПараметра)
	
	// Флаг "ЭтоОписаниеВозвращаемогоЗначения" проверять бесполезно,
	// т.к. если имя или тип параметра начинается со "*",
	// то ему автоматически сбрасывается флаг ЭтоОписаниеВозвращаемогоЗначения = Ложь.
	
	// Проверяем секцию описания параметра. Если это не "ВозвращаемоеЗначение", тогда выходим.
	СекцияОписания = СтрокаОписанияПараметра.СекцияОписания;
	Если СекцияОписания <> "ВозвращаемоеЗначение" Тогда
		Возврат;
	КонецЕсли;
	
	// Проверяем флаг "ОписаниеПараметраНачинаетсяСоЗвездочки".
	Если НЕ СтрокаОписанияПараметра.ОписаниеПараметраНачинаетсяСоЗвездочки Тогда
		Возврат;
	КонецЕсли;
	
	// Если это не параметр верхнего уровня, то пропускаем.
	Если НЕ СтрокаОписанияПараметра.ЭтоПараметрВерхнегоУровня Тогда
		Возврат;
	КонецЕсли;
	
	ПозицияИмениПараметра = СтрокаОписанияПараметра.ПозицияИмениПараметра;
	Если ПозицияИмениПараметра = 0 Тогда
		Возврат;
	КонецЕсли;
	
	// Ищем предыдущий параметр верхнего уровня в секции "ВозвращаемоеЗначение", у которого отсутствует звездочка.
	СтрокаОписанияПредыдущегоПараметра = Неопределено;
	ТаблицаОписанияПараметров = СтрокаОписанияПараметра.Владелец();
	ИндексСтрокиОписанияПараметра = ТаблицаОписанияПараметров.Индекс(СтрокаОписанияПараметра);
	Для ИндексСтроки = 1 По ИндексСтрокиОписанияПараметра Цикл
		
		// Если секция не совпадает, то прерываем.
		ИндексСтрокиВверх = ИндексСтрокиОписанияПараметра - ИндексСтроки;
		СтрокаОписанияПараметраВверх = ТаблицаОписанияПараметров[ИндексСтрокиВверх];
		Если СтрокаОписанияПараметраВверх.СекцияОписания <> СекцияОписания Тогда
			Прервать;
		КонецЕсли;
		
		// Если это не параметр верхнего уровня, то пропускаем.
		Если НЕ СтрокаОписанияПараметраВверх.ЭтоПараметрВерхнегоУровня Тогда
			Продолжить;
		КонецЕсли;
		
		// Если параметр не начинается со звездочки, то прерываем.
		Если НЕ СтрокаОписанияПараметраВверх.ОписаниеПараметраНачинаетсяСоЗвездочки Тогда
			СтрокаОписанияПредыдущегоПараметра = СтрокаОписанияПараметраВверх;
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	// Если не нашли параметр, который начинается со звездочки, то выходим.
	Если СтрокаОписанияПредыдущегоПараметра = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	// Устанавливаем отступ текущего параметра как отступ предыдущего + 2 пробела.
	ПолноеОписаниеПредыдущегоПараметра = СтрокаОписанияПредыдущегоПараметра.ПолноеОписаниеПараметра;
	ОтступПредыдущегоПараметра = ПолучитьОтступПослеЗнакаКомментария(ПолноеОписаниеПредыдущегоПараметра, Ложь);
	ОтступПредыдущегоПараметра = СтрЗаменить(ОтступПредыдущегоПараметра, Символы.Таб, "  ");
	
	НовыйОтступТекущегоПараметра = ОтступПредыдущегоПараметра + "  ";
	
	ПолноеОписаниеПараметра = СтрокаОписанияПараметра.ПолноеОписаниеПараметра;
	ПолноеОписаниеПараметра = "//" + НовыйОтступТекущегоПараметра + Сред(ПолноеОписаниеПараметра, ПозицияИмениПараметра);
	
	// Переопределяем остальные колонки строки описания параметра.
	ПерваяСтрокаПолногоОписанияПараметра = СтрПолучитьСтроку(ПолноеОписаниеПараметра, 1);
	ПереопределитьОписаниеПараметра(СтрокаОписанияПараметра, ПерваяСтрокаПолногоОписанияПараметра);
	СтрокаОписанияПараметра.ЭтоПараметрВерхнегоУровня = Ложь;
	
	// Сдвигаем все параметры ниже с уровнем вложенности больше текущего.
	УровеньВложенностиПараметра = СтрокаОписанияПараметра.УровеньВложенностиПараметра;
	Для ИндексСтроки = ИндексСтрокиОписанияПараметра + 1 По ТаблицаОписанияПараметров.Количество() - 1 Цикл
		
		// Если секция не совпадает, то прерываем.
		СтрокаОписанияСледующегоПараметра = ТаблицаОписанияПараметров[ИндексСтроки];
		Если СтрокаОписанияСледующегоПараметра.СекцияОписания <> СекцияОписания Тогда
			Прервать;
		КонецЕсли;
		
		// Если уровень вложенности следующего параметра не больше текущего, то прерываем.
		Если СтрокаОписанияСледующегоПараметра.УровеньВложенностиПараметра <= УровеньВложенностиПараметра Тогда
			Прервать;
		КонецЕсли;
		
		// Если имя параметра не определено, то пропускаем.
		ПозицияИмениСледующегоПараметра = СтрокаОписанияСледующегоПараметра.ПозицияИмениПараметра;
		Если ПозицияИмениСледующегоПараметра = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		// Сдвигаем параметр относительного текущего на 2 пробела.
		НовыйОтступСледующегоПараметра = НовыйОтступТекущегоПараметра + "  ";
		ПолноеОписаниеСледующегоПараметра = СтрокаОписанияСледующегоПараметра.ПолноеОписаниеПараметра;
		ПолноеОписаниеСледующегоПараметра = "//" + НовыйОтступСледующегоПараметра + Сред(ПолноеОписаниеСледующегоПараметра, ПозицияИмениСледующегоПараметра);
		
		ПерваяСтрокаПолногоОписанияСледующегоПараметра = СтрПолучитьСтроку(ПолноеОписаниеСледующегоПараметра, 1);
		ПереопределитьОписаниеПараметра(СтрокаОписанияСледующегоПараметра, ПерваяСтрокаПолногоОписанияСледующегоПараметра);
		СтрокаОписанияСледующегоПараметра.ЭтоПараметрВерхнегоУровня = Ложь;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура УдалитьЗвездочкуВПараметреОписанияВозвращаемогоЗначения(СтрокаОписанияПараметра)
	
	// Флаг "ЭтоОписаниеВозвращаемогоЗначения" проверять бесполезно,
	// т.к. если имя или тип параметра начинается со "*",
	// то ему автоматически сбрасывается флаг ЭтоОписаниеВозвращаемогоЗначения = Ложь.
	
	// Проверяем секцию описания параметра. Если это не "ВозвращаемоеЗначение", тогда выходим.
	МассивТекстВозвращаемоеЗначение = Контекст["МассивТекстВозвращаемоеЗначение"];
	СекцияОписания = СтрокаОписанияПараметра.СекцияОписания;
	Если МассивТекстВозвращаемоеЗначение.Найти(СекцияОписания) = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	// Проверяем флаг "ОписаниеПараметраНачинаетсяСоЗвездочки".
	Если НЕ СтрокаОписанияПараметра.ОписаниеПараметраНачинаетсяСоЗвездочки Тогда
		Возврат;
	КонецЕсли;
	
	// Если это не параметр верхнего уровня, то пропускаем.
	Если НЕ СтрокаОписанияПараметра.ЭтоПараметрВерхнегоУровня Тогда
		Возврат;
	КонецЕсли;
	
	// Удаляем звездочку в начале описания параметра.
	ПолноеОписаниеПараметра = СтрокаОписанияПараметра.ПолноеОписаниеПараметра;
	ПозицияЗвездочки = СтрНайти(ПолноеОписаниеПараметра, "*");
	Если ПозицияЗвездочки = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ПолноеОписаниеПараметраДоЗвездочки = Лев(ПолноеОписаниеПараметра, ПозицияЗвездочки - 1);
	ПолноеОписаниеПараметраПослеЗвездочки = Сред(ПолноеОписаниеПараметра, ПозицияЗвездочки);
	
	Пока СтрНачинаетсяС(ПолноеОписаниеПараметраПослеЗвездочки, "*") Цикл
		ПолноеОписаниеПараметраПослеЗвездочки = Сред(ПолноеОписаниеПараметраПослеЗвездочки, 2);
		ПолноеОписаниеПараметраПослеЗвездочки = СокрЛ(ПолноеОписаниеПараметраПослеЗвездочки);
	КонецЦикла;
	
	ПолноеОписаниеПараметра = ПолноеОписаниеПараметраДоЗвездочки + ПолноеОписаниеПараметраПослеЗвездочки;
	ПерваяСтрокаПолногоОписанияПараметра = СтрПолучитьСтроку(ПолноеОписаниеПараметра, 1);
	
	// Переопределяем остальные колонки строки описания параметра.
	ПереопределитьОписаниеПараметра(СтрокаОписанияПараметра, ПерваяСтрокаПолногоОписанияПараметра);
	СтрокаОписанияПараметра.НеобходимоПовторноеФорматирование = Истина;
	
КонецПроцедуры

Процедура ЗаменитьОписаниеТипаПараметраСДлинойСтрокиИЧисла(СтрокаОписанияПараметра)
	
	// Если тип параметра не определен, то выходим.
	ТипПараметра = СтрокаОписанияПараметра.ТипПараметра;
	Если ПустаяСтрока(ТипПараметра) Тогда
		Возврат;
	КонецЕсли;
	
	ПозицияТипаПараметра = СтрокаОписанияПараметра.ПозицияТипаПараметра;
	Если ПозицияТипаПараметра = 0 Тогда
		Возврат;
	КонецЕсли;
	
	// Если в типе нет скобок, то выходим.
	ПозицияОткрывающейсяСкобки = СтрНайти(ТипПараметра, "(");
	Если ПозицияОткрывающейсяСкобки = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ПозицияЗакрывающейсяСкобки = СтрНайти(ТипПараметра, ")");
	Если ПозицияЗакрывающейсяСкобки = 0 Тогда
		Возврат;
	КонецЕсли;
	
	// Если кроме скобок в типе параметра ничего не указано, то выходим.
	ТипПараметраБезДлины = Лев(ТипПараметра, ПозицияОткрывающейсяСкобки - 1);
	Если ПустаяСтрока(ТипПараметраБезДлины) Тогда
		Возврат;
	КонецЕсли;
	
	ТипПараметраБезДлины = СокрЛП(ТипПараметраБезДлины);
	
	// Получаем текст в скобках.
	ТекстДлиныТипаПараметраВСкобках = Сред(ТипПараметра, ПозицияОткрывающейсяСкобки + 1, ПозицияЗакрывающейсяСкобки - ПозицияОткрывающейсяСкобки - 1);
	// В скобках может быть указано несколько чисел через запятую, например, для типа "Число" будет указана длина и точность числа.
	МассивЭлементовДлины = СтрРазделить(ТекстДлиныТипаПараметраВСкобках, ",", Ложь);
	Если МассивЭлементовДлины.Количество() = 0 Тогда
		// Если текст пустой, то выходим.
		Возврат;
	КонецЕсли;
	
	// Берем только первое число в скобках.
	ДлинаТипаПараметра = МассивЭлементовДлины[0];
	Если НЕ апк_ЭтоЧисло(ДлинаТипаПараметра) Тогда
		// Если это не число, то выходим.
		Возврат;
	КонецЕсли;
	
	// Добавляем статичный текст, например, "строка длиной 25 символов" в начало текстового описания параметра.
	ДлинаТипаПараметра = Число(ДлинаТипаПараметра);
	
	Если КодОсновногоЯзыка = "ru" Тогда
		// Для русского языка получаем длину типа параметра в виде числа прописью и склонение слова "символ".
		ДлинаТипаПараметраПрописью = ЧислоПрописью(ДлинаТипаПараметра, НСтр("ru='Л=ru_RU'"), НСтр("ru='символ, символа, символов, м,,,,, 0'"));
		МассивСловТипаПараметраПрописью = СтрРазделить(ДлинаТипаПараметраПрописью, " ", Ложь);
		СловоСимволов = МассивСловТипаПараметраПрописью[МассивСловТипаПараметраПрописью.ВГраница()];
		
		ДополнительноеТекстовоеОписание = НРег(ТипПараметраБезДлины) + " длиной %1 %2";
		ДополнительноеТекстовоеОписание = СтрШаблон(ДополнительноеТекстовоеОписание, ДлинаТипаПараметра, СловоСимволов);
	Иначе
		ДополнительноеТекстовоеОписание = "a %1-character-long " + НРег(ТипПараметраБезДлины);
		ДополнительноеТекстовоеОписание = СтрШаблон(ДополнительноеТекстовоеОписание, ДлинаТипаПараметра);
	КонецЕсли;
	
	// Если исходное текстовое описание параметра не пустое, то добавляем запятую.
	ТекстовоеОписаниеПараметра = СтрокаОписанияПараметра.ТекстовоеОписаниеПараметра;
	Если НЕ ПустаяСтрока(ТекстовоеОписаниеПараметра) Тогда
		// Если текстовое описание параметра расположено в той же строке, то добавляем пробел.
		// Если на следующей строке, то перенос.
		ДополнительноеТекстовоеОписание = ДополнительноеТекстовоеОписание + ","
			+ ?(СтрокаОписанияПараметра.ПозицияТекстовогоОписанияПараметра = 0, Символы.ПС, " ");
	КонецЕсли;
	
	// Переопределяем полное описание параметра.
	ПолноеОписаниеПараметра = СтрокаОписанияПараметра.ПолноеОписаниеПараметра;
	ПолноеОписаниеПараметраДоТипаПараметра = Лев(ПолноеОписаниеПараметра, ПозицияТипаПараметра - 1);
	
	ПолноеОписаниеПараметра = ПолноеОписаниеПараметраДоТипаПараметра + ТипПараметраБезДлины + " - "
		+ ДополнительноеТекстовоеОписание + ТекстовоеОписаниеПараметра;
	
	ПерваяСтрокаПолногоОписанияПараметра = СтрПолучитьСтроку(ПолноеОписаниеПараметра, 1);
	
	// Переопределяем остальные колонки строки описания параметра.
	ПереопределитьОписаниеПараметра(СтрокаОписанияПараметра, ПерваяСтрокаПолногоОписанияПараметра);
	
КонецПроцедуры

Процедура ДобавитьПробелПослеТекстаГиперссылкиСмВТекстовоеОписаниеПараметра(СтрокаОписанияПараметра)
	
	// Если текстовое описание параметра не заполнено, то выходим.
	ТекстовоеОписаниеПараметра = СтрокаОписанияПараметра.ТекстовоеОписаниеПараметра;
	Если ПустаяСтрока(ТекстовоеОписаниеПараметра) Тогда
		Возврат;
	КонецЕсли;
	
	МассивТекстСм = Контекст["МассивТекстСм"];
	РезультатПоискаТекстаСм = СтрНачинаетсяСПоМассиву(ВРег(СокрЛ(ТекстовоеОписаниеПараметра)), МассивТекстСм);
	Если НЕ РезультатПоискаТекстаСм.Успешно Тогда
		// Если текстовое описание не начинается с текста гиперссылки "см.", то выходим.
		Возврат;
	КонецЕсли;
	
	// Если в текстовом описании уже есть текст "см." / "see" с пробелом, выходим.
	ТекстГиперссылкиСм = РезультатПоискаТекстаСм.НайденныйЭлемент;
	Если СтрНайти(ТекстГиперссылкиСм, " ") > 0 Тогда
		Возврат;
	КонецЕсли;
	
	// Добавим пробел после литерала с учетом найденного текста гиперссылки "см.".
	ИсходноеТекстовоеОписаниеЛев = Лев(ТекстовоеОписаниеПараметра, СтрДлина(ТекстГиперссылкиСм));
	ИсходноеТекстовоеОписаниеПрав = Прав(ТекстовоеОписаниеПараметра, СтрДлина(ТекстовоеОписаниеПараметра) - СтрДлина(ТекстГиперссылкиСм));
	ИсходноеТекстовоеОписаниеПрав = СокрЛ(ИсходноеТекстовоеОписаниеПрав);
	
	// Если весь текст после гиперссылки "см." находится на следующей строке, то пробел не нужен, выходим.
	Если СтрНачинаетсяС(ИсходноеТекстовоеОписаниеПрав, "//") Тогда
		Возврат;
	КонецЕсли;
	
	НовоеТекстовоеОписание = ИсходноеТекстовоеОписаниеЛев + " " + ИсходноеТекстовоеОписаниеПрав;
	
	// Изменяем данные описания параметра.
	СтрокаОписанияПараметра.ТекстовоеОписаниеПараметра = НовоеТекстовоеОписание;
	СтрокаОписанияПараметра.ПолноеОписаниеПараметра = СтрЗаменить(СтрокаОписанияПараметра.ПолноеОписаниеПараметра, ТекстовоеОписаниеПараметра, НовоеТекстовоеОписание);
	СтрокаОписанияПараметра.СостояниеПараметра = "Изменен";
	
КонецПроцедуры

// Исправляет описание (комментарии) процедур и функций:
// - Удаляет комментарии после "КонецПроцедуры" и "КонецФункции" в той же строке.
// - Вставляет строку с пустым комментарием между комментарием и началом процедуры или функции.
// - Удаляет лишние символы из описания параметра, например, "- ,", ", -" или " - - ".
// - Удаляет лишний текст "обязательный" и "необязательный" из описания параметра.
// - Приводит см-описания параметров к стандарту "см. <Модуль.Функция>".
// - Определяет тип параметра из имени параметра, если он оформлен в скобках.
// - Определяет тип параметра в начале текстового описания параметра, если он не выделен явно.
// - Заменяет неправильное описание типа параметра на соответствующее языку платформы.
// - Заменяет тип параметра "Соответствие" на "Соответствие из КлючИЗначение",
//   если далее описаны свойства "Ключ" и "Значение".
// - Заменяет символы табуляции на пробелы в строке комментария перед описанием параметра: 1 таб на 2 пробела.
// - Выравнивает отступы типа параметра относительно предыдущего после замены табов на пробелы.
// - Разделяет множественный тип параметра (несколько типов через запятую) по отдельным строкам.
// - Удаляет незначащее текстовое описание параметра для структур, таблиц значений и деревьев значений.
// - Заменяет первую заглавную букву текстового описания параметра на строчную.
// - Удаляет лишний дефис в конце строки с описанием параметра.
// - Добавляет двоеточие в конце текстового описания параметра перед описанием свойств (колонок) составных типов.
// - Исправляет неправильное описание секции "Возвращаемое значение".
// - Добавляет дополнительный отступ в 2 пробела для параметров и свойств параметров,
//   являющихся описанием возвращаемого значения.
// - Удаляет лишние символы звездочек в начале параметров и типов описания возвращаемого значения.
// - Выносит длину типа параметра в текстовое описание, если в типе параметра указана длина строки или числа в скобках.
//
Функция ИсправитьОписаниеПроцедурИФункций(ДокументТекст, ЭтоПервыйЗапуск = Истина)
	
	ФайлИзменен = Ложь;
	
	КоличествоСтрок = ДокументТекст.КоличествоСтрок();
	Если КоличествоСтрок = 0 Тогда
		Возврат ФайлИзменен;
	КонецЕсли;
	
	ТекстМодуля = ДокументТекст.ПолучитьТекст();
	Если ПустаяСтрока(ТекстМодуля) Тогда
		Возврат ФайлИзменен;
	КонецЕсли;
	
	ТаблицаМетодовМодуля = ПолучитьТаблицуПроцедурИФункций(ТекстМодуля);
	КоличествоМетодов = ТаблицаМетодовМодуля.Количество();
	Если КоличествоМетодов = 0 Тогда
		Возврат ФайлИзменен;
	КонецЕсли;
	
	НеобходимоПовторноеФорматирование = Ложь;
	
	НомерПоследнегоМетода = КоличествоМетодов - 1;
	Для НомерМетодаМодуля = 0 По НомерПоследнегоМетода Цикл
		
		СтрокаТаблицыМетодовМодуля = ТаблицаМетодовМодуля[НомерПоследнегоМетода - НомерМетодаМодуля];
		
		// Удаляем комментарий после конструкций "КонецПроцедуры" и "КонецФункции".
		НомерСтрокиКонцаМетода = СтрокаТаблицыМетодовМодуля.НомерСтрокиКонцаМетода;
		СтрокаМодуляИсходная = ДокументТекст.ПолучитьСтроку(НомерСтрокиКонцаМетода);
		СтрокаМодуляРезультат = УдалитьКомментарийПослеКонецПроцедурыФункции(СтрокаМодуляИсходная);
		Если СтрокаМодуляРезультат <> СтрокаМодуляИсходная Тогда
			ДокументТекст.ЗаменитьСтроку(НомерСтрокиКонцаМетода, СтрокаМодуляРезультат);
			ФайлИзменен = Истина;
		КонецЕсли;
		
		ТекстКомментарияМетода = СтрокаТаблицыМетодовМодуля.ТекстКомментарияМетода;
		
		НомерСтрокиНачалаКомментарияМетода = СтрокаТаблицыМетодовМодуля.НомерСтрокиНачалаКомментарияМетода;
		НомерСтрокиКонцаКомментарияМетода  = СтрокаТаблицыМетодовМодуля.НомерСтрокиКонцаКомментарияМетода;
		
		// Для комментариев перед процедурами и функциями, начинающихся с корректной гиперссылки,
		// получаем только строку с гиперссылкой и служебные комментарии.
		НовыйТекстКомментарияМетода = ОчиститьКомментарийПередМетодомСодержащийГиперссылку(СтрокаТаблицыМетодовМодуля);
		Если НЕ ПустаяСтрока(НовыйТекстКомментарияМетода) Тогда
			
			// Если получили новый комментарий для процедуры (функции), то проверяем, изменился ли он.
			Если НовыйТекстКомментарияМетода <> ТекстКомментарияМетода Тогда
				
				// Если изменился, то заменяем его. Удаляем все строки комментария.
				Для НомерСтроки = НомерСтрокиНачалаКомментарияМетода По НомерСтрокиКонцаКомментарияМетода Цикл
					ДокументТекст.УдалитьСтроку(НомерСтрокиНачалаКомментарияМетода);
				КонецЦикла;
				
				// Вставляем новый комментарий построчно.
				КоличествоСтрокНовогоКомментарияМетода = СтрЧислоСтрок(НовыйТекстКомментарияМетода);
				Для НомерСтрокиКомментарияМетода = 1 По КоличествоСтрокНовогоКомментарияМетода Цикл
					СтрокаНовогоКомментарияМетода = СтрПолучитьСтроку(НовыйТекстКомментарияМетода, НомерСтрокиКомментарияМетода);
					ДокументТекст.ВставитьСтроку(НомерСтрокиНачалаКомментарияМетода + НомерСтрокиКомментарияМетода - 1, СтрокаНовогоКомментарияМетода);
				КонецЦикла;
				
				// Устанавливаем флаг, что файл с текстом модуля изменен.
				ФайлИзменен = Истина;
				
			КонецЕсли;
			
			// В любом случае, параметры и возвращаемое значение проверять не требуется, пропускаем.
			Продолжить;
			
		КонецЕсли;
		
		// Вставляем пустой комментарий перед началом процедуры и функции.
		Если ВставитьПустойКомментарийПередНачаломПроцедурыФункции(ТекстКомментарияМетода) Тогда
			ДокументТекст.ВставитьСтроку(НомерСтрокиКонцаКомментарияМетода + 1, "//");
			ФайлИзменен = Истина;
		КонецЕсли;
		
		Контекст.Вставить("ТекущийОбрабатываемыйМетод", СтрокаТаблицыМетодовМодуля);
		
		ТаблицаОписанияПараметровИсходная = ПолучитьТаблицуОписанияПараметровМетода(ТекстКомментарияМетода);
		ТаблицаОписанияПараметровИзмененная = ТаблицаОписанияПараметровИсходная.Скопировать();
		
		// Вводим дополнительные переменные.
		СекцияОписанияПараметраРодителя = "";
		ТекстовоеОписаниеПараметраРодителяЯвляетсяГиперссылкой = Ложь;
		УровеньВложенностиПараметраРодителя = 0;
		
		// Обрабатываем параметры в таблице описания параметров.
		Для Каждого СтрокаТаблицыОписанияПараметров Из ТаблицаОписанияПараметровИзмененная Цикл
			
			СекцияОписанияТекущегоПараметра = СтрокаТаблицыОписанияПараметров.СекцияОписания;
			УровеньВложенностиТекущегоПараметра = СтрокаТаблицыОписанияПараметров.УровеньВложенностиПараметра;
			
			// Для параметров-родителей, текстовое описание которых является гиперссылкой,
			// не обрабатываем подчиненные параметры или свойства с уровнем вложенности больше текущего параметра,
			// т.к. их необходимо удалить.
			Если ТекстовоеОписаниеПараметраРодителяЯвляетсяГиперссылкой
				И (СекцияОписанияТекущегоПараметра = СекцияОписанияПараметраРодителя)
				И (УровеньВложенностиТекущегоПараметра > УровеньВложенностиПараметраРодителя) Тогда
				
				СтрокаТаблицыОписанияПараметров.СостояниеПараметра = "Удален";
				Продолжить;
			КонецЕсли;
			
			// Удаляем лишние (мусорные) символы внутри описания параметра, например, "- ,".
			УдалитьЛишниеСимволыИзОписанияПараметра(СтрокаТаблицыОписанияПараметров);
			
			// Удаляем текст "обязательный" и "необязательный" из описания параметра.
			УдалитьТекстОбязательныйНеобязательныйИзОписанияПараметра(СтрокаТаблицыОписанияПараметров);
			
			// Переопределяем текстовое описание параметра в виде гиперссылки на объект, метод или параметр при ее наличии.
			УстановитьТекстГиперссылкиВОписаниеПараметра(СтрокаТаблицыОписанияПараметров);
			ТекстОшибки = СтрокаТаблицыОписанияПараметров.ТекстОшибки;
			Если НЕ ПустаяСтрока(ТекстОшибки) Тогда
				НомерСтрокиНачалаОписанияПараметраВКомментарии = СтрокаТаблицыОписанияПараметров.НомерСтрокиНачалаОписанияПараметра;
				НомерСтрокиНачалаОписанияПараметраВМодуле = НомерСтрокиНачалаКомментарияМетода + НомерСтрокиНачалаОписанияПараметраВКомментарии - 1;
				ОбработатьИсключение(Контекст["ТекущийОбрабатываемыйФайл"], ТекстОшибки, НомерСтрокиНачалаОписанияПараметраВМодуле);
			КонецЕсли;
			
			// Иногда тип параметра указан в скобках после имени параметра, тогда он определяется как имя параметра.
			// Пытаемся выделить тип из имени параметра.
			УстановитьТипПараметраИзИмениПараметра(СтрокаТаблицыОписанияПараметров);
			
			// Пытаемся определить тип параметра из текстового описания, если он изначально не заполнен верно.
			УстановитьТипПараметраИзТекстовогоОписанияПараметра(СтрокаТаблицыОписанияПараметров);
			
			// Заменяем некорректно написанный тип параметра на соответствующий языку платформы.
			ЗаменитьНеправильноеОписаниеТипаПараметра(СтрокаТаблицыОписанияПараметров);
			
			// Заменяем тип параметра "Соответствие" на "Соответствие из КлючИЗначение".
			ЗаменитьОписаниеТипаПараметраСоответствие(СтрокаТаблицыОписанияПараметров);
			
			// Заменяем символы табуляции на пробелы перед описанием параметра: 1 таб на 2 пробела.
			ЗаменитьТабыНаПробелыПередОписаниемПараметра(СтрокаТаблицыОписанияПараметров);
			
			// Выравниваем отступ типа параметра относительно предыдущего после замены табов на пробелы.
			ВыровнятьТипПараметраОтносительноПредыдущего(СтрокаТаблицыОписанияПараметров);
			
			// 20.11.2020: функционал по переносу типов по строкам отключен, т.к. работает не всегда корректно.
			// Переносим каждый тип параметра на новую строку.
			//РазделитьТипыПараметраПоСтрокам(СтрокаТаблицыОписанияПараметров);
			
			// Удаляем текстовое описание параметра, если оно является незначимым.
			УдалитьНезначащееТекстовоеОписаниеПараметра(СтрокаТаблицыОписанияПараметров);
			
			// Добавить пробел после текста гиперссылки "см.".
			ДобавитьПробелПослеТекстаГиперссылкиСмВТекстовоеОписаниеПараметра(СтрокаТаблицыОписанияПараметров);
			
			// Устанавливаем первую букву текстового описания параметра в нижний регистр.
			УстановитьПервыйСимволТекстовогоОписанияПараметраВНижнийРегистр(СтрокаТаблицыОписанияПараметров);
			
			// Удаляем лишний дефис в конце строки описания параметра.
			УдалитьДефисВКонцеСтрокиОписанияПараметра(СтрокаТаблицыОписанияПараметров);
			
			// Добавляем двоеточие перед описанием свойств или колонок составных типов.
			ДобавитьДвоеточиеВКонцеСтрокиОписанияПараметра(СтрокаТаблицыОписанияПараметров);
			
			// Если секция "Возвращаемое значение" оформлена неправильно, то приводим ее к правильному формату.
			ФорматироватьОписаниеСекцииВозвращаемоеЗначение(СтрокаТаблицыОписанияПараметров);
			
			// Если описание параметра возвращаемого значения оформлено в несколько строк,
			// то каждая следующая строка с таким же отступом является отдельным параметром.
			// Для таких строк параметров добавляем дополнительный отступ в 2 пробела.
			ДобавитьДополнительныйОтступДляПараметраОписанияВозвращаемогоЗначения(СтрокаТаблицыОписанияПараметров);
			
			// Если параметр является свойством параметра описания возвращаемого значения
			// и его отступ равен отступу параметра описания возвращаемого значения,
			// то добавляем дополнительный отступ в 2 пробела.
			ДобавитьДополнительныйОтступДляСвойстваПараметраОписанияВозвращаемогоЗначения(СтрокаТаблицыОписанияПараметров);
			
			// У параметров описания возвращаемого значения, начинающихся со звездочки, удаляем все символы "*".
			УдалитьЗвездочкуВПараметреОписанияВозвращаемогоЗначения(СтрокаТаблицыОписанияПараметров);
			
			// Если в типе параметра указана длина строки или числа в скобках,
			// то выносим эту длину в текстовое описание параметра.
			ЗаменитьОписаниеТипаПараметраСДлинойСтрокиИЧисла(СтрокаТаблицыОписанияПараметров);
			
			// Запоминаем значение дополнительных переменных для проверки следующего параметра.
			СекцияОписанияПараметраРодителя = СекцияОписанияТекущегоПараметра;
			УровеньВложенностиПараметраРодителя = УровеньВложенностиТекущегоПараметра;
			ТекстовоеОписаниеПараметраРодителяЯвляетсяГиперссылкой = СтрокаТаблицыОписанияПараметров.ТекстовоеОписаниеПараметраЯвляетсяГиперссылкой;
			
			Если СтрокаТаблицыОписанияПараметров.НеобходимоПовторноеФорматирование Тогда
				НеобходимоПовторноеФорматирование = Истина;
			КонецЕсли;
			
		КонецЦикла;
		
		// Изменяем описание параметров в тексте модуля.
		НомерПоследнегоПараметра = ТаблицаОписанияПараметровИзмененная.Количество() - 1;
		Для НомерПараметра = 0 По НомерПоследнегоПараметра Цикл
			
			// Обрабатываем описание параметров в тексте модуля снизу вверх.
			НомерПараметраСКонцаТаблицыОписанияПараметров = НомерПоследнегоПараметра - НомерПараметра;
			СтрокаТаблицыОписанияПараметровИзмененная = ТаблицаОписанияПараметровИзмененная[НомерПараметраСКонцаТаблицыОписанияПараметров];
			
			Если СтрокаТаблицыОписанияПараметровИзмененная.СостояниеПараметра = "Исходный" Тогда
				Продолжить;
			КонецЕсли;
			
			ФайлИзменен = Истина;
			
			СтрокаТаблицыОписанияПараметровИсходная = ТаблицаОписанияПараметровИсходная[НомерПараметраСКонцаТаблицыОписанияПараметров];
			
			// Заменяем описание параметра в исходном текстовом документе из измененной таблицы описания параметров.
			НомерСтрокиНачалаОписанияПараметраВКомментарии = СтрокаТаблицыОписанияПараметровИсходная.НомерСтрокиНачалаОписанияПараметра;
			НомерСтрокиНачалаОписанияПараметраВМодулеИсходный = НомерСтрокиНачалаКомментарияМетода + НомерСтрокиНачалаОписанияПараметраВКомментарии - 1;
			
			НомерСтрокиКонцаОписанияПараметраВКомментарии = СтрокаТаблицыОписанияПараметровИсходная.НомерСтрокиКонцаОписанияПараметра;
			НомерСтрокиКонцаОписанияПараметраВМодулеИсходный = НомерСтрокиНачалаКомментарияМетода + НомерСтрокиКонцаОписанияПараметраВКомментарии - 1;
			
			// Сначала удаляем исходный текст.
			Для НомерСтроки = НомерСтрокиНачалаОписанияПараметраВМодулеИсходный По НомерСтрокиКонцаОписанияПараметраВМодулеИсходный Цикл
				ДокументТекст.УдалитьСтроку(НомерСтрокиНачалаОписанияПараметраВМодулеИсходный);
			КонецЦикла;
			
			// Если параметр был изменен, то вставляем измененные строки.
			Если СтрокаТаблицыОписанияПараметровИзмененная.СостояниеПараметра = "Изменен" Тогда
				
				НомерСтрокиНачалаОписанияПараметраВКомментарии = СтрокаТаблицыОписанияПараметровИзмененная.НомерСтрокиНачалаОписанияПараметра;
				НомерСтрокиНачалаОписанияПараметраВМодулеИзмененный = НомерСтрокиНачалаКомментарияМетода + НомерСтрокиНачалаОписанияПараметраВКомментарии - 1;
				
				НомерСтрокиКонцаОписанияПараметраВКомментарии = СтрокаТаблицыОписанияПараметровИзмененная.НомерСтрокиКонцаОписанияПараметра;
				НомерСтрокиКонцаОписанияПараметраВМодулеИзмененный = НомерСтрокиНачалаКомментарияМетода + НомерСтрокиКонцаОписанияПараметраВКомментарии - 1;
				
				ПолноеОписаниеПараметра = СтрокаТаблицыОписанияПараметровИзмененная.ПолноеОписаниеПараметра;
				
				Для НомерСтроки = НомерСтрокиНачалаОписанияПараметраВМодулеИзмененный По НомерСтрокиКонцаОписанияПараметраВМодулеИзмененный Цикл
					СтрокаПолногоОписанияПараметра = СтрПолучитьСтроку(ПолноеОписаниеПараметра, НомерСтроки - НомерСтрокиНачалаОписанияПараметраВМодулеИзмененный + 1);
					ДокументТекст.ВставитьСтроку(НомерСтроки, СтрокаПолногоОписанияПараметра);
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	// Если необходим повторный запуск форматирования описаний процедур и функций, то перезапустим.
	Если НеобходимоПовторноеФорматирование И ЭтоПервыйЗапуск Тогда
		ИсправитьОписаниеПроцедурИФункций(ДокументТекст, Ложь);
	КонецЕсли;
	
	Возврат ФайлИзменен;
	
КонецФункции

Функция ЗаменитьДвойнойСимволТочкаСЗапятойНаОдинарный(ДокументТекст)
	
	ФайлИзменен = Ложь;
	
	КоличествоСтрок = ДокументТекст.КоличествоСтрок();
	Если КоличествоСтрок = 0 Тогда
		Возврат ФайлИзменен;
	КонецЕсли;
	
	ТекстМодуля = ДокументТекст.ПолучитьТекст();
	Если ПустаяСтрока(ТекстМодуля) Тогда
		Возврат ФайлИзменен;
	КонецЕсли;
	
	ТекстПоиска = ";;";
	ТекстЗамены = ";";
	
	ДлинаТекстаПоиска = СтрДлина(ТекстПоиска);
	
	ПозицияПоискаВМодуле = 0;
	Пока Истина Цикл
		
		ПозицияПоискаВМодуле = СтрНайти(ТекстМодуля, ТекстПоиска,, ПозицияПоискаВМодуле + 1);
		Если ПозицияПоискаВМодуле = 0 Тогда
			Прервать;
		КонецЕсли;
		
		ТекстМодуляДоТекстаПоиска = Лев(ТекстМодуля, ПозицияПоискаВМодуле - 1);
		
		СтрокаМодуля = ПолучитьПоследнююСтрокуМодуля(ТекстМодуляДоТекстаПоиска);
		Если СтрокаОткрыта(СтрокаМодуля) Тогда
			// Если двойной символ ";;" находится в кавычках, то пропускаем.
			Продолжить;
		КонецЕсли;
		
		СтрокаМодуляБезКомментария = УдалитьКомментарийИзСтроки(СтрокаМодуля);
		Если СтрокаМодуля <> СтрокаМодуляБезКомментария Тогда
			// Если после удаления комментария строка изменилась, значит, двойной символ ";;" находится в комментарии, пропускаем.
			Продолжить;
		КонецЕсли;
		
		ТекстМодуляПослеТекстаПоиска = Сред(ТекстМодуля, ПозицияПоискаВМодуле + ДлинаТекстаПоиска);
		ТекстМодуля = ТекстМодуляДоТекстаПоиска + ТекстЗамены + ТекстМодуляПослеТекстаПоиска;
		
		ФайлИзменен = Истина;
		
	КонецЦикла;
	
	Если ФайлИзменен Тогда
		ДокументТекст.УстановитьТекст(ТекстМодуля);
	КонецЕсли;
	
	Возврат ФайлИзменен;
	
КонецФункции

Функция СтрокаОткрыта(Знач СтрокаМодуля)
	
	Если СтрЧислоСтрок(СтрокаМодуля) > 1 Тогда
		СтрокаМодуля = ПолучитьПоследнююСтрокуМодуля(СтрокаМодуля);
	КонецЕсли;
	
	КоличествоКавычек = СтрЧислоВхождений(СтрокаМодуля, """");
	КоличествоКавычекЧетное = (КоличествоКавычек % 2 = 0);
	
	Возврат ?(СтрНачинаетсяС(СокрЛ(СтрокаМодуля), "|"), КоличествоКавычекЧетное, НЕ КоличествоКавычекЧетное);
	
КонецФункции

Функция ПолучитьПоследнююСтрокуМодуля(Знач ТекстМодуля)
	
	ДокументТекст = Новый ТекстовыйДокумент;
	ДокументТекст.УстановитьТекст(ТекстМодуля);
	
	НомерПоследнейСтроки = ДокументТекст.КоличествоСтрок();
	Возврат ДокументТекст.ПолучитьСтроку(НомерПоследнейСтроки);
	
КонецФункции

#КонецОбласти

#Область ЛокализацияДинамическихСписков

Функция УдалитьКомментарийИзСтроки(Знач СтрокаМодуля)
	
	Если ПустаяСтрока(СтрокаМодуля) Тогда
		Возврат СтрокаМодуля;
	КонецЕсли;
	
	ПозицияКомментария = СтрНайти(СтрокаМодуля, "//");
	Если ПозицияКомментария = 0 Тогда
		Возврат СтрокаМодуля;
	КонецЕсли;
	
	// Например, URLСтрока = "http://downloads.v8.1c.ru/tmplts/ITS/KLADR/"; - не проверяем на комментарий.
	СтрокаМодуля = СтрЗаменить(СтрокаМодуля, "://", "<<ВНЕШНЕЕСОЕДИНЕНИЕ>>");
	ПозицияКомментария = СтрНайти(СтрокаМодуля, "//");
	
	// Есть комментарий.
	Если ПозицияКомментария > 0 Тогда
		ПозицияКавычек = СтрНайти(СтрокаМодуля, """");
		СтрокаОткрыта = СтрНачинаетсяС(СокрЛ(СтрокаМодуля), "|");
		
		// Нет кавычек, удаляем комментарий.
		Если ПозицияКавычек = 0 Тогда
			СтрокаМодуля = Лев(СтрокаМодуля, ПозицияКомментария - 1);
			
		// Знак комментария в открытой строке, например:
		// |//////////////////";
		ИначеЕсли СтрокаОткрыта И ПозицияКавычек > 0 Тогда
			ПозицияКомментария = СтрНайти(СтрокаМодуля, "//",, ПозицияКавычек);
			Если ПозицияКомментария > 0 Тогда
				СтрокаМодуля = Лев(СтрокаМодуля, ПозицияКомментария - 1);
			КонецЕсли;
			
		// Строка не открыта, кавычки после комментария, удаляем комментарий.
		ИначеЕсли ПозицияКавычек > ПозицияКомментария Тогда
			СтрокаМодуля = Лев(СтрокаМодуля, ПозицияКомментария - 1);
			
		Иначе
			КоличествоКавычекДоКомментария = СтрЧислоВхождений(Лев(СтрокаМодуля, ПозицияКомментария), """");
			// Строка открывается и закрывается до комментария, удаляем комментарий.
			Если КоличествоКавычекДоКомментария % 2 = 0 Тогда
				СтрокаМодуля = Лев(СтрокаМодуля, ПозицияКомментария - 1);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Возврат СтрЗаменить(СтрокаМодуля, "<<ВНЕШНЕЕСОЕДИНЕНИЕ>>", "://");;
	
КонецФункции

Функция ПолучитьТекстМодуляБезКомментариев(ТекстМодуля)
	
	РазборТекста = Новый ТекстовыйДокумент;
	РазборТекста.УстановитьТекст(ТекстМодуля);
	
	КоличествоСтрок = РазборТекста.КоличествоСтрок();
	
	Для Счетчик = 1 По КоличествоСтрок Цикл
		СтрокаМодуля = РазборТекста.ПолучитьСтроку(Счетчик);
		СтрокаМодуля = УдалитьКомментарийИзСтроки(СтрокаМодуля);
		РазборТекста.ЗаменитьСтроку(Счетчик, СтрокаМодуля);
	КонецЦикла;
	
	Возврат РазборТекста.ПолучитьТекст();
	
КонецФункции

Функция ПолучитьПсевдонимыРазыменованныхПолейТекстаЗапроса(Знач ТекстЗапроса)
	
	МассивРазыменованныхПолей = Новый Массив;
	
	МассивТекстВыбрать = Новый Массив;
	МассивТекстВыбрать.Добавить(" ВЫБРАТЬ ");
	МассивТекстВыбрать.Добавить(" SELECT ");
	
	МассивТекстИз = Новый Массив;
	МассивТекстИз.Добавить(" ИЗ ");
	МассивТекстИз.Добавить(" FROM ");
	
	МассивТекстКак = Новый Массив;
	МассивТекстКак.Добавить(" КАК ");
	МассивТекстКак.Добавить(" AS ");
	
	СтрокаОператоровЗапроса = "РАЗРЕШЕННЫЕ , РАЗЛИЧНЫЕ , КАК СТРОКА(, ALLOWED , DISTINCT , AS STRING(";
	МассивОператоровЗапроса = СтрРазделить(СтрокаОператоровЗапроса, ",");
	
	ТекстЗапросаВРег = ВРег(ТекстЗапроса);
	ТекстЗапросаВРег = СтрЗаменить(ТекстЗапросаВРег, Символы.ПС, " ");
	ТекстЗапросаВРег = СтрЗаменить(ТекстЗапросаВРег, Символы.Таб, " ");
	ТекстЗапросаВРег = СтрЗаменить(ТекстЗапросаВРег, "(", " ");
	ТекстЗапросаВРег = СтрЗаменить(ТекстЗапросаВРег, ")", " ");
	ТекстЗапросаВРег = СтрЗаменить(ТекстЗапросаВРег, "{", " ");
	ТекстЗапросаВРег = СтрЗаменить(ТекстЗапросаВРег, "}", " ");
	
	ТекстЗапросаВРег = " " + ТекстЗапросаВРег; // чтобы найти первый оператор "ВЫБРАТЬ".
	
	ПозицияВыбрать = 0;
	ПозицияИз = 0;
	Пока Истина Цикл
		
		РезультатПоиска = СтрНайтиПоМассиву(ТекстЗапросаВРег, МассивТекстВыбрать,, ПозицияВыбрать + 1, Истина);
		Если НЕ РезультатПоиска.Успешно Тогда
			Прервать;
		КонецЕсли;
		
		ПозицияВыбрать = РезультатПоиска.Позиция;
		
		РезультатПоискаТекстИз = СтрНайтиПоМассиву(ТекстЗапросаВРег, МассивТекстИз,, ПозицияВыбрать + 1, Истина);
		Если НЕ РезультатПоискаТекстИз.Успешно Тогда
			ПозицияИз = СтрДлина(ТекстЗапросаВРег);
		КонецЕсли;
		
		ПозицияИз = РезультатПоискаТекстИз.Позиция;
		СтрДлинаТекстВыбрать = СтрДлина(РезультатПоиска.НайденныйЭлемент);
		
		ПозицияВыбранныхПолей = ПозицияВыбрать + СтрДлинаТекстВыбрать - 1; // т.к. добавили лишний пробел в запрос.
		ТекстВыбранныхПолей = Сред(ТекстЗапроса, ПозицияВыбранныхПолей, ПозицияИз - ПозицияВыбранныхПолей);
		
		// Убираем табы, переносы и некоторые операторы запроса.
		ТекстВыбранныхПолей = СтрЗаменить(ТекстВыбранныхПолей, Символы.ПС, " ");
		ТекстВыбранныхПолей = СтрЗаменить(ТекстВыбранныхПолей, Символы.Таб, " ");
		Для Каждого ОператорЗапроса Из МассивОператоровЗапроса Цикл
			ТекстВыбранныхПолей = СтрЗаменить(ТекстВыбранныхПолей, ОператорЗапроса, " ");
		КонецЦикла;
		
		ТекстВыбранныхПолей = СокрЛП(ТекстВыбранныхПолей);
		
		МассивВыбранныхПолей = СтрРазделить(ТекстВыбранныхПолей, ",");
		Для Каждого ВыбранноеПоле Из МассивВыбранныхПолей Цикл
			
			// Проверяем, что указан псевдоним поля.
			РезультатПоискаТекстКак = СтрНайтиПоМассиву(ВРег(ВыбранноеПоле), МассивТекстКак,,, Истина);
			Если НЕ РезультатПоискаТекстКак.Успешно Тогда
				Продолжить;
			КонецЕсли;
			
			ПозицияКак = РезультатПоискаТекстКак.Позиция;
			СтрДлинаТекстКак = СтрДлина(РезультатПоискаТекстКак.НайденныйЭлемент);
			
			// Получаем псевдоним поля.
			ПсевдонимПоля = Сред(ВыбранноеПоле, ПозицияКак + СтрДлинаТекстКак);
			ПсевдонимПоля = СокрЛП(ПсевдонимПоля);
			
			// Если псевдоним совпадает с именем выбираемого поля, то пропускаем, т.к. поле не разыменовано.
			// Платформа при пустом заголовке колонки таблицы на форме подставит необходимое имя из синонима реквизита (поля).
			ВыбранноеПолеДоПсевдонима = Лев(ВыбранноеПоле, ПозицияКак - 1);
			ВыбранноеПолеДоПсевдонима = СокрП(ВыбранноеПолеДоПсевдонима);
			Если СтрЗаканчиваетсяНа(ВРег(ВыбранноеПолеДоПсевдонима), "." + ВРег(ПсевдонимПоля)) Тогда
				Продолжить;
			КонецЕсли;
			
			Если МассивРазыменованныхПолей.Найти(ПсевдонимПоля) = Неопределено Тогда
				МассивРазыменованныхПолей.Добавить(ПсевдонимПоля);
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат МассивРазыменованныхПолей;
	
КонецФункции

#Область ЛокализацияДинамическихСписковXML

Функция ПолучитьТекстЗапросаРеквизитаДинамическийСписок(ДокументDOM, ЭлементDOMРеквизит)
	
	ВыражениеПолученияЗапроса = "xmlns:Settings/xmlns:QueryText";
	
	ТекстЗапроса = ПолучитьЗначениеЭлементаDOMПоВыражениюXPath(ВыражениеПолученияЗапроса, ДокументDOM, ЭлементDOMРеквизит);
	Если ПустаяСтрока(ТекстЗапроса) Тогда
		Возврат "";
	КонецЕсли;
	
	Если СтрНайти(ТекстЗапроса, "//") > 0 Тогда
		ТекстЗапроса = ПолучитьТекстМодуляБезКомментариев(ТекстЗапроса);
	КонецЕсли;
	
	Возврат ТекстЗапроса;
	
КонецФункции

// Заполняет заголовки колонок таблицы формы, связанной с реквизитом формы типа "ДинамическийСписок".
// Заголовки заполняются путем преобразования наименования колонки (добавляются пробелы
// и первые буквы слов переводятся в нижний регистр).
// Заполняются заголовки только тех колонок, которые связаны с составными полями запроса динамического списка.
// Поле считается НЕ составным, если оно выбирается по шаблону "Таблица.Поле1.Поле2...",
// все остальные поля считаются составными (комбинация других полей, "ВЫБОР...КОГДА...ТОГДА" и др.).
//
Функция ЗаполнитьЗаголовкиПолейДинамическогоСписка(ДокументDOM)
	
	ФормаИзменена = Ложь;
	
	ВыражениеПоискаПоТипуШаблон = "//xmlns:Attributes/xmlns:Attribute/xmlns:Type/v8:Type[text()='%1']";
	ВыражениеПоискаПоПутиКДаннымШаблон = "//xmlns:ChildItems/*/xmlns:DataPath[text()='%1']";
	
	МассивТиповДинамическийСписок = Новый Массив;
	МассивТиповДинамическийСписок.Добавить("cfg:DynamicList");
	МассивТиповДинамическийСписок.Добавить("dl:DynamicList");
	
	Для Каждого ТипДинамическийСписок Из МассивТиповДинамическийСписок Цикл
		
		ВыражениеПоискаПоТипу = СтрШаблон(ВыражениеПоискаПоТипуШаблон, ТипДинамическийСписок);
		РезультатXPath = ВычислитьВыражениеXPath(ВыражениеПоискаПоТипу, ДокументDOM);
		Пока Истина Цикл
			
			ЭлементDOMv8Type = РезультатXPath.ПолучитьСледующий();
			Если ЭлементDOMv8Type = Неопределено Тогда
				Прервать;
			КонецЕсли;
			
			ЭлементDOMType = ЭлементDOMv8Type.РодительскийУзел;
			Если ЭлементDOMType = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			ЭлементDOMРеквизит = ЭлементDOMType.РодительскийУзел;
			Если ЭлементDOMРеквизит = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			ИмяРеквизита = ПолучитьИмяЭлемента(ДокументDOM, ЭлементDOMРеквизит);
			Если ПустаяСтрока(ИмяРеквизита) Тогда
				Продолжить;
			КонецЕсли;
			
			// Получаем текст запроса динамического списка.
			ТекстЗапроса = ПолучитьТекстЗапросаРеквизитаДинамическийСписок(ДокументDOM, ЭлементDOMРеквизит);
			Если ПустаяСтрока(ТекстЗапроса) Тогда
				// Пропускаем динамический список с пустым запросом.
				Продолжить;
			КонецЕсли;
			
			МассивРазыменованныхПолей = ПолучитьПсевдонимыРазыменованныхПолейТекстаЗапроса(ТекстЗапроса);
			Если МассивРазыменованныхПолей.Количество() = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			Для Каждого РазыменованноеПоле Из МассивРазыменованныхПолей Цикл
				
				// Наименование колонки таблицы будет состоять из имени реквизита и псевдонима.
				ПутьКДанным = ИмяРеквизита + "." + РазыменованноеПоле;
				
				// Ищем по пути к данным псевдоним поля в колонках таблицы, связанной с реквизитом динамического списка.
				ВыражениеПоискаПоПутиКДанным = СтрШаблон(ВыражениеПоискаПоПутиКДаннымШаблон, ПутьКДанным);
				РезультатПоискаПоПутиКДанным = ВычислитьВыражениеXPath(ВыражениеПоискаПоПутиКДанным, ДокументDOM);
				Пока Истина Цикл
					
					ЭлементDOMПутьКДанным = РезультатПоискаПоПутиКДанным.ПолучитьСледующий();
					Если ЭлементDOMПутьКДанным = Неопределено Тогда
						Прервать;
					КонецЕсли;
					
					ЭлементDOMПоле = ЭлементDOMПутьКДанным.РодительскийУзел;
					Если ЭлементDOMПоле = Неопределено Тогда
						Продолжить;
					КонецЕсли;
					
					ЗаголовокПоля = ПолучитьЗаголовокЭлемента(ДокументDOM, ЭлементDOMПоле);
					Если НЕ ПустаяСтрока(ЗаголовокПоля) Тогда
						Продолжить;
					КонецЕсли;
					
					ИмяПоля = ПолучитьИмяЭлемента(ДокументDOM, ЭлементDOMПоле);
					Если ПустаяСтрока(ИмяПоля) Тогда
						Продолжить;
					КонецЕсли;
					
					НовыйЗаголовокПоля = ПолучитьЗаголовокПоИмениЭлементаФормы(ИмяПоля);
					УстановитьЗаголовокЭлемента(ДокументDOM, ЭлементDOMПоле, НовыйЗаголовокПоля, КодОсновногоЯзыка);
					
					ФормаИзменена = Истина;
					
				КонецЦикла;
				
			КонецЦикла;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ФормаИзменена;
	
КонецФункции

#КонецОбласти

#Область ЛокализацияДинамическихСписковEDT

Функция ПолучитьТекстЗапросаРеквизитаДинамическийСписокEDT(ДокументDOM, ЭлементDOMРеквизит)
	
	ВыражениеПолученияЗапроса = "extInfo/queryText";
	
	ТекстЗапроса = ПолучитьЗначениеЭлементаDOMПоВыражениюXPath(ВыражениеПолученияЗапроса, ДокументDOM, ЭлементDOMРеквизит);
	Если ПустаяСтрока(ТекстЗапроса) Тогда
		Возврат "";
	КонецЕсли;
	
	Если СтрНайти(ТекстЗапроса, "//") > 0 Тогда
		ТекстЗапроса = ПолучитьТекстМодуляБезКомментариев(ТекстЗапроса);
	КонецЕсли;
	
	Возврат ТекстЗапроса;
	
КонецФункции

// Заполняет заголовки колонок таблицы формы, связанной с реквизитом формы типа "ДинамическийСписок".
// Заголовки заполняются путем преобразования наименования колонки (добавляются пробелы
// и первые буквы слов переводятся в нижний регистр).
// Заполняются заголовки только тех колонок, которые связаны с составными полями запроса динамического списка.
// Поле считается НЕ составным, если оно выбирается по шаблону "Таблица.Поле1.Поле2...",
// все остальные поля считаются составными (комбинация других полей, "ВЫБОР...КОГДА...ТОГДА" и др.).
//
Функция ЗаполнитьЗаголовкиПолейДинамическогоСпискаEDT(ДокументDOM)
	
	ФормаИзменена = Ложь;
	
	ВыражениеПоискаПоТипу = "//attributes/valueType/types[text()='DynamicList']";
	ВыражениеПоискаПоПутиКДаннымШаблон = "//items/dataPath/paths/segments[text()='%1']";
	
	РезультатXPath = ВычислитьВыражениеXPath(ВыражениеПоискаПоТипу, ДокументDOM);
	Пока Истина Цикл
		
		ЭлементDOMv8Type = РезультатXPath.ПолучитьСледующий();
		Если ЭлементDOMv8Type = Неопределено Тогда
			Прервать;
		КонецЕсли;
		
		ЭлементDOMType = ЭлементDOMv8Type.РодительскийУзел;
		Если ЭлементDOMType = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ЭлементDOMРеквизит = ЭлементDOMType.РодительскийУзел;
		Если ЭлементDOMРеквизит = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ИмяРеквизита = ПолучитьИмяЭлементаEDT(ДокументDOM, ЭлементDOMРеквизит);
		Если ПустаяСтрока(ИмяРеквизита) Тогда
			Продолжить;
		КонецЕсли;
		
		// Получаем текст запроса динамического списка.
		ТекстЗапроса = ПолучитьТекстЗапросаРеквизитаДинамическийСписокEDT(ДокументDOM, ЭлементDOMРеквизит);
		Если ПустаяСтрока(ТекстЗапроса) Тогда
			// Пропускаем динамический список с пустым запросом.
			Продолжить;
		КонецЕсли;
		
		МассивРазыменованныхПолей = ПолучитьПсевдонимыРазыменованныхПолейТекстаЗапроса(ТекстЗапроса);
		Если МассивРазыменованныхПолей.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Для Каждого РазыменованноеПоле Из МассивРазыменованныхПолей Цикл
			
			// Наименование колонки таблицы будет состоять из имени реквизита и псевдонима.
			ПутьКДанным = ИмяРеквизита + "." + РазыменованноеПоле;
			
			// Ищем по пути к данным псевдоним поля в колонках таблицы, связанной с реквизитом динамического списка.
			ВыражениеПоискаПоПутиКДанным = СтрШаблон(ВыражениеПоискаПоПутиКДаннымШаблон, ПутьКДанным);
			РезультатПоискаПоПутиКДанным = ВычислитьВыражениеXPath(ВыражениеПоискаПоПутиКДанным, ДокументDOM);
			Пока Истина Цикл
				
				ЭлементDOMПутьКДанным = РезультатПоискаПоПутиКДанным.ПолучитьСледующий();
				Если ЭлементDOMПутьКДанным = Неопределено Тогда
					Прервать;
				КонецЕсли;
				
				ЭлементDOMdataPath = ЭлементDOMПутьКДанным.РодительскийУзел;
				Если ЭлементDOMdataPath = Неопределено Тогда
					Прервать;
				КонецЕсли;
				
				ЭлементDOMПоле = ЭлементDOMdataPath.РодительскийУзел;
				Если ЭлементDOMПоле = Неопределено Тогда
					Продолжить;
				КонецЕсли;
				
				ЗаголовокПоля = ПолучитьЗаголовокЭлементаEDT(ДокументDOM, ЭлементDOMПоле, КодОсновногоЯзыка);
				Если НЕ ПустаяСтрока(ЗаголовокПоля) Тогда
					Продолжить;
				КонецЕсли;
				
				ИмяПоля = ПолучитьИмяЭлементаEDT(ДокументDOM, ЭлементDOMПоле);
				Если ПустаяСтрока(ИмяПоля) Тогда
					Продолжить;
				КонецЕсли;
				
				НовыйЗаголовокПоля = ПолучитьЗаголовокПоИмениЭлементаФормы(ИмяПоля);
				УстановитьЗаголовокЭлементаEDT(ДокументDOM, ЭлементDOMПоле, НовыйЗаголовокПоля, КодОсновногоЯзыка);
				
				ФормаИзменена = Истина;
				
			КонецЦикла;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ФормаИзменена;
	
КонецФункции

#КонецОбласти

#КонецОбласти

#Область ЛокализацияСКД

Функция ЗаполнитьСинонимыДляВычисляемыхПолей(ДокументDOM, СтрокаПоискаПолейСКД)
	
	ФормаИзменена = Ложь;
	
	РезультатXPath = ВычислитьВыражениеXPath(СтрокаПоискаПолейСКД.ВыражениеПоискаПоТипу, ДокументDOM);
	Если РезультатXPath = Неопределено Тогда
		Возврат ФормаИзменена;
	КонецЕсли;
	
	Пока Истина Цикл
		
		ЭлементDOMv8Type = РезультатXPath.ПолучитьСледующий();
		Если ЭлементDOMv8Type = Неопределено Тогда
			Прервать;
		КонецЕсли;
		
		// Проверим наличие заголовка у элемента.
		Если СтрокаПоискаПолейСКД.ИспользоватьФорматированиеДляXML Тогда
			ЗаголовокРеквизита = ПолучитьЗаголовокПоляСКД(ДокументDOM, ЭлементDOMv8Type, СтрокаПоискаПолейСКД.ПрефиксТипа, КодОсновногоЯзыка);
		Иначе
			Если СтрокаПоискаПолейСКД.ФорматированиеПоляДляСКД Тогда
				ЗаголовокРеквизита = ПолучитьЗаголовокПоляСКД(ДокументDOM, ЭлементDOMv8Type, СтрокаПоискаПолейСКД.ПрефиксТипа, КодОсновногоЯзыка);
			Иначе
				ЗаголовокРеквизита = ПолучитьЗаголовокПоляДинамическогоСпискаEDT(ДокументDOM, ЭлементDOMv8Type, КодОсновногоЯзыка);
			КонецЕсли;
		КонецЕсли;
		
		Если НЕ ПустаяСтрока(ЗаголовокРеквизита) Тогда
			// Если есть заголовок у реквизита, то нет необходимости его добавлять.
			Продолжить;
		КонецЕсли;
		
		// Получим имя реквизита.
		ПрефиксТипа = ?(СтрокаПоискаПолейСКД.ПрефиксТипа = "", "", СтрШаблон("%1:", СтрокаПоискаПолейСКД.ПрефиксТипа));
		ИмяРеквизита = ПолучитьЗначениеЭлементаDOMПоВыражениюXPath(СтрШаблон("%1field", ПрефиксТипа), ДокументDOM, ЭлементDOMv8Type);
		Если ПустаяСтрока(ИмяРеквизита) Тогда
			Продолжить;
		КонецЕсли;
		
		ЭлементDOMРеквизит = ЭлементDOMv8Type.РодительскийУзел;
		Если ЭлементDOMРеквизит = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ТекстЗапроса = ПолучитьЗначениеЭлементаDOMПоВыражениюXPath(СтрокаПоискаПолейСКД.УзелТекстаЗапроса, ДокументDOM, ЭлементDOMРеквизит);
		Если ПустаяСтрока(ТекстЗапроса) Тогда
			Продолжить;
		КонецЕсли;
		
		Если СтрНайти(ТекстЗапроса, "//") > 0 Тогда
			ТекстЗапроса = ПолучитьТекстМодуляБезКомментариев(ТекстЗапроса);
		КонецЕсли;
		
		ТекстЗапроса = ПолучитьТекстЗапросаБезВложенныхТаблиц(ТекстЗапроса);
		МассивРазыменованныхПолей = ПолучитьПсевдонимыРазыменованныхПолейТекстаЗапроса(ТекстЗапроса);
		Если МассивРазыменованныхПолей.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		// Проверим, есть ли проверяемое поле в списке разыменованных полей.
		Если МассивРазыменованныхПолей.Найти(ИмяРеквизита) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		// Генерируем новый заголовок для элемента.
		ЗаголовокРеквизита = ПолучитьЗаголовокПоИмениЭлементаФормы(ИмяРеквизита);
		Если СтрокаПоискаПолейСКД.ИспользоватьФорматированиеДляXML Тогда
			УстановитьЗаголовокПоляСКД(ДокументDOM, ЭлементDOMv8Type, ЗаголовокРеквизита, СтрокаПоискаПолейСКД.ПрефиксТипа, КодОсновногоЯзыка);
		Иначе
			Если СтрокаПоискаПолейСКД.ФорматированиеПоляДляСКД Тогда
				УстановитьЗаголовокПоляСКД(ДокументDOM, ЭлементDOMv8Type, ЗаголовокРеквизита, СтрокаПоискаПолейСКД.ПрефиксТипа, КодОсновногоЯзыка);
			Иначе
				УстановитьЗаголовокПоляДинамическогоСпискаEDT(ДокументDOM, ЭлементDOMv8Type, ЗаголовокРеквизита, КодОсновногоЯзыка);
			КонецЕсли;
		КонецЕсли;
		
		ФормаИзменена = Истина;
		
	КонецЦикла;
	
	Возврат ФормаИзменена;
	
КонецФункции

Функция ПолучитьТекстЗапросаБезВложенныхТаблиц(Знач ТекстЗапроса)
	
	ТекстОткрытияВложеннойТаблицы = ".(";
	ТекстЗакрытияВложеннойТаблицы = ")";
	
	ПозицияОткрытияВложеннойТаблицы = 0;
	ПозицияЗакрытияВложеннойТаблицы = 0;
	Пока Истина Цикл
		
		ПозицияОткрытияВложеннойТаблицы = СтрНайти(ТекстЗапроса, ТекстОткрытияВложеннойТаблицы,, ПозицияОткрытияВложеннойТаблицы + 1);
		Если ПозицияОткрытияВложеннойТаблицы = 0 Тогда
			Прервать;
		КонецЕсли;
		
		ПозицияЗакрытияВложеннойТаблицы = СтрНайти(ТекстЗапроса, ТекстЗакрытияВложеннойТаблицы,, ПозицияОткрытияВложеннойТаблицы + 1);
		Если ПозицияЗакрытияВложеннойТаблицы = 0 Тогда
			ПозицияЗакрытияВложеннойТаблицы = СтрДлина(ТекстЗапроса);
		КонецЕсли;
		
		ТекстЗапросаДоВложеннойТаблицы = Лев(ТекстЗапроса, ПозицияОткрытияВложеннойТаблицы - 1);
		ТекстЗапросаПослеВложеннойТаблицы = Сред(ТекстЗапроса, ПозицияЗакрытияВложеннойТаблицы + 1);
		ТекстЗапроса = ТекстЗапросаДоВложеннойТаблицы + ТекстЗапросаПослеВложеннойТаблицы;
		
	КонецЦикла;
	
	Возврат ТекстЗапроса;
	
КонецФункции

#КонецОбласти

#Область ЛокализацияЭлементовФорм

// Генерирует заголовок ЭФ из наименования по заглавным буквам.
// 
// Если в параметр "ЗаменитьАвтогенерируемыеЗаголовки" передано значение "Истина",
// то удаляются некоторые слова ("Группа", "Список" и т.д.), например:
//     СписокСотрудник - Сотрудник
//     ГруппаПодвал - Подвал
//     ГруппаОбластьОтображения - Область отображения
// 
// Исключения из удаления описаны в параметре ТаблицаИсключенийЗаголовковЭлементовФорм:
//     ГруппаПользовательскихНастроек -> Группа пользовательских настроек.
// 
// Если в параметр "ЗаменитьАвтогенерируемыеЗаголовки" передано значение "Ложь",
// то заголовок будет сгенерирован со словами "Группа", "Список" и т.д.
//     СписокСотрудник - Список сотрудник
//     ГруппаПодвал - Группа подвал
//     ГруппаОбластьОтображения - Группа область отображения
// 
// Для автоматически нумерованных групп, например, "Группа6", числовая нумерация будет удалена - вернется значение "Группа".
// 
// Учитывает случай аббревиатур и однобуквенных местоимений, например:
//     КодОКАТО -> Код ОКАТО;
//     ФНСРоссии -> ФНС России;
//     ЗаписатьИЗакрыть -> Записать и закрыть
// 
// Поддерживает частный случай, описанный в стандарте:
//     ГруппаШапка -> Шапка.
//
Функция ПолучитьЗаголовокПоИмениЭлементаФормы(Знач ИмяЭлементаФормы, ТаблицаИсключенийЗаголовковЭлементовФорм = Неопределено)
	
	Если ТаблицаИсключенийЗаголовковЭлементовФорм <> Неопределено Тогда
		СтрокаИсключения = ТаблицаИсключенийЗаголовковЭлементовФорм.Найти(ИмяЭлементаФормы, "Наименование");
		Если СтрокаИсключения <> Неопределено Тогда
			Возврат СтрокаИсключения.Заголовок;
		КонецЕсли;
	КонецЕсли;
	
	ИмяЭлементаФормы = СокрЛП(ИмяЭлементаФормы);
	ИмяЭлементаФормыИсходное = ИмяЭлементаФормы;
	
	Если СтрДлина(ИмяЭлементаФормы) <= 1 Тогда
		Возврат ИмяЭлементаФормы;
	КонецЕсли;
	
	МассивУдаляемыхСловИзЗаголовка = Новый Массив;
	МассивУдаляемыхСловИзЗаголовка.Добавить("Группа");
	МассивУдаляемыхСловИзЗаголовка.Добавить("Group");
	МассивУдаляемыхСловИзЗаголовка.Добавить("Список");
	МассивУдаляемыхСловИзЗаголовка.Добавить("List");
	
	СтруктураПоискаУдаляемыхСлов = СтрНачинаетсяСПоМассиву(ИмяЭлементаФормы, МассивУдаляемыхСловИзЗаголовка);
	Если СтруктураПоискаУдаляемыхСлов.Успешно Тогда
		
		// Имя элемента начинается со слова "Группа" или "Список".
		// Получаем имя элемента формы без найденного слова.
		НайденныйЭлемент = СтруктураПоискаУдаляемыхСлов.НайденныйЭлемент;
		ИмяЭлементаФормы = Сред(ИмяЭлементаФормы, СтрДлина(НайденныйЭлемент) + 1);
		
		// Заголовок состоит только из слова "Группа" или "Список".
		Если ПустаяСтрока(ИмяЭлементаФормы) Тогда
			Возврат ИмяЭлементаФормыИсходное;
		КонецЕсли;
		
		Если апк_ЭтоЧисло(ИмяЭлементаФормы) Тогда
			// После найденного слова в заголовке только числовой постфикс, оставляем имя элемента без него.
			ИмяЭлементаФормы = НайденныйЭлемент;
		КонецЕсли;
		
	КонецЕсли;
	
	Заголовок = "";
	КоличествоСимволов = СтрДлина(ИмяЭлементаФормы);
	
	Для НомерСимвола = 1 По КоличествоСимволов Цикл
		
		ТекущийСимвол = Сред(ИмяЭлементаФормы, НомерСимвола, 1);
		
		Если ТекущийСимвол = "_" Тогда
			Заголовок = Заголовок + " ";
		ИначеЕсли ВРег(ТекущийСимвол) = ТекущийСимвол Тогда
			Заголовок = Заголовок + " " + ТекущийСимвол;
		Иначе
			Заголовок = Заголовок + ТекущийСимвол;
		КонецЕсли;
		
	КонецЦикла;
	
	Если ПустаяСтрока(Заголовок) Тогда
		Возврат "";
	КонецЕсли;
	
	МассивСлов = СтрРазделить(Заголовок, " ", Ложь);
	НомерПоследнегоСлова = МассивСлов.ВГраница();
	
	Заголовок = МассивСлов[0];
	
	ПредыдущееСлово = Заголовок;
	Для НомерСлова = 1 По НомерПоследнегоСлова Цикл
		
		ТекущееСлово = МассивСлов[НомерСлова];
		
		// Если длина слова больше 1 символа, то добавляем слово с пробелом и продолжаем.
		Если СтрДлина(ТекущееСлово) > 1 Тогда
			Заголовок = Заголовок + " " + НРег(ТекущееСлово);
			Продолжить;
		КонецЕсли;
		
		// Текущее слово состоит из 1 символа, проверяем предыдущее и следующее слово.
		// Если предыдущее слово также состояло из 1 символа, то началась аббревиатура.
		Если СтрДлина(МассивСлов[НомерСлова - 1]) = 1 Тогда
			Заголовок = Заголовок + ТекущееСлово;
			Продолжить;
		КонецЕсли;
		
		// Если это слово последнее, то добавим текущее с пробелом и с маленькой буквы.
		Если НомерСлова >= НомерПоследнегоСлова Тогда
			Заголовок = Заголовок + " " + НРег(ТекущееСлово);
			Продолжить;
		КонецЕсли;
		
		// Если следующее слово также из одного символа, то аббревиатура продолжается.
		Если СтрДлина(МассивСлов[НомерСлова + 1]) = 1 Тогда
			Заголовок = Заголовок + " " + ТекущееСлово;
			Продолжить;
		КонецЕсли;
		
		// Если предыдущее и следующее слово длиннее 1 символа, то текущее слово - союз или предлог.
		Заголовок = Заголовок + " " + НРег(ТекущееСлово);
		
	КонецЦикла;
	
	Заголовок = СокрЛП(Заголовок);
	Заголовок = ВРег(Лев(Заголовок, 1)) + Сред(Заголовок, 2);
	
	Возврат Заголовок;
	
КонецФункции

#Область ЛокализацияЭлементовФормXML

// Удаляет подсказки для элементов форм с типом "Группа", у которых они совпадают с синонимом или образованы из имени.
//
Функция ОчиститьПодсказкиГруппФормы(ДокументDOM)
	
	ФормаИзменена = Ложь;
	
	МассивТиповЭлементовФормы = Новый Массив;
	МассивТиповЭлементовФормы.Добавить("UsualGroup");
	МассивТиповЭлементовФормы.Добавить("Pages");
	МассивТиповЭлементовФормы.Добавить("Page");
	МассивТиповЭлементовФормы.Добавить("CommandBar");
	МассивТиповЭлементовФормы.Добавить("ColumnGroup");
	МассивТиповЭлементовФормы.Добавить("Popup");
	МассивТиповЭлементовФормы.Добавить("ButtonGroup");
	
	ВыражениеПоискаПоТипуЭлементаШаблон = "//xmlns:ChildItems/xmlns:%1";
	
	Для Каждого ТипЭлементаФормы Из МассивТиповЭлементовФормы Цикл
		
		ВыражениеПоискаПоТипуЭлемента = СтрШаблон(ВыражениеПоискаПоТипуЭлементаШаблон, ТипЭлементаФормы);
		РезультатXPath = ВычислитьВыражениеXPath(ВыражениеПоискаПоТипуЭлемента, ДокументDOM);
		Пока Истина Цикл
			
			ЭлементDOMЭлементаФормы = РезультатXPath.ПолучитьСледующий();
			Если ЭлементDOMЭлементаФормы = Неопределено Тогда
				Прервать;
			КонецЕсли;
			
			ПодсказкаЭлементаФормы = ПолучитьПодсказкуЭлемента(ДокументDOM, ЭлементDOMЭлементаФормы);
			Если ПустаяСтрока(ПодсказкаЭлементаФормы) Тогда
				Продолжить;
			КонецЕсли;
			
			ЗаголовокЭлементаФормы = ПолучитьЗаголовокЭлемента(ДокументDOM, ЭлементDOMЭлементаФормы,, КодОсновногоЯзыка);
			ИмяЭлементаФормы = ПолучитьИмяЭлемента(ДокументDOM, ЭлементDOMЭлементаФормы);
			
			ПодсказкаЭлементаФормы = ПреобразоватьТекстДляСравнения(ПодсказкаЭлементаФормы, "Группа");
			ЗаголовокЭлементаФормы = ПреобразоватьТекстДляСравнения(ЗаголовокЭлементаФормы, "Группа");
			ИмяЭлементаФормы = ПреобразоватьТекстДляСравнения(ИмяЭлементаФормы, "Группа");
			
			Если (ПодсказкаЭлементаФормы = ЗаголовокЭлементаФормы)
			 ИЛИ (ПодсказкаЭлементаФормы = ИмяЭлементаФормы) Тогда
				ОчиститьПодсказкуЭлемента(ДокументDOM, ЭлементDOMЭлементаФормы);
				ФормаИзменена = Истина;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ФормаИзменена;
	
КонецФункции

// Устанавливает заголовки для элементов форм с типом "Таблица" и "Группа", у которых заголовок не заполнен.
// Генерацию заголовков производит из наименования элемента формы по заглавным буквам.
//
Функция ЗаполнитьЗаголовкиТаблицИГруппФормыXML(ДокументDOM, ТаблицаИсключенийЗаголовковЭлементовФорм,
	ТаблицаТиповЭлементовФормы)
	
	ФормаИзменена = Ложь;
	
	ВыражениеПоискаПоТипуЭлементаШаблон = "//xmlns:ChildItems/xmlns:%1";
	
	МассивПоискаТЧ = Контекст["МассивВыраженийПоискаТабличныхЧастейXML"];
	ТаблицаСинонимовТабличныхЧастей = ПолучитьТаблицуСинонимовТабличныхЧастейXML(ДокументDOM, МассивПоискаТЧ);
	
	Для Каждого СтрокаТаблицы Из ТаблицаТиповЭлементовФормы Цикл
		
		ТипЭлементаФормы = СтрокаТаблицы.ИмяЭлемента;
		
		ВыражениеПоискаПоТипуЭлемента = СтрШаблон(ВыражениеПоискаПоТипуЭлементаШаблон, ТипЭлементаФормы);
		РезультатXPath = ВычислитьВыражениеXPath(ВыражениеПоискаПоТипуЭлемента, ДокументDOM);
		Пока Истина Цикл
			
			ЭлементDOMЭлементаФормы = РезультатXPath.ПолучитьСледующий();
			Если ЭлементDOMЭлементаФормы = Неопределено Тогда
				Прервать;
			КонецЕсли;
			
			// Очищаем заголовок таблицы, если она связана с табличной частью и заголовок таблицы совпадает с синонимом ТЧ.
			Если СтрСравнить(ТипЭлементаФормы, "Table") = 0 Тогда
				Если ОчиститьЗаголовокТаблицыФормыXML(ДокументDOM, ЭлементDOMЭлементаФормы, ТаблицаСинонимовТабличныхЧастей) Тогда
					ФормаИзменена = Истина;
				КонецЕсли;
				
				// Положение заголовка не меняем, поэтому переходим к следующему элементу формы.
				Продолжить;
			КонецЕсли;
			
			ИмяЭлементаФормы = ПолучитьИмяЭлемента(ДокументDOM, ЭлементDOMЭлементаФормы);
			ЗаголовокЭлементаФормы = ПолучитьЗаголовокЭлемента(ДокументDOM, ЭлементDOMЭлементаФормы);
			
			// Пропускаем элементы, у которых заголовок заполнен и установлен вручную, а не сгенерирован автоматически:
			// ГруппаСуммаОплаты -> Группа сумма оплаты (в данном случае необходимо установить заголовок "Сумма оплаты").
			ИмяДляСравнения = ПреобразоватьТекстДляСравнения(ИмяЭлементаФормы);
			ЗаголовокДляСравнения = СтрЗаменить(ЗаголовокЭлементаФормы, " ", "");
			ЗаголовокДляСравнения = ВРег(СокрЛП(ЗаголовокДляСравнения));
			Если (НЕ ПустаяСтрока(ЗаголовокЭлементаФормы)) И (ИмяДляСравнения <> ЗаголовокДляСравнения) Тогда
				Продолжить;
			КонецЕсли;
			
			НовыйЗаголовокЭлементаФормы = ПолучитьЗаголовокПоИмениЭлементаФормы(ИмяЭлементаФормы,
				ТаблицаИсключенийЗаголовковЭлементовФорм);
			
			// Новые пустые заголовки пропускаем.
			// Аналогично пропускаем случаи, когда заголовок не изменился, например, он есть в таблице исключений.
			Если ПустаяСтрока(НовыйЗаголовокЭлементаФормы) ИЛИ (ЗаголовокЭлементаФормы = НовыйЗаголовокЭлементаФормы) Тогда
				Продолжить;
			КонецЕсли;
			
			УстановитьЗаголовокЭлемента(ДокументDOM, ЭлементDOMЭлементаФормы, НовыйЗаголовокЭлементаФормы, КодОсновногоЯзыка);
			
			// Для обычных групп и групп с типом "страница" устанавливаем свойство "ОтображатьЗаголовок" = Ложь.
			Если СтрокаТаблицы.ОчищатьФлагОтображатьЗаголовок Тогда
				
				// Обрабатываем только обычные группы с обычным поведением и группу с типом "страница".
				ЭлементDOMПоведение = ПолучитьЭлементDOMПоВыражениюXPath("xmlns:Behavior", ДокументDOM, ЭлементDOMЭлементаФормы);
				Если (ЭлементDOMПоведение = Неопределено)
				 ИЛИ (СтрСравнить(ЭлементDOMПоведение.ТекстовоеСодержимое, "Usual") = 0) Тогда
					УстановитьОтображатьЗаголовокЭлементаФормы(ДокументDOM, ЭлементDOMЭлементаФормы);
				КонецЕсли;
				
			ИначеЕсли СтрСравнить(ТипЭлементаФормы, "Table") = 0 Тогда
				// Установим свойство "ПоложениеЗаголовка" в значение "Ложь" для таблицы.
				УстановитьПоложениеЗаголовкаДляЭлементаФормы(ДокументDOM, ЭлементDOMЭлементаФормы);
			КонецЕсли;
			
			ФормаИзменена = Истина;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ФормаИзменена;
	
КонецФункции

Функция ПолучитьТаблицуСинонимовТабличныхЧастейXML(ДокументDOM, МассивВыраженийПоискаТЧ)
	
	ТаблицаСинонимовТабличныхЧастей = Новый ТаблицаЗначений;
	ТаблицаСинонимовТабличныхЧастей.Колонки.Добавить("Имя");
	ТаблицаСинонимовТабличныхЧастей.Колонки.Добавить("КодЯзыка");
	ТаблицаСинонимовТабличныхЧастей.Колонки.Добавить("Синоним");
	
	ДокументDOMРодитель = ПолучитьДокументDOMРодителяОбъекта(ДокументDOM);
	
	Если ДокументDOMРодитель = Неопределено Тогда
		Возврат ТаблицаСинонимовТабличныхЧастей;
	КонецЕсли;
	
	ИмяТабличнойЧасти = "";
	
	СоответствиеИменСтандартныхТабличныхЧастей = Контекст["СоответствиеИменСтандартныхТабличныхЧастей"];
	
	// Получаем элементы объекта.
	МассивЭлементовDOMОбъекта = ПолучитьЭлементыDOMОбъектаПоВыражениюПоиска(ДокументDOMРодитель, МассивВыраженийПоискаТЧ);
	
	// Каждую найденную табличную часть добавляем в таблицу синонимов.
	Для Каждого ЭлементDOMОбъекта Из МассивЭлементовDOMОбъекта Цикл
		
		// Получаем имя табличной части.
		ИмяТабличнойЧасти = ПолучитьЗначениеЭлементаDOMПоВыражениюXPath("xmlns:Name", ДокументDOMРодитель, ЭлементDOMОбъекта);
		
		// Для стандартных табличных частей особое поведение - нужно смотреть атрибут в ЭлементDOMОбъекта
		Если ПустаяСтрока(ИмяТабличнойЧасти) Тогда
			Если НЕ ЭлементDOMОбъекта.ЕстьАтрибуты() Тогда
				Продолжить;
			КонецЕсли;
			
			АтрибутDOMИмяУзла = ЭлементDOMОбъекта.Атрибуты.ПолучитьИменованныйЭлемент("name");
			Если АтрибутDOMИмяУзла = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			ИмяТабличнойЧасти = СоответствиеИменСтандартныхТабличныхЧастей[АтрибутDOMИмяУзла.ТекстовоеСодержимое];
			
			Если ПустаяСтрока(ИмяТабличнойЧасти) Тогда
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		
		ЭлементDOMСиноним = ПолучитьЭлементDOMПоВыражениюXPath("xmlns:Synonym", ДокументDOMРодитель, ЭлементDOMОбъекта);
		
		Если ЭлементDOMСиноним = Неопределено Тогда
			// Для стандартных табличных частей особое поведение.
			ЭлементDOMСиноним = ПолучитьЭлементDOMПоВыражениюXPath("xr:Synonym", ДокументDOMРодитель, ЭлементDOMОбъекта);
			Если ЭлементDOMСиноним = Неопределено Тогда
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		
		// Получаем код языка и синоним для каждого языка.
		Для Каждого ДочернийЭлементDOM Из ЭлементDOMСиноним.ДочерниеУзлы Цикл
			
			КодЯзыка = ПолучитьЗначениеЭлементаDOMПоВыражениюXPath("v8:lang", ДокументDOMРодитель, ДочернийЭлементDOM);
			Если ПустаяСтрока(КодЯзыка) Тогда
				Прервать;
			КонецЕсли;
			
			Синоним = ПолучитьЗначениеЭлементаDOMПоВыражениюXPath("v8:content", ДокументDOMРодитель, ДочернийЭлементDOM);
			Если ПустаяСтрока(КодЯзыка) Тогда
				Прервать;
			КонецЕсли;
			
			НоваяСтрокаТаблицыСинонимов = ТаблицаСинонимовТабличныхЧастей.Добавить();
			НоваяСтрокаТаблицыСинонимов.Имя      = ИмяТабличнойЧасти;
			НоваяСтрокаТаблицыСинонимов.КодЯзыка = КодЯзыка;
			НоваяСтрокаТаблицыСинонимов.Синоним  = Синоним;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ТаблицаСинонимовТабличныхЧастей;
	
КонецФункции

Функция ПолучитьТаблицуСинонимовТабличныхЧастейEDT(ДокументDOM, МассивВыраженийПоискаТЧ)
	
	ТаблицаСинонимовТабличныхЧастей = Новый ТаблицаЗначений;
	ТаблицаСинонимовТабличныхЧастей.Колонки.Добавить("Имя");
	ТаблицаСинонимовТабличныхЧастей.Колонки.Добавить("КодЯзыка");
	ТаблицаСинонимовТабличныхЧастей.Колонки.Добавить("Синоним");
	
	ДокументDOMРодитель = ПолучитьДокументDOMРодителяОбъекта(ДокументDOM);
	
	Если ДокументDOMРодитель = Неопределено Тогда
		Возврат ТаблицаСинонимовТабличныхЧастей;
	КонецЕсли;
	
	// Получаем подчиненные элементы.
	МассивЭлементовDOMОбъекта = ПолучитьЭлементыDOMОбъектаПоВыражениюПоиска(ДокументDOMРодитель, МассивВыраженийПоискаТЧ);
	
	ИмяТабличнойЧасти = "";
	
	// Каждую найденную табличную часть добавляем в таблицу синонимов.
	Для Каждого ЭлементDOMОбъекта Из МассивЭлементовDOMОбъекта Цикл
		
		ИмяТабличнойЧасти = ПолучитьЗначениеЭлементаDOMПоВыражениюXPath("name", ДокументDOMРодитель, ЭлементDOMОбъекта);
		Если ПустаяСтрока(ИмяТабличнойЧасти) Тогда
			Продолжить;
		КонецЕсли;
		
		РезультатXPath = ВычислитьВыражениеXPath("synonym", ДокументDOMРодитель, ЭлементDOMОбъекта);
		
		Пока Истина Цикл
			
			ЭлементDOMСиноним = РезультатXPath.ПолучитьСледующий();
			Если ЭлементDOMСиноним = Неопределено Тогда
				Прервать;
			КонецЕсли;
			
			КодЯзыка = ПолучитьЗначениеЭлементаDOMПоВыражениюXPath("key", ДокументDOMРодитель, ЭлементDOMСиноним);
			Если ПустаяСтрока(КодЯзыка) Тогда
				Продолжить;
			КонецЕсли;
			
			Синоним = ПолучитьЗначениеЭлементаDOMПоВыражениюXPath("value", ДокументDOMРодитель, ЭлементDOMСиноним);
			Если ПустаяСтрока(Синоним) Тогда
				Продолжить;
			КонецЕсли;
			
			НоваяСтрокаТаблицыСинонимов = ТаблицаСинонимовТабличныхЧастей.Добавить();
			НоваяСтрокаТаблицыСинонимов.Имя      = ИмяТабличнойЧасти;
			НоваяСтрокаТаблицыСинонимов.КодЯзыка = КодЯзыка;
			НоваяСтрокаТаблицыСинонимов.Синоним  = Синоним;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ТаблицаСинонимовТабличныхЧастей;
	
КонецФункции

Функция ПолучитьДокументDOMРодителяОбъекта(ДокументDOM)
	
	// Получаем путь к файлу формы.
	ПутьКФайлуФормы = СтрЗаменить(ДокументDOM.БазовыйURI, "sfile://", "");
	ПутьКФайлуФормы = СтрЗаменить(ПутьКФайлуФормы, "/", РазделительПути);
	
	НайденнаяСтрокаТаблицыРезультат = Результат.Найти(ПутьКФайлуФормы, "ПолноеИмяФайла");

	
	Если НайденнаяСтрокаТаблицыРезультат = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	// Получаем путь к родителю объекта (формы).
	РодительОбъекта = НайденнаяСтрокаТаблицыРезультат.РодительОбъекта;
	
	Если ПустаяСтрока(РодительОбъекта) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	// Копируем из таблицы Результат строки объектов, соответствующих родителю формы.
	МассивСтрокРодительОбъекта = Результат.НайтиСтроки(Новый Структура("Объект", РодительОбъекта));
	
	// Получим имя файла родителя объекта для отбора.
	МассивТекстРодительОбъекта = СтрРазделить(РодительОбъекта, ".");
	ИмяРодителяОбъекта         = МассивТекстРодительОбъекта[МассивТекстРодительОбъекта.ВГраница()];
	ИмяФайлаРодителяОбъекта    = ИмяРодителяОбъекта + РазделительПути + ?(ЭтоВыгрузкаXMLФайлов(), ".xml", ".mdo");
	
	ПутьКФайлуРодителя = "";
	
	Для Каждого СтрокаРодительОбъекта Из МассивСтрокРодительОбъекта Цикл
		// Получаем путь к файлу родителя формы.
		Если СтрЗаканчиваетсяНа(СтрокаРодительОбъекта.ПолноеИмяФайла, ИмяФайлаРодителяОбъекта) Тогда
			ПутьКФайлуРодителя = СтрокаРодительОбъекта.ПолноеИмяФайла;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если ПустаяСтрока(ПутьКФайлуРодителя) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат ДокументDOM(ПутьКФайлуРодителя);
	
КонецФункции

Функция ПолучитьЭлементыDOMОбъектаПоВыражениюПоиска(ДокументDOM, МассивВыраженийПоиска)
	
	МассивРезультат = Новый Массив;
	
	Для Каждого ВыражениеПоиска Из МассивВыраженийПоиска Цикл
		РезультатXPath = ВычислитьВыражениеXPath(ВыражениеПоиска, ДокументDOM);
		
		Пока Истина Цикл
			
			ЭлементDOMТабличнойЧасти = РезультатXPath.ПолучитьСледующий();
			Если ЭлементDOMТабличнойЧасти = Неопределено Тогда
				Прервать;
			КонецЕсли;
			
			МассивРезультат.Добавить(ЭлементDOMТабличнойЧасти);
			
		КонецЦикла;
	КонецЦикла;
	
	Возврат МассивРезультат;
	
КонецФункции

Функция ОчиститьЗаголовокТаблицыФормыXML(ДокументDOM, ЭлементDOMЭлементаФормы, ТаблицаСинонимовТабличныхЧастей)
	
	// Получаем дочерний элемент DataPath.
	ЭлементDOMПутьКДанным = ПолучитьЭлементDOMПоВыражениюXPath("xmlns:DataPath", ДокументDOM, ЭлементDOMЭлементаФормы);
	
	Если ЭлементDOMПутьКДанным = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ПутьКДанным = ЭлементDOMПутьКДанным.ТекстовоеСодержимое;
	
	МассивТекстОбъект = Контекст["МассивТекстОбъектСТочкой"];
	
	ЭтоТабличнаяЧасть = Ложь;
	
	// Если в пути к данным нет "Объект." - то это не табличная часть, пропускаем.
	Для Каждого ТекстОбъект Из МассивТекстОбъект Цикл
		Если СтрНачинаетсяС(ПутьКДанным, ТекстОбъект) Тогда
			ЭтоТабличнаяЧасть = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если НЕ ЭтоТабличнаяЧасть Тогда
		Возврат Ложь;
	КонецЕсли;
	
	// Получаем имя табличной части без "Объект.".
	ИмяТабличнойЧасти = ПутьКДанным;
	Для Каждого ТекстОбъект Из МассивТекстОбъект Цикл
		ИмяТабличнойЧасти = СтрЗаменить(ИмяТабличнойЧасти, ТекстОбъект, "");
	КонецЦикла;
	
	// Для стандартных табличных частей заменяем имя.
	СоответствиеИменСтандартныхТабличныхЧастей = Контекст["СоответствиеИменСтандартныхТабличныхЧастей"];
	Если СоответствиеИменСтандартныхТабличныхЧастей[ИмяТабличнойЧасти] <> Неопределено Тогда
		ИмяТабличнойЧасти = СоответствиеИменСтандартныхТабличныхЧастей[ИмяТабличнойЧасти];
	КонецЕсли;
	
	// Получаем заголовок.
	ЭлементDOMЗаголовок = ПолучитьЭлементDOMПоВыражениюXPath("xmlns:Title", ДокументDOM, ЭлементDOMЭлементаФормы);
	Если ЭлементDOMЗаголовок = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	МассивЭлементовDOMДляУдаления = Новый Массив;
	
	// Проходимся по дочерним элементам. Каждый из них - заголовок на одном языке.
	Для Каждого ДочернийЭлементDOM Из ЭлементDOMЗаголовок.ДочерниеУзлы Цикл
		
		КодЯзыка       = ПолучитьЗначениеЭлементаDOMПоВыражениюXPath("v8:lang",    ДокументDOM, ДочернийЭлементDOM);
		ТекстЗаголовка = ПолучитьЗначениеЭлементаDOMПоВыражениюXPath("v8:content", ДокументDOM, ДочернийЭлементDOM);
		
		Если ПустаяСтрока(КодЯзыка) ИЛИ ПустаяСтрока(ТекстЗаголовка) Тогда
			Продолжить;
		КонецЕсли;
		
		// Ищем в таблице синонимов ТЧ строки, соответствующие пути к данным, языку и тексту заголовка.
		СтруктураПоиска = Новый Структура;
		СтруктураПоиска.Вставить("Имя",      ИмяТабличнойЧасти);
		СтруктураПоиска.Вставить("КодЯзыка", КодЯзыка);
		СтруктураПоиска.Вставить("Синоним",  ТекстЗаголовка);
		
		// Ищем строки в таблице синонимов.
		НайденныеСтрокиТаблицыСинонимов = ТаблицаСинонимовТабличныхЧастей.НайтиСтроки(СтруктураПоиска);
		
		Если НайденныеСтрокиТаблицыСинонимов.Количество() > 0 Тогда
			МассивЭлементовDOMДляУдаления.Добавить(ДочернийЭлементDOM);
		КонецЕсли;
		
	КонецЦикла;
	
	Если МассивЭлементовDOMДляУдаления.Количество() = 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	// Удаляем заголовки.
	Для Каждого ЭлементDOMДляУдаления Из МассивЭлементовDOMДляУдаления Цикл
		ЭлементDOMЗаголовок.УдалитьДочерний(ЭлементDOMДляУдаления);
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

Функция ОчиститьЗаголовокТаблицыФормыEDT(ДокументDOM, ЭлементDOMЭлементаФормы, ТаблицаСинонимовТабличныхЧастей)
	
	// Получаем дочерний элемент DataPath.
	ЭлементDOMПутьКДанным = ПолучитьЭлементDOMПоВыражениюXPath("dataPath/segments", ДокументDOM, ЭлементDOMЭлементаФормы);
	
	Если ЭлементDOMПутьКДанным = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ПутьКДанным = ЭлементDOMПутьКДанным.ТекстовоеСодержимое;
	
	МассивТекстОбъект = Контекст["МассивТекстОбъектСТочкой"];
	
	ЭтоТабличнаяЧасть = Ложь;
	
	// Если в пути к данным нет "Объект." - то это не табличная часть, пропускаем.
	Для Каждого ТекстОбъект Из МассивТекстОбъект Цикл
		Если СтрНайти(ПутьКДанным, ТекстОбъект) > 0 Тогда
			ЭтоТабличнаяЧасть = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если НЕ ЭтоТабличнаяЧасть Тогда
		Возврат Ложь;
	КонецЕсли;
	
	// Получаем имя табличной части без "Объект.".
	ИмяТабличнойЧасти = ПутьКДанным;
	Для Каждого ТекстОбъект Из МассивТекстОбъект Цикл
		ИмяТабличнойЧасти = СтрЗаменить(ИмяТабличнойЧасти, ТекстОбъект, "");
	КонецЦикла;
	
	МассивЭлементовDOMДляУдаления = Новый Массив;
	
	РезультатXPath = ВычислитьВыражениеXPath("title", ДокументDOM, ЭлементDOMЭлементаФормы);
	
	// Проходимся по дочерним элементам. Каждый из них - заголовок на одном языке.
	Пока Истина Цикл
		
		ЭлементDOMЗаголовок = РезультатXPath.ПолучитьСледующий();
		Если ЭлементDOMЗаголовок = Неопределено Тогда
			Прервать;
		КонецЕсли;
		
		КодЯзыка       = ПолучитьЗначениеЭлементаDOMПоВыражениюXPath("key",   ДокументDOM, ЭлементDOMЗаголовок);
		ТекстЗаголовка = ПолучитьЗначениеЭлементаDOMПоВыражениюXPath("value", ДокументDOM, ЭлементDOMЗаголовок);
		
		Если ПустаяСтрока(КодЯзыка) ИЛИ ПустаяСтрока(ТекстЗаголовка) Тогда
			Продолжить;
		КонецЕсли;
		
		// Ищем в таблице синонимов ТЧ строки, соответствующие пути к данным, языку и тексту заголовка.
		СтруктураПоиска = Новый Структура;
		СтруктураПоиска.Вставить("Имя",      ИмяТабличнойЧасти);
		СтруктураПоиска.Вставить("КодЯзыка", КодЯзыка);
		СтруктураПоиска.Вставить("Синоним",  ТекстЗаголовка);
		
		НайденныеСтрокиТаблицыСинонимов = ТаблицаСинонимовТабличныхЧастей.НайтиСтроки(СтруктураПоиска);
		
		Если НайденныеСтрокиТаблицыСинонимов.Количество() > 0 Тогда
			МассивЭлементовDOMДляУдаления.Добавить(ЭлементDOMЗаголовок);
		КонецЕсли;
		
	КонецЦикла;
	
	Если МассивЭлементовDOMДляУдаления.Количество() = 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	// Удаляем заголовки.
	Для Каждого ЭлементDOMДляУдаления Из МассивЭлементовDOMДляУдаления Цикл
		ЭлементDOMЭлементаФормы.УдалитьДочерний(ЭлементDOMДляУдаления);
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

Функция ЗаполнитьЗаголовкиКолонокРеквизитаФормы(ДокументDOM, ТаблицаИсключенийЗаголовковЭлементовФорм)
	
	ФормаИзменена = Ложь;
	
	ВыражениеПоискаКолонокРеквизита = "xmlns:Columns";
	ВыражениеПоискаПоТипуРеквизита = "//xmlns:Attributes/xmlns:Attribute/xmlns:Type/v8:Type[text()='v8:ValueTable']";
	
	РезультатXPath = ВычислитьВыражениеXPath(ВыражениеПоискаПоТипуРеквизита, ДокументDOM);
	Пока Истина Цикл
		
		// Получаем элемент, у которого тип "Таблица значений".
		ЭлементDOMТипТаблицаЗначений = РезультатXPath.ПолучитьСледующий();
		Если ЭлементDOMТипТаблицаЗначений = Неопределено Тогда
			Прервать;
		КонецЕсли;
		
		// Получаем элемент, который является родителем найденного элемента. У родителя тег Type.
		ЭлементDOMType = ЭлементDOMТипТаблицаЗначений.РодительскийУзел;
		Если ЭлементDOMType = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		// Получаем реквизит.
		ЭлементDOMРеквизит = ЭлементDOMType.РодительскийУзел;
		Если ЭлементDOMРеквизит = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		// Получаем имя найденного реквизита. Оно будет нужно для формирования полного имени реквизита.
		ИмяРеквизита = ПолучитьИмяЭлемента(ДокументDOM, ЭлементDOMРеквизит);
		Если ПустаяСтрока(ИмяРеквизита) Тогда
			Продолжить;
		КонецЕсли;
		
		// Получаем все колонки у реквизита формы.
		ЭлементDOMКолонки = ПолучитьЭлементDOMПоВыражениюXPath(ВыражениеПоискаКолонокРеквизита, ДокументDOM, ЭлементDOMРеквизит);
		Если ЭлементDOMКолонки = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ЭлементDOMКолонкиДочерниеЭлементы = ЭлементDOMКолонки.ДочерниеУзлы;
		Для Каждого ЭлементDOMКолонка Из ЭлементDOMКолонкиДочерниеЭлементы Цикл
			
			ЗаголовокКолонки = ПолучитьЗаголовокЭлемента(ДокументDOM, ЭлементDOMКолонка);
			Если НЕ ПустаяСтрока(ЗаголовокКолонки) Тогда
				Продолжить;
			КонецЕсли;
			
			// Получаем имя колонки реквизита. Оно будет нужно для формирования полного имени реквизита.
			ИмяКолонки = ПолучитьИмяЭлемента(ДокументDOM, ЭлементDOMКолонка);
			Если ПустаяСтрока(ИмяКолонки) Тогда
				Продолжить;
			КонецЕсли;
			
			// Формируем полное имя реквизита.
			ПутьКДанным = ИмяРеквизита + "." + ИмяКолонки;
			
			// Получаем все элементы, у которых в пути к данным задано полное имя реквизита.
			МассивЭлементов = ПолучитьЭлементыФормыПоРеквизиту(ДокументDOM, ПутьКДанным);
			Если МассивЭлементов.Количество() = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			ЗаполнитьЗаголовокРеквизита = Ложь;
			
			// Проверяем все заголовки найденных реквизитов.
			Для Каждого ЭлементМассива Из МассивЭлементов Цикл
				ЗаголовокЭлементаНаФорме = ПолучитьЗаголовокЭлемента(ДокументDOM, ЭлементМассива);
				Если ПустаяСтрока(ЗаголовокЭлементаНаФорме) Тогда
					ЗаполнитьЗаголовокРеквизита = Истина;
					Прервать;
				КонецЕсли;
			КонецЦикла;
			
			Если ЗаполнитьЗаголовокРеквизита Тогда
				НовыйЗаголовокРеквизитаФормы = ПолучитьЗаголовокПоИмениЭлементаФормы(ИмяКолонки, ТаблицаИсключенийЗаголовковЭлементовФорм);
				УстановитьЗаголовокЭлемента(ДокументDOM, ЭлементDOMКолонка, НовыйЗаголовокРеквизитаФормы);
				ФормаИзменена = Истина;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ФормаИзменена;
	
КонецФункции

Функция ПолучитьЭлементыФормыПоРеквизиту(ДокументDOM, ПолноеИмяРеквизита)
	
	ВыражениеПоискаПоПутиКДаннымШаблон = "//xmlns:ChildItems/*/xmlns:DataPath[text()='%1']";
	МассивЭлементовФормы = Новый Массив;
	
	// Получаем все элементы формы, у которого в свойстве ПутьКДанным указано полное имя реквизита.
	ВыражениеПоискаПоПутиКДанным = СтрШаблон(ВыражениеПоискаПоПутиКДаннымШаблон, ПолноеИмяРеквизита);
	РезультатПоискаПоПутиКДанным = ВычислитьВыражениеXPath(ВыражениеПоискаПоПутиКДанным, ДокументDOM);
	
	Пока Истина Цикл
		
		ЭлементDOMПутьКДанным = РезультатПоискаПоПутиКДанным.ПолучитьСледующий();
		Если ЭлементDOMПутьКДанным = Неопределено Тогда
			Прервать;
		КонецЕсли;
		
		ЭлементDOMПоле = ЭлементDOMПутьКДанным.РодительскийУзел;
		Если ЭлементDOMПоле = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		МассивЭлементовФормы.Добавить(ЭлементDOMПоле);
		
	КонецЦикла;
	
	Возврат МассивЭлементовФормы;
	
КонецФункции

Функция ПолучитьРеквизитФормыПоЭлементу(ДокументDOM, ЭлементDOMЭлементаФормы)
	
	ИмяРеквизита = "";
	Если ЭтоВыгрузкаXMLФайлов() Тогда
		ИмяРеквизита = ЭлементDOMЭлементаФормы.ТекстовоеСодержимое;
	Иначе
		ЭлементDOMsegments = ЭлементDOMЭлементаФормы.ПервыйДочерний;
		Если ЭлементDOMsegments <> Неопределено Тогда
			ИмяРеквизита = ЭлементDOMsegments.ТекстовоеСодержимое;
		КонецЕсли;
	КонецЕсли;
	
	Если ПустаяСтрока(ИмяРеквизита) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ТаблицаРеквизитовФормы = ?(ЭтоВыгрузкаXMLФайлов(), ПолучитьРеквизитыФормы(ДокументDOM), ПолучитьРеквизитыФормыEDT(ДокументDOM));
	
	СтрокаРеквизитаФормы = ТаблицаРеквизитовФормы.Найти(ИмяРеквизита, "ИмяРеквизита");
	Если СтрокаРеквизитаФормы = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ЭлементDOMРеквизитаФормы = СтрокаРеквизитаФормы.ЭлементDOM;
	
	Возврат ЭлементDOMРеквизитаФормы;
	
КонецФункции

Функция ПолучитьКомандуФормыПоЭлементу(ДокументDOM, ЭлементDOM)
	
	ТекстовоеСодержимое = ЭлементDOM.ТекстовоеСодержимое;
	Если НЕ ЗначениеЗаполнено(ТекстовоеСодержимое) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ИмяКоманды = СтрЗаменить(ТекстовоеСодержимое, "Form.Command.", "");
	
	ВыражениеXPath = ?(ЭтоВыгрузкаXMLФайлов(), "//xmlns:Form/xmlns:Commands/xmlns:Command[@name = '%1']", "//formCommands/name[text() = '%1']/..");
	ВыражениеПоискаПоПутиКДанным = СтрШаблон(ВыражениеXPath, ИмяКоманды);
	РезультатПоискаПоПутиКДанным = ВычислитьВыражениеXPath(ВыражениеПоискаПоПутиКДанным, ДокументDOM);
	
	Возврат РезультатПоискаПоПутиКДанным.ПолучитьСледующий();
	
КонецФункции

Функция ПолучитьЭлементыDOMЭлементовФормы(ДокументDOM)
	
	// Получаем все элементы, у которых заполнено свойство "ПутьКДанным".
	МассивЭлементовФормы = Новый Массив;
	
	ВыражениеПоискаПоПутиКДанным = ?(ЭтоВыгрузкаXMLФайлов(), "//xmlns:ChildItems/*/xmlns:DataPath", "//dataPath");
	РезультатПоискаПоПутиКДанным = ВычислитьВыражениеXPath(ВыражениеПоискаПоПутиКДанным, ДокументDOM);
	
	Пока Истина Цикл
		
		ЭлементDOMПутьКДанным = РезультатПоискаПоПутиКДанным.ПолучитьСледующий();
		Если ЭлементDOMПутьКДанным = Неопределено Тогда
			Прервать;
		КонецЕсли;
		
		МассивЭлементовФормы.Добавить(ЭлементDOMПутьКДанным);
		
	КонецЦикла;
	
	Возврат МассивЭлементовФормы;
	
КонецФункции

Функция ПолучитьЭлементыDOMКомандФормы(ДокументDOM)
	
	// Получаем все элементы, у которых заполнено свойство "ИмяКоманды".
	МассивЭлементовФормы = Новый Массив;
	
	ВыражениеПоискаПоПутиКДанным = ?(ЭтоВыгрузкаXMLФайлов(), "//xmlns:ChildItems/*/xmlns:CommandName", "//commandName");
	РезультатПоискаПоПутиКДанным = ВычислитьВыражениеXPath(ВыражениеПоискаПоПутиКДанным, ДокументDOM);
	
	Пока Истина Цикл
		
		ЭлементDOMПутьКДанным = РезультатПоискаПоПутиКДанным.ПолучитьСледующий();
		Если ЭлементDOMПутьКДанным = Неопределено Тогда
			Прервать;
		КонецЕсли;
		
		МассивЭлементовФормы.Добавить(ЭлементDOMПутьКДанным);
		
	КонецЦикла;
	
	Возврат МассивЭлементовФормы;
	
КонецФункции

Функция ПолучитьЭлементыФормыПоРеквизитуEDT(ДокументDOM, ПолноеИмяРеквизита)
	
	ВыражениеПоискаПоПутиКДаннымШаблон = "//dataPath/segments[text()='%1']";
	
	МассивЭлементовФормы = Новый Массив;
	
	// Получаем все элементы формы, у которого в свойстве ПутьКДанным указано полное имя реквизита.
	ВыражениеПоискаПоПутиКДанным = СтрШаблон(ВыражениеПоискаПоПутиКДаннымШаблон, ПолноеИмяРеквизита);
	РезультатПоискаПоПутиКДанным = ВычислитьВыражениеXPath(ВыражениеПоискаПоПутиКДанным, ДокументDOM);
	
	Пока Истина Цикл
		
		ЭлементDOMSegments = РезультатПоискаПоПутиКДанным.ПолучитьСледующий();
		Если ЭлементDOMSegments = Неопределено Тогда
			Прервать;
		КонецЕсли;
		
		ЭлементDOMDataPath = ЭлементDOMSegments.РодительскийУзел;
		Если ЭлементDOMDataPath = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ЭлементDOMПоле= ЭлементDOMDataPath.РодительскийУзел;
		Если ЭлементDOMПоле = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		МассивЭлементовФормы.Добавить(ЭлементDOMПоле);
		
	КонецЦикла;
	
	Возврат МассивЭлементовФормы;
	
КонецФункции

Функция ЗаполнитьЗаголовкиСвойствСпискаЗначений(ДокументDOM)
	
	ФормаИзменена = Ложь;
	
	СвойстваЭлементаСпискаЗначений = Новый СписокЗначений;
	СвойстваЭлементаСпискаЗначений.Добавить("Value", "Значение");
	СвойстваЭлементаСпискаЗначений.Добавить("Picture", "Картинка");
	СвойстваЭлементаСпискаЗначений.Добавить("Check", "Пометка");
	СвойстваЭлементаСпискаЗначений.Добавить("Presentation", "Представление");
	СвойстваЭлементаСпискаЗначений.Добавить("Значение", "Значение");
	СвойстваЭлементаСпискаЗначений.Добавить("Картинка", "Картинка");
	СвойстваЭлементаСпискаЗначений.Добавить("Пометка", "Пометка");
	СвойстваЭлементаСпискаЗначений.Добавить("Представление", "Представление");
	
	ВыражениеПоискаПоТипуРеквизита = "//xmlns:Attributes/xmlns:Attribute/xmlns:Type/v8:Type[text()='v8:ValueListType']";
	РезультатXPath = ВычислитьВыражениеXPath(ВыражениеПоискаПоТипуРеквизита, ДокументDOM);
	Пока Истина Цикл
		
		ЭлементDOMv8Type = РезультатXPath.ПолучитьСледующий();
		Если ЭлементDOMv8Type = Неопределено Тогда
			Прервать;
		КонецЕсли;
		
		ЭлементDOMType = ЭлементDOMv8Type.РодительскийУзел;
		Если ЭлементDOMType = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ЭлементDOMРеквизит = ЭлементDOMType.РодительскийУзел;
		Если ЭлементDOMРеквизит = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ИмяРеквизита = ПолучитьИмяЭлемента(ДокументDOM, ЭлементDOMРеквизит);
		Если ПустаяСтрока(ИмяРеквизита) Тогда
			Продолжить;
		КонецЕсли;
		
		Для Каждого СвойствоЭлементаСпискаЗначений Из СвойстваЭлементаСпискаЗначений Цикл
			
			ИмяСвойства = СвойствоЭлементаСпискаЗначений.Значение;
			ПолноеИмяСвойстваЭлемента = СтрШаблон("%1.%2", ИмяРеквизита, ИмяСвойства);
			МассивЭлементов = ПолучитьЭлементыФормыПоРеквизиту(ДокументDOM, ПолноеИмяСвойстваЭлемента);
			
			Если МассивЭлементов.Количество() = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			ЗаголовокСвойства = СвойствоЭлементаСпискаЗначений.Представление;
			
			Для Каждого ЭлементDOMЭлементаФормы Из МассивЭлементов Цикл
				
				ЗаголовокЭлемента = ПолучитьЗаголовокЭлемента(ДокументDOM, ЭлементDOMЭлементаФормы);
				Если ПустаяСтрока(ЗаголовокЭлемента) Тогда
					УстановитьЗаголовокЭлемента(ДокументDOM, ЭлементDOMЭлементаФормы, ЗаголовокСвойства, КодОсновногоЯзыка);
					ФормаИзменена = Истина;
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ФормаИзменена;
	
КонецФункции

Функция ЗаполнитьЗаголовкиЭлементовФорм(ДокументDOM)
	
	ФормаИзменена = Ложь;
	
	ЯзыкиКонфигурации         = Контекст["ТаблицаЯзыковКонфигурации"];
	ЭлементыDOMЭлементовФормы = ПолучитьЭлементыDOMЭлементовФормы(ДокументDOM);
	ЭлементыDOMКомандФормы    = ПолучитьЭлементыDOMКомандФормы(ДокументDOM);
	
	ЭлементыИКоманды = Новый Массив;
	ДополнитьМассив(ЭлементыИКоманды, ЭлементыDOMЭлементовФормы);
	ДополнитьМассив(ЭлементыИКоманды, ЭлементыDOMКомандФормы);
	
	Для Каждого ЭлементDOMdataPath Из ЭлементыИКоманды Цикл
		
		ЭлементDOMЭлементФормы = ЭлементDOMdataPath.РодительскийУзел;
		Если ЭлементDOMЭлементФормы = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Для Каждого ЯзыкКонфигурации Из ЯзыкиКонфигурации Цикл
			
			КодЯзыка = ЯзыкКонфигурации.КодЯзыка;
			
			Если ЭтоВыгрузкаXMLФайлов() Тогда
				ЗаголовокЭлемента = ПолучитьЗаголовокЭлемента(ДокументDOM, ЭлементDOMЭлементФормы,, КодЯзыка);
			Иначе
				ЗаголовокЭлемента = ПолучитьЗаголовокЭлементаEDT(ДокументDOM, ЭлементDOMЭлементФормы, КодЯзыка);
			КонецЕсли;
			
			Если НЕ ПустаяСтрока(ЗаголовокЭлемента) Тогда
				Продолжить;
			КонецЕсли;
			
			НайденныйЭлементDOM = Неопределено;
			Если СтрСравнить(ЭлементDOMdataPath.ИмяУзла, "DataPath") = 0 Тогда
				НайденныйЭлементDOM = ПолучитьРеквизитФормыПоЭлементу(ДокументDOM, ЭлементDOMdataPath);
			ИначеЕсли СтрСравнить(ЭлементDOMdataPath.ИмяУзла, "CommandName") = 0 Тогда
				НайденныйЭлементDOM = ПолучитьКомандуФормыПоЭлементу(ДокументDOM, ЭлементDOMdataPath);
			КонецЕсли;
			
			Если НайденныйЭлементDOM = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			Если ЭтоВыгрузкаXMLФайлов() Тогда
				ЗаголовокРеквизита = ПолучитьЗаголовокЭлемента(ДокументDOM, НайденныйЭлементDOM,, КодЯзыка);
			Иначе
				ЗаголовокРеквизита = ПолучитьЗаголовокЭлементаEDT(ДокументDOM, НайденныйЭлементDOM, КодЯзыка);
			КонецЕсли;
			
			Если ПустаяСтрока(ЗаголовокРеквизита) Тогда
				Продолжить;
			КонецЕсли;
			
			Если ЭтоВыгрузкаXMLФайлов() Тогда
				УстановитьЗаголовокЭлемента(ДокументDOM, ЭлементDOMЭлементФормы, ЗаголовокРеквизита, КодЯзыка);
			Иначе
				УстановитьЗаголовокЭлементаEDT(ДокументDOM, ЭлементDOMЭлементФормы, ЗаголовокРеквизита, КодЯзыка);
			КонецЕсли;
			
			ФормаИзменена = Истина;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ФормаИзменена;
	
КонецФункции

#КонецОбласти

#Область ЛокализацияЭлементовФормEDT

// Удаляет подсказки для элементов форм с типом "Групп", у которых они совпадают с синонимом или образованы из имени.
//
Функция ОчиститьПодсказкиГруппФормыEDT(ДокументDOM)
	
	ФормаИзменена = Ложь;
	
	МассивТиповЭлементовФормы = Новый Массив;
	МассивТиповЭлементовФормы.Добавить("UsualGroup");
	МассивТиповЭлементовФормы.Добавить("Pages");
	МассивТиповЭлементовФормы.Добавить("Page");
	МассивТиповЭлементовФормы.Добавить("CommandBar");
	МассивТиповЭлементовФормы.Добавить("ColumnGroup");
	МассивТиповЭлементовФормы.Добавить("Popup");
	МассивТиповЭлементовФормы.Добавить("ButtonGroup");
	
	ТекстГруппа = Контекст["ТекстГруппа"];
	
	ВыражениеПоискаПоТипуЭлементаШаблон = "//items/type[text()='%1']";
	
	Для Каждого ТипЭлементаФормы Из МассивТиповЭлементовФормы Цикл
		
		ВыражениеПоискаПоТипуЭлемента = СтрШаблон(ВыражениеПоискаПоТипуЭлементаШаблон, ТипЭлементаФормы);
		РезультатXPath = ВычислитьВыражениеXPath(ВыражениеПоискаПоТипуЭлемента, ДокументDOM);
		Пока Истина Цикл
			
			ЭлементDOMТипЭлементаФормы = РезультатXPath.ПолучитьСледующий();
			Если ЭлементDOMТипЭлементаФормы = Неопределено Тогда
				Прервать;
			КонецЕсли;
			
			ЭлементDOMЭлементаФормы = ЭлементDOMТипЭлементаФормы.РодительскийУзел;
			
			ПодсказкаЭлементаФормы = ПолучитьПодсказкуЭлементаEDT(ДокументDOM, ЭлементDOMЭлементаФормы);
			Если ПустаяСтрока(ПодсказкаЭлементаФормы) Тогда
				УдалитьПодсказкуЭлементаEDT(ДокументDOM, ЭлементDOMЭлементаФормы);
				ФормаИзменена = Истина;
				Продолжить;
			КонецЕсли;
			
			ЗаголовокЭлементаФормы = ПолучитьЗаголовокЭлементаEDT(ДокументDOM, ЭлементDOMЭлементаФормы, КодОсновногоЯзыка);
			ИмяЭлементаФормы = ПолучитьИмяЭлементаEDT(ДокументDOM, ЭлементDOMЭлементаФормы);
			
			ПодсказкаЭлементаФормы = ПреобразоватьТекстДляСравнения(ПодсказкаЭлементаФормы, ТекстГруппа);
			ЗаголовокЭлементаФормы = ПреобразоватьТекстДляСравнения(ЗаголовокЭлементаФормы, ТекстГруппа);
			ИмяЭлементаФормы = ПреобразоватьТекстДляСравнения(ИмяЭлементаФормы, ТекстГруппа);
			
			Если (ПодсказкаЭлементаФормы = ЗаголовокЭлементаФормы)
			 ИЛИ (ПодсказкаЭлементаФормы = ИмяЭлементаФормы) Тогда
				УдалитьПодсказкуЭлементаEDT(ДокументDOM, ЭлементDOMЭлементаФормы);
				ФормаИзменена = Истина;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ФормаИзменена;
	
КонецФункции

// Устанавливает заголовки для элементов форм с типом "Таблица" и "Группа", у которых заголовок не заполнен.
// Генерацию заголовков производит из наименования элемента формы по заглавным буквам.
//
Функция ЗаполнитьЗаголовкиТаблицИГруппФормыEDT(ДокументDOM, ТаблицаИсключенийЗаголовковЭлементовФорм,
	ТаблицаПоискаТаблицИГрупп)
	
	ФормаИзменена = Ложь;
	
	МассивПоискаТЧ = Контекст["МассивВыраженийПоискаТабличныхЧастейEDT"];
	ТаблицаСинонимовТабличныхЧастей = ПолучитьТаблицуСинонимовТабличныхЧастейEDT(ДокументDOM, МассивПоискаТЧ);
	
	Для Каждого СтрокаТипа Из ТаблицаПоискаТаблицИГрупп Цикл
		
		ТипЭлементаФормы = СтрокаТипа.ТипЭлемента;
		ВыражениеПоискаПоТипуЭлемента = СтрокаТипа.ВыражениеПоиска;
		ПолучатьРодителя = СтрокаТипа.ПолучатьРодителя;
		
		РезультатXPath = ВычислитьВыражениеXPath(ВыражениеПоискаПоТипуЭлемента, ДокументDOM);
		Пока Истина Цикл
			
			ЭлементDOMТипЭлементаФормы = РезультатXPath.ПолучитьСледующий();
			Если ЭлементDOMТипЭлементаФормы = Неопределено Тогда
				Прервать;
			КонецЕсли;
			
			Если ПолучатьРодителя Тогда
				ЭлементDOMЭлементаФормы = ЭлементDOMТипЭлементаФормы.РодительскийУзел;
			Иначе
				ЭлементDOMЭлементаФормы = ЭлементDOMТипЭлементаФормы;
			КонецЕсли;
			
			// Очищаем заголовок таблицы, если она связана с табличной частью и заголовок таблицы совпадает с синонимом ТЧ.
			Если СтрСравнить(ТипЭлементаФормы, "Table") = 0 Тогда
				Если ОчиститьЗаголовокТаблицыФормыEDT(ДокументDOM, ЭлементDOMЭлементаФормы, ТаблицаСинонимовТабличныхЧастей) Тогда
					ФормаИзменена = Истина;
				КонецЕсли;
				
				// Положение заголовка не меняем, поэтому переходим к следующему элементу формы.
				Продолжить;
			КонецЕсли;
			
			Если ТипЭлементаФормы = "UsualGroup" Тогда
				// Обрабатываем только обычные группы.
				ЭлементDOMПоведение = ПолучитьЭлементDOMПоВыражениюXPath("extInfo/behavior", ДокументDOM, ЭлементDOMЭлементаФормы);
				Если (ЭлементDOMПоведение <> Неопределено)
					И (СтрСравнить(ЭлементDOMПоведение.ТекстовоеСодержимое, "Usual") <> 0) Тогда
					Продолжить;
				КонецЕсли;
			КонецЕсли;
			
			ИмяЭлементаФормы = ПолучитьИмяЭлементаEDT(ДокументDOM, ЭлементDOMЭлементаФормы);
			ЗаголовокЭлементаФормы = ПолучитьЗаголовокЭлементаEDT(ДокументDOM, ЭлементDOMЭлементаФормы, КодОсновногоЯзыка);
			
			// Пропускаем элементы, у которых заголовок заполнен и установлен вручную, а не сгенерирован автоматически:
			// ГруппаСуммаОплаты -> Группа сумма оплаты (в данном случае необходимо установить заголовок "Сумма оплаты").
			ИмяДляСравнения = ПреобразоватьТекстДляСравнения(ИмяЭлементаФормы);
			ЗаголовокДляСравнения = СтрЗаменить(ЗаголовокЭлементаФормы, " ", "");
			ЗаголовокДляСравнения = ВРег(СокрЛП(ЗаголовокДляСравнения));
			Если (НЕ ПустаяСтрока(ЗаголовокЭлементаФормы)) И (ИмяДляСравнения <> ЗаголовокДляСравнения) Тогда
				Продолжить;
			КонецЕсли;
			
			НовыйЗаголовокЭлементаФормы = ПолучитьЗаголовокПоИмениЭлементаФормы(ИмяЭлементаФормы,
				ТаблицаИсключенийЗаголовковЭлементовФорм);
			
			// Новые пустые заголовки пропускаем.
			// Аналогично пропускаем случаи, когда заголовок не изменился, например, он есть в таблице исключений.
			Если (ТипЭлементаФормы <> "Table")
					И (ПустаяСтрока(НовыйЗаголовокЭлементаФормы) ИЛИ (ЗаголовокЭлементаФормы = НовыйЗаголовокЭлементаФормы)) Тогда
				Продолжить;
			КонецЕсли;
			
			УстановитьЗаголовокЭлементаEDT(ДокументDOM, ЭлементDOMЭлементаФормы, НовыйЗаголовокЭлементаФормы);
			
			// Для обычных групп и страниц устанавливаем свойство "ОтображатьЗаголовок" = Ложь.
			Если СтрокаТипа.ОчищатьФлагОтображатьЗаголовок Тогда
				
				// Обрабатываем только обычные группы.
				ЭлементDOMПоведение = ПолучитьЭлементDOMПоВыражениюXPath("extInfo/behavior", ДокументDOM, ЭлементDOMЭлементаФормы);
				Если (ЭлементDOMПоведение = Неопределено)
				 ИЛИ (СтрСравнить(ЭлементDOMПоведение.ТекстовоеСодержимое, "Usual") = 0) Тогда
					УдалитьОтображениеЗаголовкаЭлементаФормыEDT(ДокументDOM, ЭлементDOMЭлементаФормы);
				КонецЕсли;
				
			ИначеЕсли СтрСравнить(ТипЭлементаФормы, "Table") = 0 Тогда
				// Установим свойство "ПоложениеЗаголовка" в значение "Ложь" для таблицы.
				УстановитьПоложениеЗаголовкаДляЭлементаФормыEDT(ДокументDOM, ЭлементDOMЭлементаФормы);
			КонецЕсли;
			
			ФормаИзменена = Истина;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ФормаИзменена;
	
КонецФункции

#КонецОбласти

#КонецОбласти

#Область ЛокализацияРеквизитовФорм

#Область ЛокализацияРеквизитовФормXML

Функция ОчиститьЗаголовкиРеквизитовФормыНеРазмещенныхНаФорме(ДокументDOM)
	
	ФормаИзменена = Ложь;
	
	МассивРеквизитов = ПолучитьРеквизитыФормыНеРазмещенныеНаФорме(ДокументDOM);
	
	Для Каждого ЭлементDOMРеквизит Из МассивРеквизитов Цикл
		
		ВыражениеXPath = "xmlns:Title";
		ЭлементDOMЗаголовок = ПолучитьЭлементDOMПоВыражениюXPath(ВыражениеXPath, ДокументDOM, ЭлементDOMРеквизит);
		Если ЭлементDOMЗаголовок <> Неопределено Тогда
			ЭлементDOMЗаголовок.ТекстовоеСодержимое = "";
			ФормаИзменена = Истина;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ФормаИзменена;
	
КонецФункции

Функция ПолучитьРеквизитыФормыНеРазмещенныеНаФорме(ДокументDOM)
	
	МассивРеквизитов = Новый Массив;
	
	ТаблицаРеквизитов = ПолучитьРеквизитыФормы(ДокументDOM);
	Для Каждого СтрокаТаблицы Из ТаблицаРеквизитов Цикл
		
		ЭлементDOMРеквизит = СтрокаТаблицы.ЭлементDOM;
		МассивВозможныхПутей = СтрокаТаблицы.МассивВозможныхПутей;
		
		РеквизитНайден = Ложь;
		ШаблонДляПоиска = "//*[xmlns:DataPath=""%1""]";
		
		Для Каждого ЭлементМассива Из МассивВозможныхПутей Цикл
			ВыражениеПоиска = СтрШаблон(ШаблонДляПоиска, ЭлементМассива);
			
			ЭлементDOMПутьКРеквизиту = ПолучитьЭлементDOMПоВыражениюXPath(ВыражениеПоиска, ДокументDOM);
			Если ЭлементDOMПутьКРеквизиту <> Неопределено Тогда
				РеквизитНайден = Истина;
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
		Если НЕ РеквизитНайден Тогда
			МассивРеквизитов.Добавить(ЭлементDOMРеквизит);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат МассивРеквизитов;
	
КонецФункции

Функция ПолучитьРеквизитыФормы(ДокументDOM, ПолучитьПодчиненныеРеквизиты = Истина)
	
	ТаблицаРеквизитов = Новый ТаблицаЗначений;
	ТаблицаРеквизитов.Колонки.Добавить("ЭлементDOM");
	ТаблицаРеквизитов.Колонки.Добавить("ИмяРеквизита");
	ТаблицаРеквизитов.Колонки.Добавить("МассивВозможныхПутей");
	
	СоответствиеРеквизитовДляПоиска = Новый Соответствие;
	
	РезультатXPath = ВычислитьВыражениеXPath("/xmlns:Form/xmlns:Attributes/xmlns:Attribute/@name", ДокументDOM);
	Пока Истина Цикл
		
		АтрибутDOMИмяРеквизита = РезультатXPath.ПолучитьСледующий();
		Если АтрибутDOMИмяРеквизита = Неопределено Тогда
			Прервать;
		КонецЕсли;
		
		ИмяРеквизита = АтрибутDOMИмяРеквизита.ТекстовоеСодержимое;
		Если ПустаяСтрока(ИмяРеквизита) Тогда
			Продолжить;
		КонецЕсли;
		
		ЭлементDOMРеквизит = АтрибутDOMИмяРеквизита.ЭлементВладелец;
		СоответствиеРеквизитовДляПоиска.Вставить(ИмяРеквизита, ЭлементDOMРеквизит);
		
		МассивВозможныхПутей = Новый Массив;
		МассивВозможныхПутей.Добавить(ИмяРеквизита);
		
		НоваяСтрока = ТаблицаРеквизитов.Добавить();
		НоваяСтрока.ЭлементDOM = ЭлементDOMРеквизит;
		НоваяСтрока.ИмяРеквизита = ИмяРеквизита;
		НоваяСтрока.МассивВозможныхПутей = МассивВозможныхПутей;
		
	КонецЦикла;
	
	Если ПолучитьПодчиненныеРеквизиты Тогда
		
		Для Каждого ЭлементСоответствия Из СоответствиеРеквизитовДляПоиска Цикл
			
			ВыражениеДляПоиска = "xmlns:Columns/xmlns:Column/@name";
			
			РезультатXPath = ВычислитьВыражениеXPath(ВыражениеДляПоиска, ДокументDOM, ЭлементСоответствия.Значение);
			Пока Истина Цикл
				
				АтрибутDOMИмяРеквизита = РезультатXPath.ПолучитьСледующий();
				Если АтрибутDOMИмяРеквизита = Неопределено Тогда
					Прервать;
				КонецЕсли;
				
				ИмяРеквизита = АтрибутDOMИмяРеквизита.ТекстовоеСодержимое;
				Если ПустаяСтрока(ИмяРеквизита) Тогда
					Продолжить;
				КонецЕсли;
				
				ПутьРеквизита = СтрШаблон("%1.%2", ЭлементСоответствия.Ключ, ИмяРеквизита);
				
				МассивВозможныхПутей = Новый Массив;
				МассивВозможныхПутей.Добавить(ПутьРеквизита);
				МассивВозможныхПутей.Добавить(СтрШаблон("%1[0].%2", ЭлементСоответствия.Ключ, ИмяРеквизита));
				МассивВозможныхПутей.Добавить(СтрШаблон("Items.%1.CurrentData.%2", ЭлементСоответствия.Ключ, ИмяРеквизита));
				
				НоваяСтрока = ТаблицаРеквизитов.Добавить();
				НоваяСтрока.ЭлементDOM = АтрибутDOMИмяРеквизита.ЭлементВладелец;
				НоваяСтрока.ИмяРеквизита = ПутьРеквизита;
				НоваяСтрока.МассивВозможныхПутей = МассивВозможныхПутей;
				
			КонецЦикла;
		КонецЦикла;
	КонецЕсли;
	
	Возврат ТаблицаРеквизитов;
	
КонецФункции

#КонецОбласти

#Область ЛокализацияРеквизитовФормEDT

Функция ОчиститьЗаголовкиРеквизитовФормыНеРазмещенныхНаФормеEDT(ДокументDOM)
	
	ФормаИзменена = Ложь;
	
	МассивРеквизитов = ПолучитьРеквизитыФормыНеРазмещенныеНаФормеEDT(ДокументDOM);
	
	Для Каждого ЭлементDOMРеквизит Из МассивРеквизитов Цикл
		
		РезультатXPath = ВычислитьВыражениеXPath("title/value", ДокументDOM, ЭлементDOMРеквизит);
		Пока Истина Цикл
			
			ЭлементDOMЗаголовок = РезультатXPath.ПолучитьСледующий();
			Если ЭлементDOMЗаголовок = Неопределено Тогда
				Прервать;
			КонецЕсли;
			
			Если ПустаяСтрока(ЭлементDOMЗаголовок.ТекстовоеСодержимое) Тогда
				Продолжить;
			КонецЕсли;
			
			ЭлементDOMЗаголовок.ТекстовоеСодержимое = "";
			ФормаИзменена = Истина;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ФормаИзменена;
	
КонецФункции

Функция ПолучитьРеквизитыФормыНеРазмещенныеНаФормеEDT(ДокументDOM)
	
	МассивРеквизитов = Новый Массив;
	
	ТаблицаРеквизитов = ПолучитьРеквизитыФормыEDT(ДокументDOM);
	Для Каждого СтрокаТаблицы Из ТаблицаРеквизитов Цикл
		
		ЭлементDOMРеквизит = СтрокаТаблицы.ЭлементDOM;
		МассивВозможныхПутей = СтрокаТаблицы.МассивВозможныхПутей;
		
		РеквизитНайден = Ложь;
		ШаблонДляПоиска = "//dataPath[segments=""%1""]|//dataPath/paths[segments=""%1""]";
		
		Для Каждого ЭлементМассива Из МассивВозможныхПутей Цикл
			ВыражениеПоиска = СтрШаблон(ШаблонДляПоиска, ЭлементМассива);
			
			ЭлементDOMПутьКРеквизиту = ПолучитьЭлементDOMПоВыражениюXPath(ВыражениеПоиска, ДокументDOM);
			Если ЭлементDOMПутьКРеквизиту <> Неопределено Тогда
				РеквизитНайден = Истина;
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
		Если НЕ РеквизитНайден Тогда
			МассивРеквизитов.Добавить(ЭлементDOMРеквизит);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат МассивРеквизитов;
	
КонецФункции

Функция ПолучитьРеквизитыФормыEDT(ДокументDOM, ПолучитьПодчиненныеРеквизиты = Истина)
	
	ТаблицаРеквизитов = Новый ТаблицаЗначений;
	ТаблицаРеквизитов.Колонки.Добавить("ЭлементDOM");
	ТаблицаРеквизитов.Колонки.Добавить("ИмяРеквизита");
	ТаблицаРеквизитов.Колонки.Добавить("МассивВозможныхПутей");
	
	СоответствиеРеквизитовДляПоиска = Новый Соответствие;
	
	РезультатXPath = ВычислитьВыражениеXPath("/form:Form/attributes/name", ДокументDOM);
	Пока Истина Цикл
		
		ЭлементDOMИмяРеквизита = РезультатXPath.ПолучитьСледующий();
		Если ЭлементDOMИмяРеквизита = Неопределено Тогда
			Прервать;
		КонецЕсли;
		
		ИмяРеквизита = ЭлементDOMИмяРеквизита.ТекстовоеСодержимое;
		Если ПустаяСтрока(ИмяРеквизита) Тогда
			Продолжить;
		КонецЕсли;
		
		ЭлементDOMРеквизит = ЭлементDOMИмяРеквизита.РодительскийУзел;
		СоответствиеРеквизитовДляПоиска.Вставить(ИмяРеквизита, ЭлементDOMРеквизит);
		
		МассивВозможныхПутей = Новый Массив;
		МассивВозможныхПутей.Добавить(ИмяРеквизита);
		
		НоваяСтрока = ТаблицаРеквизитов.Добавить();
		НоваяСтрока.ЭлементDOM = ЭлементDOMРеквизит;
		НоваяСтрока.ИмяРеквизита = ИмяРеквизита;
		НоваяСтрока.МассивВозможныхПутей = МассивВозможныхПутей;
		
	КонецЦикла;
	
	Если ПолучитьПодчиненныеРеквизиты Тогда
		
		Для Каждого ЭлементСоответствия Из СоответствиеРеквизитовДляПоиска Цикл
			
			ВыражениеДляПоиска = "columns/name";
			
			РезультатXPath = ВычислитьВыражениеXPath(ВыражениеДляПоиска, ДокументDOM, ЭлементСоответствия.Значение);
			Пока Истина Цикл
				
				ЭлементDOMИмяРеквизита = РезультатXPath.ПолучитьСледующий();
				Если ЭлементDOMИмяРеквизита = Неопределено Тогда
					Прервать;
				КонецЕсли;
				
				ИмяРеквизита = ЭлементDOMИмяРеквизита.ТекстовоеСодержимое;
				Если ПустаяСтрока(ИмяРеквизита) Тогда
					Продолжить;
				КонецЕсли;
				
				ПутьРеквизита = СтрШаблон("%1.%2", ЭлементСоответствия.Ключ, ИмяРеквизита);
				
				МассивВозможныхПутей = Новый Массив;
				МассивВозможныхПутей.Добавить(ПутьРеквизита);
				МассивВозможныхПутей.Добавить(СтрШаблон("%1[0].%2", ЭлементСоответствия.Ключ, ИмяРеквизита));
				МассивВозможныхПутей.Добавить(СтрШаблон("Элементы.%1.ТекущиеДанные.%2", ЭлементСоответствия.Ключ, ИмяРеквизита));
				МассивВозможныхПутей.Добавить(СтрШаблон("Items.%1.CurrentData.%2", ЭлементСоответствия.Ключ, ИмяРеквизита));
				
				НоваяСтрока = ТаблицаРеквизитов.Добавить();
				НоваяСтрока.ЭлементDOM = ЭлементDOMИмяРеквизита.РодительскийУзел;
				НоваяСтрока.ИмяРеквизита = ПутьРеквизита;
				НоваяСтрока.МассивВозможныхПутей = МассивВозможныхПутей;
				
			КонецЦикла;
		КонецЦикла;
	КонецЕсли;
	
	Возврат ТаблицаРеквизитов;
	
КонецФункции

Функция ЗаполнитьЗаголовкиКолонокРеквизитаФормыEDT(ДокументDOM, ТаблицаИсключенийЗаголовковЭлементовФорм)
	
	ФормаИзменена = Ложь;
	
	ВыражениеПоискаПоТипуРеквизита = "//attributes/valueType/types[text()='ValueTable']";
	ВыражениеПоискаКолонокРеквизита = "columns";
	
	РезультатXPath = ВычислитьВыражениеXPath(ВыражениеПоискаПоТипуРеквизита, ДокументDOM);
	
	Пока Истина Цикл
		
		// Получаем элемент, у которого тип "Таблица значений".
		ЭлементDOMТипТаблицаЗначений = РезультатXPath.ПолучитьСледующий();
		Если ЭлементDOMТипТаблицаЗначений = Неопределено Тогда
			Прервать;
		КонецЕсли;
		
		// Получаем элемент, который является родителем найденного элемента. У родителя тег Type.
		ЭлементDOMValueType = ЭлементDOMТипТаблицаЗначений.РодительскийУзел;
		Если ЭлементDOMValueType = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		// Получаем реквизит.
		ЭлементDOMРеквизит = ЭлементDOMValueType.РодительскийУзел;
		Если ЭлементDOMРеквизит = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		// Получаем имя найденного реквизита. Оно будет нужно для формирования полного имени реквизита.
		ИмяРеквизита = ПолучитьИмяЭлементаEDT(ДокументDOM, ЭлементDOMРеквизит);
		Если ПустаяСтрока(ИмяРеквизита) Тогда
			Продолжить;
		КонецЕсли;
		
		РезультатXPathДляКолонок = ВычислитьВыражениеXPath(ВыражениеПоискаКолонокРеквизита, ДокументDOM, ЭлементDOMРеквизит);
		
		Пока Истина Цикл
			
			// Перебираем все колонки у реквизита формы.
			ЭлементDOMКолонка = РезультатXPathДляКолонок.ПолучитьСледующий();
			Если ЭлементDOMКолонка = Неопределено Тогда
				Прервать;
			КонецЕсли;
		
			ЗаголовокКолонки = ПолучитьЗаголовокЭлементаEDT(ДокументDOM, ЭлементDOMКолонка, КодОсновногоЯзыка);
			Если НЕ ПустаяСтрока(ЗаголовокКолонки) Тогда
				Продолжить;
			КонецЕсли;
			
			// Получаем имя колонки реквизита. Оно будет нужно для формирования полного имени реквизита.
			ИмяКолонки = ПолучитьИмяЭлементаEDT(ДокументDOM, ЭлементDOMКолонка);
			Если ПустаяСтрока(ИмяКолонки) Тогда
				Продолжить;
			КонецЕсли;
			
			// Формируем полное имя реквизита.
			ПутьКДанным = ИмяРеквизита + "." + ИмяКолонки;
			
			// Получаем все элементы, у которых в пути к данным задано полное имя реквизита.
			МассивЭлементов = ПолучитьЭлементыФормыПоРеквизитуEDT(ДокументDOM, ПутьКДанным);
			Если МассивЭлементов.Количество() = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			ЗаполнитьЗаголовокРеквизита = Ложь;
			
			// Проверяем все заголовки найденных реквизитов.
			Для Каждого ЭлементМассива Из МассивЭлементов Цикл
				ЗаголовокЭлементаНаФорме = ПолучитьЗаголовокЭлементаEDT(ДокументDOM, ЭлементМассива, КодОсновногоЯзыка);
				Если ПустаяСтрока(ЗаголовокЭлементаНаФорме) Тогда
					ЗаполнитьЗаголовокРеквизита = Истина;
					Прервать;
				КонецЕсли;
			КонецЦикла;
			
			Если ЗаполнитьЗаголовокРеквизита Тогда
				НовыйЗаголовокРеквизитаФормы = ПолучитьЗаголовокПоИмениЭлементаФормы(ИмяКолонки, ТаблицаИсключенийЗаголовковЭлементовФорм);
				УстановитьЗаголовокЭлементаEDT(ДокументDOM, ЭлементDOMКолонка, НовыйЗаголовокРеквизитаФормы, КодОсновногоЯзыка);
				ФормаИзменена = Истина;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ФормаИзменена;
	
КонецФункции

Функция ЗаполнитьЗаголовкиСвойствСпискаЗначенийEDT(ДокументDOM)
	
	ФормаИзменена = Ложь;
	
	СвойстваЭлементаСпискаЗначений = Новый СписокЗначений;
	СвойстваЭлементаСпискаЗначений.Добавить("Value", "Значение");
	СвойстваЭлементаСпискаЗначений.Добавить("Picture", "Картинка");
	СвойстваЭлементаСпискаЗначений.Добавить("Check", "Пометка");
	СвойстваЭлементаСпискаЗначений.Добавить("Presentation", "Представление");
	СвойстваЭлементаСпискаЗначений.Добавить("Значение", "Значение");
	СвойстваЭлементаСпискаЗначений.Добавить("Картинка", "Картинка");
	СвойстваЭлементаСпискаЗначений.Добавить("Пометка", "Пометка");
	СвойстваЭлементаСпискаЗначений.Добавить("Представление", "Представление");
	
	ВыражениеПоискаПоТипуРеквизита = "//attributes/valueType/types[text()='ValueList']";
	РезультатXPath = ВычислитьВыражениеXPath(ВыражениеПоискаПоТипуРеквизита, ДокументDOM);
	Пока Истина Цикл
		
		ЭлементDOMv8Types = РезультатXPath.ПолучитьСледующий();
		Если ЭлементDOMv8Types = Неопределено Тогда
			Прервать;
		КонецЕсли;
		
		ЭлементDOMValueType = ЭлементDOMv8Types.РодительскийУзел;
		Если ЭлементDOMValueType = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ЭлементDOMРеквизит = ЭлементDOMValueType.РодительскийУзел;
		Если ЭлементDOMРеквизит = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ИмяРеквизита = ПолучитьИмяЭлементаEDT(ДокументDOM, ЭлементDOMРеквизит);
		Если ПустаяСтрока(ИмяРеквизита) Тогда
			Продолжить;
		КонецЕсли;
		
		Для Каждого СвойствоЭлементаСпискаЗначений Из СвойстваЭлементаСпискаЗначений Цикл
			
			ИмяСвойства = СвойствоЭлементаСпискаЗначений.Значение;
			ПолноеИмяСвойстваЭлемента = СтрШаблон("%1.%2", ИмяРеквизита, ИмяСвойства);
			МассивЭлементов = ПолучитьЭлементыФормыПоРеквизитуEDT(ДокументDOM, ПолноеИмяСвойстваЭлемента);
			
			Если МассивЭлементов.Количество() = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			ЗаголовокСвойства = СвойствоЭлементаСпискаЗначений.Представление;
			
			Для Каждого ЭлементDOMЭлементаФормы Из МассивЭлементов Цикл
				
				ЗаголовокЭлемента = ПолучитьЗаголовокЭлементаEDT(ДокументDOM, ЭлементDOMЭлементаФормы);
				Если ПустаяСтрока(ЗаголовокЭлемента) Тогда
					УстановитьЗаголовокЭлементаEDT(ДокументDOM, ЭлементDOMЭлементаФормы, ЗаголовокСвойства, КодОсновногоЯзыка);
					ФормаИзменена = Истина;
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ФормаИзменена;
	
КонецФункции

