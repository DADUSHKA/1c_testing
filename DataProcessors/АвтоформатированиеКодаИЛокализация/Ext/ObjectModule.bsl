Функция ИнициализироватьТаблицуТиповПараметров()
	
	ТаблицаТиповПараметров = ПолучитьТаблицуИзМакета("ТипыПараметров");
	ТаблицаТиповПараметров.Колонки.Добавить("ТипПараметраДляЗаменыВРег");
	
	МассивСтрокДляУдаления = Новый Массив;
	
	Для Каждого СтрокаТипаПараметра Из ТаблицаТиповПараметров Цикл
		Если ПустаяСтрока(СтрокаТипаПараметра.ТипПараметраДляПоиска) Тогда
			МассивСтрокДляУдаления.Добавить(СтрокаТипаПараметра);
			Продолжить;
		КонецЕсли;
		
		СтрокаТипаПараметра.ТипПараметраДляПоиска        = ВРег(СтрокаТипаПараметра.ТипПараметраДляПоиска);
		СтрокаТипаПараметра.ТипПараметраДляЗаменыВРег    = ВРег(СтрокаТипаПараметра.ТипПараметраДляЗамены);
		СтрокаТипаПараметра.ИспользоватьДляВыделенияТипа = Булево(СтрокаТипаПараметра.ИспользоватьДляВыделенияТипа);
		СтрокаТипаПараметра.ЗаменятьПриПолученииОписания = Булево(СтрокаТипаПараметра.ЗаменятьПриПолученииОписания);
		СтрокаТипаПараметра.ЗаменятьПриФорматировании    = Булево(СтрокаТипаПараметра.ЗаменятьПриФорматировании);
		СтрокаТипаПараметра.СоставнойТипПараметра        = Булево(СтрокаТипаПараметра.СоставнойТипПараметра);
	КонецЦикла;
	
	// Сортировка очень важна для последовательной замены типов при получении описания параметров.
	ТаблицаТиповПараметров.Сортировать("ТипПараметраДляПоиска Убыв");
	
	ТаблицаТиповПараметров.Индексы.Добавить("ТипПараметраДляПоиска");
	
	Возврат ТаблицаТиповПараметров;
	
КонецФункции

