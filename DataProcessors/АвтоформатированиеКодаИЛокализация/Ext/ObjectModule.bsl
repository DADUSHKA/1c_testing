Процедура УстановитьЗаголовокПоляСКД(ДокументDOM, ЭлементDOMЭлементаФормы, ЗаголовокДляУстановки, ПрефиксПоля = "xmlns", КодЯзыка = "ru")
	
	// Проверяем элемент "title".
	ЭлементDOMTitle = ПолучитьЭлементDOMПоВыражениюXPath(СтрШаблон("%1:title[@xsi:type='v8:LocalStringType']", ПрефиксПоля), ДокументDOM, ЭлементDOMЭлементаФормы);
	Если ЭлементDOMTitle = Неопределено Тогда
		// Возможно, что элемент был добавлен в предыдущей итерации без указания пространства имен. Ищем еще раз.
		ЭлементDOMTitle = ПолучитьЭлементDOMПоВыражениюXPath("title[@xsi:type='v8:LocalStringType']", ДокументDOM, ЭлементDOMЭлементаФормы);
	КонецЕсли;
	
	Если ЭлементDOMTitle = Неопределено Тогда
		// Если элемента "title" не найдено и устанавливаемый заголовок пустой, то выходим.
		Если ПустаяСтрока(ЗаголовокДляУстановки) Тогда
			Возврат;
		КонецЕсли;
		// Иначе добавляем элемент "title".
		ЭлементDOMTitle = ДобавитьДочернийЭлементDOM(ДокументDOM, ЭлементDOMЭлементаФормы, СтрШаблон("%1title", ?(ПрефиксПоля = "xmlns", "", СтрШаблон("%1:", ПрефиксПоля))));
		ЭлементDOMTitle.УстановитьАтрибут("http://www.w3.org/2001/XMLSchema-instance", "xsi:type", "v8:LocalStringType");
	КонецЕсли;
	
	// Проверяем элемент "v8:item" с подчиненным элементом на русском языке.
	ВыражениеXPath = СтрШаблон("v8:item/v8:lang[text()='%1']", КодЯзыка);
	ЭлементDOMv8lang = ПолучитьЭлементDOMПоВыражениюXPath(ВыражениеXPath, ДокументDOM, ЭлементDOMTitle);
	Если ЭлементDOMv8lang = Неопределено Тогда
		// Если элемента "v8:item" на русском языке не найдено и устанавливаемый заголовок пустой, то выходим.
		Если ПустаяСтрока(ЗаголовокДляУстановки) Тогда
			Возврат;
		КонецЕсли;
		// Иначе добавляем элемент "v8:item".
		ЭлементDOMv8item = ДобавитьДочернийЭлементDOM(ДокументDOM, ЭлементDOMTitle, "v8:item");
		ЭлементDOMv8lang = ДобавитьДочернийЭлементDOM(ДокументDOM, ЭлементDOMv8item, "v8:lang", КодЯзыка);
	КонецЕсли;
	
	ЭлементDOMv8item = ЭлементDOMv8lang.РодительскийУзел;
	ЭлементDOMv8content = ПолучитьЭлементDOMПоВыражениюXPath("v8:content", ДокументDOM, ЭлементDOMv8item);
	Если ЭлементDOMv8content = Неопределено Тогда
		ЭлементDOMv8content = ДобавитьДочернийЭлементDOM(ДокументDOM, ЭлементDOMv8item, "v8:content", ЗаголовокДляУстановки);
	Иначе
		ЭлементDOMv8content.ТекстовоеСодержимое = ЗаголовокДляУстановки;
	КонецЕсли;
	
КонецПроцедуры

