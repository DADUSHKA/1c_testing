Процедура УстановитьЗаголовокЭлементаEDT(ДокументDOM, ЭлементDOMЭлементаФормы, ЗаголовокДляУстановки, КодЯзыка = "ru")
	
	// Проверяем элемент "title/key" с подчиненным элементом на русском языке.
	ВыражениеXPath = СтрШаблон("title/key[text()='%1']", КодЯзыка);
	ЭлементDOMkey = ПолучитьЭлементDOMПоВыражениюXPath(ВыражениеXPath, ДокументDOM, ЭлементDOMЭлементаФормы);
	Если ЭлементDOMkey = Неопределено Тогда
		
		// Если элемента "key" на русском языке не найдено и устанавливаемый заголовок пустой, то выходим.
		Если ПустаяСтрока(ЗаголовокДляУстановки) Тогда
			Возврат;
		КонецЕсли;
		
		// В файле проекта EDT для каждого языка элемент "title" дублируется, поэтому добавляем элемент "title" и "key".
		ЭлементDOMtitle = ДобавитьДочернийЭлементDOM(ДокументDOM, ЭлементDOMЭлементаФормы, "title");
		ЭлементDOMkey = ДобавитьДочернийЭлементDOM(ДокументDOM, ЭлементDOMtitle, "key", КодЯзыка);
		
		// Перенесем элемент "title" после узла "userVisible".
		ВставитьЭлементDOMПослеУказанногоУзла(ДокументDOM, ЭлементDOMЭлементаФормы, ЭлементDOMtitle, "userVisible");
		
	Иначе
		
		// Если элемент "key" с заданным языком существует, то определяем родительский элемент "title".
		ЭлементDOMtitle = ЭлементDOMkey.РодительскийУзел;
		Если ЭлементDOMtitle = Неопределено Тогда
			Возврат;
		КонецЕсли;
		
	КонецЕсли;
	
	ЭлементDOMvalue = ПолучитьЭлементDOMПоВыражениюXPath("value", ДокументDOM, ЭлементDOMtitle);
	Если ЭлементDOMvalue = Неопределено Тогда
		ЭлементDOMvalue = ДобавитьДочернийЭлементDOM(ДокументDOM, ЭлементDOMtitle, "value", ЗаголовокДляУстановки);
	Иначе
		ЭлементDOMvalue.ТекстовоеСодержимое = ЗаголовокДляУстановки;
	КонецЕсли;
	
КонецПроцедуры

Процедура ВставитьЭлементDOMПослеУказанногоУзла(ДокументDOM, ЭлементDOMРодителя, ЭлементDOMВставляемогоУзла, ИмяУзла)
	
	ЭлементDOMУказанногоУзла = ПолучитьЭлементDOMПоВыражениюXPath(ИмяУзла, ДокументDOM, ЭлементDOMРодителя);
	Если ЭлементDOMУказанногоУзла = Неопределено Тогда
		// Если указанного узла не существует, то выходим.
		Возврат;
	КонецЕсли;
	
	// Получаем следующий узел после указанного.
	ЭлементDOMПослеУказанногоУзла = ЭлементDOMУказанногоУзла.СледующийСоседний;
	Если ЭлементDOMПослеУказанногоУзла = Неопределено Тогда
		// Если указанный узел - последний, то переносить не надо, выходим.
		Возврат;
	КонецЕсли;
	
	Если ЭлементDOMВставляемогоУзла = ЭлементDOMПослеУказанногоУзла Тогда
		// Если вставляемый узел сразу после указанного узла, то выходим.
		Возврат;
	КонецЕсли;
	
	// Переносим вставляемый узел после указанного узла.
	ЭлементDOMРодителя.ВставитьПеред(ЭлементDOMВставляемогоУзла, ЭлементDOMПослеУказанногоУзла);
	
КонецПроцедуры

Процедура УстановитьСинонимОбъектаEDT(ДокументDOM, ЭлементDOMСвойствОбъекта, СинонимОбъекта)
	
	// Проверяем элемент "synonym".
	ЭлементDOMСиноним = ПолучитьЭлементDOMПоВыражениюXPath("synonym", ДокументDOM, ЭлементDOMСвойствОбъекта);
	Если ЭлементDOMСиноним = Неопределено Тогда
		// Если элемента "synonym" не найдено и устанавливаемый синоним пустой, то выходим.
		Если ПустаяСтрока(СинонимОбъекта) Тогда
			Возврат;
		КонецЕсли;
		// Иначе добавляем элемент "synonym".
		ЭлементDOMСиноним = ДобавитьДочернийЭлементDOM(ДокументDOM, ЭлементDOMСвойствОбъекта, "synonym");
	КонецЕсли;
	
	// Проверяем элемент "key" с подчиненным элементом на основном языке конфигурации.
	ЭлементDOMkey = ПолучитьЭлементDOMПоВыражениюXPath(СтрШаблон("key[text()='%1']", КодОсновногоЯзыка), ДокументDOM, ЭлементDOMСиноним);
	Если ЭлементDOMkey = Неопределено Тогда
		// Если элемента "key" не найдено и устанавливаемый синоним пустой, то выходим.
		Если ПустаяСтрока(СинонимОбъекта) Тогда
			Возврат;
		КонецЕсли;
		// Иначе добавляем элемент "key".
		ЭлементDOMkey = ДобавитьДочернийЭлементDOM(ДокументDOM, ЭлементDOMСиноним, "key", КодОсновногоЯзыка);
	КонецЕсли;
	
	ЭлементDOMvalue = ПолучитьЭлементDOMПоВыражениюXPath("value", ДокументDOM, ЭлементDOMСиноним);
	Если ЭлементDOMvalue = Неопределено Тогда
		ЭлементDOMvalue = ДобавитьДочернийЭлементDOM(ДокументDOM, ЭлементDOMСиноним, "value", СинонимОбъекта);
	Иначе
		ЭлементDOMvalue.ТекстовоеСодержимое = СинонимОбъекта;
	КонецЕсли;
	
КонецПроцедуры

Процедура УдалитьОтображениеЗаголовкаЭлементаФормыEDT(ДокументDOM, ЭлементDOMЭлементаФормы)
	
	ВыражениеПоиска = "extInfo/showTitle";
	ЗначениеОтображенияЗаголовка = ПолучитьЗначениеЭлементаDOMПоВыражениюXPath(ВыражениеПоиска, ДокументDOM, ЭлементDOMЭлементаФормы);
	Если СтрСравнить(ЗначениеОтображенияЗаголовка, "false") <> 0 Тогда
		// Если узел "showTitle" не равен "false", то выходим.
		Возврат;
	КонецЕсли;
	
	ЭлементDOMГруппаСвойств = ПолучитьЭлементDOMПоВыражениюXPath("extInfo", ДокументDOM, ЭлементDOMЭлементаФормы);
	Если ЭлементDOMГруппаСвойств = Неопределено Тогда
		// Данный узел выгружается всегда. Если его нет в файле, значит файл имеет неверную структуру.
		// Поэтому не добавляем узел программно, а сразу выходим из процедуры.
		Возврат;
	КонецЕсли;
	
	ЭлементDOMОтображениеЗаголовка = ПолучитьЭлементDOMПоВыражениюXPath("showTitle", ДокументDOM, ЭлементDOMГруппаСвойств);
	Если ЭлементDOMОтображениеЗаголовка = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	// Удаляем тег <showTitle>, т.к. в EDT этого тега нет, если значение по умолчанию "false".
	ЭлементDOMГруппаСвойств.УдалитьДочерний(ЭлементDOMОтображениеЗаголовка);
	
КонецПроцедуры

Процедура УстановитьПоложениеЗаголовкаДляЭлементаФормыEDT(ДокументDOM, ЭлементDOMЭлементаФормы, ЗначениеПоложениеЗаголовка = "None")
	
	ЭлементDOMПоложениеЗаголовка = ПолучитьЭлементDOMПоВыражениюXPath("titleLocation", ДокументDOM, ЭлементDOMЭлементаФормы);
	Если ЭлементDOMПоложениеЗаголовка = Неопределено Тогда
		ЭлементDOMПоложениеЗаголовка = ДобавитьДочернийЭлементDOM(ДокументDOM, ЭлементDOMЭлементаФормы, "titleLocation", ЗначениеПоложениеЗаголовка);
	Иначе
		ЭлементDOMПоложениеЗаголовка.ТекстовоеСодержимое = ЗначениеПоложениеЗаголовка;
	КонецЕсли;
	
КонецПроцедуры

Процедура УстановитьПризнакИспользоватьВсегдаEDT(ДокументDOM, ЭлементDOMРеквизит, ИмяРеквизитаСсылка)
	
	ЭлементDOMИспользоватьВсегда = ДобавитьДочернийЭлементDOM(ДокументDOM, ЭлементDOMРеквизит, "notDefaultUseAlwaysAttributes");
	ЭлементDOMИспользоватьВсегда.УстановитьАтрибут("http://www.w3.org/2001/XMLSchema-instance", "xsi:type", "form:DataPath");
	
	ДобавитьДочернийЭлементDOM(ДокументDOM, ЭлементDOMИспользоватьВсегда, "segments", ИмяРеквизитаСсылка);
	
КонецПроцедуры

Процедура УстановитьЗаголовокПоляДинамическогоСпискаEDT(ДокументDOM, ЭлементDOMЭлементаФормы, ЗаголовокДляУстановки, КодЯзыка = "ru")
	
	// Проверяем элемент "title/key" с подчиненным элементом на русском языке.
	ВыражениеXPath = СтрШаблон("title/localValue/content/key[text()='%1']", КодЯзыка);
	ЭлементDOMkey = ПолучитьЭлементDOMПоВыражениюXPath(ВыражениеXPath, ДокументDOM, ЭлементDOMЭлементаФормы);
	Если ЭлементDOMkey = Неопределено Тогда
		
		// Если элемента "key" на русском языке не найдено и устанавливаемый заголовок пустой, то выходим.
		Если ПустаяСтрока(ЗаголовокДляУстановки) Тогда
			Возврат;
		КонецЕсли;
		
		// В файле проекта EDT для каждого языка элемент "title" дублируется, поэтому добавляем элемент "title" и "key".
		ЭлементDOMtitle = ДобавитьДочернийЭлементDOM(ДокументDOM, ЭлементDOMЭлементаФормы, "title");
		ЭлементDOMlocalValue = ДобавитьДочернийЭлементDOM(ДокументDOM, ЭлементDOMtitle, "localValue");
		ЭлементDOMcontent = ДобавитьДочернийЭлементDOM(ДокументDOM, ЭлементDOMlocalValue, "content");
		ЭлементDOMkey = ДобавитьДочернийЭлементDOM(ДокументDOM, ЭлементDOMcontent, "key", КодЯзыка);
		
		// Перенесем элемент "title" после узла "field".
		ВставитьЭлементDOMПослеУказанногоУзла(ДокументDOM, ЭлементDOMЭлементаФормы, ЭлементDOMtitle, "field");
		
	Иначе
		
		// Если элемент "key" с заданным языком существует, то определяем родительский элемент "title".
		ЭлементDOMcontent = ЭлементDOMkey.РодительскийУзел;
		Если ЭлементDOMcontent = Неопределено Тогда
			Возврат;
		КонецЕсли;
		
	КонецЕсли;
	
	ЭлементDOMvalue = ПолучитьЭлементDOMПоВыражениюXPath("value", ДокументDOM, ЭлементDOMcontent);
	Если ЭлементDOMvalue = Неопределено Тогда
		ЭлементDOMvalue = ДобавитьДочернийЭлементDOM(ДокументDOM, ЭлементDOMcontent, "value", ЗаголовокДляУстановки);
	Иначе
		ЭлементDOMvalue.ТекстовоеСодержимое = ЗаголовокДляУстановки;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

