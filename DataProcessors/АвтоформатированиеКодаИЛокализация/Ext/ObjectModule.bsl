Процедура ПривестиКонфигурациюКСтандартам(ЗначениеФлаговНаФорме = Неопределено) Экспорт
	
	Попытка
		ЗаполнитьКонтекст();
		КодОсновногоЯзыка = Контекст["КодОсновногоЯзыкаКонфигурации"];
		
		// Если вызов из формы, то заменим текущее значение флагов на выбранное пользователем.
		Если ЗначениеФлаговНаФорме <> Неопределено Тогда
			ЗначениеФлагов = ЗначениеФлаговНаФорме;
		КонецЕсли;
		
		// Если все-таки значение флагов по какой-то причине не заполнено, переопределим по умолчанию.
		Если ЗначениеФлагов = Неопределено Тогда
			ЗначениеФлагов = ПолучитьЗначенияФлаговПоУмолчанию();
		КонецЕсли;
		
		ЭтоВыгрузкаXMLФайлов = ЭтоВыгрузкаXMLФайлов();
		УстановленОтборПоОбъектам = ПроверитьУстановленОтборПоОбъектам();
		ИнициализироватьТаблицуВыбранныхОбъектов();
		
		Если ЗначениеФлагов.Стандарт437 Тогда
			ПривестиКонфигурациюКСтандарту437();
		КонецЕсли;
		
		Если ЗначениеФлагов.Стандарт441 Тогда
			ПривестиКонфигурациюКСтандарту441();
		КонецЕсли;
		
		Если ЗначениеФлагов.Стандарт453 Тогда
			ПривестиКонфигурациюКСтандарту453();
		КонецЕсли;
		
		Если ЗначениеФлагов.Стандарт455 Тогда
			ПривестиКонфигурациюКСтандарту455();
		КонецЕсли;
		
		Если ЗначениеФлагов.Стандарт456 Тогда
			ПривестиКонфигурациюКСтандарту456();
		КонецЕсли;
		
		Если ЗначениеФлагов.Стандарт458 Тогда
			ПривестиКонфигурациюКСтандарту458();
		КонецЕсли;
		
		Если ЗначениеФлагов.Стандарт467 Тогда
			ПривестиКонфигурациюКСтандарту467();
		КонецЕсли;
		
		Если ЗначениеФлагов.Стандарт474 Тогда
			ПривестиКонфигурациюКСтандарту474();
		КонецЕсли;
		
		Если ЗначениеФлагов.Стандарт478 Тогда
			Если ЭтоВыгрузкаXMLФайлов Тогда
				ПривестиКонфигурациюКСтандарту478();
			Иначе
				ПривестиКонфигурациюКСтандарту478EDT();
			КонецЕсли;
		КонецЕсли;
		
		Если ЗначениеФлагов.Стандарт644 Тогда
			ПривестиКонфигурациюКСтандарту644();
		КонецЕсли;
		
		Если ЗначениеФлагов.Стандарт680 Тогда
			ПривестиКонфигурациюКСтандарту680();
		КонецЕсли;
		
		Если ЗначениеФлагов.Стандарт702 Тогда
			Если ЭтоВыгрузкаXMLФайлов Тогда
				ПривестиКонфигурациюКСтандарту702();
			Иначе
				ПривестиКонфигурациюКСтандарту702EDT();
			КонецЕсли;
		КонецЕсли;
		
		Если ЗначениеФлагов.Стандарт762 Тогда
			ПривестиКонфигурациюКСтандарту762();
		КонецЕсли;
		
		Если ЗначениеФлагов.Стандарт765 Тогда
			Если ЭтоВыгрузкаXMLФайлов Тогда
				ПривестиКонфигурациюКСтандарту765();
			Иначе
				ПривестиКонфигурациюКСтандарту765EDT();
			КонецЕсли;
		КонецЕсли;
		
		Если ЗначениеФлагов.Стандарт767 Тогда
			Если ЭтоВыгрузкаXMLФайлов Тогда
				ПривестиКонфигурациюКСтандарту767();
			Иначе
				ПривестиКонфигурациюКСтандарту767EDT();
			КонецЕсли;
		КонецЕсли;
		
	Исключение
		
		Объект = НСтр("ru='Обработка АвтоформатированиеКодаИЛокализация'; en='Обработка АвтоформатированиеКодаИЛокализация'",
			КодОсновногоЯзыка);
		ОписаниеОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		СформироватьXMLФайлОшибки(Объект, ОписаниеОшибки);
		
	КонецПопытки;
	
КонецПроцедуры

Функция ПроверитьФайлВыбранДляРедактирования(ПолноеИмяФайла)
	
	СтрокаФайлаРезультата = Результат.Найти(ПолноеИмяФайла, "ПолноеИмяФайла");
	Если СтрокаФайлаРезультата = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если УстановленОтборПоОбъектам Тогда
		СтрокаСтруктуры = ТаблицаВыбранныхОбъектов.Найти(СтрокаФайлаРезультата.Объект, "ПутьОбъекта");
		Если СтрокаСтруктуры = Неопределено Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЕсли;
	
	Если (НЕ СтрокаФайлаРезультата.ЗахваченВХранилище)
		 ИЛИ (НЕ СтрокаФайлаРезультата.РедактированиеРазрешено)
		 ИЛИ (НЕ СтрокаФайлаРезультата.ВыбранДляИзменения)
		 ИЛИ СтрокаФайлаРезультата.СодержитОшибки Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

#Область ПроцедурыИФункцииПриведенияКСтандарту437ОформлениеТекстовЗапросов

Функция ПривестиОбъектКСтандарту437(ПолноеИмяФайла)
	
	ДокументТекст = ПолучитьТекстовыйДокументИзФайла(ПолноеИмяФайла, КодировкаТекста.UTF8);
	Если ДокументТекст = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	
	ОбъектИзменен = Ложь;
	
	Если ЗначениеФлагов.КаноническийВидКлючевыхСловЗапроса Тогда
		
		ВремяНачалаЗамера = ТекущаяУниверсальнаяДатаВМиллисекундах();
		ОбъектИзмененПравилом = ПроверкаКаноническогоНаписанияКлючевыхСловЗапроса(ДокументТекст);
		ОбъектИзменен = ОбъектИзменен ИЛИ ОбъектИзмененПравилом;
		
		Если ОбъектИзмененПравилом Тогда
			ЗаполнитьВремяПриведенияКСтандарту("КаноническийВидКлючевыхСловЗапроса", ВремяНачалаЗамера);
			ДобавитьСтрокуВТаблицуИзмененныхОбъектов(ПолноеИмяФайла, "КаноническийВидКлючевыхСловЗапроса");
		КонецЕсли;
		
	КонецЕсли;
	
	Если ОбъектИзменен Тогда
		ЗаписатьИзмененияВФайл(ДокументТекст, ПолноеИмяФайла);
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

Процедура ПривестиКонфигурациюКСтандарту437()
	
	МассивФайлов = НайтиФайлы(КаталогВыгрузкиРезультат, "*.bsl", Истина);
	Для Каждого Файл Из МассивФайлов Цикл
		
