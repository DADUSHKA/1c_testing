				УдалитьПодсказкуЭлементаEDT(ДокументDOM, ЭлементDOMРеквизита);
				Продолжить;
			КонецЕсли;
			
			СинонимРеквизита = ПолучитьСинонимОбъектаEDT(ДокументDOM, ЭлементDOMРеквизита);
			
			ПодсказкаРеквизита = ПреобразоватьТекстДляСравнения(ПодсказкаРеквизита);
