	КонецПопытки;
	
	Возврат Истина;
	
КонецФункции

Процедура СокрТекстДокумента(ДокументТекст, Слева = Истина, Справа = Истина)
	
	ТекстМодуля = ДокументТекст.ПолучитьТекст();
	
	Если Слева Тогда
		ТекстМодуля = СокрЛ(ТекстМодуля);
	КонецЕсли;
	
	Если Справа Тогда
		ТекстМодуля = СокрП(ТекстМодуля);
	КонецЕсли;
	
	ДокументТекст.УстановитьТекст(ТекстМодуля);
	
КонецПроцедуры

Функция ПолучитьКодОсновногоЯзыкаКонфигурации()
	
	КодОсновногоЯзыкаКонфигурации = КодОсновногоЯзыка;
	
	ПутьКФайлуКонфигурации = ?(ЭтоВыгрузкаXMLФайлов, КаталогВыгрузкиРезультат + "Configuration.xml",
		КаталогВыгрузкиРезультат + СтрШаблон("src%1Configuration%1Configuration.mdo", РазделительПути));
	
	Если НЕ апк_ФайлСуществует(ПутьКФайлуКонфигурации) Тогда
		Возврат КодОсновногоЯзыкаКонфигурации;
	КонецЕсли;
	
	ВыражениеПоискаОсновногоЯзыка = ?(ЭтоВыгрузкаXMLФайлов, "//xmlns:DefaultLanguage", "//defaultLanguage");
	ДокументDOM = ДокументDOM(ПутьКФайлуКонфигурации);
	
	РезультатXPath = ВычислитьВыражениеXPath(ВыражениеПоискаОсновногоЯзыка, ДокументDOM);
	
	ЭлементDOMОсновнойЯзык = РезультатXPath.ПолучитьСледующий();
	Если ЭлементDOMОсновнойЯзык = Неопределено Тогда
		Возврат КодОсновногоЯзыкаКонфигурации;
	КонецЕсли;
	
	ОсновнойЯзыкКонфигурации = ЭлементDOMОсновнойЯзык.ТекстовоеСодержимое;
	ОсновнойЯзыкКонфигурации = СтрЗаменить(ОсновнойЯзыкКонфигурации, "Language.", "");
	
	ТаблицаЯзыковКонфигурации = Контекст["ТаблицаЯзыковКонфигурации"];
	Если ТаблицаЯзыковКонфигурации.Количество() = 0 Тогда
		Возврат КодОсновногоЯзыкаКонфигурации;
	КонецЕсли;
	
	НайденнаяСтрока = ТаблицаЯзыковКонфигурации.Найти(ОсновнойЯзыкКонфигурации, "Наименование");
	Если НайденнаяСтрока = Неопределено Тогда
		Возврат КодОсновногоЯзыкаКонфигурации;
	КонецЕсли;
	
	КодЯзыка = НайденнаяСтрока.КодЯзыка;
	// Для языков, отличных от русского и английского, возвращаем значение "en".
	КодЯзыка = ?(КодЯзыка <> "ru" И КодЯзыка <> "en", "en", КодЯзыка);
	
	Возврат КодЯзыка;
	
КонецФункции

Процедура ЗаполнитьВремяПриведенияКСтандарту(Стандарт, ВремяНачалаЗамера)
	
	ТаблицаЗамеровВремениВыполнения = Контекст["ТаблицаЗамеровВремениВыполнения"];
	
	НоваяСтрока = ТаблицаЗамеровВремениВыполнения.Добавить();
	НоваяСтрока.Стандарт = Стандарт;
	НоваяСтрока.ВремяПриведенияКСтандарту = ((ТекущаяУниверсальнаяДатаВМиллисекундах() - ВремяНачалаЗамера) / 1000);
	
	Контекст.Вставить("ТаблицаЗамеровВремениВыполнения", ТаблицаЗамеровВремениВыполнения);
	
КонецПроцедуры

