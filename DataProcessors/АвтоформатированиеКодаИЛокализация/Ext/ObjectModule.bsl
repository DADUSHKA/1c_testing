#Область РегистрацияОшибокСППР

Функция ПолучитьТекстовыйДокументИзФайла(ПолноеИмяФайла, КодировкаФайла = "")
	
	// Если в файле есть ошибки, то не пытаемся читать его повторно.
	Если ФайлСодержитОшибки(ПолноеИмяФайла) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ДокументТекст = Новый ТекстовыйДокумент;
	
	Попытка
		Если ПустаяСтрока(КодировкаФайла) Тогда
			ДокументТекст.Прочитать(ПолноеИмяФайла);
		Иначе
			ДокументТекст.Прочитать(ПолноеИмяФайла, КодировкаФайла);
		КонецЕсли;
	Исключение
		ЗаписатьОшибкуЧтенияФайлаВТаблицуРезультат(ПолноеИмяФайла, ИнформацияОбОшибке());
		Возврат Неопределено;
	КонецПопытки;
	
	Возврат ДокументТекст;
	
КонецФункции

Функция ФайлСодержитОшибки(ПолноеИмяФайла)
	
	СтрокаТаблицы = Результат.Найти(ПолноеИмяФайла, "ПолноеИмяФайла");
	Если СтрокаТаблицы = Неопределено Тогда
		СтрокаТаблицы = Результат.Добавить();
		СтрокаТаблицы.ПолноеИмяФайла = ПолноеИмяФайла;
	КонецЕсли;
	
	Если НЕ апк_ФайлСуществует(ПолноеИмяФайла) Тогда
		СтрокаТаблицы.СодержитОшибки = Истина;
		СтрокаТаблицы.ОписаниеОшибки = СтрШаблон(НСтр("ru='Файл не существует по пути: %1'; en='Файл не существует по пути: %1'",
			КодОсновногоЯзыка), ПолноеИмяФайла);
	КонецЕсли;
	
	Если СтрокаТаблицы.СодержитОшибки Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

Процедура ЗаписатьОшибкуЧтенияФайлаВТаблицуРезультат(ПолноеИмяФайла, ИнформацияОбОшибке)
	
	ОписаниеОшибки = ?(ТипЗнч(ИнформацияОбОшибке) = Тип("Строка"), ИнформацияОбОшибке,
		ПодробноеПредставлениеОшибки(ИнформацияОбОшибке));
	
	СтрокаТаблицы = Результат.Найти(ПолноеИмяФайла, "ПолноеИмяФайла");
	Если СтрокаТаблицы = Неопределено Тогда
		СтрокаТаблицы = Результат.Добавить();
		СтрокаТаблицы.ПолноеИмяФайла = ПолноеИмяФайла;
	КонецЕсли;
	
	СтрокаТаблицы.СодержитОшибки = Истина;
	СтрокаТаблицы.ОписаниеОшибки = ОписаниеОшибки;
	
	СформироватьXMLФайлОшибки(СтрокаТаблицы.Объект, ОписаниеОшибки, ПолноеИмяФайла);
	
КонецПроцедуры

Процедура СформироватьXMLФайлОшибки(Объект, ИнформацияОбОшибке = "", ПолноеИмяФайла = "", Комментарий = "") Экспорт
	
	Если НЕ апк_ФайлСуществует(КаталогФайловОшибокСППР) Тогда
		Возврат;
	КонецЕсли;
	
	ПорядокВоспроизведения = СтрШаблон(НСтр("ru='Для воспроизведения:
		|запустить обработку АвтоформатированиеКодаИЛокализация.epf в пакетном режиме.
		|В качестве параметра запуска указать путь к файлу настроек: ""%1"".';
		|en='Для воспроизведения:
		|запустить обработку АвтоформатированиеКодаИЛокализация.epf в пакетном режиме.
		|В качестве параметра запуска указать путь к файлу настроек: ""%1"".'", КодОсновногоЯзыка),
		ПутьКФайлуНастроекАвтоформатирования);
	
	
	ИдентификаторОшибки = Строка(Новый УникальныйИдентификатор());
	ТипОшибки = НСтр("ru='Ошибка при выполнении обработки АвтоформатированиеКодаИЛокализация';
		|en='Ошибка при выполнении обработки АвтоформатированиеКодаИЛокализация'", КодОсновногоЯзыка);
	
	
	Ошибка = СоздатьОписаниеОшибки();
	Ошибка.ТипОшибки              = ТипОшибки;
	Ошибка.ИсходнаяИнформация     = ПолноеИмяФайла;
	Ошибка.ПорядокВоспроизведения = ПорядокВоспроизведения;
	Ошибка.УточнениеРасположения  = ИнформацияОбОшибке;
	Ошибка.Комментарий            = Комментарий;
	Ошибка.ОбъектМетаданных       = Объект;
	Ошибка.ДатаОбнаружения        = ТекущаяДатаСеанса();
	Ошибка.КодСценария            = ИдентификаторОшибки;
	
	ОбщиеИмяФайлов = Формат(ТекущаяДатаСеанса(), "ДФ=yyyyMMddHHmmss") + "_" + ИдентификаторОшибки;
	ИмяФайлаОшибки = ОтредактироватьПутьККаталогу(КаталогФайловОшибокСППР) + ОбщиеИмяФайлов + ".xml";
	
	ФайлОшибки = Новый ЗаписьТекста(ИмяФайлаОшибки, КодировкаТекста.UTF8);
	ФайлОшибки.Записать(ТекстОшибкиXML(Ошибка));
	ФайлОшибки.Закрыть();
	
КонецПроцедуры

