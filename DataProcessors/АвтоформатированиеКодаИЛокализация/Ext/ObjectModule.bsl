Процедура ЗагрузитьСтруктуруКонфигурации() Экспорт
	
	Если СтруктураКонфигурации.Количество() > 0 Тогда
		Возврат;
	КонецЕсли;
	
	Если ЭтоВыгрузкаXMLФайлов() Тогда
		ЗагрузитьСтруктуруКонфигурацииXML();
	Иначе
		ЗагрузитьСтруктуруКонфигурацииEDT();
	КонецЕсли;
	
КонецПроцедуры

