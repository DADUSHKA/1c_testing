	СтруктураПараметровДереваКонфигурации.Вставить("НаименованиеОбъекта", "");
	СтруктураПараметровДереваКонфигурации.Вставить("НаименованиеПодчиненногоОбъекта", "");
	СтруктураПараметровДереваКонфигурации.Вставить("ДобавлятьВеткуМетаданных", Истина);
	СтруктураПараметровДереваКонфигурации.Вставить("ТаблицаТиповОбъектовДляДереваКонфигурации", ТаблицаТиповОбъектовДляДереваКонфигурации);
	СтруктураПараметровДереваКонфигурации.Вставить("Родитель", "");
	СтруктураПараметровДереваКонфигурации.Вставить("ТипОбъектаРус", "");
	СтруктураПараметровДереваКонфигурации.Вставить("ТипОбъектаАнгл", "");
	СтруктураПараметровДереваКонфигурации.Вставить("ТипОбъектаРусМнФормы", "");
	СтруктураПараметровДереваКонфигурации.Вставить("ТипОбъектаАнглМнФормы", "");
	СтруктураПараметровДереваКонфигурации.Вставить("ТипОбъекта", "");
	СтруктураПараметровДереваКонфигурации.Вставить("ТаблицаПодчиненныхТипов", Новый ТаблицаЗначений);
	СтруктураПараметровДереваКонфигурации.Вставить("ТипПодчиненногоОбъекта", "");
	СтруктураПараметровДереваКонфигурации.Вставить("ТипПодчиненногоОбъектаАнгл", "");
	СтруктураПараметровДереваКонфигурации.Вставить("ТипПодчиненногоОбъектаАнглМнФормы", "");
	СтруктураПараметровДереваКонфигурации.Вставить("ДеревоДанных", Новый ДеревоЗначений);
	СтруктураПараметровДереваКонфигурации.Вставить("МассивСтандартныхРеквизитов", МассивСтандартныхРеквизитовДляПроверкиСуществования);
	
	ЗаполнитьСоставОбщихОбъектовКонфигурацииXML(СтруктураПараметровДереваКонфигурации);
	
	// Все объекты заполняем общей процедурой в цикле.
	СтруктураОтбораДереваКонфигурации = Новый Структура;
	СтруктураОтбораДереваКонфигурации.Вставить("Родитель", "");
	МассивТиповОбъектовДереваКонфигурации = ТаблицаТиповОбъектовДляДереваКонфигурации.НайтиСтроки(СтруктураОтбораДереваКонфигурации);
	Для Каждого СтрокаТипаОбъекта Из МассивТиповОбъектовДереваКонфигурации Цикл
		
		СтруктураПараметровДереваКонфигурации.КаталогОбъектов = КаталогВыгрузкиКопия;
		СтруктураПараметровДереваКонфигурации.ИДРодителя = "";
		СтруктураПараметровДереваКонфигурации.ПутьРодителя = "";
		СтруктураПараметровДереваКонфигурации.СтрокаДанныхОбъекты = СтрокаДанныхОбъекты;
		
		ЗаполнитьЗначенияСвойств(СтруктураПараметровДереваКонфигурации, СтрокаТипаОбъекта);
		СтруктураПараметровДереваКонфигурации.ТипОбъекта = СтрокаТипаОбъекта.ТипОбъектаРус;
		
		ЗаполнитьСоставОбъектовПоТипуXML(СтруктураПараметровДереваКонфигурации);
		
	КонецЦикла;
	
	СтруктураПараметровДереваКонфигурации.КаталогОбъектов = КаталогВыгрузкиКопия;
	СтруктураПараметровДереваКонфигурации.СтрокаДанныхОбъекты = СтрокаДанныхОбъекты;
	
	ЗаполнитьСоставПодсистемXML(СтруктураПараметровДереваКонфигурации);
	
КонецПроцедуры

Процедура ЗаполнитьСоставОбщихОбъектовКонфигурацииXML(СтруктураПараметровДереваКонфигурации)
	
	СтрокаДанныхОбъекты = СтруктураПараметровДереваКонфигурации.СтрокаДанныхОбъекты;
	
	ИДОбщие = Новый УникальныйИдентификатор;
	ПутьОбщие = "Общие";
	
	СтрокаОбщие = СтруктураКонфигурации.Добавить();
	СтрокаОбщие.ТипОбъекта = "ВеткаМетаданных";
	СтрокаОбщие.Объект = ПутьОбщие;
	СтрокаОбщие.ПутьОбъекта = ПутьОбщие;
	СтрокаОбщие.ИД = ИДОбщие;
	
	СтруктураПараметровДереваКонфигурации.СтрокаОбщие = СтрокаОбщие;
	
	КаталогОбъектов = СтруктураПараметровДереваКонфигурации.КаталогВыгрузки;
	
	ТаблицаТиповОбъектовДляДереваКонфигурации = СтруктураПараметровДереваКонфигурации.ТаблицаТиповОбъектовДляДереваКонфигурации;
	
	// Остальные объекты заполняем общей процедурой в цикле.
	СтруктураОтбораВеткаОбщие = Новый Структура;
	СтруктураОтбораВеткаОбщие.Вставить("Родитель", ПутьОбщие);
	МассивТиповОбъектовВеткаОбщие = ТаблицаТиповОбъектовДляДереваКонфигурации.НайтиСтроки(СтруктураОтбораВеткаОбщие);
	Для Каждого СтрокаТипаОбъекта Из МассивТиповОбъектовВеткаОбщие Цикл
		
		ТипОбъектаРус = СтрокаТипаОбъекта.ТипОбъектаРус;
		Если ТипОбъектаРус = "Подсистема" Тогда
			// Подсистемы пропускаем, для них есть отдельное заполнение.
			Продолжить;
		КонецЕсли;
		
		СтруктураПараметровДереваКонфигурации.СтрокаДанныхОбъекты = СтрокаДанныхОбъекты;
		СтруктураПараметровДереваКонфигурации.ИДРодителя = ИДОбщие;
		СтруктураПараметровДереваКонфигурации.ПутьРодителя = ПутьОбщие;
		СтруктураПараметровДереваКонфигурации.КаталогОбъектов = КаталогОбъектов;
		
		ЗаполнитьЗначенияСвойств(СтруктураПараметровДереваКонфигурации, СтрокаТипаОбъекта);
		СтруктураПараметровДереваКонфигурации.ТипОбъекта = ТипОбъектаРус;
		
		ЗаполнитьСоставОбъектовПоТипуXML(СтруктураПараметровДереваКонфигурации);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьСоставОбъектовПоТипуXML(СтруктураПараметровДереваКонфигурации)
	
	ИДВетки = Новый УникальныйИдентификатор;
	
	СтрокаВеткиОбъектов = СтруктураКонфигурации.Добавить();
	СтрокаВеткиОбъектов.ТипОбъекта = "ВеткаМетаданных";
	СтрокаВеткиОбъектов.Объект = СтруктураПараметровДереваКонфигурации.ТипОбъектаРусМнФормы;
	СтрокаВеткиОбъектов.ПутьОбъекта = СтруктураПараметровДереваКонфигурации.ТипОбъектаРусМнФормы;
	СтрокаВеткиОбъектов.ИД = ИДВетки;
	СтрокаВеткиОбъектов.ИДРодителя = СтруктураПараметровДереваКонфигурации.ИДРодителя;
	
	СтрокаДанныхОбъекты = СтруктураПараметровДереваКонфигурации.СтрокаДанныхОбъекты;
	Если СтрокаДанныхОбъекты = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТипОбъектаАнгл = СтруктураПараметровДереваКонфигурации.ТипОбъектаАнгл;
	
	СтруктураОтбора = Новый Структура;
	СтруктураОтбора.Вставить("Имя", ТипОбъектаАнгл);
	
	МассивСтрокОбъекты = СтрокаДанныхОбъекты.Строки.НайтиСтроки(СтруктураОтбора, Ложь);
	Если МассивСтрокОбъекты.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ТипОбъектаАнглМнФормы = СтруктураПараметровДереваКонфигурации.ТипОбъектаАнглМнФормы;
	КаталогОбъектов = СтруктураПараметровДереваКонфигурации.КаталогОбъектов + ТипОбъектаАнглМнФормы + РазделительПути;
	СтруктураПараметровДереваКонфигурации.КаталогОбъектов = КаталогОбъектов;
	
	ЭтоФорма = Ложь;
	Если СтруктураПараметровДереваКонфигурации.ТипОбъектаРус = "ОбщаяФорма" Тогда
		ЭтоФорма = Истина;
	КонецЕсли;
	
	ТипОбъекта = СтруктураПараметровДереваКонфигурации.ТипОбъекта;
	ТипОбъектаРусМнФормы = СтруктураПараметровДереваКонфигурации.ТипОбъектаРусМнФормы;
	
	Для Каждого СтрокаДанныхОбъект Из МассивСтрокОбъекты Цикл
		
		СтруктураПараметровДереваКонфигурации.Вставить("СтрокаДанныхОбъект", СтрокаДанныхОбъект);
		
		НаименованиеОбъекта = СтрокаДанныхОбъект.Значение;
		
		ИДОбъекта = Новый УникальныйИдентификатор;
		ПутьОбъекта = ТипОбъекта + "." + НаименованиеОбъекта;
		
		СтрокаДереваОбъект = СтруктураКонфигурации.Добавить();
		СтрокаДереваОбъект.ТипОбъекта = ТипОбъекта;
		СтрокаДереваОбъект.Объект = НаименованиеОбъекта;
		СтрокаДереваОбъект.ПутьОбъекта = ПутьОбъекта;
		СтрокаДереваОбъект.ИД = ИДОбъекта;
		СтрокаДереваОбъект.ИДРодителя = ИДВетки;
		
		СтруктураПараметровДереваКонфигурации.ИДРодителя = ИДОбъекта;
		СтруктураПараметровДереваКонфигурации.ПутьРодителя = ПутьОбъекта;
		
		ТаблицаПодчиненныхТипов = СтруктураПараметровДереваКонфигурации.ТаблицаПодчиненныхТипов;
		Если ТаблицаПодчиненныхТипов = Неопределено Тогда
			СтруктураПараметровДереваКонфигурации.ИДРодителя = ИДВетки;
			СтруктураПараметровДереваКонфигурации.ПутьРодителя = "";
			Продолжить;
		КонецЕсли;
		
		ФайлОбъекта = СтруктураПараметровДереваКонфигурации.КаталогОбъектов + НаименованиеОбъекта + ".xml";
		Если НЕ апк_ФайлСуществует(ФайлОбъекта) Тогда
			СтруктураПараметровДереваКонфигурации.ИДРодителя = ИДВетки;
			СтруктураПараметровДереваКонфигурации.ПутьРодителя = "";
			Продолжить;
		КонецЕсли;
		
		ДеревоДанных = XML_РазобратьФайлВыгрузки(ФайлОбъекта);
		СтруктураПараметровДереваКонфигурации.ДеревоДанных = ДеревоДанных;
		СтруктураПараметровДереваКонфигурации.НаименованиеОбъекта = НаименованиеОбъекта;
		
		Для Каждого СтрокаПодчиненногоТипа Из ТаблицаПодчиненныхТипов Цикл
			
			ЗаполнитьЗначенияСвойств(СтруктураПараметровДереваКонфигурации, СтрокаПодчиненногоТипа);
			
			ЗаполнитьСоставПодчиненныхОбъектов(СтруктураПараметровДереваКонфигурации);
			
		КонецЦикла;
		
		СтруктураПараметровДереваКонфигурации.ИДРодителя = ИДВетки;
		СтруктураПараметровДереваКонфигурации.ПутьРодителя = "";
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьСоставПодчиненныхОбъектов(СтруктураПараметровДереваКонфигурации)
	
	СтрокаДанныхОбъект = СтруктураПараметровДереваКонфигурации.СтрокаДанныхОбъект;
	ДеревоДанных = СтруктураПараметровДереваКонфигурации.ДеревоДанных;
	
	ТипОбъекта = СтруктураПараметровДереваКонфигурации.ТипОбъекта;
	ТипОбъектаАнгл = СтруктураПараметровДереваКонфигурации.ТипОбъектаАнгл;
	ТипПодчиненногоОбъекта = СтруктураПараметровДереваКонфигурации.ТипПодчиненногоОбъекта;
	ТипПодчиненногоОбъектаАнгл = СтруктураПараметровДереваКонфигурации.ТипПодчиненногоОбъектаАнгл;
	ТипПодчиненногоОбъектаАнглМнФормы = СтруктураПараметровДереваКонфигурации.ТипПодчиненногоОбъектаАнглМнФормы;
	ИДРодителя = СтруктураПараметровДереваКонфигурации.ИДРодителя;
	ПутьРодителя = СтруктураПараметровДереваКонфигурации.ПутьРодителя;
	
	ЭтоСтандартныйРеквизит = (ТипПодчиненногоОбъекта = "СтандартныйРеквизит");
	ЭтоСтандартнаяТабличнаяЧасть = (ТипПодчиненногоОбъекта = "СтандартнаяТабличнаяЧасть");
	
	Если ЭтоСтандартныйРеквизит ИЛИ ЭтоСтандартнаяТабличнаяЧасть Тогда
		ТипПодчиненногоОбъектаАнгл = "xr:" + ТипПодчиненногоОбъектаАнгл;
		СтрокаПоискаПодчиненныеОбъекты = СтрШаблон("MetaDataObject.%1.Properties.%2", ТипОбъектаАнгл, ТипПодчиненногоОбъектаАнглМнФормы);
	Иначе
		СтрокаПоискаПодчиненныеОбъекты = СтрШаблон("MetaDataObject.%1.ChildObjects", ТипОбъектаАнгл);
	КонецЕсли;
	
	СтрокаДанныхПодчиненныеОбъекты = ПолучитьСтрокуДереваПоПравилуПоиска(ДеревоДанных, СтрокаПоискаПодчиненныеОбъекты);
	Если СтрокаДанныхПодчиненныеОбъекты = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СтруктураДанныхПодчиненныеОбъекты = Новый Структура;
	СтруктураДанныхПодчиненныеОбъекты.Вставить("Имя", ТипПодчиненногоОбъектаАнгл);
	
	МассивДанныхПодчиненныеОбъекты = СтрокаДанныхПодчиненныеОбъекты.Строки.НайтиСтроки(СтруктураДанныхПодчиненныеОбъекты);
	Если МассивДанныхПодчиненныеОбъекты.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	КаталогОбъектов = СтруктураПараметровДереваКонфигурации.КаталогОбъектов;
	НаименованиеОбъекта = СтруктураПараметровДереваКонфигурации.НаименованиеОбъекта;
	
	ЭтоФорма = (ТипПодчиненногоОбъекта = "Форма");
	ЭтоМакет = (ТипПодчиненногоОбъекта = "Макет");
	ЭтоТабличнаяЧасть = (ТипПодчиненногоОбъекта = "ТабличнаяЧасть");
	ЭтоОперацияWebСервиса = (ТипПодчиненногоОбъекта = "Операция");
	ЭтоШаблонURL = (ТипПодчиненногоОбъекта = "ШаблонURL");
	
	Для Каждого СтрокаДанныхПодчиненногоОбъекта Из МассивДанныхПодчиненныеОбъекты Цикл
		
		Если ЭтоФорма ИЛИ ЭтоМакет Тогда
			СтрокаДанныхПодчиненныйОбъект = СтрокаДанныхПодчиненногоОбъекта;
		ИначеЕсли ЭтоСтандартныйРеквизит ИЛИ ЭтоСтандартнаяТабличнаяЧасть Тогда
			СтрокаДанныхПодчиненныйОбъект = ПолучитьСтрокуДереваПоПравилуПоиска(СтрокаДанныхПодчиненногоОбъекта, "Атрибуты.name");
		Иначе
			СтрокаДанныхПодчиненныйОбъект = ПолучитьСтрокуДереваПоПравилуПоиска(СтрокаДанныхПодчиненногоОбъекта, "Properties.Name");
		КонецЕсли;
		
		Если СтрокаДанныхПодчиненныйОбъект = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		НаименованиеПодчиненногоОбъекта = СтрокаДанныхПодчиненныйОбъект.Значение;
		
		Если ЭтоСтандартныйРеквизит ИЛИ ЭтоСтандартнаяТабличнаяЧасть Тогда
			
			НаименованиеПодчиненногоОбъекта = ПолучитьНаименованиеСтандартногоРеквизита(НаименованиеПодчиненногоОбъекта);
			
			СтруктураПараметровДереваКонфигурации.НаименованиеПодчиненногоОбъекта = НаименованиеПодчиненногоОбъекта;
			
			// Для стандартных реквизитов необходима дополнительная проверка существования.
			// Т.к. в XML выгружаются либо все стандартные реквизиты, либо ни одного.
			Если НЕ СтандартныйРеквизитСуществует(СтруктураПараметровДереваКонфигурации) Тогда
				// Если стандартный реквизит не существует, то пропускаем.
				Продолжить;
			КонецЕсли;
			
		КонецЕсли;
		
		ИДОбъекта = Новый УникальныйИдентификатор;
		ПутьОбъекта = СтрШаблон("%1.%2.%3", ПутьРодителя, ТипПодчиненногоОбъекта, НаименованиеПодчиненногоОбъекта);
		
		СтрокаДереваПодчиненногоОбъекта = СтруктураКонфигурации.Добавить();
		СтрокаДереваПодчиненногоОбъекта.ТипОбъекта = ТипПодчиненногоОбъекта;
		СтрокаДереваПодчиненногоОбъекта.Объект = НаименованиеПодчиненногоОбъекта;
		СтрокаДереваПодчиненногоОбъекта.ПутьОбъекта = ПутьОбъекта;
		СтрокаДереваПодчиненногоОбъекта.ИД = ИДОбъекта;
		СтрокаДереваПодчиненногоОбъекта.ИДРодителя = ИДРодителя;
		
		// Проверяем реквизиты табличной части, операции web-сервиса и шаблоны URL.
		Если ЭтоТабличнаяЧасть ИЛИ ЭтоОперацияWebСервиса ИЛИ ЭтоШаблонURL Тогда
			
			СтрокаДанныхРеквизитыТабличнойЧасти = ПолучитьСтрокуДереваПоПравилуПоиска(СтрокаДанныхПодчиненногоОбъекта, "ChildObjects");
			Если СтрокаДанныхРеквизитыТабличнойЧасти = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			ТипПодчиненногоОбъектаПодчиненногоОбъекта = "";
			ИмяПодчиненногоОбъектаПодчиненногоОбъектаАнгл = "";
			Если ЭтоТабличнаяЧасть Тогда
				ТипПодчиненногоОбъектаПодчиненногоОбъекта = "Реквизит";
				ИмяПодчиненногоОбъектаПодчиненногоОбъектаАнгл = "Attribute";
			ИначеЕсли ЭтоОперацияWebСервиса Тогда
				ТипПодчиненногоОбъектаПодчиненногоОбъекта = "Параметр";
				ИмяПодчиненногоОбъектаПодчиненногоОбъектаАнгл = "Parameter";
			ИначеЕсли ЭтоШаблонURL Тогда
				ТипПодчиненногоОбъектаПодчиненногоОбъекта = "МетодШаблонаURL";
				ИмяПодчиненногоОбъектаПодчиненногоОбъектаАнгл = "Method";
			Иначе
				Продолжить;
			КонецЕсли;
			
			ЗаполнитьСоставПодчиненныхОбъектовПодчиненныхОбъектов(СтрокаДанныхРеквизитыТабличнойЧасти,
				ИДОбъекта,
				ПутьОбъекта,
				СтруктураПараметровДереваКонфигурации,
				ТипПодчиненногоОбъектаПодчиненногоОбъекта,
				ИмяПодчиненногоОбъектаПодчиненногоОбъектаАнгл);
			
			// Для табличной части необходимо также заполнить стандартные реквизиты, например, НомерСтроки.
			Если ЭтоТабличнаяЧасть Тогда
				
				СтрокаДанныхСтандартныеРеквизитыТабличнойЧасти = ПолучитьСтрокуДереваПоПравилуПоиска(СтрокаДанныхПодчиненногоОбъекта,
					"Properties.StandardAttributes");
				Если СтрокаДанныхСтандартныеРеквизитыТабличнойЧасти = Неопределено Тогда
					Продолжить;
				КонецЕсли;
				
				ЗаполнитьСоставПодчиненныхОбъектовПодчиненныхОбъектов(СтрокаДанныхСтандартныеРеквизитыТабличнойЧасти,
					ИДОбъекта,
					ПутьОбъекта,
					СтруктураПараметровДереваКонфигурации,
					"СтандартныйРеквизит",
					"xr:StandardAttribute");
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьСоставПодчиненныхОбъектовПодчиненныхОбъектов(СтрокаДанных, ИДРодителя, ПутьРодителя,
	СтруктураПараметровДереваКонфигурации, ТипОбъекта, ИмяОбъектаАнгл)
	
	СтруктураДанныхПодчиненныхОбъектов = Новый Структура;
	СтруктураДанныхПодчиненныхОбъектов.Вставить("Имя", ИмяОбъектаАнгл);
	
	МассивДанныхПодчиненныхОбъектов = СтрокаДанных.Строки.НайтиСтроки(СтруктураДанныхПодчиненныхОбъектов);
	Если МассивДанныхПодчиненныхОбъектов.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ЭтоСтандартныйРеквизит = (ТипОбъекта = "СтандартныйРеквизит");
	СтрокаПоиска = ?(ЭтоСтандартныйРеквизит, "Атрибуты.name", "Properties.Name");
	
	Для Каждого СтрокаДанныхПодчиненногоОбъекта Из МассивДанныхПодчиненныхОбъектов Цикл
		
		СтрокаДанныхИмениПодчиненногоОбъекта = ПолучитьСтрокуДереваПоПравилуПоиска(СтрокаДанныхПодчиненногоОбъекта, СтрокаПоиска);
		Если СтрокаДанныхИмениПодчиненногоОбъекта = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		НаименованиеПодчиненногоОбъекта = СтрокаДанныхИмениПодчиненногоОбъекта.Значение;
		
		Если ЭтоСтандартныйРеквизит Тогда
			НаименованиеПодчиненногоОбъекта = ПолучитьНаименованиеСтандартногоРеквизита(НаименованиеПодчиненногоОбъекта);
		КонецЕсли;
		
		СтрокаДереваПодчиненногоОбъекта = СтруктураКонфигурации.Добавить();
		СтрокаДереваПодчиненногоОбъекта.ТипОбъекта = ТипОбъекта;
		СтрокаДереваПодчиненногоОбъекта.Объект = НаименованиеПодчиненногоОбъекта;
		СтрокаДереваПодчиненногоОбъекта.ПутьОбъекта = СтрШаблон("%1.%2.%3",
			ПутьРодителя, ТипОбъекта, НаименованиеПодчиненногоОбъекта);
		СтрокаДереваПодчиненногоОбъекта.ИД = Новый УникальныйИдентификатор;
		СтрокаДереваПодчиненногоОбъекта.ИДРодителя = ИДРодителя;
		
	КонецЦикла;
	
КонецПроцедуры

Функция СтандартныйРеквизитСуществует(СтруктураПараметровДереваКонфигурации)
	
	РеквизитСуществует = Истина;
	
	НаименованиеСтандартногоРеквизита = СтруктураПараметровДереваКонфигурации.НаименованиеПодчиненногоОбъекта;
	
	МассивСтандартныхРеквизитов = СтруктураПараметровДереваКонфигурации.МассивСтандартныхРеквизитов;
	Если МассивСтандартныхРеквизитов.Найти(НаименованиеСтандартногоРеквизита) = Неопределено Тогда
		Возврат РеквизитСуществует;
	КонецЕсли;
	
	ДеревоДанных = СтруктураПараметровДереваКонфигурации.ДеревоДанных;
	ТипОбъекта = СтруктураПараметровДереваКонфигурации.ТипОбъекта;
	ТипОбъектаАнгл = СтруктураПараметровДереваКонфигурации.ТипОбъектаАнгл;
	
	// Проверяем наличие стандартного реквизита.
	Если (НаименованиеСтандартногоРеквизита = "Владелец") ИЛИ (НаименованиеСтандартногоРеквизита = "Owner") Тогда
		
		// Если это владелец, то проверяем наличие свойства "Владельцы".
		СтрокаПоиска = СтрШаблон("MetaDataObject.%1.Properties.Owners", ТипОбъектаАнгл);
		
		СтрокаДереваДанныхВладельцы = ПолучитьСтрокуДереваПоПравилуПоиска(ДеревоДанных, СтрокаПоиска);
		Если СтрокаДереваДанныхВладельцы = Неопределено Тогда
			Возврат Ложь;
		КонецЕсли;
		
		РеквизитСуществует = (СтрокаДереваДанныхВладельцы.Строки.Количество() > 0);
		
	ИначеЕсли (НаименованиеСтандартногоРеквизита = "Наименование") ИЛИ (НаименованиеСтандартногоРеквизита = "Description") Тогда
		
		// Если это код, то проверяем длину кода.
		СтрокаПоиска = СтрШаблон("MetaDataObject.%1.Properties.DescriptionLength", ТипОбъектаАнгл);
		
		СтрокаДереваДанныхДлинаНаименования = ПолучитьСтрокуДереваПоПравилуПоиска(ДеревоДанных, СтрокаПоиска);
		Если СтрокаДереваДанныхДлинаНаименования = Неопределено Тогда
			Возврат Ложь;
		КонецЕсли;
		
		СтрокаДереваДанныхДлинаНаименованияЗначение = СтрокаДереваДанныхДлинаНаименования.Значение;
		Если НЕ апк_ЭтоЧисло(СтрокаДереваДанныхДлинаНаименованияЗначение) Тогда
			Возврат Ложь;
		КонецЕсли;
		
		РеквизитСуществует = Число(СтрокаДереваДанныхДлинаНаименованияЗначение) > 0;
		
	ИначеЕсли (НаименованиеСтандартногоРеквизита = "Код") ИЛИ (НаименованиеСтандартногоРеквизита = "Code") Тогда
		
		// Если это код, то проверяем длину кода.
		СтрокаПоиска = СтрШаблон("MetaDataObject.%1.Properties.CodeLength", ТипОбъектаАнгл);
		
		СтрокаДереваДанныхДлинаКода = ПолучитьСтрокуДереваПоПравилуПоиска(ДеревоДанных, СтрокаПоиска);
		Если СтрокаДереваДанныхДлинаКода = Неопределено Тогда
			Возврат Ложь;
		КонецЕсли;
		
		СтрокаДереваДанныхДлинаКодаЗначение = СтрокаДереваДанныхДлинаКода.Значение;
		Если НЕ апк_ЭтоЧисло(СтрокаДереваДанныхДлинаКодаЗначение) Тогда
			Возврат Ложь;
		КонецЕсли;
		
		РеквизитСуществует = Число(СтрокаДереваДанныхДлинаКодаЗначение) > 0;
		
	ИначеЕсли (НаименованиеСтандартногоРеквизита = "Родитель") ИЛИ (НаименованиеСтандартногоРеквизита = "Parent") Тогда
		
		// Если это родитель, то проверяем свойство "Иерархия".
		СтрокаПоиска = СтрШаблон("MetaDataObject.%1.Properties.Hierarchical", ТипОбъектаАнгл);
		
		СтрокаДереваДанныхИерархия = ПолучитьСтрокуДереваПоПравилуПоиска(ДеревоДанных, СтрокаПоиска);
		Если СтрокаДереваДанныхИерархия = Неопределено Тогда
			Возврат Ложь;
		КонецЕсли;
		
		СтрокаДереваДанныхИерархияЗначение = СтрокаДереваДанныхИерархия.Значение;
		РеквизитСуществует = апк_ЭтоБулево(СтрокаДереваДанныхИерархияЗначение);
		
	ИначеЕсли (НаименованиеСтандартногоРеквизита = "ЭтоГруппа") ИЛИ (НаименованиеСтандартногоРеквизита = "IsFolder") Тогда
		
		// Если это группа, то проверяем свойство "Иерархия".
		СтрокаПоиска = СтрШаблон("MetaDataObject.%1.Properties.Hierarchical", ТипОбъектаАнгл);
		
		СтрокаДереваДанныхИерархия = ПолучитьСтрокуДереваПоПравилуПоиска(ДеревоДанных, СтрокаПоиска);
		Если СтрокаДереваДанныхИерархия = Неопределено Тогда
			Возврат Ложь;
		КонецЕсли;
		
		СтрокаДереваДанныхИерархияЗначение = СтрокаДереваДанныхИерархия.Значение;
		СтрокаДереваДанныхИерархияЗначение = апк_ЭтоБулево(СтрокаДереваДанныхИерархияЗначение);
		
		// Если есть иерархия, то проверяем ее значение.
		Если НЕ СтрокаДереваДанныхИерархияЗначение Тогда
			Возврат Ложь;
		КонецЕсли;
		
		// Для планов видов характеристик достаточно, чтобы была иерархия, остальные свойства не проверяем.
		Если ТипОбъекта = "ПланВидовХарактеристик" Тогда
			Возврат РеквизитСуществует;
		КонецЕсли;
		
		СтрокаПоиска = СтрШаблон("MetaDataObject.%1.Properties.HierarchyType", ТипОбъектаАнгл);
		
		СтрокаДереваДанныхТипИерархии = ПолучитьСтрокуДереваПоПравилуПоиска(ДеревоДанных, СтрокаПоиска);
		Если СтрокаДереваДанныхТипИерархии = Неопределено Тогда
			Возврат Ложь;
		КонецЕсли;
		
		РеквизитСуществует = (СтрокаДереваДанныхТипИерархии.Значение = "HierarchyFoldersAndItems");
		
	КонецЕсли;
	
	Возврат РеквизитСуществует;
	
КонецФункции

Функция ПолучитьНаименованиеКонфигурации(ДеревоДанных)
	
	НаименованиеКонфигурации = "Конфигурация";
	
	СтрокаПоискаНаименование = "MetaDataObject.Configuration.Properties.Name";
	СтрокаДанныхНаименование = ПолучитьСтрокуДереваПоПравилуПоиска(ДеревоДанных, СтрокаПоискаНаименование);
	Если СтрокаДанныхНаименование <> Неопределено Тогда
		НаименованиеКонфигурации = СтрокаДанныхНаименование.Значение;
	КонецЕсли;
	
	Возврат НаименованиеКонфигурации;
	
КонецФункции

Процедура ЗаполнитьСоставПодсистемXML(СтруктураПараметровДереваКонфигурации)
	
	ИДРодителя = СтруктураПараметровДереваКонфигурации.ИДРодителя;
	ПутьРодителя = СтруктураПараметровДереваКонфигурации.ПутьРодителя;
	
	ДобавлятьВеткуМетаданных = СтруктураПараметровДереваКонфигурации.ДобавлятьВеткуМетаданных;
	Если ДобавлятьВеткуМетаданных Тогда
		
		СтруктураПараметровДереваКонфигурации.ТипОбъекта = "Подсистема";
		СтруктураПараметровДереваКонфигурации.ТипОбъектаРус = "Подсистема";
		СтруктураПараметровДереваКонфигурации.ТипОбъектаРусМнФормы = "Подсистемы";
		СтруктураПараметровДереваКонфигурации.ТипОбъектаАнгл = "Subsystem";
		СтруктураПараметровДереваКонфигурации.ТипОбъектаАнглМнФормы = "Subsystems";
		
		ИД = Новый УникальныйИдентификатор;
		ПутьРодителя = СтруктураПараметровДереваКонфигурации.ТипОбъектаРусМнФормы;
		
		СтрокаОбъекта = СтруктураКонфигурации.Вставить(2);
		СтрокаОбъекта.ТипОбъекта = "ВеткаМетаданных";
		СтрокаОбъекта.Объект = СтруктураПараметровДереваКонфигурации.ТипОбъектаРусМнФормы;
		СтрокаОбъекта.ПутьОбъекта = ПутьРодителя;
		СтрокаОбъекта.ИД = ИД;
		СтрокаОбъекта.ИДРодителя = СтруктураПараметровДереваКонфигурации.СтрокаОбщие.ИД;;
		
		ИДРодителя = ИД;
		ПутьРодителя = "";
		
	КонецЕсли;
	
	СтрокаДанныхОбъекты = СтруктураПараметровДереваКонфигурации.СтрокаДанныхОбъекты;
	Если СтрокаДанныхОбъекты = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТипОбъекта = СтруктураПараметровДереваКонфигурации.ТипОбъекта;
	ТипОбъектаАнгл = СтруктураПараметровДереваКонфигурации.ТипОбъектаАнгл;
	
	СтруктураОтбора = Новый Структура;
	СтруктураОтбора.Вставить("Имя", ТипОбъектаАнгл);
	
	МассивСтрокОбъекты = СтрокаДанныхОбъекты.Строки.НайтиСтроки(СтруктураОтбора, Ложь);
	Если МассивСтрокОбъекты.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ТипОбъектаАнглМнФормы = СтруктураПараметровДереваКонфигурации.ТипОбъектаАнглМнФормы;
	ТипОбъектаРусМнФормы = СтруктураПараметровДереваКонфигурации.ТипОбъектаРусМнФормы;
	
	КаталогОбъектов = СтруктураПараметровДереваКонфигурации.КаталогОбъектов + ТипОбъектаАнглМнФормы + РазделительПути;
	
	Для Каждого СтрокаДанныхОбъект Из МассивСтрокОбъекты Цикл
		
		НаименованиеОбъекта = СтрокаДанныхОбъект.Значение;
		
		ИДОбъекта = Новый УникальныйИдентификатор;
		ПутьОбъекта = СтрШаблон("%1.%2", ПутьРодителя, НаименованиеОбъекта);
		ПутьОбъекта = СтрСоединить(СтрРазделить(ПутьОбъекта, ".", Ложь), ".");
		
		СтрокаДереваОбъект = СтруктураКонфигурации.Добавить();
		СтрокаДереваОбъект.ТипОбъекта = ТипОбъекта;
		СтрокаДереваОбъект.Объект = НаименованиеОбъекта;
		СтрокаДереваОбъект.ПутьОбъекта = ПутьОбъекта;
		СтрокаДереваОбъект.ИД = ИДОбъекта;
		СтрокаДереваОбъект.ИДРодителя = ИДРодителя;
		
		ФайлОбъекта = КаталогОбъектов + НаименованиеОбъекта + ".xml";
		
		ДеревоДанных = XML_РазобратьФайлВыгрузки(ФайлОбъекта);
		ЗаполнитьСоставОбъектовПодсистемы(СтрокаДереваОбъект, ДеревоДанных);
		
		СтрокаПоискаОбъекты = СтрШаблон("MetaDataObject.%1.ChildObjects", ТипОбъектаАнгл);
		СтрокаДанныхОбъекты = ПолучитьСтрокуДереваПоПравилуПоиска(ДеревоДанных, СтрокаПоискаОбъекты);
		Если СтрокаДанныхОбъекты = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Если СтрокаДанныхОбъекты.Строки.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		КаталогОбъекта = КаталогОбъектов + НаименованиеОбъекта + РазделительПути;
		
		СтруктураПараметровДереваКонфигурации.ИДРодителя = ИДОбъекта;
		СтруктураПараметровДереваКонфигурации.ПутьРодителя = ПутьОбъекта;
		СтруктураПараметровДереваКонфигурации.КаталогОбъектов = КаталогОбъекта;
		СтруктураПараметровДереваКонфигурации.ДобавлятьВеткуМетаданных = Ложь;
		СтруктураПараметровДереваКонфигурации.СтрокаДанныхОбъекты = СтрокаДанныхОбъекты;
		
		ЗаполнитьСоставПодсистемXML(СтруктураПараметровДереваКонфигурации);
		
		СтруктураПараметровДереваКонфигурации.КаталогОбъектов = КаталогОбъектов;
		СтруктураПараметровДереваКонфигурации.СтрокаДанныхОбъекты = СтрокаДанныхОбъекты;
		
	КонецЦикла;
	
	СтрокаОбъектыБезПодсистем = СтруктураКонфигурации.Добавить();
	СтрокаОбъектыБезПодсистем.Объект = НСтр("ru='<Не входящие в подсистемы>'; en='<Не входящие в подсистемы>'",
		КодОсновногоЯзыка);
	
КонецПроцедуры

Процедура ЗаполнитьСоставОбъектовПодсистемы(СтрокаДереваПодсистема, ДеревоДанныхПодсистемы)
	
	СтрокаПоискаСостав = "MetaDataObject.Subsystem.Properties.Content";
	СтрокаДанныхСостав = ПолучитьСтрокуДереваПоПравилуПоиска(ДеревоДанныхПодсистемы, СтрокаПоискаСостав);
	Если СтрокаДанныхСостав = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если СтрокаДанныхСостав.Строки.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого СтрокаДанныхОбъекта Из СтрокаДанныхСостав.Строки Цикл
		
		ПутьОбъектаАнгл = СтрокаДанныхОбъекта.Значение;
		МассивПутиАнгл = СтрРазделить(ПутьОбъектаАнгл, ".");
		Если МассивПутиАнгл.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		МассивПутиАнгл[0] = ПолучитьТипОбъектаПоТаблицеТипов(МассивПутиАнгл[0]);
		
		ПутьОбъекта = СтрСоединить(МассивПутиАнгл, ".");
		СтрокаСтруктурыКонфигурации = СтруктураКонфигурации.Найти(ПутьОбъекта, "ПутьОбъекта");
		Если СтрокаСтруктурыКонфигурации = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаТаблицы = СоставПодсистем.Добавить();
		СтрокаТаблицы.ИДПодсистемы = СтрокаДереваПодсистема.ИД;
		СтрокаТаблицы.ИДОбъекта = СтрокаСтруктурыКонфигурации.ИД;
		
	КонецЦикла;
	
КонецПроцедуры

Функция ПолучитьЯзыкиКонфигурацииXML()
	
	ТаблицаЯзыковКонфигурации = Новый ТаблицаЗначений;
	ТаблицаЯзыковКонфигурации.Колонки.Добавить("Наименование");
	ТаблицаЯзыковКонфигурации.Колонки.Добавить("Синоним");
	ТаблицаЯзыковКонфигурации.Колонки.Добавить("КодЯзыка");
	
	ВыражениеПоискаКодаЯзыка = "//xmlns:LanguageCode";
	
	// Ищем файлы языков в каталоге языков.
	КаталогЯзыков = КаталогВыгрузкиРезультат + СтрШаблон("%1Languages%1", РазделительПути);
	МаскаФайлов   = "*.xml";
	ФайлыЯзыков   = НайтиФайлы(КаталогЯзыков, МаскаФайлов, Ложь);
	
	Для Каждого ФайлЯзыка Из ФайлыЯзыков Цикл
		
		ДокументDOM = ДокументDOM(ФайлЯзыка.ПолноеИмя);
		Если ДокументDOM = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		// Ищем код языка.
		РезультатXPath = ВычислитьВыражениеXPath(ВыражениеПоискаКодаЯзыка, ДокументDOM);
		
		ЭлементDOMКодЯзыка = РезультатXPath.ПолучитьСледующий();
		Если ЭлементDOMКодЯзыка = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		НовыйЯзык = ТаблицаЯзыковКонфигурации.Добавить();
		НовыйЯзык.КодЯзыка = ЭлементDOMКодЯзыка.ТекстовоеСодержимое;
		
		ЭлементDOMЯзык = ЭлементDOMКодЯзыка.РодительскийУзел;
		Если ЭлементDOMЯзык = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		НовыйЯзык.Наименование = ПолучитьЗначениеЭлементаDOMПоВыражениюXPath("xmlns:Name", ДокументDOM, ЭлементDOMЯзык);
		НовыйЯзык.Синоним = ПолучитьЗначениеЭлементаDOMПоВыражениюXPath("xmlns:Synonym/v8:item/v8:content", ДокументDOM, ЭлементDOMЯзык);
		
	КонецЦикла;
	
	Возврат ТаблицаЯзыковКонфигурации;
	
КонецФункции

#КонецОбласти

#Область ПолучениеСтруктурыКонфигурацииEDT

Процедура ЗагрузитьСтруктуруКонфигурацииEDT()
	
	КаталогВыгрузкиКопия = ОтредактироватьПутьККаталогу(КаталогВыгрузкиРезультат) + "src" + РазделительПути;
	
	ПутьКФайлуКонфигурации = КаталогВыгрузкиКопия + СтрШаблон("Configuration%1Configuration.mdo", РазделительПути);
	Если НЕ апк_ФайлСуществует(ПутьКФайлуКонфигурации) Тогда
		Возврат;
	КонецЕсли;
	
	ТаблицаТиповОбъектовИнициализировать();
	ТаблицаТиповОбъектовДляДереваКонфигурации = ПолучитьТаблицуТиповОбъектовДляДереваКонфигурации();
	
	ДеревоДанных = XML_РазобратьФайлВыгрузки(ПутьКФайлуКонфигурации);
	
	НаименованиеКонфигурации = ПолучитьНаименованиеКонфигурацииEDT(ДеревоДанных);
	
	СтрокаКонфигурации = СтруктураКонфигурации.Добавить();
	СтрокаКонфигурации.ТипОбъекта = "Конфигурация";
	СтрокаКонфигурации.Объект = НаименованиеКонфигурации + " (Конфигурация)";
	СтрокаКонфигурации.ПутьОбъекта = НаименованиеКонфигурации;
	СтрокаКонфигурации.ИД = Новый УникальныйИдентификатор;
	
	СтрокаПоискаОбъекты = "mdclass:Configuration";
	СтрокаДанныхОбъекты = ПолучитьСтрокуДереваПоПравилуПоиска(ДеревоДанных, СтрокаПоискаОбъекты);
	
	МассивСтандартныхРеквизитовДляПроверкиСуществования = Новый Массив;
	МассивСтандартныхРеквизитовДляПроверкиСуществования.Добавить("Родитель");
	МассивСтандартныхРеквизитовДляПроверкиСуществования.Добавить("Владелец");
	МассивСтандартныхРеквизитовДляПроверкиСуществования.Добавить("ЭтоГруппа");
	МассивСтандартныхРеквизитовДляПроверкиСуществования.Добавить("Код");
	МассивСтандартныхРеквизитовДляПроверкиСуществования.Добавить("Наименование");
	МассивСтандартныхРеквизитовДляПроверкиСуществования.Добавить("Parent");
	МассивСтандартныхРеквизитовДляПроверкиСуществования.Добавить("Owner");
	МассивСтандартныхРеквизитовДляПроверкиСуществования.Добавить("Code");
	МассивСтандартныхРеквизитовДляПроверкиСуществования.Добавить("Description");
	
	СтруктураПараметровДереваКонфигурации = Новый Структура;
	СтруктураПараметровДереваКонфигурации.Вставить("КаталогВыгрузки", КаталогВыгрузкиКопия);
	СтруктураПараметровДереваКонфигурации.Вставить("КаталогОбъектов", КаталогВыгрузкиКопия);
	СтруктураПараметровДереваКонфигурации.Вставить("ИДРодителя", "");
	СтруктураПараметровДереваКонфигурации.Вставить("ПутьРодителя", "");
	СтруктураПараметровДереваКонфигурации.Вставить("СтрокаДанныхОбъекты", СтрокаДанныхОбъекты);
	СтруктураПараметровДереваКонфигурации.Вставить("СтрокаОбщие", "");
	СтруктураПараметровДереваКонфигурации.Вставить("НаименованиеОбъекта", "");
	СтруктураПараметровДереваКонфигурации.Вставить("НаименованиеПодчиненногоОбъекта", "");
	СтруктураПараметровДереваКонфигурации.Вставить("ДобавлятьВеткуМетаданных", Истина);
	СтруктураПараметровДереваКонфигурации.Вставить("ТаблицаТиповОбъектовДляДереваКонфигурации", ТаблицаТиповОбъектовДляДереваКонфигурации);
	СтруктураПараметровДереваКонфигурации.Вставить("Родитель", "");
	СтруктураПараметровДереваКонфигурации.Вставить("ТипОбъектаРус", "");
	СтруктураПараметровДереваКонфигурации.Вставить("ТипОбъектаАнгл", "");
	СтруктураПараметровДереваКонфигурации.Вставить("ТипОбъектаРусМнФормы", "");
	СтруктураПараметровДереваКонфигурации.Вставить("ТипОбъектаАнглМнФормы", "");
	СтруктураПараметровДереваКонфигурации.Вставить("ТипОбъекта", "");
	СтруктураПараметровДереваКонфигурации.Вставить("ТаблицаПодчиненныхТипов", Новый ТаблицаЗначений);
	СтруктураПараметровДереваКонфигурации.Вставить("ТипПодчиненногоОбъекта", "");
	СтруктураПараметровДереваКонфигурации.Вставить("ТипПодчиненногоОбъектаАнгл", "");
	СтруктураПараметровДереваКонфигурации.Вставить("ТипПодчиненногоОбъектаАнглМнФормы", "");
	СтруктураПараметровДереваКонфигурации.Вставить("ДеревоДанных", Новый ДеревоЗначений);
	СтруктураПараметровДереваКонфигурации.Вставить("МассивСтандартныхРеквизитов", МассивСтандартныхРеквизитовДляПроверкиСуществования);
	
	ЗаполнитьСоставОбщихОбъектовКонфигурацииEDT(СтруктураПараметровДереваКонфигурации);
	
	// Все объекты заполняем общей процедурой в цикле.
	СтруктураОтбораДереваКонфигурации = Новый Структура;
	СтруктураОтбораДереваКонфигурации.Вставить("Родитель", "");
	МассивТиповОбъектовДереваКонфигурации = ТаблицаТиповОбъектовДляДереваКонфигурации.НайтиСтроки(СтруктураОтбораДереваКонфигурации);
	Для Каждого СтрокаТипаОбъекта Из МассивТиповОбъектовДереваКонфигурации Цикл
		
		СтруктураПараметровДереваКонфигурации.КаталогОбъектов = КаталогВыгрузкиКопия;
		СтруктураПараметровДереваКонфигурации.ИДРодителя = "";
		СтруктураПараметровДереваКонфигурации.ПутьРодителя = "";
		СтруктураПараметровДереваКонфигурации.СтрокаДанныхОбъекты = СтрокаДанныхОбъекты;
		
		ЗаполнитьЗначенияСвойств(СтруктураПараметровДереваКонфигурации, СтрокаТипаОбъекта);
		СтруктураПараметровДереваКонфигурации.ТипОбъекта = СтрокаТипаОбъекта.ТипОбъектаРус;
		
		ЗаполнитьСоставОбъектовПоТипуEDT(СтруктураПараметровДереваКонфигурации);
		
	КонецЦикла;
	
	СтруктураПараметровДереваКонфигурации.КаталогОбъектов = КаталогВыгрузкиКопия;
	СтруктураПараметровДереваКонфигурации.СтрокаДанныхОбъекты = СтрокаДанныхОбъекты;
	
	ЗаполнитьСоставПодсистемEDT(СтруктураПараметровДереваКонфигурации);
	
КонецПроцедуры

Процедура ЗаполнитьСоставОбщихОбъектовКонфигурацииEDT(СтруктураПараметровДереваКонфигурации)
	
	СтрокаДанныхОбъекты = СтруктураПараметровДереваКонфигурации.СтрокаДанныхОбъекты;
	
	ИДОбщие = Новый УникальныйИдентификатор;
	ПутьОбщие = "Общие";
	
	СтрокаОбщие = СтруктураКонфигурации.Добавить();
	СтрокаОбщие.ТипОбъекта = "ВеткаМетаданных";
	СтрокаОбщие.Объект = ПутьОбщие;
	СтрокаОбщие.ПутьОбъекта = ПутьОбщие;
	СтрокаОбщие.ИД = ИДОбщие;
	
	СтруктураПараметровДереваКонфигурации.СтрокаОбщие = СтрокаОбщие;
	
	КаталогОбъектов = СтруктураПараметровДереваКонфигурации.КаталогВыгрузки;
	
	ТаблицаТиповОбъектовДляДереваКонфигурации = СтруктураПараметровДереваКонфигурации.ТаблицаТиповОбъектовДляДереваКонфигурации;
	
	// Остальные объекты заполняем общей процедурой в цикле.
	СтруктураОтбораВеткаОбщие = Новый Структура;
	СтруктураОтбораВеткаОбщие.Вставить("Родитель", ПутьОбщие);
	МассивТиповОбъектовВеткаОбщие = ТаблицаТиповОбъектовДляДереваКонфигурации.НайтиСтроки(СтруктураОтбораВеткаОбщие);
	Для Каждого СтрокаТипаОбъекта Из МассивТиповОбъектовВеткаОбщие Цикл
		
		ТипОбъектаРус = СтрокаТипаОбъекта.ТипОбъектаРус;
		Если ТипОбъектаРус = "Подсистема" Тогда
			// Подсистемы пропускаем, для них есть отдельное заполнение.
			Продолжить;
		КонецЕсли;
		
		СтруктураПараметровДереваКонфигурации.СтрокаДанныхОбъекты = СтрокаДанныхОбъекты;
		СтруктураПараметровДереваКонфигурации.ИДРодителя = ИДОбщие;
		СтруктураПараметровДереваКонфигурации.ПутьРодителя = ПутьОбщие;
		СтруктураПараметровДереваКонфигурации.КаталогОбъектов = КаталогОбъектов;
		
		ЗаполнитьЗначенияСвойств(СтруктураПараметровДереваКонфигурации, СтрокаТипаОбъекта);
		СтруктураПараметровДереваКонфигурации.ТипОбъекта = ТипОбъектаРус;
		
		ЗаполнитьСоставОбъектовПоТипуEDT(СтруктураПараметровДереваКонфигурации);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьСоставОбъектовПоТипуEDT(СтруктураПараметровДереваКонфигурации)
	
	ИДВетки = Новый УникальныйИдентификатор;
	
	СтрокаВеткиОбъектов = СтруктураКонфигурации.Добавить();
	СтрокаВеткиОбъектов.ТипОбъекта = "ВеткаМетаданных";
	СтрокаВеткиОбъектов.Объект = СтруктураПараметровДереваКонфигурации.ТипОбъектаРусМнФормы;
	СтрокаВеткиОбъектов.ПутьОбъекта = СтруктураПараметровДереваКонфигурации.ТипОбъектаРусМнФормы;
	СтрокаВеткиОбъектов.ИД = ИДВетки;
	СтрокаВеткиОбъектов.ИДРодителя = СтруктураПараметровДереваКонфигурации.ИДРодителя;
	
	СтрокаДанныхОбъекты = СтруктураПараметровДереваКонфигурации.СтрокаДанныхОбъекты;
	Если СтрокаДанныхОбъекты = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТипОбъектаАнглМнФормы = СтруктураПараметровДереваКонфигурации.ТипОбъектаАнглМнФормы;
	
	СтруктураОтбора = Новый Структура;
	СтруктураОтбора.Вставить("ИмяНРег", НРег(ТипОбъектаАнглМнФормы));
	
	МассивСтрокОбъекты = СтрокаДанныхОбъекты.Строки.НайтиСтроки(СтруктураОтбора, Ложь);
	Если МассивСтрокОбъекты.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	КаталогОбъектов = СтруктураПараметровДереваКонфигурации.КаталогОбъектов + ТипОбъектаАнглМнФормы + РазделительПути;
	СтруктураПараметровДереваКонфигурации.КаталогОбъектов = КаталогОбъектов;
	
	ЭтоФорма = Ложь;
	Если СтруктураПараметровДереваКонфигурации.ТипОбъектаРус = "ОбщаяФорма" Тогда
		ЭтоФорма = Истина;
	КонецЕсли;
	
	ТипОбъекта = СтруктураПараметровДереваКонфигурации.ТипОбъекта;
	ТипОбъектаРусМнФормы = СтруктураПараметровДереваКонфигурации.ТипОбъектаРусМнФормы;
	
	Для Каждого СтрокаДанныхОбъект Из МассивСтрокОбъекты Цикл
		
		СтруктураПараметровДереваКонфигурации.Вставить("СтрокаДанныхОбъект", СтрокаДанныхОбъект);
		
		МассивНаименованияОбъекта = СтрРазделить(СтрокаДанныхОбъект.Значение, ".");
		Если МассивНаименованияОбъекта.Количество() <> 2 Тогда
			Продолжить;
		КонецЕсли;
		
		НаименованиеОбъекта = МассивНаименованияОбъекта[1];
		
		ИДОбъекта = Новый УникальныйИдентификатор;
		ПутьОбъекта = ТипОбъекта + "." + НаименованиеОбъекта;
		
		СтрокаДереваОбъект = СтруктураКонфигурации.Добавить();
		СтрокаДереваОбъект.ТипОбъекта = ТипОбъекта;
		СтрокаДереваОбъект.Объект = НаименованиеОбъекта;
		СтрокаДереваОбъект.ПутьОбъекта = ПутьОбъекта;
		СтрокаДереваОбъект.ИД = ИДОбъекта;
		СтрокаДереваОбъект.ИДРодителя = ИДВетки;
		
		СтруктураПараметровДереваКонфигурации.ИДРодителя = ИДОбъекта;
		СтруктураПараметровДереваКонфигурации.ПутьРодителя = ПутьОбъекта;
		
		ТаблицаПодчиненныхТипов = СтруктураПараметровДереваКонфигурации.ТаблицаПодчиненныхТипов;
		Если ТаблицаПодчиненныхТипов = Неопределено Тогда
			СтруктураПараметровДереваКонфигурации.ИДРодителя = ИДВетки;
			СтруктураПараметровДереваКонфигурации.ПутьРодителя = "";
			Продолжить;
		КонецЕсли;
		
		ФайлОбъекта = СтрШаблон("%1%2%3%2.mdo", СтруктураПараметровДереваКонфигурации.КаталогОбъектов,
			НаименованиеОбъекта, РазделительПути);
		Если НЕ апк_ФайлСуществует(ФайлОбъекта) Тогда
			СтруктураПараметровДереваКонфигурации.ИДРодителя = ИДВетки;
			СтруктураПараметровДереваКонфигурации.ПутьРодителя = "";
			Продолжить;
		КонецЕсли;
		
		ДеревоДанных = XML_РазобратьФайлВыгрузки(ФайлОбъекта);
		СтруктураПараметровДереваКонфигурации.ДеревоДанных = ДеревоДанных;
		СтруктураПараметровДереваКонфигурации.НаименованиеОбъекта = НаименованиеОбъекта;
		
		Для Каждого СтрокаПодчиненногоТипа Из ТаблицаПодчиненныхТипов Цикл
			
			ЗаполнитьЗначенияСвойств(СтруктураПараметровДереваКонфигурации, СтрокаПодчиненногоТипа);
			
			ЗаполнитьСоставПодчиненныхОбъектовEDT(СтруктураПараметровДереваКонфигурации);
			
		КонецЦикла;
		
		СтруктураПараметровДереваКонфигурации.ИДРодителя = ИДВетки;
		СтруктураПараметровДереваКонфигурации.ПутьРодителя = "";
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьСоставПодчиненныхОбъектовEDT(СтруктураПараметровДереваКонфигурации)
	
	СтрокаДанныхОбъект = СтруктураПараметровДереваКонфигурации.СтрокаДанныхОбъект;
	ДеревоДанных = СтруктураПараметровДереваКонфигурации.ДеревоДанных;
	
	ТипОбъекта = СтруктураПараметровДереваКонфигурации.ТипОбъекта;
	ТипОбъектаАнгл = СтруктураПараметровДереваКонфигурации.ТипОбъектаАнгл;
	ТипПодчиненногоОбъекта = СтруктураПараметровДереваКонфигурации.ТипПодчиненногоОбъекта;
	ТипПодчиненногоОбъектаАнгл = СтруктураПараметровДереваКонфигурации.ТипПодчиненногоОбъектаАнгл;
	ТипПодчиненногоОбъектаАнглМнФормы = СтруктураПараметровДереваКонфигурации.ТипПодчиненногоОбъектаАнглМнФормы;
	ИДРодителя = СтруктураПараметровДереваКонфигурации.ИДРодителя;
	ПутьРодителя = СтруктураПараметровДереваКонфигурации.ПутьРодителя;
	
	ЭтоСтандартныйРеквизит = (ТипПодчиненногоОбъекта = "СтандартныйРеквизит");
	ЭтоСтандартнаяТабличнаяЧасть = (ТипПодчиненногоОбъекта = "СтандартнаяТабличнаяЧасть");
	
	СтрокаПоискаПодчиненныеОбъекты = СтрШаблон("mdclass:%1", ТипОбъектаАнгл);
	
	СтрокаДанныхПодчиненныеОбъекты = ПолучитьСтрокуДереваПоПравилуПоиска(ДеревоДанных, СтрокаПоискаПодчиненныеОбъекты);
	Если СтрокаДанныхПодчиненныеОбъекты = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СтруктураДанныхПодчиненныеОбъекты = Новый Структура;
	СтруктураДанныхПодчиненныеОбъекты.Вставить("ИмяНРег", НРег(ТипПодчиненногоОбъектаАнглМнФормы));
	
	МассивДанныхПодчиненныеОбъекты = СтрокаДанныхПодчиненныеОбъекты.Строки.НайтиСтроки(СтруктураДанныхПодчиненныеОбъекты);
	Если МассивДанныхПодчиненныеОбъекты.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	КаталогОбъектов = СтруктураПараметровДереваКонфигурации.КаталогОбъектов;
	НаименованиеОбъекта = СтруктураПараметровДереваКонфигурации.НаименованиеОбъекта;
	
	ЭтоТабличнаяЧасть = (ТипПодчиненногоОбъекта = "ТабличнаяЧасть");
	ЭтоОперацияWebСервиса = (ТипПодчиненногоОбъекта = "Операция");
	ЭтоШаблонURL = (ТипПодчиненногоОбъекта = "ШаблонURL");
	
	Для Каждого СтрокаДанныхПодчиненногоОбъекта Из МассивДанныхПодчиненныеОбъекты Цикл
		
		СтрокаДанныхПодчиненныйОбъект = ПолучитьСтрокуДереваПоПравилуПоиска(СтрокаДанныхПодчиненногоОбъекта, "name");
		Если СтрокаДанныхПодчиненныйОбъект = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		НаименованиеПодчиненногоОбъекта = СтрокаДанныхПодчиненныйОбъект.Значение;
		
		Если ЭтоСтандартныйРеквизит ИЛИ ЭтоСтандартнаяТабличнаяЧасть Тогда
			
			НаименованиеПодчиненногоОбъекта = ПолучитьНаименованиеСтандартногоРеквизита(НаименованиеПодчиненногоОбъекта);
			
			СтруктураПараметровДереваКонфигурации.НаименованиеПодчиненногоОбъекта = НаименованиеПодчиненногоОбъекта;
			
			// Для стандартных реквизитов необходима дополнительная проверка существования.
			// Т.к. в XML выгружаются либо все стандартные реквизиты, либо ни одного.
			Если НЕ СтандартныйРеквизитСуществуетEDT(СтруктураПараметровДереваКонфигурации) Тогда
				// Если стандартный реквизит не существует, то пропускаем.
				Продолжить;
			КонецЕсли;
			
		КонецЕсли;
		
		ИДОбъекта = Новый УникальныйИдентификатор;
		ПутьОбъекта = СтрШаблон("%1.%2.%3", ПутьРодителя, ТипПодчиненногоОбъекта, НаименованиеПодчиненногоОбъекта);
		
		СтрокаДереваПодчиненногоОбъекта = СтруктураКонфигурации.Добавить();
		СтрокаДереваПодчиненногоОбъекта.ТипОбъекта = ТипПодчиненногоОбъекта;
		СтрокаДереваПодчиненногоОбъекта.Объект = НаименованиеПодчиненногоОбъекта;
		СтрокаДереваПодчиненногоОбъекта.ПутьОбъекта = ПутьОбъекта;
		СтрокаДереваПодчиненногоОбъекта.ИД = ИДОбъекта;
		СтрокаДереваПодчиненногоОбъекта.ИДРодителя = ИДРодителя;
		
		// Проверяем реквизиты табличной части, операции web-сервиса и шаблоны URL.
		Если ЭтоТабличнаяЧасть ИЛИ ЭтоОперацияWebСервиса ИЛИ ЭтоШаблонURL Тогда
			
			ТипПодчиненногоОбъектаПодчиненногоОбъекта = "";
			ИмяПодчиненногоОбъектаПодчиненногоОбъектаАнгл = "";
			Если ЭтоТабличнаяЧасть Тогда
				ТипПодчиненногоОбъектаПодчиненногоОбъекта = "Реквизит";
				ИмяПодчиненногоОбъектаПодчиненногоОбъектаАнгл = "attributes";
			ИначеЕсли ЭтоОперацияWebСервиса Тогда
				ТипПодчиненногоОбъектаПодчиненногоОбъекта = "Параметр";
				ИмяПодчиненногоОбъектаПодчиненногоОбъектаАнгл = "parameters";
			ИначеЕсли ЭтоШаблонURL Тогда
				ТипПодчиненногоОбъектаПодчиненногоОбъекта = "МетодШаблонаURL";
				ИмяПодчиненногоОбъектаПодчиненногоОбъектаАнгл = "methods";
			Иначе
				Продолжить;
			КонецЕсли;
			
			ЗаполнитьСоставПодчиненныхОбъектовПодчиненныхОбъектовEDT(СтрокаДанныхПодчиненногоОбъекта,
				ИДОбъекта,
				ПутьОбъекта,
				СтруктураПараметровДереваКонфигурации,
				ТипПодчиненногоОбъектаПодчиненногоОбъекта,
				ИмяПодчиненногоОбъектаПодчиненногоОбъектаАнгл);
			
			// Для табличной части необходимо также заполнить стандартные реквизиты, например, НомерСтроки.
			Если ЭтоТабличнаяЧасть Тогда
				
				ЗаполнитьСоставПодчиненныхОбъектовПодчиненныхОбъектовEDT(СтрокаДанныхПодчиненногоОбъекта,
					ИДОбъекта,
					ПутьОбъекта,
					СтруктураПараметровДереваКонфигурации,
					"СтандартныйРеквизит",
					"standardAttributes");
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьСоставПодчиненныхОбъектовПодчиненныхОбъектовEDT(СтрокаДанных, ИДРодителя, ПутьРодителя,
	СтруктураПараметровДереваКонфигурации, ТипОбъекта, ИмяОбъектаАнгл)
	
	СтруктураДанныхПодчиненныхОбъектов = Новый Структура;
	СтруктураДанныхПодчиненныхОбъектов.Вставить("ИмяНРег", НРег(ИмяОбъектаАнгл));
	
	МассивДанныхПодчиненныхОбъектов = СтрокаДанных.Строки.НайтиСтроки(СтруктураДанныхПодчиненныхОбъектов);
	Если МассивДанныхПодчиненныхОбъектов.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ЭтоСтандартныйРеквизит = (ТипОбъекта = "СтандартныйРеквизит");
	
	Для Каждого СтрокаДанныхПодчиненногоОбъекта Из МассивДанныхПодчиненныхОбъектов Цикл
		
		СтрокаДанныхИмениПодчиненногоОбъекта = ПолучитьСтрокуДереваПоПравилуПоиска(СтрокаДанныхПодчиненногоОбъекта, "name");
		Если СтрокаДанныхИмениПодчиненногоОбъекта = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		НаименованиеПодчиненногоОбъекта = СтрокаДанныхИмениПодчиненногоОбъекта.Значение;
		
		Если ЭтоСтандартныйРеквизит Тогда
			НаименованиеПодчиненногоОбъекта = ПолучитьНаименованиеСтандартногоРеквизита(НаименованиеПодчиненногоОбъекта);
		КонецЕсли;
		
		СтрокаДереваПодчиненногоОбъекта = СтруктураКонфигурации.Добавить();
		СтрокаДереваПодчиненногоОбъекта.ТипОбъекта = ТипОбъекта;
		СтрокаДереваПодчиненногоОбъекта.Объект = НаименованиеПодчиненногоОбъекта;
		СтрокаДереваПодчиненногоОбъекта.ПутьОбъекта = СтрШаблон("%1.%2.%3",
			ПутьРодителя, ТипОбъекта, НаименованиеПодчиненногоОбъекта);
		СтрокаДереваПодчиненногоОбъекта.ИД = Новый УникальныйИдентификатор;
		СтрокаДереваПодчиненногоОбъекта.ИДРодителя = ИДРодителя;
		
	КонецЦикла;
	
КонецПроцедуры

Функция СтандартныйРеквизитСуществуетEDT(СтруктураПараметровДереваКонфигурации)
	
	РеквизитСуществует = Истина;
	
	НаименованиеСтандартногоРеквизита = СтруктураПараметровДереваКонфигурации.НаименованиеПодчиненногоОбъекта;
	
	МассивСтандартныхРеквизитов = СтруктураПараметровДереваКонфигурации.МассивСтандартныхРеквизитов;
	Если МассивСтандартныхРеквизитов.Найти(НаименованиеСтандартногоРеквизита) = Неопределено Тогда
		Возврат РеквизитСуществует;
	КонецЕсли;
	
	ДеревоДанных = СтруктураПараметровДереваКонфигурации.ДеревоДанных;
	ТипОбъекта = СтруктураПараметровДереваКонфигурации.ТипОбъекта;
	ТипОбъектаАнгл = СтруктураПараметровДереваКонфигурации.ТипОбъектаАнгл;
	
	// Проверяем наличие стандартного реквизита.
	Если (НаименованиеСтандартногоРеквизита = "Владелец") ИЛИ (НаименованиеСтандартногоРеквизита = "Owner") Тогда
		
		// Если это владелец, то проверяем наличие свойства "Владельцы".
		СтрокаПоискаПодчиненныеОбъекты = СтрШаблон("mdclass:%1", ТипОбъектаАнгл);
		СтрокаПоиска = СтрШаблон("mdclass:%1.owners", ТипОбъектаАнгл);
		
		СтрокаДереваДанныхВладельцы = ПолучитьСтрокуДереваПоПравилуПоиска(ДеревоДанных, СтрокаПоиска);
		
		РеквизитСуществует = (СтрокаДереваДанныхВладельцы <> Неопределено);
		
	ИначеЕсли (НаименованиеСтандартногоРеквизита = "Наименование") ИЛИ (НаименованиеСтандартногоРеквизита = "Description") Тогда
		
		// Если это наименование, то проверяем длину кода.
		СтрокаПоиска = СтрШаблон("mdclass:%1.descriptionLength", ТипОбъектаАнгл);
		
		СтрокаДереваДанныхДлинаНаименования = ПолучитьСтрокуДереваПоПравилуПоиска(ДеревоДанных, СтрокаПоиска);
		Если СтрокаДереваДанныхДлинаНаименования = Неопределено Тогда
			Возврат Ложь;
		КонецЕсли;
		
		СтрокаДереваДанныхДлинаНаименованияЗначение = СтрокаДереваДанныхДлинаНаименования.Значение;
		Если НЕ апк_ЭтоЧисло(СтрокаДереваДанныхДлинаНаименованияЗначение) Тогда
			Возврат Ложь;
		КонецЕсли;
		
		РеквизитСуществует = Число(СтрокаДереваДанныхДлинаНаименованияЗначение) > 0;
		
	ИначеЕсли (НаименованиеСтандартногоРеквизита = "Код") ИЛИ (НаименованиеСтандартногоРеквизита = "Code") Тогда
		
		// Если это код, то проверяем длину кода.
		СтрокаПоиска = СтрШаблон("mdclass:%1.codeLength", ТипОбъектаАнгл);
		
		СтрокаДереваДанныхДлинаКода = ПолучитьСтрокуДереваПоПравилуПоиска(ДеревоДанных, СтрокаПоиска);
		Если СтрокаДереваДанныхДлинаКода = Неопределено Тогда
			Возврат Ложь;
		КонецЕсли;
		
		СтрокаДереваДанныхДлинаКодаЗначение = СтрокаДереваДанныхДлинаКода.Значение;
		Если НЕ апк_ЭтоЧисло(СтрокаДереваДанныхДлинаКодаЗначение) Тогда
			Возврат Ложь;
		КонецЕсли;
		
		РеквизитСуществует = Число(СтрокаДереваДанныхДлинаКодаЗначение) > 0;
		
	ИначеЕсли (НаименованиеСтандартногоРеквизита = "Родитель") ИЛИ (НаименованиеСтандартногоРеквизита = "Parent") Тогда
		
		// Если это родитель, то проверяем свойство "Иерархия".
		СтрокаПоиска = СтрШаблон("mdclass:%1.hierarchical", ТипОбъектаАнгл);
		
		СтрокаДереваДанныхИерархия = ПолучитьСтрокуДереваПоПравилуПоиска(ДеревоДанных, СтрокаПоиска);
		Если СтрокаДереваДанныхИерархия = Неопределено Тогда
			Возврат Ложь;
		КонецЕсли;
		
		СтрокаДереваДанныхИерархияЗначение = СтрокаДереваДанныхИерархия.Значение;
		РеквизитСуществует = апк_ЭтоБулево(СтрокаДереваДанныхИерархияЗначение);
		
	ИначеЕсли (НаименованиеСтандартногоРеквизита = "ЭтоГруппа") ИЛИ (НаименованиеСтандартногоРеквизита = "IsFolder") Тогда
		
		// Если это группа, то проверяем свойство "Иерархия".
		СтрокаПоиска = СтрШаблон("mdclass:%1.hierarchical", ТипОбъектаАнгл);
		
		СтрокаДереваДанныхИерархия = ПолучитьСтрокуДереваПоПравилуПоиска(ДеревоДанных, СтрокаПоиска);
		Если СтрокаДереваДанныхИерархия = Неопределено Тогда
			Возврат Ложь;
		КонецЕсли;
		
		СтрокаДереваДанныхИерархияЗначение = СтрокаДереваДанныхИерархия.Значение;
		СтрокаДереваДанныхИерархияЗначение = апк_ЭтоБулево(СтрокаДереваДанныхИерархияЗначение);
		
		// Если есть иерархия, то проверяем ее значение.
		Если НЕ СтрокаДереваДанныхИерархияЗначение Тогда
			Возврат Ложь;
		КонецЕсли;
		
		// Для планов видов характеристик достаточно, чтобы была иерархия, остальные свойства не проверяем.
		Если ТипОбъекта = "ПланВидовХарактеристик" Тогда
			Возврат РеквизитСуществует;
		КонецЕсли;
		
		СтрокаПоиска = СтрШаблон("mdclass:%1.hierarchyType", ТипОбъектаАнгл);
		
		СтрокаДереваДанныхТипИерархии = ПолучитьСтрокуДереваПоПравилуПоиска(ДеревоДанных, СтрокаПоиска);
		Если СтрокаДереваДанныхТипИерархии = Неопределено Тогда
			// Если значение иерархии "Иерархия групп и элементов", то это свойство не выгружается в файл.
			Возврат Истина;
		КонецЕсли;
		
		РеквизитСуществует = (СтрСравнить(СтрокаДереваДанныхТипИерархии.Значение, "HierarchyFoldersAndItems") = 0);
		
	КонецЕсли;
	
	Возврат РеквизитСуществует;
	
КонецФункции

Функция ПолучитьНаименованиеКонфигурацииEDT(ДеревоДанных)
	
	НаименованиеКонфигурации = "Конфигурация";
	
	СтрокаПоискаНаименование = "mdclass:Configuration.Name";
	СтрокаДанныхНаименование = ПолучитьСтрокуДереваПоПравилуПоиска(ДеревоДанных, СтрокаПоискаНаименование);
	Если СтрокаДанныхНаименование <> Неопределено Тогда
		НаименованиеКонфигурации = СтрокаДанныхНаименование.Значение;
	КонецЕсли;
	
	Возврат НаименованиеКонфигурации;
	
КонецФункции

Процедура ЗаполнитьСоставПодсистемEDT(СтруктураПараметровДереваКонфигурации)
	
	ИДРодителя = СтруктураПараметровДереваКонфигурации.ИДРодителя;
	ПутьРодителя = СтруктураПараметровДереваКонфигурации.ПутьРодителя;
	
	ДобавлятьВеткуМетаданных = СтруктураПараметровДереваКонфигурации.ДобавлятьВеткуМетаданных;
	Если ДобавлятьВеткуМетаданных Тогда
		
		СтруктураПараметровДереваКонфигурации.ТипОбъекта = "Подсистема";
		СтруктураПараметровДереваКонфигурации.ТипОбъектаРус = "Подсистема";
		СтруктураПараметровДереваКонфигурации.ТипОбъектаРусМнФормы = "Подсистемы";
		СтруктураПараметровДереваКонфигурации.ТипОбъектаАнгл = "Subsystem";
		СтруктураПараметровДереваКонфигурации.ТипОбъектаАнглМнФормы = "Subsystems";
		
		ИД = Новый УникальныйИдентификатор;
		ПутьРодителя = СтруктураПараметровДереваКонфигурации.ТипОбъектаРусМнФормы;
		
		СтрокаОбъекта = СтруктураКонфигурации.Вставить(2);
		СтрокаОбъекта.ТипОбъекта = "ВеткаМетаданных";
		СтрокаОбъекта.Объект = СтруктураПараметровДереваКонфигурации.ТипОбъектаРусМнФормы;
		СтрокаОбъекта.ПутьОбъекта = ПутьРодителя;
		СтрокаОбъекта.ИД = ИД;
		СтрокаОбъекта.ИДРодителя = СтруктураПараметровДереваКонфигурации.СтрокаОбщие.ИД;;
		
		ИДРодителя = ИД;
		ПутьРодителя = "";
		
	КонецЕсли;
	
	СтрокаДанныхОбъекты = СтруктураПараметровДереваКонфигурации.СтрокаДанныхОбъекты;
	Если СтрокаДанныхОбъекты = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТипОбъекта = СтруктураПараметровДереваКонфигурации.ТипОбъекта;
	ТипОбъектаАнглМнФормы = СтруктураПараметровДереваКонфигурации.ТипОбъектаАнглМнФормы;
	
	СтруктураОтбора = Новый Структура;
	СтруктураОтбора.Вставить("ИмяНРег", НРег(ТипОбъектаАнглМнФормы));
	
	МассивСтрокОбъекты = СтрокаДанныхОбъекты.Строки.НайтиСтроки(СтруктураОтбора, Ложь);
	Если МассивСтрокОбъекты.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ТипОбъектаРусМнФормы = СтруктураПараметровДереваКонфигурации.ТипОбъектаРусМнФормы;
	ТипОбъектаАнгл = СтруктураПараметровДереваКонфигурации.ТипОбъектаАнгл;
	
	КаталогОбъектов = СтруктураПараметровДереваКонфигурации.КаталогОбъектов + ТипОбъектаАнглМнФормы + РазделительПути;
	
	Для Каждого СтрокаДанныхОбъект Из МассивСтрокОбъекты Цикл
		
		НаименованиеОбъекта = СтрокаДанныхОбъект.Значение;
		НаименованиеОбъекта = СтрЗаменить(НаименованиеОбъекта, "Subsystem.", "");
		
		ИДОбъекта = Новый УникальныйИдентификатор;
		ПутьОбъекта = СтрШаблон("%1.%2", ПутьРодителя, НаименованиеОбъекта);
		ПутьОбъекта = СтрСоединить(СтрРазделить(ПутьОбъекта, ".", Ложь), ".");
		
		СтрокаДереваОбъект = СтруктураКонфигурации.Добавить();
		СтрокаДереваОбъект.ТипОбъекта = ТипОбъекта;
		СтрокаДереваОбъект.Объект = НаименованиеОбъекта;
		СтрокаДереваОбъект.ПутьОбъекта = ПутьОбъекта;
		СтрокаДереваОбъект.ИД = ИДОбъекта;
		СтрокаДереваОбъект.ИДРодителя = ИДРодителя;
		
		ФайлОбъекта = СтрШаблон("%1%2%3%2.mdo", КаталогОбъектов, НаименованиеОбъекта, РазделительПути);
		Если НЕ апк_ФайлСуществует(ФайлОбъекта) Тогда
			Продолжить;
		КонецЕсли;
		
		ДеревоДанных = XML_РазобратьФайлВыгрузки(ФайлОбъекта);
		
		СтрокаДанныхПодсистемы = ПолучитьСтрокуДереваПоПравилуПоиска(ДеревоДанных, "mdclass:Subsystem");
		Если СтрокаДанныхПодсистемы = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ЗаполнитьСоставОбъектовПодсистемыEDT(СтрокаДереваОбъект, СтрокаДанныхПодсистемы);
		
		КаталогОбъекта = КаталогОбъектов + НаименованиеОбъекта + РазделительПути;
		
		СтруктураПараметровДереваКонфигурации.ИДРодителя = ИДОбъекта;
		СтруктураПараметровДереваКонфигурации.ПутьРодителя = ПутьОбъекта;
		СтруктураПараметровДереваКонфигурации.КаталогОбъектов = КаталогОбъекта;
		СтруктураПараметровДереваКонфигурации.ДобавлятьВеткуМетаданных = Ложь;
		СтруктураПараметровДереваКонфигурации.СтрокаДанныхОбъекты = СтрокаДанныхПодсистемы;
		
		ЗаполнитьСоставПодсистемEDT(СтруктураПараметровДереваКонфигурации);
		
		СтруктураПараметровДереваКонфигурации.КаталогОбъектов = КаталогОбъектов;
		СтруктураПараметровДереваКонфигурации.СтрокаДанныхОбъекты = СтрокаДанныхПодсистемы;
		
	КонецЦикла;
	
	СтрокаОбъектыБезПодсистем = СтруктураКонфигурации.Добавить();
	СтрокаОбъектыБезПодсистем.Объект = НСтр("ru='<Не входящие в подсистемы>'; en='<Не входящие в подсистемы>'",
		КодОсновногоЯзыка);
	
КонецПроцедуры

Процедура ЗаполнитьСоставОбъектовПодсистемыEDT(СтрокаДереваПодсистема, ДеревоДанныхПодсистемы)
	
	СтруктураОтбора = Новый Структура;
	СтруктураОтбора.Вставить("ИмяНРег", "content");
	
	МассивСтрокСостав = ДеревоДанныхПодсистемы.Строки.НайтиСтроки(СтруктураОтбора, Ложь);
	Если МассивСтрокСостав.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого СтрокаДанныхОбъекта Из МассивСтрокСостав Цикл
		
		ПутьОбъектаАнгл = СтрокаДанныхОбъекта.Значение;
		МассивПутиАнгл = СтрРазделить(ПутьОбъектаАнгл, ".");
		Если МассивПутиАнгл.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		МассивПутиАнгл[0] = ПолучитьТипОбъектаПоТаблицеТипов(МассивПутиАнгл[0]);
		
		ПутьОбъекта = СтрСоединить(МассивПутиАнгл, ".");
		СтрокаСтруктурыКонфигурации = СтруктураКонфигурации.Найти(ПутьОбъекта, "ПутьОбъекта");
		Если СтрокаСтруктурыКонфигурации = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаТаблицы = СоставПодсистем.Добавить();
		СтрокаТаблицы.ИДПодсистемы = СтрокаДереваПодсистема.ИД;
		СтрокаТаблицы.ИДОбъекта = СтрокаСтруктурыКонфигурации.ИД;
		
	КонецЦикла;
	
КонецПроцедуры

Функция ПолучитьЯзыкиКонфигурацииEDT()
	
	ТаблицаЯзыковКонфигурации = Новый ТаблицаЗначений;
	ТаблицаЯзыковКонфигурации.Колонки.Добавить("Наименование");
	ТаблицаЯзыковКонфигурации.Колонки.Добавить("Синоним");
	ТаблицаЯзыковКонфигурации.Колонки.Добавить("КодЯзыка");
	
	ФайлКонфигурации = ПолучитьФайлКонфигурации();
	Если НЕ апк_ФайлСуществует(ФайлКонфигурации) Тогда
		Возврат ТаблицаЯзыковКонфигурации;
	КонецЕсли;
	
	ДокументDOM = ДокументDOM(ФайлКонфигурации);
	Если ДокументDOM = Неопределено Тогда
		Возврат ТаблицаЯзыковКонфигурации;
	КонецЕсли;
	
	ВыражениеПоискаКодаЯзыка = "//languages/languageCode";
	РезультатXPath = ВычислитьВыражениеXPath(ВыражениеПоискаКодаЯзыка, ДокументDOM);
	Пока Истина Цикл
		
		ЭлементDOMКодЯзыка = РезультатXPath.ПолучитьСледующий();
		Если ЭлементDOMКодЯзыка = Неопределено Тогда
			Прервать;
		КонецЕсли;
		
		НовыйЯзык = ТаблицаЯзыковКонфигурации.Добавить();
		НовыйЯзык.КодЯзыка = ЭлементDOMКодЯзыка.ТекстовоеСодержимое;
		
		ЭлементDOMЯзык = ЭлементDOMКодЯзыка.РодительскийУзел;
		Если ЭлементDOMЯзык = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		НовыйЯзык.Наименование = ПолучитьЗначениеЭлементаDOMПоВыражениюXPath("name", ДокументDOM, ЭлементDOMЯзык);
		НовыйЯзык.Синоним = ПолучитьЗначениеЭлементаDOMПоВыражениюXPath("synonym/value", ДокументDOM, ЭлементDOMЯзык);
		
	КонецЦикла;
	
	Возврат ТаблицаЯзыковКонфигурации;
	
КонецФункции

#КонецОбласти

#Область РазборФайлаВыгрузкиXML

// Функция получает дерево значений из файла xml формы
//
Функция XML_РазобратьФайлВыгрузки(ПолноеИмяФайла, ДеревоДанных = "") Экспорт
	
	XML_СоздатьДеревоФайлаВыгрузки(ДеревоДанных);
	
	ЧтениеXML = XML_ПрочитатьФайлВыгрузки(ПолноеИмяФайла);
	Если ЧтениеXML = Неопределено Тогда
		Возврат ДеревоДанных;
	КонецЕсли;
	
	XML_ПолучитьДеревоИзФайлаВыгрузки(ДеревоДанных, ЧтениеXML, ПолноеИмяФайла);
	
	Возврат ДеревоДанных;
	
КонецФункции

// Функция создает пустое дерево значений структуры "Имя, ИмяНРег, Значение".
// Параметры:
//   Дерево - ДеревоЗначений, дерево значений, которое будет приведено к необходимой структуре и очищено.
// Возвращаемое значение:
//   ДеревоЗначений.
Функция XML_СоздатьДеревоФайлаВыгрузки(Дерево = "")
	
	Если ТипЗнч(Дерево) <> Тип("ДеревоЗначений") Тогда
		Дерево = Новый ДеревоЗначений;
	КонецЕсли;
	
	Описание = Новый ОписаниеТипов("Строка");
	Колонки = Дерево.Колонки;
	
	Если Колонки.Найти("Имя") = Неопределено Тогда
		Колонки.Добавить("Имя", Описание);
	КонецЕсли;
	
	Если Колонки.Найти("ИмяНРег") = Неопределено Тогда
		Колонки.Добавить("ИмяНРег", Описание);
	КонецЕсли;
	
	Если Колонки.Найти("Значение") = Неопределено Тогда
		Колонки.Добавить("Значение", Описание);
	КонецЕсли;
	
	Дерево.Строки.Очистить();
	
	Возврат Дерево;
	
КонецФункции

Функция XML_ПрочитатьФайлВыгрузки(ПутьФайла)
	
	ЧтениеXML = Новый ЧтениеXML;
	ЧтениеXML.ИгнорироватьПробелы = Ложь;
	
	Попытка
		ЧтениеXML.ОткрытьФайл(ПутьФайла);
	Исключение
		ЗаписатьОшибкуЧтенияФайлаВТаблицуРезультат(ПутьФайла, ИнформацияОбОшибке());
		Возврат Неопределено;
	КонецПопытки;
	
	Возврат ЧтениеXML;
	
КонецФункции

Функция XML_ПолучитьДеревоИзФайлаВыгрузки(ДеревоДанных, ЧтениеXML, ПолноеИмяФайла = "")
	
	Попытка
		Пока ЧтениеXML.Прочитать() Цикл
			
			ТипУзла = ЧтениеXML.ТипУзла;
			
			Если ТипУзла = ТипУзлаXML.НачалоЭлемента Тогда
				СтрокаДерева = XML_ДобавитьСтрокуДерева(ДеревоДанных, ЧтениеXML.Имя);
				
				XML_ДобавитьАтрибутыВДерево(СтрокаДерева, ЧтениеXML);
				XML_ПолучитьДеревоИзФайлаВыгрузки(СтрокаДерева, ЧтениеXML, ПолноеИмяФайла);
			ИначеЕсли ТипУзла = ТипУзлаXML.Текст Тогда
				ДеревоДанных.Значение = ЧтениеXML.Значение;
			ИначеЕсли ТипУзла = ТипУзлаXML.КонецЭлемента Тогда
				Возврат "";
			КонецЕсли;
			
		КонецЦикла;
	Исключение
		ЗаписатьОшибкуЧтенияФайлаВТаблицуРезультат(ПолноеИмяФайла, ИнформацияОбОшибке());
		Возврат Неопределено;
	КонецПопытки;
	
КонецФункции

Функция XML_ДобавитьСтрокуДерева(ДеревоДанных, Имя, Значение = "", Системная = Ложь)
	
	СтрокаДерева = ДеревоДанных.Строки.Добавить();
	
	СтрокаДерева.Имя = Имя;
	СтрокаДерева.ИмяНРег = НРег(Имя);
	СтрокаДерева.Значение = Значение;
	
	Возврат СтрокаДерева;
	
КонецФункции

Функция XML_ДобавитьАтрибутыВДерево(ДеревоДанных, ЧтениеXML)
	
	Если ЧтениеXML.КоличествоАтрибутов() = 0 Тогда
		Возврат "";
	КонецЕсли;
	
	СтрокаАтрибутов = XML_ДобавитьСтрокуДерева(ДеревоДанных, "Атрибуты", "", Истина);
	
	Для Счетчик = 0 По ЧтениеXML.КоличествоАтрибутов() - 1 Цикл
		XML_ДобавитьСтрокуДерева(СтрокаАтрибутов, ЧтениеXML.ИмяАтрибута(Счетчик), ЧтениеXML.ПолучитьАтрибут(Счетчик));
	КонецЦикла;
	
КонецФункции

#КонецОбласти

Функция ПолучитьСтрокуОбъекта(ОбъектПуть)
	
	Возврат СтруктураКонфигурации.Найти(ОбъектПуть, "ПутьОбъекта");
	
КонецФункции

Функция ПолучитьСтрокуРодителяОбъекта(ОбъектПуть)
	
	СтрокаОбъекта = СтруктураКонфигурации.Найти(ОбъектПуть, "ПутьОбъекта");
	Если СтрокаОбъекта = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат СтруктураКонфигурации.Найти(СтрокаОбъекта.ИДРодителя, "ИД");
	
КонецФункции

Процедура ЗаполнитьТаблицуОбъектовИПодсистем()
	
	ТаблицаОбъектовИПодсистем = Контекст["ТаблицаОбъектовИПодсистем"];
	Если ТаблицаОбъектовИПодсистем <> Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	// Загружаем структуру конфигурации и состав подсистем.
	ЗагрузитьСтруктуруКонфигурации();
	
	ТаблицаСтруктурыКонфигурации = СтруктураКонфигурации.Выгрузить();
	ТаблицаСоставаПодсистем = СоставПодсистем.Выгрузить();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	*
	|ПОМЕСТИТЬ вт_СтруктураКонфигурации
	|ИЗ
	|	&СтруктураКонфигурации КАК СтруктураКонфигурации
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	*
	|ПОМЕСТИТЬ вт_СоставПодсистем
	|ИЗ
	|	&СоставПодсистем КАК СоставПодсистем
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт_СтруктураКонфигурацииОбъект.ПутьОбъекта КАК ОбъектПуть,
	|	вт_СтруктураКонфигурацииПодсистема.ПутьОбъекта КАК ПодсистемаПуть
	|ИЗ
	|	вт_СоставПодсистем КАК вт_СоставПодсистем
	|	ЛЕВОЕ СОЕДИНЕНИЕ вт_СтруктураКонфигурации КАК вт_СтруктураКонфигурацииОбъект
	|		ПО вт_СоставПодсистем.ИДОбъекта = вт_СтруктураКонфигурацииОбъект.ИД
	|	ЛЕВОЕ СОЕДИНЕНИЕ вт_СтруктураКонфигурации КАК вт_СтруктураКонфигурацииПодсистема
	|		ПО вт_СоставПодсистем.ИДПодсистемы = вт_СтруктураКонфигурацииПодсистема.ИД";
	
	Запрос.УстановитьПараметр("СтруктураКонфигурации", ТаблицаСтруктурыКонфигурации);
	Запрос.УстановитьПараметр("СоставПодсистем", ТаблицаСоставаПодсистем);
	
	ТаблицаОбъектовИПодсистем = Запрос.Выполнить().Выгрузить();
	
	ТаблицаОбъектовИПодсистемКопия = ТаблицаОбъектовИПодсистем.Скопировать();
	
	ТаблицаОбъектовИПодсистем.Колонки.Добавить("ВходитВСоставДочернихПодсистем");
	ТаблицаОбъектовИПодсистем.ЗаполнитьЗначения(Ложь, "ВходитВСоставДочернихПодсистем");
	
	Для Каждого СтрокаОбъектаИПодсистемы Из ТаблицаОбъектовИПодсистемКопия Цикл
		
		ПодсистемаПуть = СтрокаОбъектаИПодсистемы.ПодсистемаПуть;
		Пока Истина Цикл
			
			СтрокаРодителяОбъекта = ПолучитьСтрокуРодителяОбъекта(ПодсистемаПуть);
			Если СтрокаРодителяОбъекта = Неопределено Тогда
				Прервать;
			КонецЕсли;
			
			Если СтрокаРодителяОбъекта.ТипОбъекта = "ВеткаМетаданных" Тогда
				Прервать;
			КонецЕсли;
			
			ПодсистемаПуть = СтрокаРодителяОбъекта.ПутьОбъекта;
			
			НоваяСтрокаОбъектаИПодсистемы = ТаблицаОбъектовИПодсистем.Добавить();
			НоваяСтрокаОбъектаИПодсистемы.ОбъектПуть = СтрокаОбъектаИПодсистемы.ОбъектПуть;
			НоваяСтрокаОбъектаИПодсистемы.ПодсистемаПуть = ПодсистемаПуть;
			НоваяСтрокаОбъектаИПодсистемы.ВходитВСоставДочернихПодсистем = Истина;
			
		КонецЦикла;
		
	КонецЦикла;
	
	ТаблицаОбъектовИПодсистем.Индексы.Добавить("ОбъектПуть, ПодсистемаПуть");
	
	Контекст.Вставить("ТаблицаОбъектовИПодсистем", ТаблицаОбъектовИПодсистем);
	
КонецПроцедуры

Функция ОбъектВходитВПодсистему(Знач ОбъектПуть, ПодсистемаПуть, ПроверятьДочерниеПодсистемы = Истина)
	
	ОбъектВходитВПодсистему = Ложь;
	
	Если ПустаяСтрока(ОбъектПуть) Тогда
		Возврат ОбъектВходитВПодсистему;
	КонецЕсли;
	
	ТаблицаТиповОбъектовВУ = ПолучитьТаблицуТиповОбъектовДляДереваКонфигурации();
	
	// Получаем путь к родителю объекта, если это не объект верхнего уровня.
	// Например, если на входе форма, то нужно получить справочник, т.к. сама форма не входит в подсистемы.
	Пока Истина Цикл
		
		СтрокаОбъекта = ПолучитьСтрокуОбъекта(ОбъектПуть);
		Если СтрокаОбъекта = Неопределено Тогда
			Прервать;
		КонецЕсли;
		
		// Если нашли тип объекта среди типов объектов верхнего уровня, то прерываем.
		Если ТаблицаТиповОбъектовВУ.Найти(СтрокаОбъекта.ТипОбъекта) <> Неопределено Тогда
			Прервать;
		КонецЕсли;
		
		// Если родителя не нашли, выходим.
		СтрокаРодителяОбъекта = ПолучитьСтрокуРодителяОбъекта(ОбъектПуть);
		Если СтрокаРодителяОбъекта = Неопределено Тогда
			Прервать;
		КонецЕсли;
		
		// Если родитель - ветка метаданных, то прерываем.
		ТипРодителяОбъекта = СтрокаРодителяОбъекта.ТипОбъекта;
		Если ТипРодителяОбъекта = "ВеткаМетаданных" Тогда
			Прервать;
		КонецЕсли;
		
		// Берем родителя объекта.
		ОбъектПуть = СтрокаРодителяОбъекта.ПутьОбъекта;
		
	КонецЦикла;
	
	СтруктураОбъектИПодсистема = Новый Структура;
	
	ТаблицаОбъектовИПодсистем = Контекст["ТаблицаОбъектовИПодсистем"];
	Если ТаблицаОбъектовИПодсистем = Неопределено Тогда
		ЗаполнитьТаблицуОбъектовИПодсистем();
	КонецЕсли;
	
	Если ТипЗнч(ПодсистемаПуть) = Тип("Строка") Тогда
		МассивПодсистем = Новый Массив;
		МассивПодсистем.Добавить(ПодсистемаПуть);
	ИначеЕсли ТипЗнч(ПодсистемаПуть) = Тип("Массив") Тогда
		МассивПодсистем = ПодсистемаПуть;
	КонецЕсли;
	
	Для Каждого Подсистема Из МассивПодсистем Цикл
		
		Если ПустаяСтрока(Подсистема) Тогда
			Продолжить;
		КонецЕсли;
		
		Подсистема = СокрЛП(Подсистема);
		
		СтруктураОбъектИПодсистема.Очистить();
		
		СтруктураОбъектИПодсистема.Вставить("ОбъектПуть", ОбъектПуть);
		СтруктураОбъектИПодсистема.Вставить("ПодсистемаПуть", Подсистема);
		Если НЕ ПроверятьДочерниеПодсистемы Тогда
			СтруктураОбъектИПодсистема.Вставить("ВходитВСоставДочернихПодсистем", Ложь);
		КонецЕсли;
		
		МассивОбъектовИПодсистем = ТаблицаОбъектовИПодсистем.НайтиСтроки(СтруктураОбъектИПодсистема);
		Если МассивОбъектовИПодсистем.Количество() > 0 Тогда
			ОбъектВходитВПодсистему = Истина;
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ОбъектВходитВПодсистему;
	
КонецФункции

#КонецОбласти

#Область ПроцедурыИФункцииДляРаботыСДокументомDOM

Функция ДокументDOM(ПутьКФайлу)
	
	// Если в файле есть ошибки, то не пытаемся читать его повторно.
	Если ФайлСодержитОшибки(ПутьКФайлу) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Попытка
		ЧтениеXML = Новый ЧтениеXML;
		ЧтениеXML.ОткрытьФайл(ПутьКФайлу);
		
		ПостроительDOM = Новый ПостроительDOM;
		ДокументDOM = ПостроительDOM.Прочитать(ЧтениеXML);
		
		ЧтениеXML.Закрыть();
	Исключение
		ЗаписатьОшибкуЧтенияФайлаВТаблицуРезультат(ПутьКФайлу, ИнформацияОбОшибке());
		Возврат Неопределено;
	КонецПопытки;
	
	Возврат ДокументDOM;
	
КонецФункции

Процедура ЗаписатьДокументDOMВФайл(ДокументDOM, ПолноеИмяФайла)
	
	ПараметрыЗаписи = ПараметрыЗаписиДокументаDOM(ПолноеИмяФайла);
	
	Кодировка      = ПараметрыЗаписи.Кодировка;
	СимволыОтступа = ПараметрыЗаписи.СимволыОтступа;
	
	ПараметрыЗаписиXML = Новый ПараметрыЗаписиXML(Кодировка,,,, СимволыОтступа);
	
	ЗаписьXML = Новый ЗаписьXML;
	ЗаписьXML.ОткрытьФайл(ПолноеИмяФайла, ПараметрыЗаписиXML, ПараметрыЗаписи.ДобавлятьBOM);
	
	ЗаписьDOM = Новый ЗаписьDOM;
	ЗаписьDOM.Записать(ДокументDOM, ЗаписьXML);
	
	ЗаписьXML.Закрыть();
	
	Если НЕ ЭтоВыгрузкаXMLФайлов() Тогда
		ИсправитьФайлXMLПроектаEDT(ПолноеИмяФайла, ПараметрыЗаписи);
	КонецЕсли;
	
	СтрокаРезультата = Результат.Найти(ПолноеИмяФайла, "ПолноеИмяФайла");
	Если СтрокаРезультата <> Неопределено Тогда
		СтрокаРезультата.Изменен = Истина;
	КонецЕсли;
	
КонецПроцедуры

Функция ПолучитьКодировкуФайла(ПолноеИмяФайла)
	
	КодировкаФайла = "";
	
	Если НЕ апк_ФайлСуществует(ПолноеИмяФайла) Тогда
		Возврат КодировкаФайла;
	КонецЕсли;
	
	Если СтрЗаканчиваетсяНа(НРег(ПолноеИмяФайла), ".bsl")
	 ИЛИ СтрЗаканчиваетсяНа(НРег(ПолноеИмяФайла), ".txt") Тогда
		КодировкаФайла = "UTF-8";
	Иначе
		ДокументDOM = ДокументDOM(ПолноеИмяФайла);
		Если ДокументDOM = Неопределено Тогда
			Возврат КодировкаФайла;
		КонецЕсли;
		КодировкаФайла = ДокументDOM.КодировкаXML;
	КонецЕсли;
	
	Возврат КодировкаФайла;
	
КонецФункции

Функция ПараметрыЗаписиДокументаDOM(ПолноеИмяФайла)
	
	ДокументТекст = ПолучитьТекстовыйДокументИзФайла(ПолноеИмяФайла);
	
	КодировкаBOM     = ОпределитьBOMФайла(ПолноеИмяФайла);
	НаличиеBOM       = (НЕ ПустаяСтрока(КодировкаBOM));
	Кодировка        = ?(НаличиеBOM, КодировкаBOM, ПолучитьКодировкуФайла(ПолноеИмяФайла));
	РазделительСтрок = ?(ДокументТекст = Неопределено, Символы.ПС, ДокументТекст.РазделительСтрок);
	ТекстДокумента   = ?(ДокументТекст = Неопределено, "", ДокументТекст.ПолучитьТекст());
	
	ПараметрыЗаписи = Новый Структура;
	ПараметрыЗаписи.Вставить("РазделительСтрок",           РазделительСтрок);
	ПараметрыЗаписи.Вставить("Кодировка",                  Кодировка);
	ПараметрыЗаписи.Вставить("ДобавлятьBOM",               НаличиеBOM);
	ПараметрыЗаписи.Вставить("СимволыОтступа",             ОпределитьСимволыОтступа(ПолноеИмяФайла));
	ПараметрыЗаписи.Вставить("ТекстТегаКорневогоЭлемента", ПолучитьТекстТегаКорневогоЭлементаEDT(ПолноеИмяФайла));
	ПараметрыЗаписи.Вставить("ЕстьПустаяСтрокаВКонце",     СтрЗаканчиваетсяНа(ТекстДокумента, РазделительСтрок));
	
	Возврат ПараметрыЗаписи;
	
КонецФункции

Функция ВычислитьВыражениеXPath(Выражение, ДокументDOM, ЭлементDOM = Неопределено)
	
	Разыменователь = ДокументDOM.СоздатьРазыменовательПИ();
	УзелКонтекста = ?(ЭлементDOM = Неопределено, ДокументDOM, ЭлементDOM);
	Попытка
		РезультатXPath = ДокументDOM.ВычислитьВыражениеXPath(Выражение, УзелКонтекста, Разыменователь);
	Исключение
		РезультатXPath = Неопределено;
	КонецПопытки;
	
	Возврат РезультатXPath;
	
КонецФункции

Функция ПолучитьЭлементDOMПоВыражениюXPath(Выражение, ДокументDOM, ЭлементDOM = Неопределено)
	
	РезультатXPath = ВычислитьВыражениеXPath(Выражение, ДокументDOM, ЭлементDOM);
	Если РезультатXPath = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат РезультатXPath.ПолучитьСледующий();
	
КонецФункции

Функция ПолучитьЗначениеЭлементаDOMПоВыражениюXPath(Выражение, ДокументDOM, ЭлементDOM = Неопределено,
	ЗначениеПоУмолчанию = "")
	
	ЭлементDOMРезультат = ПолучитьЭлементDOMПоВыражениюXPath(Выражение, ДокументDOM, ЭлементDOM);
	
	// Если такого выражения нет, то возвращаем значение по умолчанию.
	Если ЭлементDOMРезультат = Неопределено Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;
	
	Возврат ЭлементDOMРезультат.ТекстовоеСодержимое;
	
КонецФункции

Функция ДобавитьДочернийЭлементDOM(ДокументDOM, ЭлементDOMРодителя, ИмяЭлемента, ТекстовоеСодержимое = "")
	
	НовыйЭлементDOM = ДокументDOM.СоздатьЭлемент(ИмяЭлемента);
	НовыйЭлементDOM.ТекстовоеСодержимое = ТекстовоеСодержимое;
	
	ЭлементDOMРодителя.ДобавитьДочерний(НовыйЭлементDOM);
	
	Возврат НовыйЭлементDOM;
	
КонецФункции

#Область ПроцедурыИФункцииДляРазбораЭлементовФормXML

Функция ПолучитьИмяЭлемента(ДокументDOM, ЭлементDOM, Префикс = "xmlns", ТипПолучения = "Атрибут")
	
	Если ТипПолучения = "Атрибут" Тогда
		Имя = ЭлементDOM.ПолучитьАтрибут("name");
	ИначеЕсли ТипПолучения = "Узел" Тогда
		Имя = ПолучитьЗначениеЭлементаDOMПоВыражениюXPath(Префикс + ":Name", ДокументDOM, ЭлементDOM);
	Иначе
		Имя = "";
	КонецЕсли;
	
	Если Имя = Неопределено Тогда
		Имя = "";
	КонецЕсли;
	
	Возврат Имя;
	
КонецФункции

Функция ПолучитьЗаголовокЭлемента(ДокументDOM, ЭлементDOMЭлемента, Префикс = "xmlns", КодЯзыка = "ru")
	
	ВыражениеXPath = СтрШаблон("%1:Title/v8:item/v8:lang[text()='%2']", Префикс, КодЯзыка);
	ЭлементDOMЯзык = ПолучитьЭлементDOMПоВыражениюXPath(ВыражениеXPath, ДокументDOM, ЭлементDOMЭлемента);
	
	Если ЭлементDOMЯзык = Неопределено Тогда
		// Возможно, при добавлении заголовка не было указано пространство имен, проверяем заголовок в дочерних элементах.
		Заголовок = ПолучитьЗаголовокЭлементаПоДочернимУзлам(ДокументDOM, ЭлементDOMЭлемента, КодЯзыка);
	Иначе
		ЭлементDOMЭлементаЗаголовка = ЭлементDOMЯзык.РодительскийУзел;
		Заголовок = ПолучитьЗначениеЭлементаDOMПоВыражениюXPath("v8:content", ДокументDOM, ЭлементDOMЭлементаЗаголовка);
	КонецЕсли;
	
	Возврат Заголовок;
	
КонецФункции

Функция ПолучитьЗаголовокЭлементаПоДочернимУзлам(ДокументDOM, ЭлементDOMЭлемента, КодЯзыка)
	
	Заголовок = "";
	
	// Получаем узел "Title".
	ЭлементDOMЗаголовок = ПолучитьЭлементDOMПоВыражениюXPath("Title", ДокументDOM, ЭлементDOMЭлемента);
	Если ЭлементDOMЗаголовок = Неопределено Тогда
		Возврат Заголовок;
	КонецЕсли;
	
	ЭлементDOMЯзык = Неопределено;
	
	// Обходим дочерние узлы узла "Title".
	ДочерниеУзлыЗаголовка = ЭлементDOMЗаголовок.ДочерниеУзлы;
	Для Каждого ДочернийУзелЗаголовка Из ДочерниеУзлыЗаголовка Цикл
		// Проверяем только узел "v8:item".
		Если СтрСравнить(ДочернийУзелЗаголовка.ИмяЭлемента, "v8:item") <> 0 Тогда
			Продолжить;
		КонецЕсли;
		// Обходим дочерние узлы.
		Для Каждого ДочернийУзелЭлементаЗаголовка Из ДочернийУзелЗаголовка.ДочерниеУзлы Цикл
			// Ищем узел "v8:lang", текстовое содержимое которого - код соответствующего языка.
			Если (СтрСравнить(ДочернийУзелЭлементаЗаголовка.ИмяЭлемента, "v8:lang") = 0)
				И (СтрСравнить(ДочернийУзелЭлементаЗаголовка.ТекстовоеСодержимое, КодЯзыка) = 0) Тогда
				// Узел "v8:lang" найден, выходим.
				ЭлементDOMЯзык = ДочернийУзелЭлементаЗаголовка;
				Прервать;
				
			КонецЕсли;
			
		КонецЦикла;
		
		Если ЭлементDOMЯзык <> Неопределено Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Если ЭлементDOMЯзык = Неопределено Тогда
		Возврат Заголовок;
	КонецЕсли;
	
	// Получаем родительский узел для узла "v8:lang".
	ЭлементDOMЗаголовка = ЭлементDOMЯзык.РодительскийУзел;
	
	// Обходим дочерние узлы родительского узла.
	Для Каждого ДочернийУзелЭлементаЗаголовка Из ЭлементDOMЗаголовка.ДочерниеУзлы Цикл
		// Ищем узел "v8:content".
		Если СтрСравнить(ДочернийУзелЭлементаЗаголовка.ИмяЭлемента, "v8:content") = 0 Тогда
			// Узел "v8:content" найден, получаем заголовок.
			Заголовок = ДочернийУзелЭлементаЗаголовка.ТекстовоеСодержимое;
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Заголовок;
	
КонецФункции

Функция ПолучитьСинонимОбъекта(ДокументDOM, ЭлементDOMСвойствОбъекта, Префикс = "xmlns")
	
	ВыражениеXPath = СтрШаблон("%1:Synonym/v8:item/v8:lang[text()='%2']", Префикс, КодОсновногоЯзыка);
	ЭлементDOMЯзык = ПолучитьЭлементDOMПоВыражениюXPath(ВыражениеXPath, ДокументDOM, ЭлементDOMСвойствОбъекта);
	Если ЭлементDOMЯзык = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	
	ЭлементDOMv8item = ЭлементDOMЯзык.РодительскийУзел;
	
	Синоним = ПолучитьЗначениеЭлементаDOMПоВыражениюXPath("v8:content", ДокументDOM, ЭлементDOMv8item);
	
	Возврат Синоним;
	
КонецФункции

Функция ПолучитьПодсказкуЭлемента(ДокументDOM, ЭлементDOMЭлемента, Префикс = "xmlns")
	
	ВыражениеXPath = СтрШаблон("%1:ToolTip/v8:item/v8:lang[text()='%2']", Префикс, КодОсновногоЯзыка);
	ЭлементDOMЯзык = ПолучитьЭлементDOMПоВыражениюXPath(ВыражениеXPath, ДокументDOM, ЭлементDOMЭлемента);
	Если ЭлементDOMЯзык = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	
	ЭлементDOMv8item = ЭлементDOMЯзык.РодительскийУзел;
	
