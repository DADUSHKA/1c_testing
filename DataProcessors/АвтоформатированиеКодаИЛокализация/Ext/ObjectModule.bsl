Процедура ДобавитьИсключениеВТаблицуИсключенийЗаголовковЭлементовФорм(ТаблицаИсключений, Наименование, Заголовок)
	
	НовоеИсключение = ТаблицаИсключений.Добавить();
	НовоеИсключение.Наименование = Наименование;
	НовоеИсключение.Заголовок = Заголовок;
	
КонецПроцедуры

Функция ПолучитьТаблицуИсключенийЗаголовковЭлементовФорм()
	
	ТаблицаИсключений = Новый ТаблицаЗначений;
	ТаблицаИсключений.Колонки.Добавить("Наименование");
	ТаблицаИсключений.Колонки.Добавить("Заголовок");
	
	ДобавитьИсключениеВТаблицуИсключенийЗаголовковЭлементовФорм(ТаблицаИсключений, "ФНСРоссии", "ФНС России"); // АПК:1297 - не локализуется
	ДобавитьИсключениеВТаблицуИсключенийЗаголовковЭлементовФорм(ТаблицаИсключений, "ГруппаПользовательскихНастроек", "Группа пользовательских настроек"); // АПК:1297 - не локализуется
	
	Возврат ТаблицаИсключений;
	
КонецФункции

Функция ПолучитьПараметрыСтандарта765()
	
	ТаблицаИсключенийЗаголовковЭлементовФорм = ПолучитьТаблицуИсключенийЗаголовковЭлементовФорм();
	ХранилищеИсключенийЗаголовковЭлементовФорм = ПолучитьХранилищеЗначений(ТаблицаИсключенийЗаголовковЭлементовФорм);
	
	ПараметрыСтандарта765 = Новый Структура;
	ПараметрыСтандарта765.Вставить("ХранилищеИсключенийЗаголовковЭлементовФорм", ХранилищеИсключенийЗаголовковЭлементовФорм);
	
	Возврат ПараметрыСтандарта765;
	
КонецФункции

#Область ПроцедурыИФункцииПриведенияКСтандарту765ЛокализацияЭлементовФормXML

Функция ПривестиОбъектКСтандарту765(ПолноеИмяФайла, ПараметрыСтандарта765)
	
	ТаблицаИсключенийЗаголовковЭлементовФорм = ПараметрыСтандарта765.ХранилищеИсключенийЗаголовковЭлементовФорм.Получить();
	ТаблицаТиповЭлементовФорм = ПараметрыСтандарта765.ТаблицаТиповЭлементовФорм;
	
	ДокументDOM = ДокументDOM(ПолноеИмяФайла);
	Если ДокументDOM = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	
	ОбъектИзменен = Ложь;
	
	Если ЗначениеФлагов.ОчисткаПодсказокГруппФорм Тогда
		
		ВремяНачалаЗамера = ТекущаяУниверсальнаяДатаВМиллисекундах();
		ОбъектИзмененПравилом = ОчиститьПодсказкиГруппФормы(ДокументDOM);
		ОбъектИзменен = ОбъектИзменен ИЛИ ОбъектИзмененПравилом;
		
		Если ОбъектИзмененПравилом Тогда
			ЗаполнитьВремяПриведенияКСтандарту("ОчисткаПодсказокГруппФорм", ВремяНачалаЗамера);
			ДобавитьСтрокуВТаблицуИзмененныхОбъектов(ПолноеИмяФайла, "ОчисткаПодсказокГруппФорм");
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЗначениеФлагов.ЗаполнениеЗаголовковГруппИТаблицФорм
		ИЛИ ЗначениеФлагов.ЗаменаАвтогенерируемыхЗаголовков Тогда
		
		ВремяНачалаЗамера = ТекущаяУниверсальнаяДатаВМиллисекундах();
		
		ОбъектИзмененПравилом = ЗаполнитьЗаголовкиТаблицИГруппФормыXML(ДокументDOM,
			ТаблицаИсключенийЗаголовковЭлементовФорм,
			ТаблицаТиповЭлементовФорм);
		
		ОбъектИзменен = ОбъектИзменен ИЛИ ОбъектИзмененПравилом;
		
		Если ОбъектИзмененПравилом Тогда
			ЗаполнитьВремяПриведенияКСтандарту("ЗаполнениеЗаголовковГруппИТаблицФорм", ВремяНачалаЗамера);
			ДобавитьСтрокуВТаблицуИзмененныхОбъектов(ПолноеИмяФайла, "ЗаполнениеЗаголовковГруппИТаблицФорм");
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЗначениеФлагов.ОчисткаЗаголовковРеквизитовФормыНеРазмещенныхНаФорме Тогда
		
		ВремяНачалаЗамера = ТекущаяУниверсальнаяДатаВМиллисекундах();
		ОбъектИзмененПравилом = ОчиститьЗаголовкиРеквизитовФормыНеРазмещенныхНаФорме(ДокументDOM);
		ОбъектИзменен = ОбъектИзменен ИЛИ ОбъектИзмененПравилом;
		
		Если ОбъектИзмененПравилом Тогда
			ЗаполнитьВремяПриведенияКСтандарту("ОчисткаЗаголовковРеквизитовФормыНеРазмещенныхНаФорме", ВремяНачалаЗамера);
			ДобавитьСтрокуВТаблицуИзмененныхОбъектов(ПолноеИмяФайла, "ОчисткаЗаголовковРеквизитовФормыНеРазмещенныхНаФорме");
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЗначениеФлагов.ЗаполнениеЗаголовковКолонокДинамическогоСписка Тогда
		
		ВремяНачалаЗамера = ТекущаяУниверсальнаяДатаВМиллисекундах();
		ОбъектИзмененПравилом = ЗаполнитьЗаголовкиПолейДинамическогоСписка(ДокументDOM);
		ОбъектИзменен = ОбъектИзменен ИЛИ ОбъектИзмененПравилом;
		
		Если ОбъектИзмененПравилом Тогда
			ЗаполнитьВремяПриведенияКСтандарту("ЗаполнениеЗаголовковКолонокДинамическогоСписка", ВремяНачалаЗамера);
			ДобавитьСтрокуВТаблицуИзмененныхОбъектов(ПолноеИмяФайла, "ЗаполнениеЗаголовковКолонокДинамическогоСписка");
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЗначениеФлагов.ЗаполнениеЗаголовковКолонокТаблицыЗначений Тогда
		
		ВремяНачалаЗамера = ТекущаяУниверсальнаяДатаВМиллисекундах();
		ОбъектИзмененПравилом = ЗаполнитьЗаголовкиКолонокРеквизитаФормы(ДокументDOM, ТаблицаИсключенийЗаголовковЭлементовФорм);
		ОбъектИзменен = ОбъектИзменен ИЛИ ОбъектИзмененПравилом;
		
		Если ОбъектИзмененПравилом Тогда
			ЗаполнитьВремяПриведенияКСтандарту("ЗаполнениеЗаголовковКолонокТаблицыЗначений", ВремяНачалаЗамера);
			ДобавитьСтрокуВТаблицуИзмененныхОбъектов(ПолноеИмяФайла, "ЗаполнениеЗаголовковКолонокТаблицыЗначений");
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЗначениеФлагов.ЗаполнениеЗаголовковСвойствСпискаЗначений Тогда
		
		ВремяНачалаЗамера = ТекущаяУниверсальнаяДатаВМиллисекундах();
		ОбъектИзмененПравилом = ЗаполнитьЗаголовкиСвойствСпискаЗначений(ДокументDOM);
		ОбъектИзменен = ОбъектИзменен ИЛИ ОбъектИзмененПравилом;
		
		Если ОбъектИзмененПравилом Тогда
			ЗаполнитьВремяПриведенияКСтандарту("ЗаполнениеЗаголовковСвойствСпискаЗначений", ВремяНачалаЗамера);
			ДобавитьСтрокуВТаблицуИзмененныхОбъектов(ПолноеИмяФайла, "ЗаполнениеЗаголовковСвойствСпискаЗначений");
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЗначениеФлагов.ЗаполнениеЗаголовковЭлементовФорм Тогда
		
		ВремяНачалаЗамера = ТекущаяУниверсальнаяДатаВМиллисекундах();
		ОбъектИзмененПравилом = ЗаполнитьЗаголовкиЭлементовФорм(ДокументDOM);
		ОбъектИзменен = ОбъектИзменен ИЛИ ОбъектИзмененПравилом;
		
		Если ОбъектИзмененПравилом Тогда
			ЗаполнитьВремяПриведенияКСтандарту("ЗаполнениеЗаголовковЭлементовФорм", ВремяНачалаЗамера);
			ДобавитьСтрокуВТаблицуИзмененныхОбъектов(ПолноеИмяФайла, "ЗаполнениеЗаголовковЭлементовФорм");
		КонецЕсли;
		
	КонецЕсли;
	
	Если ОбъектИзменен Тогда
		ЗаписатьДокументDOMВФайл(ДокументDOM, ПолноеИмяФайла);
