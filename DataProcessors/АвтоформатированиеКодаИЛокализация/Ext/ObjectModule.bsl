		ПолноеИмяФайла = Файл.ПолноеИмя;
		Если ПроверитьФайлВыбранДляРедактирования(ПолноеИмяФайла) Тогда
			ПривестиПодсистемуКСтандарту467(ПолноеИмяФайла);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ПривестиОбъектКонфигурацииКСтандарту467(ФайлКонфигурации)
	
	Если НЕ апк_ФайлСуществует(ФайлКонфигурации) Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаФайлаРезультата = Результат.Найти(ФайлКонфигурации, "ПолноеИмяФайла");
	Если СтрокаФайлаРезультата = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если (НЕ СтрокаФайлаРезультата.ЗахваченВХранилище) ИЛИ (НЕ СтрокаФайлаРезультата.РедактированиеРазрешено) Тогда
		Возврат;
	КонецЕсли;
	
	ДокументDOM = ДокументDOM(ФайлКонфигурации);
	Если ДокументDOM = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ОбъектИзменен = Ложь;
	
	Если ЗначениеФлагов.СортировкаОбъектовВерхнегоУровня Тогда
		
		ВремяНачалаЗамера = ТекущаяУниверсальнаяДатаВМиллисекундах();
		ОбъектИзмененПравилом = СортироватьОбъектыМетаданных(ДокументDOM);
		ОбъектИзменен = ОбъектИзменен ИЛИ ОбъектИзмененПравилом;
		
		Если ОбъектИзмененПравилом Тогда
			ЗаполнитьВремяПриведенияКСтандарту("СортировкаОбъектовВерхнегоУровня", ВремяНачалаЗамера);
			ДобавитьСтрокуВТаблицуИзмененныхОбъектов(ФайлКонфигурации, "СортировкаОбъектовВерхнегоУровня");
		КонецЕсли;
		
	КонецЕсли;
	
	Если ОбъектИзменен Тогда
		ЗаписатьДокументDOMВФайл(ДокументDOM, ФайлКонфигурации);
	КонецЕсли;
	
КонецПроцедуры

Процедура ПривестиМодульКСтандарту467(ПолноеИмяФайла)
	
	ДокументТекст = ПолучитьТекстовыйДокументИзФайла(ПолноеИмяФайла, КодировкаТекста.UTF8);
	Если ДокументТекст = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ОбъектИзменен = Ложь;
	
	Если ЗначениеФлагов.УдалениеИзбыточногоОбращенияКОбъекту Тогда
		
		ВремяНачалаЗамера = ТекущаяУниверсальнаяДатаВМиллисекундах();
		ОбъектИзмененПравилом = УдалитьИзбыточноеОбращениеКОбъектуВКодеМодуля(ПолноеИмяФайла, ДокументТекст);
		ОбъектИзменен = ОбъектИзменен ИЛИ ОбъектИзмененПравилом;
		
		Если ОбъектИзмененПравилом Тогда
			ЗаполнитьВремяПриведенияКСтандарту("УдалениеИзбыточногоОбращенияКОбъекту", ВремяНачалаЗамера);
			ДобавитьСтрокуВТаблицуИзмененныхОбъектов(ПолноеИмяФайла, "УдалениеИзбыточногоОбращенияКОбъекту");
		КонецЕсли;
		
	КонецЕсли;
	
	Если ОбъектИзменен Тогда
		ЗаписатьИзмененияВФайл(ДокументТекст, ПолноеИмяФайла);
	КонецЕсли;
	
КонецПроцедуры

Процедура ПривестиМодулиКСтандарту467()
	
	МассивФайлов = НайтиФайлы(КаталогВыгрузкиРезультат, "*.bsl", Истина);
	Для Каждого Файл Из МассивФайлов Цикл
		
		ПолноеИмяФайла = Файл.ПолноеИмя;
		Если ПроверитьФайлВыбранДляРедактирования(ПолноеИмяФайла) Тогда
			ПривестиМодульКСтандарту467(ПолноеИмяФайла);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ПривестиКонфигурациюКСтандарту467()
	
	ПривестиПодсистемыКСтандарту467();
	
	ФайлКонфигурации = ПолучитьФайлКонфигурации();
	ПривестиОбъектКонфигурацииКСтандарту467(ФайлКонфигурации);
	
	ПривестиМодулиКСтандарту467();
	
КонецПроцедуры

#КонецОбласти

