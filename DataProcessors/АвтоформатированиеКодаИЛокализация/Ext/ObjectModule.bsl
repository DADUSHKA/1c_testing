#Область УстановкаПризнакаИспользоватьВсегда

Функция УстановитьПризнакиИспользоватьВсегдаДляПолейДинамическихСписков(ДокументDOM)
	
	ФормаИзменена = Ложь;
	
	ВыражениеПоискаПоТипуШаблон = "//xmlns:Attributes/xmlns:Attribute/xmlns:Type/v8:Type[text()='%1']";
	ВыражениеПоискаПоПутиКДаннымШаблон = "//xmlns:ChildItems/*/xmlns:DataPath[text()='%1']";
	ВыражениеПоискаИспользуемыхВсегдаШаблон = "//xmlns:UseAlways/xmlns:Field[text()='%1']";
	
	МассивСсылокШаблон = Новый Массив;
	МассивСсылокШаблон.Добавить(".Ссылка");
	МассивСсылокШаблон.Добавить(".Ref");
	
	МассивТиповДинамическийСписок = Новый Массив;
	МассивТиповДинамическийСписок.Добавить("cfg:DynamicList");
	МассивТиповДинамическийСписок.Добавить("dl:DynamicList");
	
	Для Каждого ТипДинамическийСписок Из МассивТиповДинамическийСписок Цикл
		
		ВыражениеПоискаПоТипу = СтрШаблон(ВыражениеПоискаПоТипуШаблон, ТипДинамическийСписок);
		РезультатXPath = ВычислитьВыражениеXPath(ВыражениеПоискаПоТипу, ДокументDOM);
		Пока Истина Цикл
			
			ЭлементDOMv8Type = РезультатXPath.ПолучитьСледующий();
			Если ЭлементDOMv8Type = Неопределено Тогда
				Прервать;
			КонецЕсли;
			
			ЭлементDOMType = ЭлементDOMv8Type.РодительскийУзел;
			Если ЭлементDOMType = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			ЭлементDOMРеквизит = ЭлементDOMType.РодительскийУзел;
			Если ЭлементDOMРеквизит = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			ИмяРеквизита = ПолучитьИмяЭлемента(ДокументDOM, ЭлементDOMРеквизит);
			Если ПустаяСтрока(ИмяРеквизита) Тогда
				Продолжить;
			КонецЕсли;
			
			Для Каждого СсылкаШаблон Из МассивСсылокШаблон Цикл
				ИмяРеквизитаСсылка = ИмяРеквизита + СсылкаШаблон;
				
				ВыражениеПоискаПоПутиКДанным = СтрШаблон(ВыражениеПоискаПоПутиКДаннымШаблон, ИмяРеквизитаСсылка);
				РезультатПоискаПоПутиКДанным = ВычислитьВыражениеXPath(ВыражениеПоискаПоПутиКДанным, ДокументDOM);
				
				ЭлементDOMСсылка = РезультатПоискаПоПутиКДанным.ПолучитьСледующий();
				Если ЭлементDOMСсылка <> Неопределено Тогда
					Прервать;
				КонецЕсли;
				
			КонецЦикла;
			
			Если ЭлементDOMСсылка = Неопределено Тогда
				// Не найден элементом формы с типом <ИмяДинамическогоСписка>.Ссылка
				Продолжить;
			КонецЕсли;
			
			ВыражениеПоискаИспользуемыхВсегда = СтрШаблон(ВыражениеПоискаИспользуемыхВсегдаШаблон, ИмяРеквизитаСсылка);
			РезультатПоискаПоПутиКДанным = ВычислитьВыражениеXPath(ВыражениеПоискаИспользуемыхВсегда, ДокументDOM);
			
			ЭлементDOMИспользоватьВсегда = РезультатПоискаПоПутиКДанным.ПолучитьСледующий();
			Если ЭлементDOMИспользоватьВсегда = Неопределено Тогда
				УстановитьПризнакИспользоватьВсегда(ДокументDOM, ЭлементDOMРеквизит, ИмяРеквизитаСсылка);
				ФормаИзменена = Истина;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ФормаИзменена;
	
КонецФункции

Функция УстановитьПризнакиИспользоватьВсегдаДляПолейДинамическихСписковEDT(ДокументDOM)
	
	ФормаИзменена = Ложь;
	
	ВыражениеПоискаПоТипу = "//attributes/valueType/types[text()='DynamicList']";
	ВыражениеПоискаПоПутиКДаннымШаблон = "//items/dataPath/paths/segments[text()='%1']";
	ВыражениеПоискаИспользуемыхВсегдаШаблон = "//notDefaultUseAlwaysAttributes/segments[text()='%1']";
	
	МассивСсылокШаблон = Новый Массив;
	МассивСсылокШаблон.Добавить(".Ссылка");
	МассивСсылокШаблон.Добавить(".Ref");
	
	РезультатXPath = ВычислитьВыражениеXPath(ВыражениеПоискаПоТипу, ДокументDOM);
	Пока Истина Цикл
		
		ЭлементDOMv8Type = РезультатXPath.ПолучитьСледующий();
		Если ЭлементDOMv8Type = Неопределено Тогда
			Прервать;
		КонецЕсли;
		
		ЭлементDOMType = ЭлементDOMv8Type.РодительскийУзел;
		Если ЭлементDOMType = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ЭлементDOMРеквизит = ЭлементDOMType.РодительскийУзел;
		Если ЭлементDOMРеквизит = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ИмяРеквизита = ПолучитьИмяЭлементаEDT(ДокументDOM, ЭлементDOMРеквизит);
		Если ПустаяСтрока(ИмяРеквизита) Тогда
			Продолжить;
		КонецЕсли;
		
		Для Каждого СсылкаШаблон Из МассивСсылокШаблон Цикл
			ИмяРеквизитаСсылка = ИмяРеквизита + СсылкаШаблон;
			
			ВыражениеПоискаПоПутиКДанным = СтрШаблон(ВыражениеПоискаПоПутиКДаннымШаблон, ИмяРеквизитаСсылка);
			РезультатПоискаПоПутиКДанным = ВычислитьВыражениеXPath(ВыражениеПоискаПоПутиКДанным, ДокументDOM);
			
			ЭлементDOMСсылка = РезультатПоискаПоПутиКДанным.ПолучитьСледующий();
			Если ЭлементDOMСсылка <> Неопределено Тогда
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
		Если ЭлементDOMСсылка = Неопределено Тогда
			// Не найден элементом формы с типом <ИмяДинамическогоСписка>.Ссылка
			Продолжить;
		КонецЕсли;
		
		ВыражениеПоискаИспользуемыхВсегда = СтрШаблон(ВыражениеПоискаИспользуемыхВсегдаШаблон, ИмяРеквизитаСсылка);
		РезультатПоискаПоПутиКДанным = ВычислитьВыражениеXPath(ВыражениеПоискаИспользуемыхВсегда, ДокументDOM, ЭлементDOMРеквизит);
		
		ЭлементDOMИспользоватьВсегда = РезультатПоискаПоПутиКДанным.ПолучитьСледующий();
		Если ЭлементDOMИспользоватьВсегда = Неопределено Тогда
			УстановитьПризнакИспользоватьВсегдаEDT(ДокументDOM, ЭлементDOMРеквизит, ИмяРеквизитаСсылка);
			ФормаИзменена = Истина;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ФормаИзменена;
	
КонецФункции

#КонецОбласти

#Область ИсправлениеФайловФормПроектаEDT

Функция ПолучитьТекстТегаКорневогоЭлементаEDT(ПолноеИмяФайла)
	
	ТекстXML = ПолучитьТекстФайла(ПолноеИмяФайла, КодировкаТекста.UTF8, Ложь);
	Если ПустаяСтрока(ТекстXML) Тогда
		Возврат "";
	КонецЕсли;
	
	// Тег корневого элемента для XML-файла формы проекта EDT должен начинаться с "<form:Form".
	ПозицияОткрытияТега = СтрНайти(ТекстXML, Контекст["ТегКорневогоЭлементаФайлаXMLФормыПроектаEDT"]);
	Если ПозицияОткрытияТега = 0 Тогда
		Возврат "";
	КонецЕсли;
	
	// Если нашли, то ищем символ закрытия тега ">".
	ПозицияЗакрытияТега = СтрНайти(ТекстXML, ">",, ПозицияОткрытияТега);
	Если ПозицияЗакрытияТега = 0 Тогда
		Возврат "";
	КонецЕсли;
	
	ТекстТегаКорневогоЭлемента = Сред(ТекстXML, ПозицияОткрытияТега, ПозицияЗакрытияТега - ПозицияОткрытияТега + 1);
	
	Возврат ТекстТегаКорневогоЭлемента;
	
КонецФункции

Функция ИсправитьТегКорневогоЭлементаEDT(ТекстXML, ТекстТегаКорневогоЭлемента)
	
	Если ПустаяСтрока(ТекстТегаКорневогоЭлемента) Тогда
		Возврат ТекстXML;
	КонецЕсли;
	
	// Тег корневого элемента для XML-файла формы проекта EDT должен начинаться с "<form:Form".
	ПозицияОткрытияТега = СтрНайти(ТекстXML, Контекст["ТегКорневогоЭлементаФайлаXMLФормыПроектаEDT"]);
	Если ПозицияОткрытияТега = 0 Тогда
		Возврат ТекстXML;
	КонецЕсли;
	
	// Если нашли, то ищем символ закрытия тега ">".
	ПозицияЗакрытияТега = СтрНайти(ТекстXML, ">",, ПозицияОткрытияТега);
	Если ПозицияЗакрытияТега = 0 Тогда
		Возврат ТекстXML;
	КонецЕсли;
	
	ИсправленныйТекстXML = Лев(ТекстXML, ПозицияОткрытияТега - 1) + ТекстТегаКорневогоЭлемента + Сред(ТекстXML, ПозицияЗакрытияТега + 1);
	
	Возврат ИсправленныйТекстXML;
	
КонецФункции

Функция ИсправитьКавычкиВТекстеXMLEDT(Знач ТекстXML)
	
	ТаблицаТеговПоискаКавычекEDT = Контекст["ТаблицаТеговПоискаКавычекEDT"];
	
	Для Каждого СтрокаТаблицы Из ТаблицаТеговПоискаКавычекEDT Цикл
		
		ТекстНачалоТега = СтрокаТаблицы.НачалоТега;
		ТекстКонецТега  = СтрокаТаблицы.КонецТега;
		ДлинаНачалоТега = СтрДлина(ТекстНачалоТега);
		
		ПозицияКонцаТега = 0;
		Пока Истина Цикл
			
			// Определяем позицию открывающего тега.
			ПозицияНачалаТега = СтрНайти(ТекстXML, ТекстНачалоТега,, ПозицияКонцаТега + 1);
			Если ПозицияНачалаТега = 0 Тогда
				Прервать;
			КонецЕсли;
			
			// Определяем позицию закрывающего тега.
			ПозицияКонцаТега = СтрНайти(ТекстXML, ТекстКонецТега,, ПозицияНачалаТега);
			Если ПозицияКонцаТега = 0 Тогда
				Прервать;
			КонецЕсли;
			
			ПозицияНачалаТега = ПозицияНачалаТега + ДлинаНачалоТега;
			
			// Получаем значение тега.
			СтрокаМеждуТегами = Сред(ТекстXML, ПозицияНачалаТега, ПозицияКонцаТега - ПозицияНачалаТега);
			
			// Ищем кавычки в значении тега.
			Если СтрНайти(СтрокаМеждуТегами, """") = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			// Меняем кавычки на "&quot;".
			СтрокаЗамены = СтрЗаменить(СтрокаМеждуТегами, """", Контекст["ЗаменаСимволаКавычкаДляXML"]);
			ТекстXML = Лев(ТекстXML, ПозицияНачалаТега - 1) + СтрокаЗамены + Сред(ТекстXML, ПозицияКонцаТега);
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ТекстXML;
	
КонецФункции

Процедура ИсправитьФайлXMLПроектаEDT(ПолноеИмяФайла, ПараметрыЗаписи)
	
	Кодировка = ПараметрыЗаписи.Кодировка;
	
	ИсходныйТекстXML = ПолучитьТекстФайла(ПолноеИмяФайла, Кодировка, Ложь);
	Если ПустаяСтрока(ИсходныйТекстXML) Тогда
		Возврат;
	КонецЕсли;
	
	// При записи файла XML проекта EDT изменяется порядок атрибутов корневого элемента формы.
	// Возвращаем прежний текст тега из XML-файла формы.
	ТекстТегаКорневогоЭлемента = ПараметрыЗаписи.ТекстТегаКорневогоЭлемента;
	
	ТекстXML = ИсправитьТегКорневогоЭлементаEDT(ИсходныйТекстXML, ТекстТегаКорневогоЭлемента);
	
	// Заменяем текст "&gt;" на символ ">".
	ТекстXML = СтрЗаменить(ТекстXML, Контекст["ЗаменаСимволаБольшеДляXML"], ">");
	
	// Заменяем кавычки в значениях тегов и в текстах запросов динамических списков на "&quot;".
	ТекстXML = ИсправитьКавычкиВТекстеXMLEDT(ТекстXML);
	
	// Заменяем сокращенные пустые теги на полные.
	ЗаменитьСокращенныеПустыеТегиНаПолные(ТекстXML);
	
	// Проверяем наличие разделителя строк в конце текста файла.
	ТекстXML = СокрП(ТекстXML);
	Если ПараметрыЗаписи.ЕстьПустаяСтрокаВКонце Тогда
		// Добавляем разделитель строк в конец текста, если в исходном тексте разделитель есть.
		ТекстXML = ТекстXML + ПараметрыЗаписи.РазделительСтрок;
	КонецЕсли;
	
	Если ИсходныйТекстXML = ТекстXML Тогда
		Возврат;
	КонецЕсли;
	
	ЗаписатьТекстовыйФайл(ПолноеИмяФайла, ТекстXML, ПараметрыЗаписи);
	
КонецПроцедуры

Процедура ЗаменитьСокращенныеПустыеТегиНаПолные(ТекстXML)
	
	ТаблицаПустыхТегов = Контекст["ТаблицаПустыхТегов"];
	
	Для Каждого СтрокаТаблицыПустыхТегов Из ТаблицаПустыхТегов Цикл
		ТекстXML = СтрЗаменить(ТекстXML, СтрокаТаблицыПустыхТегов.СокращенныйТег, СтрокаТаблицыПустыхТегов.ПолныйТег);
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область ОбщиеТребованияПоЛокализацииКонфигурации

Функция ОчиститьИзлишнююЛокализацию(ДокументDOM)
	
	ОбъектИзменен = Ложь;
	
	ТаблицаЯзыковКонфигурации = Контекст["ТаблицаЯзыковКонфигурации"];
	Если ТаблицаЯзыковКонфигурации.Количество() = 0 Тогда
		Возврат ОбъектИзменен;
	КонецЕсли;
	
	МассивВыраженийПеревода = Новый Массив;
	МассивВыраженийПеревода.Добавить("//xmlns:languageInfo/xmlns:id");
	МассивВыраженийПеревода.Добавить("//v8:item/v8:lang");
	Если НЕ ЭтоВыгрузкаXMLФайлов Тогда
		МассивВыраженийПеревода.Добавить("//synonym/key");
		МассивВыраженийПеревода.Добавить("//title/key");
	КонецЕсли;
	
	Для Каждого ВыражениеПеревода Из МассивВыраженийПеревода Цикл
		
		РезультатXPath = ВычислитьВыражениеXPath(ВыражениеПеревода, ДокументDOM);
		Если РезультатXPath = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Пока Истина Цикл
			
			ЭлементDOMКодЯзыка = РезультатXPath.ПолучитьСледующий();
			Если ЭлементDOMКодЯзыка = Неопределено Тогда
				Прервать;
			КонецЕсли;
			
			КодЯзыка = ЭлементDOMКодЯзыка.ТекстовоеСодержимое;
			
			// Если код языка есть среди языков конфигурации, то пропускаем.
			Если ТаблицаЯзыковКонфигурации.Найти(КодЯзыка, "КодЯзыка") <> Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			// Если не нашли, то удаляем перевод целиком вместе с узлом языка.
			ЭлементDOMУзелЯзыка = ЭлементDOMКодЯзыка.РодительскийУзел;
			Если ЭлементDOMУзелЯзыка = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			ЭлементDOMУзелЯзыкаРодитель = ЭлементDOMУзелЯзыка.РодительскийУзел;
			Если ЭлементDOMУзелЯзыкаРодитель = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			ЭлементDOMУзелЯзыкаРодитель.УдалитьДочерний(ЭлементDOMУзелЯзыка);
			
			ОбъектИзменен = Истина;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ОбъектИзменен;
	
КонецФункции

#КонецОбласти

#Область ИмяСинонимКомментарий

Функция ИзменитьСинонимОбъекта(ДокументDOM, ПараметрыИзмененияСинонима)
	
	ОбъектИзменен = Ложь;
	
	ЭлементDOMСвойства = ПолучитьЭлементDOMПоВыражениюXPath(ПараметрыИзмененияСинонима.ВыражениеПоискаСвойств, ДокументDOM);
	Если ЭлементDOMСвойства = Неопределено Тогда
		Возврат ОбъектИзменен;
	КонецЕсли;
	
	// Получаем имя объекта.
	Если ПараметрыИзмененияСинонима.ТипВыгрузкиФайлов = "XML" Тогда
		ИмяОбъекта = ПолучитьИмяЭлемента(ДокументDOM, ЭлементDOMСвойства,, "Узел");
	Иначе
		ИмяОбъекта = ПолучитьИмяЭлементаEDT(ДокументDOM, ЭлементDOMСвойства);
	КонецЕсли;
	
	// Меняем синоним объекта, если его имя содержит определенную фразу, иначе выходим.
	Если СтрНайти(ИмяОбъекта, ПараметрыИзмененияСинонима.ИмяОбъекта) = 0 Тогда
		Возврат ОбъектИзменен;
	КонецЕсли;
	
	// Получаем синоним объекта.
	Если ПараметрыИзмененияСинонима.ТипВыгрузкиФайлов = "XML" Тогда
		ТекущийСиноним = ПолучитьСинонимОбъекта(ДокументDOM, ЭлементDOMСвойства);
	Иначе
		ТекущийСиноним = ПолучитьСинонимОбъектаEDT(ДокументDOM, ЭлементDOMСвойства);
	КонецЕсли;
	
	// Меняем синоним объекта, если оно содержит определенную фразу, иначе выходим.
	ИсходныйСиноним = ПараметрыИзмененияСинонима.ИсходныйСиноним;
	Если СтрНайти(ТекущийСиноним, ИсходныйСиноним) = 0 Тогда
		Возврат ОбъектИзменен;
	КонецЕсли;
	
	НовыйСиноним = ПараметрыИзмененияСинонима.НовыйСиноним;
	ТекущийСиноним = СтрЗаменить(ТекущийСиноним, ИсходныйСиноним, НовыйСиноним);
	
	// Устанавливаем синоним объекта.
	Если ПараметрыИзмененияСинонима.ТипВыгрузкиФайлов = "XML" Тогда
		УстановитьСинонимОбъекта(ДокументDOM, ЭлементDOMСвойства, ТекущийСиноним);
	Иначе
		УстановитьСинонимОбъектаEDT(ДокументDOM, ЭлементDOMСвойства, ТекущийСиноним);
	КонецЕсли;
	
	ОбъектИзменен = Истина;
	
	Возврат ОбъектИзменен;
	
КонецФункции

#КонецОбласти

