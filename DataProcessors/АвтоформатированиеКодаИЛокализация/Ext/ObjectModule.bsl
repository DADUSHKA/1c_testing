Функция ПолучитьВыражениеПоискаКлючевыхСлов(ТаблицаКлючевыхСлов)
	
	МассивКлючевыхСлов = ТаблицаКлючевыхСлов.ВыгрузитьКолонку("Эталон");
	КлючевыеСловаСтрокой = СтрСоединить(МассивКлючевыхСлов, "\b|\b");
	ВыражениеПоиска = СтрШаблон("\b%1\b", КлючевыеСловаСтрокой);
	
	Возврат ВыражениеПоиска;
	
КонецФункции

Функция ПроверкаКаноническогоНаписанияКлючевыхСлов(ДокументТекст)
	
	ФайлИзменен = Ложь;
	
	ТекстМодуля = ДокументТекст.ПолучитьТекст();
	
	// Получаем таблицу ключевых слов.
	ТаблицаКлючевыхСлов = Контекст["ТаблицаКлючевыхСлов"];
	
	// Получаем регулярное выражения для поиска ключевых слов.
	ВыражениеПоиска = Контекст["ВыражениеПоискаКлючевыхСлов"];
	РезультатПоискаКлючевыхСлов = СтрНайтиВсеПоРегулярномуВыражению(ТекстМодуля, ВыражениеПоиска, Истина, Истина);
	
	Если РезультатПоискаКлючевыхСлов.Количество() = 0 Тогда
		Возврат ФайлИзменен;
	КонецЕсли;
	
	ОбластьОткрыта = Ложь;
	НомерПровереннойСтроки = 0;
	СтрокаМодуляИсходная = "";
	
	Для Каждого РезультатПоиска Из РезультатПоискаКлючевыхСлов Цикл
		
		НайденноеСловоИсходное = РезультатПоиска.Значение;
		Если ТаблицаКлючевыхСлов.Найти(НайденноеСловоИсходное, "Эталон") <> Неопределено Тогда
			// Слово найдено среди эталонов, пропускаем.
			Продолжить;
		КонецЕсли;
		
		ПозицияКлючевогоСлова = РезультатПоиска.НачальнаяПозиция;
		НомерСтроки = ПолучитьНомерСтрокиМодуля(ТекстМодуля, ПозицияКлючевогоСлова);
		
		// Несколько ключевых слов могут быть в одной строке.
		ЭтоНоваяПроверяемаяСтрока = (НомерСтроки <> НомерПровереннойСтроки);
		СтрокаМодуляИсходная  = ?(ЭтоНоваяПроверяемаяСтрока, ДокументТекст.ПолучитьСтроку(НомерСтроки), СтрокаМодуляИсходная);
		
		Если ПустаяСтрока(СтрокаМодуляИсходная) Тогда
			Продолжить;
		КонецЕсли;
		
		ЭтоЗакомментированнаяСтрока = Ложь;
		
		// Дополнительную проверку проводим только для новой проверяемой строки.
		Если ЭтоНоваяПроверяемаяСтрока Тогда
			
			НомерПровереннойСтроки = НомерСтроки;
			
			// Если вся строка - это комментарий, то пропускаем.
			СтрокаМодуляСокрЛ = СокрЛ(СтрокаМодуляИсходная);
			ЭтоЗакомментированнаяСтрока = СтрНачинаетсяС(СтрокаМодуляСокрЛ, "//");
			Если ЭтоЗакомментированнаяСтрока Тогда
				Продолжить;
			КонецЕсли;
			
			ОбластьОткрыта = ОбластьИспользованиеМодальностиОткрыта(СтрокаМодуляИсходная, ОбластьОткрыта);
			Если ОбластьОткрыта Тогда
				Продолжить;
			КонецЕсли;
			
			СтрокаМодуля = СтрокаМодуляИсходная;
			// Если строка начинается с "|", значит, это текст в кавычках, заменяем на кавычку.
			Если СтрНачинаетсяС(СтрокаМодуляСокрЛ, "|") Тогда
				ПозицияСимвола = СтрНайти(СтрокаМодуля, "|");
				СтрокаМодуля = апк_СтрЗаменить(СтрокаМодуля, """", ПозицияСимвола, ПозицияСимвола);
			КонецЕсли;
			
			СтрокаМодуля = СтрЗаменить(СтрокаМодуля, """""", "  ");
			ДлинаСтроки = СтрДлина(СтрокаМодуля);
			
			// Заменяем весь текст в кавычках на пробелы.
			Пока Истина Цикл
				
				ПозицияКавычекНачало = СтрНайти(СтрокаМодуля, """");
				Если ПозицияКавычекНачало = 0 Тогда
					Прервать;
				КонецЕсли;
				
				ПозицияКавычекКонец = 0;
				
				// Если кавычка не в конце строки, то ищем закрывающую.
				Если ПозицияКавычекНачало < ДлинаСтроки Тогда
					ПозицияКавычекКонец = СтрНайти(СтрокаМодуля, """",, ПозицияКавычекНачало + 1);
				КонецЕсли;
				
				Если ПозицияКавычекКонец = 0 Тогда
					// Если закрывающая кавычка не найдена, то берем конец строки.
					ПозицияКавычекКонец = ДлинаСтроки;
				КонецЕсли;
				
				// Заменяем на пробелы весь текст в кавычках.
				СтрокаМодуля = апк_СтрЗаменить(СтрокаМодуля, " ", ПозицияКавычекНачало, ПозицияКавычекКонец);
				
			КонецЦикла;
			
			// Ищем комментарий в строке после текста кода.
			ПозицияКомментария = СтрНайти(СтрокаМодуля, "//");
			Если ПозицияКомментария > 0 Тогда
				// Удаляем все до конца строки.
				СтрокаМодуля = апк_СтрЗаменить(СтрокаМодуля, " ", ПозицияКомментария, СтрДлина(СтрокаМодуля));
			КонецЕсли;
			
			Если ПустаяСтрока(СтрокаМодуля) ИЛИ СтрНайти(СтрокаМодуля, НайденноеСловоИсходное) = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			СтрокаМодуля = СтрЗаменить(СтрокаМодуля, Символы.Таб, " ");
			СтрокаМодуля = СтрЗаменить(СтрокаМодуля, "(", " ");
			СтрокаМодуля = СтрЗаменить(СтрокаМодуля, ")", " ");
			СтрокаМодуля = СтрЗаменить(СтрокаМодуля, ";", " ");
			
		ИначеЕсли ПустаяСтрока(СтрокаМодуля) ИЛИ СтрНайти(СтрокаМодуля, НайденноеСловоИсходное) = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Если ЭтоЗакомментированнаяСтрока Тогда
			Продолжить;
		КонецЕсли;
		
		// Добавляем пробелы в начале и конце, чтобы поиск сработал корректно (например, "Процедура" пишется сначала строки)
		// и совпадал номер символа в строках.
		СтрокаМодуля = СтрШаблон(" %1 ", СтрокаМодуля);
		СтрокаМодуляВРег = ВРег(СтрокаМодуля);
		СтрокаМодуляИсправленная = СтрШаблон(" %1 ", СтрокаМодуляИсходная);
		
		// Получаем слово для поиска.
		СловоДляПоиска = СтрШаблон(" %1 ", ВРег(НайденноеСловоИсходное));
		
		СтрокаТаблицы = ТаблицаКлючевыхСлов.Найти(СловоДляПоиска, "СловоДляПоиска");
		Если СтрокаТаблицы = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаИзменена = Ложь;
		
		ДлинаЭталона = СтрокаТаблицы.ДлинаЭталона;
		Эталон       = СтрокаТаблицы.Эталон;
		
		// Ищем вхождение ключевого слова в строке модуля.
		ПозицияПоиска = 0;
		Пока Истина Цикл
			
			ПозицияПоиска = СтрНайти(СтрокаМодуляВРег, СловоДляПоиска,, ПозицияПоиска + 1);
			Если ПозицияПоиска = 0 Тогда
				Прервать;
			КонецЕсли;
			
			ПозицияСловаНачало = ПозицияПоиска + 1;
			ПозицияСловаКонец = ПозицияСловаНачало + ДлинаЭталона;
			
			НайденноеСлово = Сред(СтрокаМодуля, ПозицияСловаНачало, ДлинаЭталона);
			Если НайденноеСлово = Эталон Тогда
				Продолжить;
			КонецЕсли;
			
			// Меняем исходное ключевое слово на эталон.
			СтрокаДо = Лев(СтрокаМодуляИсправленная, ?(ЭтоНоваяПроверяемаяСтрока, ПозицияПоиска, ПозицияПоиска - 1));
			СтрокаПосле = Сред(СтрокаМодуляИсправленная, ?(ЭтоНоваяПроверяемаяСтрока, ПозицияСловаКонец, ПозицияСловаКонец - 1));
			
			СтрокаМодуляИсправленная = СтрокаДо + Эталон + СтрокаПосле;
			
			СтрокаИзменена = Истина;
			
		КонецЦикла;
		
		Если СтрокаИзменена Тогда
			// Удаляем пробелы в начале и конце.
			НачальныйСимвол = ?(ЭтоНоваяПроверяемаяСтрока, 2, 1);
			КоличествоСимволовСКонца = ?(ЭтоНоваяПроверяемаяСтрока, 2, 0);
			
			СтрокаМодуляИсправленная = Сред(СтрокаМодуляИсправленная, НачальныйСимвол,
				СтрДлина(СтрокаМодуляИсправленная) - КоличествоСимволовСКонца);
			
			ДокументТекст.ЗаменитьСтроку(НомерСтроки, СтрокаМодуляИсправленная);
			ФайлИзменен = Истина;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ФайлИзменен;
	
КонецФункции

