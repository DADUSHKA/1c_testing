Функция ПолучитьТаблицуТиповОбъектовРеквизитEDT()
	
	ТаблицаТиповОбъектовРеквизит = Новый ТаблицаЗначений;
	ТаблицаТиповОбъектовРеквизит.Колонки.Добавить("ТипОбъекта");
	ТаблицаТиповОбъектовРеквизит.Колонки.Добавить("ВыражениеПоиска");
	
	// Реквизит
	НовыйТипРеквизита = ТаблицаТиповОбъектовРеквизит.Добавить();
	НовыйТипРеквизита.ТипОбъекта = "Реквизит";
	НовыйТипРеквизита.ВыражениеПоиска = "/mdclass:%1/attributes";
	
	// Реквизит табличной части
	НовыйТипРеквизита = ТаблицаТиповОбъектовРеквизит.Добавить();
	НовыйТипРеквизита.ТипОбъекта = "Реквизит";
	НовыйТипРеквизита.ВыражениеПоиска = "/mdclass:%1/tabularSections/attributes";
	
	// Стандартный реквизит.
	НовыйТипРеквизита = ТаблицаТиповОбъектовРеквизит.Добавить();
	НовыйТипРеквизита.ТипОбъекта = "СтандартныйРеквизит";
	НовыйТипРеквизита.ВыражениеПоиска = "/mdclass:%1/standardAttributes";
	
	// Измерение.
	НовыйТипРеквизита = ТаблицаТиповОбъектовРеквизит.Добавить();
	НовыйТипРеквизита.ТипОбъекта = "Измерение";
	НовыйТипРеквизита.ВыражениеПоиска = "/mdclass:%1/dimensions";
	
	// Ресурс.
	НовыйТипРеквизита = ТаблицаТиповОбъектовРеквизит.Добавить();
	НовыйТипРеквизита.ТипОбъекта = "Ресурс";
	НовыйТипРеквизита.ВыражениеПоиска = "/mdclass:%1/resources";
	
	Возврат ТаблицаТиповОбъектовРеквизит;
	
КонецФункции

Функция ПолучитьТаблицуОбъектовИмеющихРеквизитыEDT(ФайлКонфигурации)
	
	ТаблицаОбъектов = Новый ТаблицаЗначений;
	ТаблицаОбъектов.Колонки.Добавить("ПолноеИмя");
	ТаблицаОбъектов.Колонки.Добавить("ТипОбъекта");
	
	Если НЕ апк_ФайлСуществует(ФайлКонфигурации) Тогда
		Возврат ТаблицаОбъектов;
	КонецЕсли;
	
	МассивТиповОбъектовИмеющихРеквизиты = ПолучитьМассивТиповОбъектовИмеющихРеквизиты();
	
	ДокументDOM = ДокументDOM(ФайлКонфигурации);
	Если ДокументDOM = Неопределено Тогда
		Возврат ТаблицаОбъектов;
	КонецЕсли;
	
	ЭлементDOMПодчиненныеОбъекты = ПолучитьЭлементDOMПоВыражениюXPath("/mdclass:Configuration", ДокументDOM);
	Если ЭлементDOMПодчиненныеОбъекты = Неопределено Тогда
		Возврат ТаблицаОбъектов;
	КонецЕсли;
	
	ТаблицаТиповОбъектовИнициализировать();
	
	Для Каждого СтрокаТипа Из ТаблицаТиповОбъектов Цикл
		
		Если МассивТиповОбъектовИмеющихРеквизиты.Найти(СтрокаТипа.Имя) = Неопределено Тогда
			// Если такого типа нет в массиве типов объектов, имеющих реквизиты, то пропускаем.
			Продолжить;
		КонецЕсли;
		
		ТипОбъектаАнглМнФормы = СтрокаТипа.ИмяАнглМнФормы;
		Если ПустаяСтрока(ТипОбъектаАнглМнФормы) Тогда
			Продолжить;
		КонецЕсли;
		
		ТипОбъектаАнгл = СтрокаТипа.ИмяАнгл;
		
		ИмяОбъектаДляПоиска = НРег(Сред(ТипОбъектаАнглМнФормы, 1, 1)) + Сред(ТипОбъектаАнглМнФормы,2);
		ВыражениеПоискаПоТипу = СтрШаблон("/mdclass:Configuration/%1", ИмяОбъектаДляПоиска);
		
		РезультатXPath = ВычислитьВыражениеXPath(ВыражениеПоискаПоТипу, ДокументDOM);
		Пока Истина Цикл
			
			ЭлементDOM = РезультатXPath.ПолучитьСледующий();
			Если ЭлементDOM = Неопределено Тогда
				Прервать;
			КонецЕсли;
			
			ИмяОбъекта = ЭлементDOM.ТекстовоеСодержимое;
			МассивИмени = СтрРазделить(ИмяОбъекта, ".");
			ИмяОбъекта = МассивИмени[МассивИмени.ВГраница()];
			
			ПолноеИмяФайла = СтрШаблон("%1src%2%3%2%4%2%4.mdo", КаталогВыгрузкиРезультат, РазделительПути, ТипОбъектаАнглМнФормы, ИмяОбъекта);
			Если НЕ апк_ФайлСуществует(ПолноеИмяФайла) Тогда
				Продолжить;
			КонецЕсли;
			
			СтрокаОбъекта = ТаблицаОбъектов.Добавить();
			СтрокаОбъекта.ПолноеИмя  = ПолноеИмяФайла;
			СтрокаОбъекта.ТипОбъекта = ТипОбъектаАнгл;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ТаблицаОбъектов;
	
КонецФункции

