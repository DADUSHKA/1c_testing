Функция ПолучитьПараметрыСтандарта474()
	
	ТаблицаИзмененийСинонимов = Новый ТаблицаЗначений;
	ТаблицаИзмененийСинонимов.Колонки.Добавить("КаталогОбъектов");
	ТаблицаИзмененийСинонимов.Колонки.Добавить("ИскатьВПодкаталогах");
	ТаблицаИзмененийСинонимов.Колонки.Добавить("РасширениеФайлов");
	ТаблицаИзмененийСинонимов.Колонки.Добавить("ИмяОбъекта");
	ТаблицаИзмененийСинонимов.Колонки.Добавить("ИсходныйСиноним");
	ТаблицаИзмененийСинонимов.Колонки.Добавить("НовыйСиноним");
	ТаблицаИзмененийСинонимов.Колонки.Добавить("ТипВыгрузкиФайлов");
	ТаблицаИзмененийСинонимов.Колонки.Добавить("ВыражениеПоискаСвойств");
	
	НоваяСтрокаТаблицы = ТаблицаИзмененийСинонимов.Добавить();
	НоваяСтрокаТаблицы.КаталогОбъектов = "Roles";
	НоваяСтрокаТаблицы.ИмяОбъекта = "ДобавлениеИзменение";
	НоваяСтрокаТаблицы.ИсходныйСиноним = НСтр("ru='Добавление изменение'; en='Add edit'", КодОсновногоЯзыка);
	НоваяСтрокаТаблицы.НовыйСиноним = НСтр("ru='Добавление и изменение'; en='Add and edit'", КодОсновногоЯзыка);
	НоваяСтрокаТаблицы.РасширениеФайлов = "*.xml";
	НоваяСтрокаТаблицы.ИскатьВПодкаталогах = Ложь;
	НоваяСтрокаТаблицы.ТипВыгрузкиФайлов = "XML";
	НоваяСтрокаТаблицы.ВыражениеПоискаСвойств = "/xmlns:MetaDataObject/xmlns:Role/xmlns:Properties";
	
	НоваяСтрокаТаблицы = ТаблицаИзмененийСинонимов.Добавить();
	НоваяСтрокаТаблицы.КаталогОбъектов = "Roles";
	НоваяСтрокаТаблицы.ИмяОбъекта = "ДобавлениеИзменение";
	НоваяСтрокаТаблицы.ИсходныйСиноним = НСтр("ru='Добавление изменение'; en='Add edit'", КодОсновногоЯзыка);
	НоваяСтрокаТаблицы.НовыйСиноним = НСтр("ru='Добавление и изменение'; en='Add and edit'", КодОсновногоЯзыка);
	НоваяСтрокаТаблицы.РасширениеФайлов = "*.mdo";
	НоваяСтрокаТаблицы.ИскатьВПодкаталогах = Истина;
	НоваяСтрокаТаблицы.ТипВыгрузкиФайлов = "EDT";
	НоваяСтрокаТаблицы.ВыражениеПоискаСвойств = "/mdclass:Role";
	
	ПараметрыСтандарта474 = Новый Структура;
	ПараметрыСтандарта474.Вставить("ТаблицаИзмененийСинонимов", ТаблицаИзмененийСинонимов);
	
	Возврат ПараметрыСтандарта474;
	
КонецФункции

Процедура ПривестиОбъектКСтандарту474(ПолноеИмяФайла, ПараметрыСтандарта474)
	
	ДокументDOM = ДокументDOM(ПолноеИмяФайла);
	Если ДокументDOM = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ОбъектИзменен = Ложь;
	
	Если ЗначениеФлагов.ДобавлениеСоюзовИПредлоговВСинонимыОбъектов Тогда
		
		ВремяНачалаЗамера = ТекущаяУниверсальнаяДатаВМиллисекундах();
		ОбъектИзмененПравилом = ИзменитьСинонимОбъекта(ДокументDOM, ПараметрыСтандарта474.ПараметрыИзмененияСинонима);
		ОбъектИзменен = ОбъектИзменен ИЛИ ОбъектИзмененПравилом;
		
		Если ОбъектИзмененПравилом Тогда
			ЗаполнитьВремяПриведенияКСтандарту("ДобавлениеСоюзовИПредлоговВСинонимыОбъектов", ВремяНачалаЗамера);
			ДобавитьСтрокуВТаблицуИзмененныхОбъектов(ПолноеИмяФайла, "ДобавлениеСоюзовИПредлоговВСинонимыОбъектов");
		КонецЕсли;
		
	КонецЕсли;
	
	Если ОбъектИзменен Тогда
		ЗаписатьДокументDOMВФайл(ДокументDOM, ПолноеИмяФайла);
	КонецЕсли;
	
КонецПроцедуры

Процедура ПривестиКонфигурациюКСтандарту474()
	
	ПараметрыСтандарта474 = ПолучитьПараметрыСтандарта474();
	ТаблицаИзмененийСинонимов = ПараметрыСтандарта474.ТаблицаИзмененийСинонимов;
	
	ТипВыгрузкиФайлов = ?(ЭтоВыгрузкаXMLФайлов, "XML", "EDT");
	
	СтруктураОтбораТипВыгрузкиФайлов = Новый Структура;
	СтруктураОтбораТипВыгрузкиФайлов.Вставить("ТипВыгрузкиФайлов", ТипВыгрузкиФайлов);
	
	ТаблицаИзмененийСинонимовПоТипуВыгрузки = ТаблицаИзмененийСинонимов.Скопировать(СтруктураОтбораТипВыгрузкиФайлов);
	Для Каждого СтрокаИзмененийСинонима Из ТаблицаИзмененийСинонимовПоТипуВыгрузки Цикл
		
		ПараметрыСтандарта474.Вставить("ПараметрыИзмененияСинонима", СтрокаИзмененийСинонима);
		
		КаталогОбъектов = СтрокаИзмененийСинонима.КаталогОбъектов;
		КаталогПоискаФайлов = КаталогВыгрузкиРезультат + КаталогОбъектов;
		Если НЕ ЭтоВыгрузкаXMLФайлов Тогда
			Если НЕ апк_ФайлСуществует(КаталогПоискаФайлов) Тогда
				КаталогПоискаФайлов = КаталогВыгрузкиРезультат + "src";
				КаталогПоискаФайлов = ОтредактироватьПутьККаталогу(КаталогПоискаФайлов) + КаталогОбъектов;
			КонецЕсли;
		КонецЕсли;
		
		Если НЕ апк_ФайлСуществует(КаталогПоискаФайлов) Тогда
			Продолжить;
		КонецЕсли;
		
		МассивФайлов = НайтиФайлы(КаталогПоискаФайлов, СтрокаИзмененийСинонима.РасширениеФайлов, СтрокаИзмененийСинонима.ИскатьВПодкаталогах);
		Для Каждого Файл Из МассивФайлов Цикл
			
			ПолноеИмяФайла = Файл.ПолноеИмя;
			Если ПроверитьФайлВыбранДляРедактирования(ПолноеИмяФайла) Тогда
				ПривестиОбъектКСтандарту474(ПолноеИмяФайла, ПараметрыСтандарта474);
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

