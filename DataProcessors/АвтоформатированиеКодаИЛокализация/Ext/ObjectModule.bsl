Функция ПолучитьТаблицуИзМакета(Макет)
	
	ТаблицаДанных = Новый ТаблицаЗначений;
	
	ТабличныйДокумент = ПолучитьМакет(Макет);
	
	РабочаяОбласть = ТабличныйДокумент.ПолучитьОбласть();
	Для НомерКолонки = 1 По РабочаяОбласть.ШиринаТаблицы Цикл
		ИмяКолонки = РабочаяОбласть.Область(1, НомерКолонки).Текст;
		ТаблицаДанных.Колонки.Добавить(ИмяКолонки);
	КонецЦикла;
	
	Для НомерСтроки = 2 По РабочаяОбласть.ВысотаТаблицы Цикл
		НоваяСтрока = ТаблицаДанных.Добавить();
		Для НомерКолонки = 1 По РабочаяОбласть.ШиринаТаблицы Цикл
			НоваяСтрока[НомерКолонки - 1] = РабочаяОбласть.Область(НомерСтроки, НомерКолонки).Текст;
		КонецЦикла;
	КонецЦикла;
	
	Возврат ТаблицаДанных;
	
КонецФункции

