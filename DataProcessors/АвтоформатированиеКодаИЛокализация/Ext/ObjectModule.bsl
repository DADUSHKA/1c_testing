	ЭлементDOMv8item = ЭлементDOMЯзык.РодительскийУзел;
	
	Заголовок = ПолучитьЗначениеЭлементаDOMПоВыражениюXPath("v8:content", ДокументDOM, ЭлементDOMv8item);
	
