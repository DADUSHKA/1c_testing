&НаСервере
Функция ФайлСуществуетНаСервере(Знач ИмяФайла)
	
	Файл = Новый Файл(ИмяФайла);
	Возврат Файл.Существует();
	
КонецФункции

&НаСервере
Процедура ОчиститьКаталогиВыгрузки(Знач Маска = "*")
	
	Попытка
		УдалитьФайлы(Объект.КаталогВыгрузки, Маска);
		УдалитьФайлы(Объект.КаталогВыгрузкиРезультат, Маска);
	Исключение
	КонецПопытки;
	
КонецПроцедуры

&НаСервере
// Получает путь к временному файлу в родительском каталоге выгрузки.
//
Функция апк_ПолучитьИмяВременногоФайла(Расширение = "")
	
	КаталогВыгрузкиРодитель = ПолучитьКаталогФайла(Объект.КаталогВыгрузки);
	
	ИмяФайла = ПолучитьИмяВременногоФайла(Расширение);
	Файл = Новый Файл(ИмяФайла);
	
	Возврат КаталогВыгрузкиРодитель + Файл.Имя;
	
КонецФункции

&НаСервере
Функция ПолучитьКаталогФайла(ПутьКФайлу)
	
	Файл = Новый Файл(ПутьКФайлу);
	Возврат Файл.Путь;
	
КонецФункции

&НаСервере
Процедура СкопироватьКаталогВыгрузки(Источник, Приемник)
	
	ДоступОбъект = РеквизитФормыВЗначение("Объект");
	ДоступОбъект.СкопироватьКаталогВыгрузки(Источник, Приемник);
	ЗначениеВРеквизитФормы(ДоступОбъект, "Объект");
	
КонецПроцедуры

&НаСервере
Функция ОтредактироватьПутьККаталогу(Каталог)
	
	Если ПустаяСтрока(Каталог) Тогда
		Возврат Каталог;
	КонецЕсли;
	
	Если НЕ СтрЗаканчиваетсяНа(Каталог, ПолучитьРазделительПути()) Тогда
		Каталог = Каталог + ПолучитьРазделительПути();
	КонецЕсли;
	
	Возврат Каталог;
	
КонецФункции

&НаСервере
Функция апк_ПолучитьФайлИзАрхива(ФайлАрхива)
	
	ПолученныйФайл = "";
	
	ВременныйКаталог = ПолучитьИмяВременногоФайла();
	апк_РаспаковатьАрхив(ФайлАрхива, ВременныйКаталог);
	
	МассивФайлов = НайтиФайлы(ВременныйКаталог, "*.xml");
	Если МассивФайлов.Количество() > 0 Тогда
		ПолученныйФайл = МассивФайлов[0].ПолноеИмя;
	КонецЕсли;
	
	Возврат ПолученныйФайл;
	
КонецФункции

&НаСервере
// Процедура предназначена для распаковки архива.
//
// Параметры:
// ИмяФайла - имя файла архива.
// ИмяКаталога - каталог, в который распаковывается архив.
Процедура апк_РаспаковатьАрхив(ИмяФайла, Каталог)
	
	Если НЕ ФайлСуществуетНаСервере(Каталог) Тогда
		СоздатьКаталог(Каталог);
	КонецЕсли;
	
	Попытка
		ЧтениеZipФайла = Новый ЧтениеZipФайла(ИмяФайла);
		ЧтениеZipФайла.ИзвлечьВсе(Каталог);
		ЧтениеZipФайла.Закрыть();
	Исключение
		// АПК:280 - действия при исключении не требуются.
	КонецПопытки;
	
КонецПроцедуры

&НаСервере
// Удаляет в попытке указанный файл или каталог.
// Действует аналогично методу УдалитьФайлы().
//
Процедура апк_ФайлУдалить(Знач ИмяФайла, Знач Маска = "")
	
	Если НЕ ФайлСуществуетНаСервере(ИмяФайла) Тогда
		Возврат;
	КонецЕсли;
	
	Попытка
		УдалитьФайлы(ИмяФайла, Маска);
	Исключение;
	КонецПопытки;
	
КонецПроцедуры

#КонецОбласти

#Область КомандыЗапускаКонфигуратораВПакетномРежиме

&НаСервере
Функция ЗагрузитьКонфигурациюИзХранилища()
	
	КаталогХранилища = Объект.КаталогХранилища;
	
	Если ПустаяСтрока(КаталогХранилища) Тогда
		Возврат "";
	КонецЕсли;
	
	ДоступОбъект = РеквизитФормыВЗначение("Объект");
	
	Статус = ДоступОбъект.ЗагрузитьКонфигурациюИзХранилища();
	Если НЕ ПустаяСтрока(Статус) Тогда
		СтрокаСообщения = НСтр("ru='Не удалось загрузить конфигурацию из хранилища по причине:%1%2';
			|en='Не удалось загрузить конфигурацию из хранилища по причине:%1%2'", Объект.КодОсновногоЯзыка);
		СтрокаСообщения = СтрШаблон(СтрокаСообщения, Символы.ПС, Статус);
		Возврат СтрокаСообщения;
	КонецЕсли;
	
	ЗначениеВРеквизитФормы(ДоступОбъект, "Объект");
	
	Возврат "";
	
КонецФункции

