Функция ПолучитьТаблицуСтандартовИзМакетаНаСервере()
	
	ДоступОбъект = РеквизитФормыВЗначение("Объект");
	ТаблицаСтандартов = ДоступОбъект.ПолучитьТаблицуСтандартовИзМакета();
	ЗначениеВРеквизитФормы(ДоступОбъект, "Объект");
	
