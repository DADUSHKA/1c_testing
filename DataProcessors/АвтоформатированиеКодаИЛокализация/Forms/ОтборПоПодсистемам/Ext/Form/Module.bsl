
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ТаблицаСтруктурыКонфигурации = Параметры.СтруктураКонфигурации.Выгрузить();
	
	ПараметрыОтбора = Новый Структура;
	ПараметрыОтбора.Вставить("ТипОбъекта", "Подсистема");
	
	ТаблицаПодсистем = ТаблицаСтруктурыКонфигурации.Скопировать(ПараметрыОтбора);
	ТаблицаПодсистем.Индексы.Добавить("ИДРодителя");
	
	КореньКонфигурации = ТаблицаСтруктурыКонфигурации.Найти("Конфигурация", "ТипОбъекта");
	Если КореньКонфигурации = Неопределено Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	КоллекцияЭлементов = ДеревоПодсистем.ПолучитьЭлементы();
	
	СтрокаКорня = КоллекцияЭлементов.Добавить();
	ЗаполнитьЗначенияСвойств(СтрокаКорня, КореньКонфигурации);
	
	ПараметрыОтбора.Вставить("ТипОбъекта", "ВеткаМетаданных");
	ПараметрыОтбора.Вставить("Объект", "Подсистемы");
	
	МассивВеткиПодсистемы = ТаблицаСтруктурыКонфигурации.НайтиСтроки(ПараметрыОтбора);
	Если МассивВеткиПодсистемы.Количество() = 0 Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	ВеткаПодсистем = МассивВеткиПодсистемы[0];
	
	ЗаполнитьДеревоПодсистем(СтрокаКорня.ПолучитьЭлементы(), ТаблицаПодсистем, ВеткаПодсистем.ИД);
	
	ПустойИД = Новый УникальныйИдентификатор("00000000-0000-0000-0000-000000000000");
	ПустаяПодсистема = ТаблицаСтруктурыКонфигурации.Найти(ПустойИД, "ИД");
	
	СтрокаОбъектыБезПодсистем = КоллекцияЭлементов.Добавить();
	ЗаполнитьЗначенияСвойств(СтрокаОбъектыБезПодсистем, ПустаяПодсистема);
	СтрокаОбъектыБезПодсистем.Флаг = ПустаяПодсистема.ПодсистемаВыбрана;
	СтрокаОбъектыБезПодсистем.ИндексКартинки = 2;
	
	ЗаполнитьФлагиДерева();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ДеревоПодсистемФлагПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.ДеревоПодсистем.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЗначениеФлага = ТекущиеДанные.Флаг;
	
	Если ЗначениеФлага = 0 ИЛИ ЗначениеФлага = 1 Тогда
		ТекущиеДанные.Флаг = 1;
		УстанавливаемоеЗначение = 1;
	Иначе
		ТекущиеДанные.Флаг = 0;
		УстанавливаемоеЗначение = 0;
	КонецЕсли;
	
	КоллекцияЭлементов = ТекущиеДанные.ПолучитьЭлементы();
	ОтметитьВсеПодчиненныеОбъекты(КоллекцияЭлементов, УстанавливаемоеЗначение);
	
	УстановитьФлагРодителю(ТекущиеДанные.ПолучитьИдентификатор());
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Установить(Команда)
	
	МассивПодсистем = Новый Массив;
	СформироватьМассивВыбранныхПодсистем(МассивПодсистем);
	Закрыть(МассивПодсистем);
	
КонецПроцедуры

&НаКлиенте
Процедура Отключить(Команда)
	
	МассивПодсистем = Новый Массив;
	Закрыть(МассивПодсистем);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункций

&НаСервере
Процедура ЗаполнитьДеревоПодсистем(КоллекцияЭлементов, ТаблицаПодсистем, ИДРодителя)
	
	СтруктураОтбора = Новый Структура;
	СтруктураОтбора.Вставить("ИДРодителя", ИДРодителя);
	
	МассивСтрок = ТаблицаПодсистем.НайтиСтроки(СтруктураОтбора);
	Для Каждого СтрокаСтруктуры Из МассивСтрок Цикл
		СтрокаДерева = КоллекцияЭлементов.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаДерева, СтрокаСтруктуры);
		СтрокаДерева.Флаг = СтрокаСтруктуры.ПодсистемаВыбрана;
		СтрокаДерева.ИндексКартинки = 2;
		
		ЗаполнитьДеревоПодсистем(СтрокаДерева.ПолучитьЭлементы(), ТаблицаПодсистем, СтрокаСтруктуры.ИД);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура СформироватьМассивВыбранныхПодсистем(МассивПодсистем, КоллекцияЭлементов = Неопределено)
	
	Если КоллекцияЭлементов = Неопределено Тогда
		КоллекцияЭлементов = ДеревоПодсистем.ПолучитьЭлементы();
	КонецЕсли;
	
	Для Каждого СтрокаКоллекции Из КоллекцияЭлементов Цикл
		
		Если (СтрокаКоллекции.Флаг = 1)
			// Выполняем проверку на индекс картинки, чтобы не добавлять корень конфигурации в массив.
			И (СтрокаКоллекции.ИндексКартинки > 0) Тогда
			
			МассивПодсистем.Добавить(СтрокаКоллекции.ИД);
			
		КонецЕсли;
		
		СформироватьМассивВыбранныхПодсистем(МассивПодсистем, СтрокаКоллекции.ПолучитьЭлементы());
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ОтметитьВсеПодчиненныеОбъекты(КоллекцияЭлементов, УстанавливаемоеЗначение)
	
	Для Каждого СтрокаДерева Из КоллекцияЭлементов Цикл
		СтрокаДерева.Флаг = УстанавливаемоеЗначение;
		ОтметитьВсеПодчиненныеОбъекты(СтрокаДерева.ПолучитьЭлементы(), УстанавливаемоеЗначение)
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьФлагРодителю(Знач ИДСтроки)
	
	ТекущаяСтрокаДерева = ДеревоПодсистем.НайтиПоИдентификатору(ИДСтроки);
	Если ТекущаяСтрокаДерева = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаРодителя = ТекущаяСтрокаДерева.ПолучитьРодителя();
	ПроверитьЗначениеФлагаУРодителей(СтрокаРодителя);
	
КонецПроцедуры

&НаСервере
Процедура ПроверитьЗначениеФлагаУРодителей(СтрокаРодителя)
	
	Если СтрокаРодителя = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	НайденУстановленныйФлаг = Ложь;
	НайденНеУстановленныйФлаг = Ложь;
	НайденФлагСоВторымЗначением = Ложь;
	
	КоллекцияЭлементов = СтрокаРодителя.ПолучитьЭлементы();
	Для Каждого СтрокаКоллекции Из КоллекцияЭлементов Цикл
		
		Если СтрокаКоллекции.Флаг = 1 Тогда
			НайденУстановленныйФлаг = Истина;
		ИначеЕсли СтрокаКоллекции.Флаг = 2 Тогда
			НайденФлагСоВторымЗначением = Истина;
		Иначе
			НайденНеУстановленныйФлаг = Истина;
		КонецЕсли;
		
		Если НайденФлагСоВторымЗначением Тогда
			Прервать;
		КонецЕсли;
		
		Если НайденФлагСоВторымЗначением ИЛИ (НайденУстановленныйФлаг И НайденНеУстановленныйФлаг) Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Если НайденФлагСоВторымЗначением ИЛИ (НайденУстановленныйФлаг И НайденНеУстановленныйФлаг) Тогда
		СтрокаРодителя.Флаг = 2;
	ИначеЕсли НайденУстановленныйФлаг И (НЕ НайденНеУстановленныйФлаг) Тогда
		СтрокаРодителя.Флаг = 1;
	Иначе
		СтрокаРодителя.Флаг = 0;
	КонецЕсли;
	
	ПроверитьЗначениеФлагаУРодителей(СтрокаРодителя.ПолучитьРодителя());
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьФлагиДерева()
	
	СоответствиеРодителей = Новый Соответствие;
	ПолучитьСоответствиеСтрокРодителейНижнегоУровня(СоответствиеРодителей);
	
	Для Каждого ЭлементСоответствия Из СоответствиеРодителей Цикл
		ПроверитьЗначениеФлагаУРодителей(ЭлементСоответствия.Ключ);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ПолучитьСоответствиеСтрокРодителейНижнегоУровня(СоответствиеРодителей, СтрокаДерева = Неопределено)
	
	Если СтрокаДерева = Неопределено Тогда
		КоллекцияСтрок = ДеревоПодсистем.ПолучитьЭлементы();
		Если КоллекцияСтрок.Количество() = 0 Тогда
			Возврат;
		КонецЕсли;
	Иначе
		КоллекцияСтрок = СтрокаДерева.ПолучитьЭлементы();
	КонецЕсли;
	
	Если КоллекцияСтрок.Количество() = 0 Тогда
		СоответствиеРодителей.Вставить(СтрокаДерева.ПолучитьРодителя(), Истина);
		Возврат;
	КонецЕсли;
	
	Для Каждого СтрокаКоллекции Из КоллекцияСтрок Цикл
		ПолучитьСоответствиеСтрокРодителейНижнегоУровня(СоответствиеРодителей, СтрокаКоллекции);
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти