
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ОбъектИсточник = Параметры.Объект;
	
	СвойстваИсключения = "Результат, ЗахваченныеОбъекты, ПравилаПоддержкиОбъектов, СтруктураКонфигурации, СоставПодсистем, ТаблицаИзмененныхОбъектовИСтандартов";
	ЗаполнитьЗначенияСвойств(Объект, ОбъектИсточник,, СвойстваИсключения);
	ЗаполнитьТаблицуОбъекта(ОбъектИсточник, "СтруктураКонфигурации");
	ЗаполнитьТаблицуОбъекта(ОбъектИсточник, "СоставПодсистем");
	
	ЗаполнитьСписокВыбранныхПодсистем();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если Объект.СтруктураКонфигурации.Количество() = 0 Тогда
		ПодключитьОбработчикОжидания("ВопросПриОткрытииФормы", 0.1, Истина);
	Иначе
		Состояние(НСтр("ru='Построение дерева структуры конфигурации';
			|en='Построение дерева структуры конфигурации'", Объект.КодОсновногоЯзыка));
		ПостроитьДеревоСтруктурыКонфигурации();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	ПараметрыОповещения = Новый Структура;
	ПараметрыОповещения.Вставить("Объект", Объект);
	ПараметрыОповещения.Вставить("ОбновитьТаблицуСтруктуры", ОбновитьТаблицуСтруктуры);
	
	Оповестить("апк_ЗакрытиеФормыВыбораОбъектов", ПараметрыОповещения, ВладелецФормы);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура СтруктураКонфигурацииФлагПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.ДеревоСтруктурыКонфигурации.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЗначениеФлага = ТекущиеДанные.Флаг;
	
	Если ЗначениеФлага = 0 ИЛИ ЗначениеФлага = 1 Тогда
		ТекущиеДанные.Флаг = 1;
		УстанавливаемоеЗначение = 1;
	Иначе
		ТекущиеДанные.Флаг = 0;
		УстанавливаемоеЗначение = 0;
	КонецЕсли;
	
	КоллекцияЭлементов = ТекущиеДанные.ПолучитьЭлементы();
	ОтметитьВсеПодчиненныеОбъекты(КоллекцияЭлементов, УстанавливаемоеЗначение);
	
	УстановитьФлагРодителю(ТекущиеДанные.ПолучитьИдентификатор());
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ВыбратьВсе(Команда)
	
	УстановитьЗначениеФлагов(1);
	
КонецПроцедуры

&НаКлиенте
Процедура ОтменитьВсе(Команда)
	
	УстановитьЗначениеФлагов(0);
	
КонецПроцедуры

&НаКлиенте
Процедура ОтборПоПодсистемам(Команда)
	
	Состояние(НСтр("ru='Построение дерева подсистем'; en='Построение дерева подсистем'", Объект.КодОсновногоЯзыка));
	
	Параметр = Новый Структура("СтруктураКонфигурации", Объект.СтруктураКонфигурации);
	ОписаниеОповещения = Новый ОписаниеОповещения("ПослеОкончанияВыбораПодсистем", ЭтотОбъект);
	
	МассивИмениФормы = СтрРазделить(ИмяФормы, ".");
	Если МассивИмениФормы.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ВидОбработки = МассивИмениФормы[0];
	
	ОткрытьФорму(СтрШаблон("%1.АвтоформатированиеКодаИЛокализация.Форма.ОтборПоПодсистемам", ВидОбработки), Параметр, ЭтаФорма,
		УникальныйИдентификатор,,, ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура Принять(Команда)
	
	ЗаполнитьФлагиВСтруктуруКонфигурации();
	ЗаполнитьВыбранныеПодсистемыКонфигурации();
	ОбновитьТаблицуСтруктуры = Истина;
	Закрыть();
	
КонецПроцедуры

&НаКлиенте
Процедура Обновить(Команда)
	
	Объект.СтруктураКонфигурации.Очистить();
	Объект.СоставПодсистем.Очистить();
	ВыбранныеПодсистемы.Очистить();
	Элементы.ДеревоСтруктурыКонфигурацииОтборПоПодсистемам.Пометка = Ложь;
	ОбновитьТаблицуСтруктуры = Истина;
	
	ЗагрузитьСтруктуруКонфигурации();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ВопросПриОткрытииФормы()
	
	ОписаниеОповещение = Новый ОписаниеОповещения("НачатьЗагрузкуСтруктурыКонфигурации_ДиалогПоказан", ЭтотОбъект);
	ТекстВопроса = НСтр("ru='Для выбора состава объектов требуется собрать сведения о конфигурации.
		|Эта операция может занять длительное время. Продолжить?';
		|en='Для выбора состава объектов требуется собрать сведения о конфигурации.
		|Эта операция может занять длительное время. Продолжить?'", Объект.КодОсновногоЯзыка);
	ПоказатьВопрос(ОписаниеОповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
	
КонецПроцедуры

&НаКлиенте
Процедура НачатьЗагрузкуСтруктурыКонфигурации_ДиалогПоказан(Ответ, ДополнительныеПараметры) Экспорт
	
	Если Ответ = КодВозвратаДиалога.Нет Тогда
		Закрыть();
	Иначе
		ЗагрузитьСтруктуруКонфигурации();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьСтруктуруКонфигурации()
	
	// Установим флаг выгрузки и загрузки в зависимости от типа источника.
	Объект.ВыгружатьКонфигурациюВФайлыXML = (Объект.ТипИсточника <> 2);
	
	ХранилищеУказано = НЕ ПустаяСтрока(Объект.КаталогХранилища);
	
	Если Объект.ВыгружатьКонфигурациюВФайлыXML Тогда
		
		Если ХранилищеУказано Тогда
			Состояние(НСтр("ru='Выполняется загрузка конфигурации из хранилища';
				|en='Выполняется загрузка конфигурации из хранилища'", Объект.КодОсновногоЯзыка));
			
			Статус = ЗагрузитьКонфигурациюИзХранилища();
			Если ПустаяСтрока(Статус) Тогда
				апк_Сообщить(НСтр("ru='Конфигурация успешно загружена из хранилища.';
					|en='Конфигурация успешно загружена из хранилища.'", Объект.КодОсновногоЯзыка));
			Иначе
				апк_Сообщить(Статус);
				Возврат;
			КонецЕсли;
		КонецЕсли;
		
		Состояние(НСтр("ru='Выполняется выгрузка конфигурации в файлы XML';
			|en='Выполняется выгрузка конфигурации в файлы XML'", Объект.КодОсновногоЯзыка));
		
		Статус = ВыгрузитьКонфигурациюВФайлыXML();
		Если ПустаяСтрока(Статус) Тогда
			апк_Сообщить(НСтр("ru='Выгрузка конфигурации в файлы XML завершена.';
				|en='Выгрузка конфигурации в файлы XML завершена.'", Объект.КодОсновногоЯзыка));
			Состояние();
		Иначе
			апк_Сообщить(Статус);
			Возврат;
		КонецЕсли;
		
	КонецЕсли;
	
	Состояние(НСтр("ru='Сбор сведений о структуре конфигурации';
		|en='Сбор сведений о структуре конфигурации'", Объект.КодОсновногоЯзыка));
	ЗагрузитьСтруктуруКонфигурацииНаСервере();
	
	Состояние(НСтр("ru='Построение дерева структуры конфигурации';
		|en='Построение дерева структуры конфигурации'", Объект.КодОсновногоЯзыка));
	ПостроитьДеревоСтруктурыКонфигурации();
	
	Если Объект.ВыгружатьКонфигурациюВФайлыXML Тогда
		ОчиститьКаталогиВыгрузки("");
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ЗагрузитьКонфигурациюИзХранилища()
	
	ДоступОбъект = РеквизитФормыВЗначение("Объект");
	Статус = ДоступОбъект.ЗагрузитьКонфигурациюИзХранилища();
	ЗначениеВРеквизитФормы(ДоступОбъект, "Объект");
	
	Возврат Статус;
	
КонецФункции

&НаСервере
Функция ВыгрузитьКонфигурациюВФайлыXML()
	
	Объект.КаталогВыгрузки = ПолучитьИмяВременногоФайла("");
	КаталогДобавитьСлэш(Объект.КаталогВыгрузки);
	СоздатьКаталог(Объект.КаталогВыгрузки);
	
	// Если указан готовый каталог выгрузки XML, то выгружать конфигурацию в XML не надо.
	// Копируем файлы выгрузки из указанного каталога и выходим.
	Если НЕ Объект.ВыгружатьКонфигурациюВФайлыXML Тогда
		СкопироватьКаталогВыгрузки(Объект.КаталогВыгрузкиРезультат, Объект.КаталогВыгрузки);
		Возврат "";
	КонецЕсли;
	
	Объект.КаталогВыгрузкиРезультат = ПолучитьИмяВременногоФайла("");
	КаталогДобавитьСлэш(Объект.КаталогВыгрузкиРезультат);
	СоздатьКаталог(Объект.КаталогВыгрузкиРезультат);
	
	ОчиститьКаталогиВыгрузки();
	
	ДоступОбъект = РеквизитФормыВЗначение("Объект");
	
	Статус = ДоступОбъект.ВыгрузитьКонфигурациюВФайлыXML();
	Если НЕ ПустаяСтрока(Статус) Тогда
		СтрокаСообщения = НСтр("ru='Не удалось выгрузить конфигурацию в файлы XML по причине:%1%2';
			|en='Не удалось выгрузить конфигурацию в файлы XML по причине:%1%2'", Объект.КодОсновногоЯзыка);
		СтрокаСообщения = СтрШаблон(СтрокаСообщения, Символы.ПС, Статус);
		Возврат СтрокаСообщения;
	КонецЕсли;
	ЗначениеВРеквизитФормы(ДоступОбъект, "Объект");
	
	СкопироватьКаталогВыгрузки(Объект.КаталогВыгрузки, Объект.КаталогВыгрузкиРезультат);
	
	Возврат "";
	
КонецФункции

&НаСервере
Процедура СкопироватьКаталогВыгрузки(Источник, Приемник)
	
	ДоступОбъект = РеквизитФормыВЗначение("Объект");
	ДоступОбъект.СкопироватьКаталогВыгрузки(Источник, Приемник);
	ЗначениеВРеквизитФормы(ДоступОбъект, "Объект");
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьСтруктуруКонфигурацииНаСервере()
	
	ДоступОбъект = РеквизитФормыВЗначение("Объект");
	ДоступОбъект.ЗагрузитьСтруктуруКонфигурации();
	ЗначениеВРеквизитФормы(ДоступОбъект, "Объект");
	
КонецПроцедуры

#Область ПостроениеДереваСтруктурыКонфигурации

&НаСервере
Процедура ПостроитьДеревоСтруктурыКонфигурации()
	
	МассивИДОбъектов = ПолучитьМассивОбъектовПоВыбраннымПодсистемам();
	ОтборПоПодсистемам = (ВыбранныеПодсистемы.Количество() > 0);
	
	МассивТиповВходящихВПодсистемы = ПолучитьТипыОбъектовВходящихВПодсистемы();
	ТаблицаИндексовКартинок = ПолучитьТаблицуИндексовКартинок();
	
	ТаблицаСтруктуры = Объект.СтруктураКонфигурации.Выгрузить(, "ИД, ИДРодителя, Объект, ТипОбъекта, Флаг");
	ТаблицаСтруктуры.Индексы.Добавить("ИДРодителя");
	
	ПустойИД = Новый УникальныйИдентификатор("00000000-0000-0000-0000-000000000000");
	
	ПараметрыФормированияДерева = Новый Структура;
	ПараметрыФормированияДерева.Вставить("МассивИДОбъектов", МассивИДОбъектов);
	ПараметрыФормированияДерева.Вставить("ОтборПоПодсистемам", ОтборПоПодсистемам);
	ПараметрыФормированияДерева.Вставить("МассивТиповВходящихВПодсистемы", МассивТиповВходящихВПодсистемы);
	ПараметрыФормированияДерева.Вставить("ТаблицаИндексовКартинок", ТаблицаИндексовКартинок);
	ПараметрыФормированияДерева.Вставить("ТаблицаСтруктуры", ТаблицаСтруктуры);
	ПараметрыФормированияДерева.Вставить("ПустойИД", ПустойИД);
	
	КоллекцияЭлементов = ДеревоСтруктурыКонфигурации.ПолучитьЭлементы();
	
	КоллекцияЭлементов.Очистить();
	
	ПостроитьДеревоСтруктурыКонфигурацииРекурсивно(КоллекцияЭлементов, ПустойИД, ПараметрыФормированияДерева);
	ЗаполнитьФлагиДерева();
	
	Элементы.ДеревоСтруктурыКонфигурацииОтборПоПодсистемам.Пометка = ОтборПоПодсистемам;
	
КонецПроцедуры

&НаСервере
Процедура ПостроитьДеревоСтруктурыКонфигурацииРекурсивно(КоллекцияЭлементов, ИДРодителя, ПараметрыФормированияДерева)
	
	МассивИДОбъектов = ПараметрыФормированияДерева.МассивИДОбъектов;
	ОтборПоПодсистемам = ПараметрыФормированияДерева.ОтборПоПодсистемам;
	МассивТиповВходящихВПодсистемы = ПараметрыФормированияДерева.МассивТиповВходящихВПодсистемы;
	ТаблицаИндексовКартинок = ПараметрыФормированияДерева.ТаблицаИндексовКартинок;
	ТаблицаСтруктуры = ПараметрыФормированияДерева.ТаблицаСтруктуры;
	ПустойИД = ПараметрыФормированияДерева.ПустойИД;
	
	КоллекцияЭлементов.Очистить();
	
	СтруктураОтбора = Новый Структура;
	СтруктураОтбора.Вставить("ИДРодителя", ИДРодителя);
	
	МассивСтрок = ТаблицаСтруктуры.НайтиСтроки(СтруктураОтбора);
	Для Каждого СтрокаСтруктуры Из МассивСтрок Цикл
		
		Если СтрокаСтруктуры.ИД = ПустойИД Тогда
			Продолжить;
		КонецЕсли;
		
		Если ОтборПоПодсистемам
			И (МассивТиповВходящихВПодсистемы.Найти(СтрокаСтруктуры.ТипОбъекта) <> Неопределено)
			И МассивИДОбъектов.Найти(СтрокаСтруктуры.ИД) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаДерева = КоллекцияЭлементов.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаДерева, СтрокаСтруктуры);
		СтрокаДерева.ИндексКартинки = ПолучитьИндексКартинки(ТаблицаИндексовКартинок, СтрокаСтруктуры);
		
		ПостроитьДеревоСтруктурыКонфигурацииРекурсивно(СтрокаДерева.ПолучитьЭлементы(), СтрокаСтруктуры.ИД,
			ПараметрыФормированияДерева);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьТаблицуИндексовКартинок()
	
	ТипыОбъектов = Новый ТаблицаЗначений();
	ТипыОбъектов.Колонки.Добавить("ИмяВЕдинственномЧисле");
	ТипыОбъектов.Колонки.Добавить("ИмяВоМножественномЧисле");
	ТипыОбъектов.Колонки.Добавить("ИндексКартинки");
	
	ДобавитьНовыйТип(ТипыОбъектов, "Корень",						"Корень",						0);
	ДобавитьНовыйТип(ТипыОбъектов, "Конфигурация",					"Конфигурации",					0);
	ДобавитьНовыйТип(ТипыОбъектов, "Общие",							"Общие",						1);
	ДобавитьНовыйТип(ТипыОбъектов, "Подсистема",					"Подсистемы",					2);
	ДобавитьНовыйТип(ТипыОбъектов, "ОбщийМодуль",					"ОбщиеМодули",					3);
	ДобавитьНовыйТип(ТипыОбъектов, "ПараметрСеанса",				"ПараметрыСеанса",				4);
	ДобавитьНовыйТип(ТипыОбъектов, "Роль",							"Роли",							5);
	ДобавитьНовыйТип(ТипыОбъектов, "ОбщийРеквизит",					"ОбщиеРеквизиты",				6);
	ДобавитьНовыйТип(ТипыОбъектов, "ПланОбмена",					"ПланыОбмена",					7);
	ДобавитьНовыйТип(ТипыОбъектов, "КритерийОтбора",				"КритерииОтбора",				8);
	ДобавитьНовыйТип(ТипыОбъектов, "ПодпискаНаСобытие",				"ПодпискиНаСобытия",			9);
	ДобавитьНовыйТип(ТипыОбъектов, "РегламентноеЗадание",			"РегламентныеЗадания",			10);
