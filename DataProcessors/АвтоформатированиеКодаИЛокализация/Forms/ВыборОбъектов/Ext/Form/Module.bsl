&НаСервере
Функция ПолучитьИндексКартинки(ТаблицаИндексовКартинок, СтрокаСтруктуры)
	
	КолонкаДляПоиска = "ИмяВЕдинственномЧисле";
	
	ТипОбъекта = СтрокаСтруктуры.ТипОбъекта;
	Если ТипОбъекта = "ВеткаМетаданных" Тогда
		КолонкаДляПоиска = "ИмяВоМножественномЧисле";
		ТипОбъекта = СтрокаСтруктуры.Объект;
	КонецЕсли;
	
	СтрокаИндексаКартинки = ТаблицаИндексовКартинок.Найти(ТипОбъекта, КолонкаДляПоиска);
	Возврат ?(СтрокаИндексаКартинки = Неопределено, 0, СтрокаИндексаКартинки.ИндексКартинки);
	
КонецФункции

&НаСервере
Функция ПолучитьМассивОбъектовПоВыбраннымПодсистемам()
	
	ТаблицаСоставаПодсистем = Объект.СоставПодсистем.Выгрузить();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	СоставПодсистем.ИДОбъекта КАК ИДОбъекта,
	|	СоставПодсистем.ИДПодсистемы КАК ИДПодсистемы
	|ПОМЕСТИТЬ вт_СоставПодсистем
	|ИЗ
	|	&СоставПодсистем КАК СоставПодсистем
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	вт_СоставПодсистем.ИДОбъекта КАК ИДОбъекта
	|ИЗ
	|	вт_СоставПодсистем КАК вт_СоставПодсистем
	|ГДЕ
	|	вт_СоставПодсистем.ИДПодсистемы В(&СписокИДПодсистем)";
	
	Запрос.УстановитьПараметр("СоставПодсистем", ТаблицаСоставаПодсистем);
	Запрос.УстановитьПараметр("СписокИДПодсистем", ВыбранныеПодсистемы);
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	МассивИДВыбранныхОбъектов = РезультатЗапроса.ВыгрузитьКолонку("ИДОбъекта");
	
	ПустойИД = Новый УникальныйИдентификатор("00000000-0000-0000-0000-000000000000");
	ПоказатьОбъектыБезПодсистем = (ВыбранныеПодсистемы.НайтиПоЗначению(ПустойИД) <> Неопределено);
	
	Если ПоказатьОбъектыБезПодсистем Тогда
		
		ТипыОбъектовПодсистемы = ПолучитьТипыОбъектовВходящихВПодсистемы();
		
		Запрос = Новый Запрос;
		Запрос.Текст = "
		|ВЫБРАТЬ
		|	СтруктураКонфигурации.ТипОбъекта КАК ТипОбъекта,
		|	СтруктураКонфигурации.ИД КАК ИД
		|ПОМЕСТИТЬ вт_СтруктураКонфигурации
		|ИЗ
		|	&СтруктураКонфигурации КАК СтруктураКонфигурации
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СоставПодсистем.ИДОбъекта КАК ИДОбъекта
		|ПОМЕСТИТЬ вт_СоставПодсистем
		|ИЗ
		|	&СоставПодсистем КАК СоставПодсистем
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	вт_СтруктураКонфигурации.ИД КАК ИД
		|ИЗ
		|	вт_СтруктураКонфигурации КАК вт_СтруктураКонфигурации
		|		ЛЕВОЕ СОЕДИНЕНИЕ вт_СоставПодсистем КАК вт_СоставПодсистем
		|		ПО вт_СтруктураКонфигурации.ИД = вт_СоставПодсистем.ИДОбъекта
		|ГДЕ
		|	вт_СтруктураКонфигурации.ТипОбъекта В(&МассивТипов)
		|	И вт_СоставПодсистем.ИДОбъекта ЕСТЬ NULL";
		
		Запрос.УстановитьПараметр("СтруктураКонфигурации", Объект.СтруктураКонфигурации.Выгрузить());
		Запрос.УстановитьПараметр("СоставПодсистем", ТаблицаСоставаПодсистем);
		Запрос.УстановитьПараметр("МассивТипов", ТипыОбъектовПодсистемы);
		
		ТаблицаОбъектовБезПодсистем = Запрос.Выполнить().Выгрузить();
		МассивИДБезПодсистем = ТаблицаОбъектовБезПодсистем.ВыгрузитьКолонку("ИД");
		
		Для Каждого ЭлементМассива Из МассивИДБезПодсистем Цикл
			МассивИДВыбранныхОбъектов.Добавить(ЭлементМассива);
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат МассивИДВыбранныхОбъектов;
	
КонецФункции

