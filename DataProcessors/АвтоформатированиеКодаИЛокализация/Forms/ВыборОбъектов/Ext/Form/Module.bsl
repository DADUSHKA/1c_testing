&НаСервере
Функция КаталогДобавитьСлэш(Каталог)
	
	Если НЕ СтрЗаканчиваетсяНа(Каталог, ПолучитьРазделительПути()) Тогда
		Каталог = Каталог + ПолучитьРазделительПути();
	КонецЕсли;
	
	Возврат Каталог;
	
КонецФункции

&НаКлиенте
Процедура апк_Сообщить(Знач ТекстСообщения, Статус = Неопределено)
	
	Если Статус = Неопределено Тогда
		Статус = СтатусСообщения.Обычное;
	КонецЕсли;
	
	ТекстСообщения = "[" + ТекущаяДата() + "]: " + ТекстСообщения;
	Сообщить(ТекстСообщения, Статус);
	
КонецПроцедуры

#Область УстановкаФлагов

&НаКлиенте
Процедура УстановитьЗначениеФлагов(УстанавливаемоеЗначение, КоллекцияЭлементов = Неопределено)
	
	Если КоллекцияЭлементов = Неопределено Тогда
		КоллекцияЭлементов = ДеревоСтруктурыКонфигурации.ПолучитьЭлементы();
	КонецЕсли;
	
	Для Каждого СтрокаДерева Из КоллекцияЭлементов Цикл
		СтрокаДерева.Флаг = УстанавливаемоеЗначение;
		УстановитьЗначениеФлагов(УстанавливаемоеЗначение, СтрокаДерева.ПолучитьЭлементы());
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ОтметитьВсеПодчиненныеОбъекты(КоллекцияЭлементов, УстанавливаемоеЗначение)
	
	Для Каждого СтрокаДерева Из КоллекцияЭлементов Цикл
		СтрокаДерева.Флаг = УстанавливаемоеЗначение;
		ОтметитьВсеПодчиненныеОбъекты(СтрокаДерева.ПолучитьЭлементы(), УстанавливаемоеЗначение)
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьФлагиДерева()
	
	СоответствиеРодителей = Новый Соответствие;
	ПолучитьСоответствиеСтрокРодителейНижнегоУровня(СоответствиеРодителей);
	
	Для Каждого ЭлементСоответствия Из СоответствиеРодителей Цикл
		ПроверитьЗначениеФлагаУРодителей(ЭлементСоответствия.Ключ);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ПолучитьСоответствиеСтрокРодителейНижнегоУровня(СоответствиеРодителей, СтрокаДерева = Неопределено)
	
	Если СтрокаДерева = Неопределено Тогда
		КоллекцияСтрок = ДеревоСтруктурыКонфигурации.ПолучитьЭлементы();
		Если КоллекцияСтрок.Количество() = 0 Тогда
			Возврат;
		КонецЕсли;
	Иначе
		КоллекцияСтрок = СтрокаДерева.ПолучитьЭлементы();
	КонецЕсли;
	
	Если КоллекцияСтрок.Количество() = 0 Тогда
		СоответствиеРодителей.Вставить(СтрокаДерева.ПолучитьРодителя(), Истина);
		Возврат;
	КонецЕсли;
	
	Для Каждого СтрокаКоллекции Из КоллекцияСтрок Цикл
		ПолучитьСоответствиеСтрокРодителейНижнегоУровня(СоответствиеРодителей, СтрокаКоллекции);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьФлагРодителю(Знач ИДСтроки)
	
	ТекущаяСтрокаДерева = ДеревоСтруктурыКонфигурации.НайтиПоИдентификатору(ИДСтроки);
	Если ТекущаяСтрокаДерева = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаРодителя = ТекущаяСтрокаДерева.ПолучитьРодителя();
	ПроверитьЗначениеФлагаУРодителей(СтрокаРодителя);
	
КонецПроцедуры

&НаСервере
Процедура ПроверитьЗначениеФлагаУРодителей(СтрокаРодителя)
	
	Если СтрокаРодителя = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	НайденУстановленныйФлаг = Ложь;
	НайденНеУстановленныйФлаг = Ложь;
	НайденФлагСоВторымЗначением = Ложь;
	
	КоллекцияЭлементов = СтрокаРодителя.ПолучитьЭлементы();
	Для Каждого СтрокаКоллекции Из КоллекцияЭлементов Цикл
		
		Если СтрокаКоллекции.Флаг = 1 Тогда
			НайденУстановленныйФлаг = Истина;
		ИначеЕсли СтрокаКоллекции.Флаг = 2 Тогда
			НайденФлагСоВторымЗначением = Истина;
		Иначе
			НайденНеУстановленныйФлаг = Истина;
		КонецЕсли;
		
		Если НайденФлагСоВторымЗначением Тогда
			Прервать;
		КонецЕсли;
		
		Если НайденФлагСоВторымЗначением ИЛИ (НайденУстановленныйФлаг И НайденНеУстановленныйФлаг) Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Если НайденФлагСоВторымЗначением ИЛИ (НайденУстановленныйФлаг И НайденНеУстановленныйФлаг) Тогда
		СтрокаРодителя.Флаг = 2;
	ИначеЕсли НайденУстановленныйФлаг И (НЕ НайденНеУстановленныйФлаг) Тогда
		СтрокаРодителя.Флаг = 1;
	Иначе
		СтрокаРодителя.Флаг = 0;
	КонецЕсли;
	
	ПроверитьЗначениеФлагаУРодителей(СтрокаРодителя.ПолучитьРодителя());
	
КонецПроцедуры

#КонецОбласти

&НаСервере
Процедура ЗаполнитьФлагиВСтруктуруКонфигурации(Знач КоллекцияЭлементов = Неопределено)
	
	ТаблицаСтруктуры = Объект.СтруктураКонфигурации.Выгрузить();
	ТаблицаСтруктуры.ЗаполнитьЗначения(Ложь, "Флаг");
	
	ЗаполнитьФлагиВСтруктуруКонфигурацииРекурсивно(ТаблицаСтруктуры);
	
	Объект.СтруктураКонфигурации.Загрузить(ТаблицаСтруктуры);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьФлагиВСтруктуруКонфигурацииРекурсивно(ТаблицаСтруктуры, КоллекцияЭлементов = Неопределено)
	
	Если КоллекцияЭлементов = Неопределено Тогда
		КоллекцияЭлементов = ДеревоСтруктурыКонфигурации.ПолучитьЭлементы();
	КонецЕсли;
	
	Для Каждого СтрокаДерева Из КоллекцияЭлементов Цикл
		
		Если СтрокаДерева.Флаг = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Если СтрокаДерева.Флаг = 1 Тогда
			
			СтрокаТаблицы = ТаблицаСтруктуры.Найти(СтрокаДерева.ИД, "ИД");
			Если СтрокаТаблицы = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			СтрокаТаблицы.Флаг = Истина;
			
		КонецЕсли;
		
		ЗаполнитьФлагиВСтруктуруКонфигурацииРекурсивно(ТаблицаСтруктуры, СтрокаДерева.ПолучитьЭлементы());
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьВыбранныеПодсистемыКонфигурации()
	
	Для Каждого СтрокаПодсистемы Из ВыбранныеПодсистемы Цикл
		
		ПараметрыОтбора = Новый Структура;
		ПараметрыОтбора.Вставить("ИД", СтрокаПодсистемы.Значение);
		
		МассивСтрок = Объект.СтруктураКонфигурации.НайтиСтроки(ПараметрыОтбора);
		Если МассивСтрок.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаСтруктуры = МассивСтрок[0];
		СтрокаСтруктуры.ПодсистемаВыбрана = Истина;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСписокВыбранныхПодсистем()
	
	ТаблицаСтруктурыКонфигурации = Объект.СтруктураКонфигурации.Выгрузить(, "ИД, ПодсистемаВыбрана");
	
	ПараметрыОтбора = Новый Структура;
	ПараметрыОтбора.Вставить("ПодсистемаВыбрана", Истина);
	
	ТаблицаВыбранныхПодсистем = ТаблицаСтруктурыКонфигурации.Скопировать(ПараметрыОтбора);
	МассивВыбранныхПодсистем = ТаблицаВыбранныхПодсистем.ВыгрузитьКолонку("ИД");
	
	ВыбранныеПодсистемы.ЗагрузитьЗначения(МассивВыбранныхПодсистем);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТаблицуОбъекта(ОбъектИсточник, ИмяТаблицы)
	
	ТаблицаИсточника = ОбъектИсточник[ИмяТаблицы].Выгрузить();
	Объект[ИмяТаблицы].Загрузить(ТаблицаИсточника);
	
КонецПроцедуры

#КонецОбласти
