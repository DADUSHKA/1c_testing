	ВедомостьДоговоры.Ссылка КАК Ссылка,
	МИНИМУМ(Договоры.НачалоДействия) КАК МинимальнаяДата
ПОМЕСТИТЬ ВТМинДата
ИЗ
	Документ.Ведомость.Договоры КАК ВедомостьДоговоры
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Договоры КАК Договоры
		ПО ВедомостьДоговоры.Договор = Договоры.Ссылка
ГДЕ
	Договоры.НачалоДействия &lt;&gt; ДАТАВРЕМЯ(1, 1, 1)

СГРУППИРОВАТЬ ПО
	ВедомостьДоговоры.Ссылка
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВедомостьДоговоры.Ссылка КАК Ссылка,
	МИНИМУМ(Договоры.НачалоДействия) КАК НачалоДействия
ПОМЕСТИТЬ ВТНужнаяДата
ИЗ
	Документ.Ведомость.Договоры КАК ВедомостьДоговоры
		ЛЕВОЕ СОЕДИНЕНИЕ ВТМинДата КАК ВТМинДата
		ПО ВедомостьДоговоры.Ссылка = ВТМинДата.Ссылка
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Договоры КАК Договоры
		ПО ВедомостьДоговоры.Договор = Договоры.Ссылка
			И (Договоры.НачалоДействия &lt;&gt; ДАТАВРЕМЯ(1, 1, 1))
ГДЕ
	ВТМинДата.МинимальнаяДата &lt;&gt; Договоры.НачалоДействия

СГРУППИРОВАТЬ ПО
	ВедомостьДоговоры.Ссылка
;

